{
  "rules": {
    "communities": {
      "$communityId": {
        ".read": "auth != null && (data.child('members').child(auth.uid).exists() || !data.child('isPrivate').val())",
        ".write": false,

        "name":        { ".write": "auth != null && data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER'" },
        "description": { ".write": "auth != null && data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER'" },
        "iconUrl":     { ".write": "auth != null && data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER'" },
        "isPrivate":   { ".write": "auth != null && data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER'" },
        "inviteToken": { ".write": "auth != null && data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER'" },
        "inviteEnabled":{ ".write": "auth != null && data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER'" },

        "members": {
          "$uid": {
            ".read": "auth != null && data.parent().parent().child('members').child(auth.uid).exists()",
            ".write": "auth != null && (auth.uid === $uid || data.parent().parent().child('members').child(auth.uid).child('role').val() === 'OWNER' || data.parent().parent().child('members').child(auth.uid).child('role').val() === 'ADMIN')"
          }
        },

        "posts": {
          "$postId": {
            ".read": "auth != null && data.parent().parent().child('members').child(auth.uid).exists()",
            ".write": "auth != null && data.parent().parent().child('members').child(auth.uid).exists() && !data.parent().parent().child('members').child(auth.uid).child('isMuted').val()",

            "reactions": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid && data.parent().parent().parent().parent().child('members').child(auth.uid).exists()"
              }
            },
            "reactionCounts": {
              "$reactionType": {
                ".write": "auth != null && data.parent().parent().parent().parent().child('members').child(auth.uid).exists()"
              }
            },
            "comments": {
              "$commentId": {
                ".write": "auth != null && data.parent().parent().parent().parent().child('members').child(auth.uid).exists()"
              }
            },
            "likes": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            },
            "likeCount": {
              ".write": "auth != null && data.parent().parent().parent().parent().child('members').child(auth.uid).exists()"
            },
            "poll": {
              "voters": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid && data.parent().parent().parent().parent().parent().child('members').child(auth.uid).exists()"
                }
              },
              "options": {
                ".write": "auth != null && data.parent().parent().parent().parent().parent().child('members').child(auth.uid).exists()"
              }
            }
          }
        },

        "join_requests": {
          ".read": "auth != null && (data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER' || data.parent().child('members').child(auth.uid).child('role').val() === 'ADMIN')",
          "$requestId": {
            ".write": "auth != null && (newData.child('requesterUid').val() === auth.uid || data.parent().parent().child('members').child(auth.uid).child('role').val() === 'OWNER' || data.parent().parent().child('members').child(auth.uid).child('role').val() === 'ADMIN')"
          }
        },

        "events": {
          ".read": "auth != null && data.parent().child('members').child(auth.uid).exists()",
          "$eventId": {
            ".write": "auth != null && data.parent().parent().child('members').child(auth.uid).exists()",
            "rsvps": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            },
            "rsvpCount": {
              ".write": "auth != null && data.parent().parent().parent().child('members').child(auth.uid).exists()"
            }
          }
        },

        "moderation_log": {
          ".read": "auth != null && (data.parent().child('members').child(auth.uid).child('role').val() === 'OWNER' || data.parent().child('members').child(auth.uid).child('role').val() === 'ADMIN')",
          "$logId": {
            ".write": "auth != null && (data.parent().parent().child('members').child(auth.uid).child('role').val() === 'OWNER' || data.parent().parent().child('members').child(auth.uid).child('role').val() === 'ADMIN')"
          }
        },

        "groups": {
          "$groupId": {
            ".read": "auth != null && data.parent().parent().child('members').child(auth.uid).exists()",
            ".write": "auth != null && (data.parent().parent().child('members').child(auth.uid).child('role').val() === 'OWNER' || data.parent().parent().child('members').child(auth.uid).child('role').val() === 'ADMIN')"
          }
        }
      }
    },

    "community_by_owner": {
      "$ownerUid": {
        ".read": "auth != null && auth.uid === $ownerUid",
        ".write": "auth != null && auth.uid === $ownerUid"
      }
    },

    "community_invites": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "community_notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notifId": {
          ".write": "auth != null && (auth.uid === $uid || true)"
        }
      }
    },

    "community_reports": {
      "$communityId": {
        ".read": false,
        "$reportId": {
          ".write": "auth != null"
        }
      }
    }
  }
}
