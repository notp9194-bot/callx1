{
  "_comment": "X Module — Firebase Realtime Database Security Rules (Production v2)",
  "_deploy": "firebase deploy --only database",
  "_instructions": [
    "1. Install Firebase CLI: npm install -g firebase-tools",
    "2. Login: firebase login",
    "3. In project root run: firebase deploy --only database",
    "   OR manually paste the 'rules' object into Firebase Console → Realtime Database → Rules"
  ],
  "rules": {
    "x": {

      "tweets": {
        "$tweetId": {
          ".read":  "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('authorUid').val() === auth.uid)",
          ".validate": "newData.hasChildren(['authorUid','text','timestamp']) && newData.child('text').val().length <= 280 && newData.child('timestamp').val() <= now + 5000",

          "isDeleted": { ".write": "auth != null && (data.parent().child('authorUid').val() === auth.uid)" },
          "likeCount":    { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "retweetCount": { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "replyCount":   { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "viewCount":    { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "bookmarkCount":{ ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "isPinned":  { ".write": "auth != null && data.parent().child('authorUid').val() === auth.uid" },
          "editedAt":  { ".write": "auth != null && data.parent().child('authorUid').val() === auth.uid" },
          "editedText":{ ".write": "auth != null && data.parent().child('authorUid').val() === auth.uid" }
        }
      },

      "global_feed": {
        ".read": "auth != null",
        "$tweetId": { ".write": "auth != null" }
      },

      "user_feeds": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null"
        }
      },

      "user_tweets": {
        "$uid": {
          ".read": "auth != null",
          "$tweetId": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "user_replies": {
        "$uid": {
          ".read": "auth != null",
          "$tweetId": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "user_media_tweets": {
        "$uid": {
          ".read": "auth != null",
          "$tweetId": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "tweet_likes": {
        "$tweetId": {
          ".read": "auth != null",
          "$uid": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "tweet_retweets": {
        "$tweetId": {
          ".read": "auth != null",
          "$uid": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "tweet_replies": {
        "$tweetId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },

      "user_likes": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          "$tweetId": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "user_retweets": {
        "$uid": {
          ".read": "auth != null",
          "$tweetId": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "user_bookmarks": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },

      "user_followers": {
        "$uid": {
          ".read": "auth != null",
          "$followerId": { ".write": "auth != null && auth.uid === $followerId" }
        }
      },

      "user_following": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          "$followingId": { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "user_muted": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },

      "user_blocked": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          "$blockedId": {
            ".write": "auth != null && (auth.uid === $uid || auth.uid === $blockedId)"
          }
        }
      },

      "users": {
        "$uid": {
          ".read":  "auth != null",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "!newData.hasChild('handle') || (newData.child('handle').val().length >= 1 && newData.child('handle').val().length <= 50)",

          "followerCount":  { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "followingCount": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "tweetCount":     { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "profileViews":   { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" },
          "isPrivate":      { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "notifications": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$notifId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['type','fromUid','timestamp'])",
            "read":     { ".write": "auth != null && auth.uid === $uid" },
            "notified": { ".write": "auth != null && (auth.uid === $uid)" }
          }
        }
      },

      "unread_notif_count": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      },

      "fcm_tokens": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['token','updatedAt'])"
        }
      },

      "dm_conversations": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null"
        }
      },

      "dm_messages": {
        "$convId": {
          ".read":  "auth != null && $convId.contains(auth.uid)",
          ".write": "auth != null && $convId.contains(auth.uid)",
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId','text','timestamp']) && newData.child('text').val().length <= 10000",
            "seen": { ".write": "auth != null && $convId.contains(auth.uid)" }
          }
        }
      },

      "dm_groups": {
        "$groupId": {
          ".read":  "auth != null && data.child('members').child(auth.uid).exists()",
          ".write": "auth != null && (!data.exists() || data.child('members').child(auth.uid).exists())",
          "members": {
            "$uid": {
              ".write": "auth != null && (auth.uid === $uid || data.parent().parent().child('ownerId').val() === auth.uid)"
            }
          }
        }
      },

      "dm_group_messages": {
        "$groupId": {
          ".read":  "auth != null && root.child('x/dm_groups').child($groupId).child('members').child(auth.uid).exists()",
          ".write": "auth != null && root.child('x/dm_groups').child($groupId).child('members').child(auth.uid).exists()",
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId','text','timestamp'])"
          }
        }
      },

      "dm_typing": {
        "$convId": {
          ".read": "auth != null && $convId.contains(auth.uid)",
          "$uid":  { ".write": "auth != null && auth.uid === $uid" }
        }
      },

      "dm_reactions": {
        "$convId": {
          "$msgId": {
            "$emoji": {
              "$uid": {
                ".read":  "auth != null && $convId.contains(auth.uid)",
                ".write": "auth != null && auth.uid === $uid && $convId.contains(auth.uid)"
              }
            }
          }
        }
      },

      "polls": {
        "$pollId": {
          ".read":  "auth != null",
          ".write": "auth != null",
          "voteCounts": {
            "$option": { ".write": "auth != null", ".validate": "newData.isNumber() && newData.val() >= 0" }
          },
          "userVotes": {
            "$uid": { ".write": "auth != null && auth.uid === $uid" }
          }
        }
      },

      "trending": {
        ".read": "auth != null",
        "$tag": { ".write": "auth != null" }
      },

      "hashtag_feeds": {
        "$tag": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      "reports": {
        "$tweetId": {
          "$uid": {
            ".read":  "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['reason','ts'])"
          }
        }
      },

      "scheduled_posts": {
        "$tweetId": {
          ".read":  "auth != null && data.child('authorUid').val() === auth.uid",
          ".write": "auth != null && (!data.exists() || data.child('authorUid').val() === auth.uid)",
          ".validate": "newData.child('scheduledAt').val() > now"
        }
      },

      "link_previews": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },

      "tweet_edits": {
        "$tweetId": {
          ".read":  "auth != null",
          ".write": "auth != null"
        }
      },

      "x_handles": {
        ".read": "auth != null",
        "$handle": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid)",
          ".validate": "newData.val() === auth.uid && $handle.length >= 1 && $handle.length <= 50"
        }
      }
    }
  }
}
