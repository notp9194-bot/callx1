{
  "_comment": "CallX — Firebase Realtime Database Security Rules (Chat Module)",
  "_version": "production-v2",
  "_changelog": "v2 (v20): Group chat rules + live location + disappearing messages + group_keys",
  "_deploy": "firebase deploy --only database",
  "_instructions": [
    "1. Install Firebase CLI: npm install -g firebase-tools",
    "2. Login: firebase login",
    "3. Merge the 'rules' section below into your existing Firebase DB rules.",
    "4. Deploy: firebase deploy --only database",
    "   OR paste manually into Firebase Console → Realtime Database → Rules tab.",
    "",
    "SECURITY MODEL:",
    "  • Every node requires auth != null — no anonymous reads/writes.",
    "  • Each chat is keyed by chatId (uid1_uid2, sorted). Only the two participants",
    "    can read or write — enforced by chatId.contains(auth.uid).",
    "  • Message status (sent/delivered/read) can only be set by the recipient.",
    "  • Reactions are per-uid so each user can only set/change their own reaction.",
    "  • User profile writes are scoped to own UID.",
    "  • FCM tokens, block lists, and mute lists are private (own-uid only).",
    "  • Typing indicators expire naturally (ephemeral writes, no retention).",
    "  • All timestamps validated to prevent future-date spoofing (+5s tolerance)."
  ],
  "rules": {

    "chats": {
      "$chatId": {
        ".read":  "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)",

        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId','timestamp']) && newData.child('timestamp').val() <= now + 5000",

            "senderId":   { ".validate": "newData.val() === auth.uid" },
            "timestamp":  { ".validate": "newData.isNumber() && newData.val() <= now + 5000" },
            "text":       { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20000)" },
            "type":       { ".validate": "newData.isString() && newData.val().length <= 50" },
            "mediaUrl":   { ".validate": "!newData.exists() || newData.isString()" },
            "thumbnailUrl": { ".validate": "!newData.exists() || newData.isString()" },
            "fileName":   { ".validate": "!newData.exists() || newData.isString()" },
            "fileSize":   { ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)" },
            "duration":   { ".validate": "!newData.exists() || newData.isNumber()" },

            "status": {
              ".write": "auth != null && $chatId.contains(auth.uid)",
              ".validate": "newData.isString() && (newData.val() === 'sent' || newData.val() === 'delivered' || newData.val() === 'read')"
            },

            "reactions": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isString() && newData.val().length <= 10"
              }
            },

            "deleted":  { ".validate": "!newData.exists() || newData.isBoolean()" },
            "edited":   { ".validate": "!newData.exists() || newData.isBoolean()" },
            "starred":  {
              ".write": "auth != null && $chatId.contains(auth.uid)",
              ".validate": "!newData.exists() || newData.isBoolean()"
            },
            "pinned":   {
              ".write": "auth != null && $chatId.contains(auth.uid)",
              ".validate": "!newData.exists() || newData.isBoolean()"
            },

            "replyToId":         { ".validate": "!newData.exists() || newData.isString()" },
            "replyToText":       { ".validate": "!newData.exists() || newData.isString()" },
            "replyToSenderName": { ".validate": "!newData.exists() || newData.isString()" },
            "replyToType":       { ".validate": "!newData.exists() || newData.isString()" },
            "forwardedFrom":     { ".validate": "!newData.exists() || newData.isString()" }
          }
        },

        "lastMsg":   { ".validate": "!newData.exists() || newData.isString()" },
        "lastTs":    { ".validate": "!newData.exists() || newData.isNumber()" },
        "unread":    {
          "$uid": {
            ".write": "auth != null && $chatId.contains(auth.uid)",
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      }
    },

    "typing": {
      "$chatId": {
        ".read":  "auth != null && $chatId.contains(auth.uid)",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && $chatId.contains(auth.uid)",
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChild('uid') && newData.child('uid').val() === $uid",

        "fcmToken": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "online":    { ".validate": "!newData.exists() || newData.isBoolean()" },
        "lastSeen":  { ".validate": "!newData.exists() || newData.isNumber()" },
        "name":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)" },
        "photoUrl":  { ".validate": "!newData.exists() || newData.isString()" },
        "thumbUrl":  { ".validate": "!newData.exists() || newData.isString()" },
        "about":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" }
      }
    },

    "blocks": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$blockedUid": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },

    "blocked": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$blockedUid": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },

    "permaBlocked": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$blockedUid": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },

    "muted": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$chatId": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },

    "notification_log": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$notifId": {
          ".validate": "newData.hasChildren(['type','timestamp'])"
        }
      }
    },

    "groups": {
      "$groupId": {
        ".read":  "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || data.child('members').child(auth.uid).exists())",

        "members": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || data.parent().parent().child('ownerId').val() === auth.uid)"
          }
        },
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId','timestamp']) && newData.child('timestamp').val() <= now + 5000",
            "status": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isString()"
              }
            },
            "reactions": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isString() && newData.val().length <= 10"
              }
            }
          }
        }
      }
    }
  }
}
