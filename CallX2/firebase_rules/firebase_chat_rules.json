{
  "_comment": "Firebase RTDB Security Rules — Chat messages ke liye",
  "_deploy_command": "firebase deploy --only database",

  "rules": {
    "messages": {
      "$chatId": {
        "$messageId": {

          ".read": "auth != null && (
            root.child('chats').child($chatId).child('participants').child(auth.uid).exists()
          )",

          ".write": "auth != null && (
            root.child('chats').child($chatId).child('participants').child(auth.uid).exists()
          )",

          "deliveredAt": {
            ".write": "auth != null && auth.uid != data.parent().child('senderId').val()",
            ".validate": "newData.isNumber() && newData.val() <= now + 5000"
          },

          "readAt": {
            ".write": "auth != null && auth.uid != data.parent().child('senderId').val()",
            ".validate": "newData.isNumber() && newData.val() <= now + 5000"
          },

          "deliveredTo": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid",
              ".validate": "newData.isNumber() && newData.val() <= now + 5000"
            }
          },

          "readBy": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid",
              ".validate": "newData.isNumber() && newData.val() <= now + 5000"
            }
          },

          "editedAt": {
            ".write": "auth != null && auth.uid === data.parent().child('senderId').val()",
            ".validate": "newData.isNumber() && newData.val() <= now + 5000"
          },

          "status": {
            ".write": "auth != null && (
              auth.uid === data.parent().child('senderId').val() ||
              root.child('chats').child($chatId).child('participants').child(auth.uid).exists()
            )"
          }
        }
      }
    }
  }
}
