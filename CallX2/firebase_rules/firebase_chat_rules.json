{
  "_comment": "CallX \u2014 Firebase Realtime Database Security Rules (Chat Module)",
  "_version": "production-v1",
  "_deploy": "firebase deploy --only database",
  "_instructions": [
    "1. Install Firebase CLI: npm install -g firebase-tools",
    "2. Login: firebase login",
    "3. Merge the 'rules' section below into your existing Firebase DB rules.",
    "4. Deploy: firebase deploy --only database",
    "   OR paste manually into Firebase Console \u2192 Realtime Database \u2192 Rules tab.",
    "",
    "SECURITY MODEL:",
    "  \u2022 Every node requires auth != null \u2014 no anonymous reads/writes.",
    "  \u2022 Each chat is keyed by chatId (uid1_uid2, sorted). Only the two participants",
    "    can read or write \u2014 enforced by chatId.contains(auth.uid).",
    "  \u2022 Message status (sent/delivered/read) can only be set by the recipient.",
    "  \u2022 Reactions are per-uid so each user can only set/change their own reaction.",
    "  \u2022 User profile writes are scoped to own UID.",
    "  \u2022 FCM tokens, block lists, and mute lists are private (own-uid only).",
    "  \u2022 Typing indicators expire naturally (ephemeral writes, no retention).",
    "  \u2022 All timestamps validated to prevent future-date spoofing (+5s tolerance)."
  ],
  "rules": {
    "chats": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid)",
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId','timestamp']) && newData.child('timestamp').val() <= now + 5000",
            "senderId": {
              ".validate": "newData.val() === auth.uid"
            },
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now + 5000"
            },
            "text": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20000)"
            },
            "type": {
              ".validate": "newData.isString() && newData.val().length <= 50"
            },
            "mediaUrl": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "thumbnailUrl": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "fileName": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "fileSize": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
            },
            "duration": {
              ".validate": "!newData.exists() || newData.isNumber()"
            },
            "status": {
              ".write": "auth != null && $chatId.contains(auth.uid)",
              ".validate": "newData.isString() && (newData.val() === 'sent' || newData.val() === 'delivered' || newData.val() === 'read')"
            },
            "reactions": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isString() && newData.val().length <= 10"
              }
            },
            "deleted": {
              ".validate": "!newData.exists() || newData.isBoolean()"
            },
            "edited": {
              ".validate": "!newData.exists() || newData.isBoolean()"
            },
            "starred": {
              ".write": "auth != null && $chatId.contains(auth.uid)",
              ".validate": "!newData.exists() || newData.isBoolean()"
            },
            "pinned": {
              ".write": "auth != null && $chatId.contains(auth.uid)",
              ".validate": "!newData.exists() || newData.isBoolean()"
            },
            "replyToId": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "replyToText": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "replyToSenderName": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "replyToType": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "forwardedFrom": {
              ".validate": "!newData.exists() || newData.isString()"
            }
          }
        },
        "lastMsg": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "lastTs": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "unread": {
          "$uid": {
            ".write": "auth != null && $chatId.contains(auth.uid)",
            ".validate": "newData.isNumber() && newData.val() >= 0"
          }
        }
      }
    },
    "typing": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && $chatId.contains(auth.uid)",
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },
    "chatPresence": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && $chatId.contains(auth.uid)",
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChild('uid') && newData.child('uid').val() === $uid",
        "fcmToken": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "online": {
          ".validate": "!newData.exists() || newData.isBoolean()"
        },
        "lastSeen": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "name": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
        },
        "photoUrl": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "thumbUrl": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "about": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
        }
      }
    },
    "blocks": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$blockedUid": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },
    "blocked": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$blockedUid": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },
    "permaBlocked": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$blockedUid": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },
    "muted": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$chatId": {
          ".validate": "newData.isBoolean() || !newData.exists()"
        }
      }
    },
    "notification_log": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$notifId": {
          ".validate": "newData.hasChildren(['type','timestamp'])"
        }
      }
    },
    "groups": {
      "$groupId": {
        ".read": "auth != null && data.child('members').child(auth.uid).exists()",
        ".write": "auth != null && (!data.exists() || data.child('members').child(auth.uid).exists())",
        "members": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || data.parent().parent().child('ownerId').val() === auth.uid)"
          }
        },
        "messages": {
          "$msgId": {
            ".validate": "newData.hasChildren(['senderId','timestamp']) && newData.child('timestamp').val() <= now + 5000",
            "status": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isString()"
              }
            },
            "reactions": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isString() && newData.val().length <= 10"
              }
            }
          }
        }
      }
    },
    "typingContent": {
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && $chatId.contains(auth.uid)",
          ".validate": "newData.isString() && newData.val().length <= 1000"
        }
      }
    },
    "chatPlayback": {
      "_comment": "ChatPlaybackPresenceController \u2014 chatPlayback/{chatId}/{uid} = messageId of the voice note/video that user currently has playing, removed the instant playback stops. Powers the per-bubble 'listening\u2026/watching\u2026' badge.",
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && $chatId.contains(auth.uid)",
          ".validate": "newData.isString() && newData.val().length <= 200"
        }
      }
    },
    "scheduledMessages": {
      "_comment": "ChatScheduledSendController \u2014 queued messages waiting for ChatScheduledMessageWorker to fire. Only the sender can read/write/cancel their own queued entries; the recipient never sees this node until the worker publishes into messages/{chatId}.",
      "$chatId": {
        ".read": "auth != null && $chatId.contains(auth.uid)",
        "$scheduleId": {
          ".write": "auth != null && $chatId.contains(auth.uid) && (!data.exists() || data.child('senderId').val() === auth.uid) && (!newData.exists() || newData.child('senderId').val() === auth.uid)",
          ".validate": "!newData.exists() || (newData.hasChildren(['senderId','chatId','sendAt']) && newData.child('sendAt').val() > now)"
        }
      }
    },
    "reelSeenDedup": {
      "_comment": "ReelSeenTracker dedup \u2014 reelSeenDedup/{viewerUid}/{reelId} \u2192 last-bubbled-at ms. 1-hour window per reelId per viewer. Written and read only by the viewer themselves.",
      "$viewerUid": {
        ".read": "auth != null && auth.uid === $viewerUid",
        ".write": "auth != null && auth.uid === $viewerUid",
        "$reelId": {
          ".validate": "newData.isNumber() && newData.val() <= now + 5000"
        }
      }
    },
    "reelSeenEvents": {
      "_comment": "ReelSeenTracker v21 side-tree \u2014 reelSeenEvents/{ownerUid}/{viewerUid}/{eventId}. Viewer writes; owner reads. messages/{chatId} is never touched.",
      "$ownerUid": {
        "$viewerUid": {
          ".read": "auth != null && auth.uid === $ownerUid",
          "$eventId": {
            ".write": "auth != null && auth.uid === $viewerUid",
            ".validate": "newData.hasChildren(['senderId','reelId','timestamp']) && newData.child('senderId').val() === auth.uid && newData.child('timestamp').val() <= now + 5000",
            "senderId": {
              ".validate": "newData.val() === auth.uid"
            },
            "senderName": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 100)"
            },
            "senderPhoto": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "reelId": {
              ".validate": "newData.isString() && newData.val().length <= 200"
            },
            "reelThumbUrl": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now + 5000"
            }
          }
        }
      }
    }
  }
}