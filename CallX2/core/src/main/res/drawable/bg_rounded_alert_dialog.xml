<?xml version="1.0" encoding="utf-8"?>
<!-- Shared rounded dark background for all AlertDialogs across the chat system.
     Same style used originally for the View Once warning dialog
     (see feature-chat bg_view_once_dialog.xml) — kept in core so every
     module can reuse it via AlertDialogStyler. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1E1E1E"/>
    <corners android:radius="20dp"/>
</shape>
