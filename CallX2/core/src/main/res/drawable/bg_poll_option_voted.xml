<?xml version="1.0" encoding="utf-8"?>
<!-- Poll feature (modernized) — option row that the current user voted for.
     Brand-colored border so "your answer" is identifiable at a glance on
     any bubble color/theme. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1F5B5BF6"/>
    <stroke android:width="1.5dp" android:color="@color/brand_primary"/>
    <corners android:radius="14dp"/>
</shape>
