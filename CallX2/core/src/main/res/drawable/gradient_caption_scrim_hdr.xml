<?xml version="1.0" encoding="utf-8"?>
<!--
    gradient_caption_scrim_hdr.xml
    ───────────────────────────────
    3-stop gradient (vs. the old flat 2-stop gradient_reel_bottom) so the
    falloff behind reel-photo captions reads more like an HDR tone-mapped
    vignette: strong, near-opaque black right behind the text for guaranteed
    contrast on any photo, then an eased mid-tone step, then a long gentle
    taper into full transparency so the transition doesn't look like a hard
    banded edge over bright photos.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#E6000000"
        android:centerColor="#5C000000"
        android:centerY="0.35"
        android:endColor="#00000000"/>
</shape>
