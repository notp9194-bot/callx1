<?xml version="1.0" encoding="utf-8"?>
<!-- Poll feature (modernized) — rounded, bordered input used for the poll
     question and each option field. A visible (if subtle) border gives the
     field definition against surface_card, instead of relying on fill alone. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_input"/>
    <stroke android:width="1dp" android:color="#14000000"/>
    <corners android:radius="14dp"/>
</shape>
