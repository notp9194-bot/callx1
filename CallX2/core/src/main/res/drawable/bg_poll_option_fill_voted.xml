<?xml version="1.0" encoding="utf-8"?>
<!-- Poll feature (modernized) — vote-share fill bar for the option the
     current user picked: bolder/more saturated than the neutral fill so
     "your bar" stands out among the rest. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#5C5B5BF6"/>
    <corners android:radius="14dp"/>
</shape>
