<?xml version="1.0" encoding="utf-8"?>
<!-- Poll feature (modernized) — small pill chip used for the "Closed" tag.
     Uses a red tint (action_danger family) so a closed poll reads at a glance. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#40EF4444"/>
    <corners android:radius="20dp"/>
</shape>
