<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CallX" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Material3 surface attrs — required for feature-status and other modules -->
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceVariant">@color/surface_input</item>
        <item name="colorSurfaceContainer">@color/surface_input</item>
        <item name="colorSurfaceContainerHigh">@color/surface_chat_bg</item>
        <item name="colorSurfaceContainerHighest">@color/surface_chat_bg</item>
        <item name="colorSurfaceContainerLow">@color/surface_bg</item>
        <item name="colorSurfaceContainerLowest">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:windowBackground">@color/surface_bg</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="Theme.CallX.Fullscreen" parent="Theme.CallX">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>
    <style name="Theme.CallX.NoActionBar" parent="Theme.CallX" />
    <style name="Theme.CallX.Transparent" parent="Theme.CallX">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
</resources>
