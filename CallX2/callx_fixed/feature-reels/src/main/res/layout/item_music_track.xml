<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Album cover art -->
    <ImageView
        android:id="@+id/iv_music_cover"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_primary"
        android:src="@drawable/ic_music_note"
        android:padding="10dp"
        android:contentDescription="Cover art"
        android:layout_marginEnd="12dp"/>

    <!-- Name + Artist + metadata -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tv_music_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_music_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:singleLine="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · "
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <TextView
                android:id="@+id/tv_music_genre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- Duration · Usage count · Badges row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_music_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_music_usage_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_music_trending_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#FF3B5C"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_music_original_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Original"
                android:textSize="10sp"
                android:textColor="#FF3B5C"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Save/bookmark -->
    <ImageButton
        android:id="@+id/btn_music_save"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_bookmark"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="?attr/colorOnSurface"
        android:contentDescription="Save sound"
        android:layout_marginEnd="4dp"/>

    <!-- Preview button -->
    <ImageButton
        android:id="@+id/btn_music_preview"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="?attr/colorOnSurface"
        android:contentDescription="Preview"/>

    <!-- Select button -->
    <TextView
        android:id="@+id/btn_music_select"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Use"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_reel_follow_btn"
        android:layout_marginStart="4dp"/>

</LinearLayout>
