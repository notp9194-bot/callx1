<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Original reel (top half) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_stitch_original"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="zoom"/>

    <!-- Camera preview (bottom half overlay) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_stitch_camera"
        android:layout_width="160dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="120dp"
        android:layout_marginEnd="16dp"/>

    <!-- Stitch divider label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:background="#AA000000"
        android:text="◀  YOUR STITCH  ▶"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"/>

    <!-- Top controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingTop="44dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_stitch_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Close"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btn_stitch_flip"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Flip camera"/>
    </LinearLayout>

    <!-- Stitch duration picker -->
    <LinearLayout
        android:id="@+id/layout_stitch_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:orientation="horizontal"
        android:paddingTop="110dp">

        <TextView
            android:id="@+id/chip_stitch_1s"
            android:layout_width="44dp"
            android:layout_height="32dp"
            android:text="1s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_speed_chip"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/chip_stitch_2s"
            android:layout_width="44dp"
            android:layout_height="32dp"
            android:text="2s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_speed_chip"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/chip_stitch_3s"
            android:layout_width="44dp"
            android:layout_height="32dp"
            android:text="3s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_speed_chip"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:id="@+id/chip_stitch_5s"
            android:layout_width="44dp"
            android:layout_height="32dp"
            android:text="5s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_speed_chip"/>
    </LinearLayout>

    <!-- Stitch info -->
    <TextView
        android:id="@+id/tv_stitch_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:paddingTop="152dp"
        android:text="First 3s of original will be stitched"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:background="#66000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"/>

    <!-- Countdown overlay -->
    <TextView
        android:id="@+id/tv_stitch_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="3"
        android:textColor="#FFFFFF"
        android:textSize="96sp"
        android:fontFamily="sans-serif-black"
        android:visibility="gone"/>

    <!-- Bottom recording controls -->
    <LinearLayout
        android:id="@+id/layout_stitch_recording"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp"
        android:paddingTop="12dp"
        android:background="#55000000"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_stitch_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp"/>

        <ProgressBar
            android:id="@+id/progress_stitch"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="60"
            android:progressTint="@color/brand_primary"
            android:progressBackgroundTint="#44FFFFFF"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"/>

        <ImageButton
            android:id="@+id/btn_stitch_record"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_camera"
            android:background="@drawable/circle_primary"
            android:tint="@color/white"
            android:padding="18dp"
            android:contentDescription="Record"/>
    </LinearLayout>

</FrameLayout>
