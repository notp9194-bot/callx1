<?xml version="1.0" encoding="utf-8"?>
<!-- Instagram-style gradient story ring — shown when a contact has a reel_story type status -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="sweep"
        android:startColor="#FF6B6B"
        android:centerColor="#FFA500"
        android:endColor="#6C5CE7"
        android:centerX="0.5"
        android:centerY="0.5"/>
</shape>
