<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="16dp" android:background="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_place_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="15sp"/>
        <TextView android:id="@+id/tv_place_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#888888" android:textSize="12sp"/>
    </LinearLayout>
</LinearLayout>
