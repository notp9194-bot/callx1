<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="top"
    android:background="?attr/selectableItemBackground">

    <!-- Unread dot -->
    <View
        android:id="@+id/dot_nc_unread"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/circle_primary"
        android:visibility="visible"/>

    <!-- User Avatar -->
    <ImageView
        android:id="@+id/iv_nc_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop"
        android:src="@drawable/circle_avatar_bg"/>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- User name + category chip row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="1dp">

            <TextView
                android:id="@+id/tv_nc_user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_nc_item_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_unread_badge"/>
        </LinearLayout>

        <!-- Activity label (e.g. "Liked your reel") -->
        <TextView
            android:id="@+id/tv_nc_activity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="2dp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Notification title -->
        <TextView
            android:id="@+id/tv_nc_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="2dp"/>

        <!-- Body text -->
        <TextView
            android:id="@+id/tv_nc_item_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"/>

        <!-- Bottom row: state badge + time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_nc_item_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_unread_badge"/>

            <TextView
                android:id="@+id/tv_nc_item_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
