<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btn_gift_back" android:layout_width="40dp"
            android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Gifts &amp; Coins" android:textColor="#FFFFFF"
            android:textSize="18sp" android:textStyle="bold" android:paddingStart="12dp"/>
    </LinearLayout>
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_gift_refresh"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <ProgressBar android:id="@+id/progress_gift_load" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="#1E1E1E" android:padding="20dp"
                    android:gravity="center" android:layout_marginBottom="16dp">
                    <TextView android:id="@+id/tv_gift_total_coins" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 Coins"
                        android:textColor="#FFD700" android:textSize="36sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_gift_usd_equiv" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="≈ $0.00 USD"
                        android:textColor="#888888" android:textSize="14sp"/>
                    <Button android:id="@+id/btn_gift_withdraw" android:layout_width="wrap_content"
                        android:layout_height="40dp" android:text="Withdraw" android:textColor="#FFFFFF"
                        android:background="@drawable/bg_btn_primary" android:layout_marginTop="12dp"
                        android:paddingHorizontal="24dp"/>
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Gift Breakdown" android:textColor="#FFFFFF" android:textSize="15sp"
                    android:textStyle="bold" android:paddingBottom="8dp"/>
                <LinearLayout android:id="@+id/layout_gift_breakdown" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical"
                    android:background="#1E1E1E" android:padding="12dp" android:layout_marginBottom="16dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Top Gifters" android:textColor="#FFFFFF" android:textSize="15sp"
                    android:textStyle="bold" android:paddingBottom="8dp"/>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_top_gifters"
                    android:layout_width="match_parent" android:layout_height="120dp"
                    android:layout_marginBottom="16dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Recent Gifts" android:textColor="#FFFFFF" android:textSize="15sp"
                    android:textStyle="bold" android:paddingBottom="8dp"/>
                <TextView android:id="@+id/layout_gift_empty" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="No gifts yet. Share your reels to receive gifts!"
                    android:textColor="#666666" android:gravity="center" android:padding="32dp" android:visibility="gone"/>
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_gift_history"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>
