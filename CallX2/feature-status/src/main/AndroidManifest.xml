<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.callx.app.status">

    <application>

        <!-- ══════════════════════════════════════════════════════════════════
             CHANNEL ACTIVITIES — WhatsApp-level upgrade (v2)
             All new activities added below existing ones.
             ══════════════════════════════════════════════════════════════════ -->

        <!-- Channel feed / viewer (follower view) -->
        <activity
            android:name="com.callx.app.channel.ChannelViewerActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- New post composer: text / image / video / link / poll / audio / document -->
        <activity
            android:name="com.callx.app.channel.ChannelPostComposerActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:exported="false"/>

        <!-- Create a new channel (name / desc / icon / category / privacy) -->
        <activity
            android:name="com.callx.app.channel.CreateChannelActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Explore / search public channels with category chips -->
        <activity
            android:name="com.callx.app.channel.ExploreChannelsActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Full-screen image / video viewer for channel post media -->
        <activity
            android:name="com.callx.app.channel.ChannelMediaViewerActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:configChanges="orientation|screenSize"
            android:exported="false"/>

        <!-- Forward a channel post to individual chats or groups (ACTUAL Firebase send) -->
        <activity
            android:name="com.callx.app.channel.ForwardPostActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Admin management: add / remove / transfer ownership + quick links to
             followers, invite link, and scheduled posts -->
        <activity
            android:name="com.callx.app.channel.ChannelAdminActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Full analytics dashboard: overview, averages, content mix, peak hour,
             top posts by views / reactions, poll performance -->
        <activity
            android:name="com.callx.app.channel.ChannelAnalyticsActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Per-channel mute/notification settings (duration picker) -->
        <activity
            android:name="com.callx.app.channel.ChannelNotificationSettingsActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- ── NEW v2 activities ─────────────────────────────────────────── -->

        <!-- Edit channel metadata: name / description / icon / category / privacy -->
        <activity
            android:name="com.callx.app.channel.ChannelEditActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Admin view / manage channel followers (join date, promote, block/remove) -->
        <activity
            android:name="com.callx.app.channel.ChannelFollowersActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Generate / share / revoke invite link + QR code (private channels) -->
        <activity
            android:name="com.callx.app.channel.ChannelInviteLinkActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Reactions detail: who reacted, per-emoji filter chips -->
        <activity
            android:name="com.callx.app.channel.ChannelReactionsDetailActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Scheduled posts: list, publish now, delete / cancel -->
        <activity
            android:name="com.callx.app.channel.ChannelScheduledPostsActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- ── NEW v3 activities ─────────────────────────────────────────── -->

        <!-- Reply / comment thread per channel post -->
        <activity
            android:name="com.callx.app.channel.ChannelReplyActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Join a channel via invite link / deep link (callx://channel/join/{code}) -->
        <activity
            android:name="com.callx.app.channel.ChannelJoinActivity"
            android:theme="@style/Theme.CallX"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="callx" android:host="channel" android:pathPrefix="/join/"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="callx.app" android:pathPrefix="/channel/join/"/>
            </intent-filter>
        </activity>

        <!-- Share a post as a branded image card -->
        <activity
            android:name="com.callx.app.channel.ChannelPostShareActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- ── NEW v4 activities ─────────────────────────────────────────── -->

        <!-- Detailed poll results: per-option progress, voter list, real-time -->
        <activity
            android:name="com.callx.app.channel.ChannelPollResultsActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Saved / bookmarked posts per channel (offline-first, SharedPreferences) -->
        <activity
            android:name="com.callx.app.channel.ChannelHighlightsActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- Admin broadcast to all followers with priority + FCM trigger -->
        <activity
            android:name="com.callx.app.channel.ChannelBroadcastActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- ── NEW v5 activities ──────────────────────────────────────────── -->

        <!-- Welcome message / auto-reply for new followers -->
        <activity
            android:name="com.callx.app.channel.ChannelAutoReplyActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- Topic tag management per channel -->
        <activity
            android:name="com.callx.app.channel.ChannelTopicsActivity"
            android:theme="@style/Theme.CallX"
            android:windowSoftInputMode="adjustResize"
            android:exported="false"/>

        <!-- WorkManager background task: deliver welcome DM to new followers -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="shortService"
            android:exported="false"
            tools:node="merge" />

        <activity android:name="com.callx.app.social.StoryReshareActivity" 
            android:exported="false" 
            android:screenOrientation="portrait" 
            android:theme="@style/Theme.AppCompat.NoActionBar" 
            android:windowSoftInputMode="adjustResize"/>

        <!-- BUG FIX: these two were never actually declared here despite the
             app manifest's v72 comment claiming they were — StatusFragment's
             explicit Intent to NewStatusActivity threw ActivityNotFoundException,
             and ChatActivity/MessagePagingAdapter's implicit ACTION_OPEN_STATUS
             intent silently failed (caught + Toast'd) with no working target. -->

        <!-- Compose a new status (camera / gallery / text) -->
        <activity
            android:name="com.callx.app.compose.NewStatusActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false"/>

        <!-- View a status (own or another user's), reached explicitly from
             StatusFragment/StatusListAdapter, and implicitly via
             ACTION_OPEN_STATUS from status-reply/reaction quote taps in chat. -->
        <activity
            android:name="com.callx.app.viewer.StatusViewerActivity"
            android:theme="@style/Theme.CallX"
            android:exported="false">
            <intent-filter>
                <action android:name="com.callx.app.ACTION_OPEN_STATUS"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
    </application>

</manifest>
