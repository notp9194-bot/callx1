<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity android:name="com.callx.app.activities.StatusViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CallX.Fullscreen">
            <!-- ACTION_OPEN_STATUS: allows feature-chat to open this activity
                 via implicit Intent without a compile-time class reference -->
            <intent-filter>
                <action android:name="com.callx.app.ACTION_OPEN_STATUS"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <activity android:name="com.callx.app.activities.NewStatusActivity"
            android:exported="false"/>

        <service android:name="com.callx.app.services.StatusBackgroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false"/>
        <receiver android:name="com.callx.app.services.StatusExpiryReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.callx.app.STATUS_EXPIRY_REMINDER"/>
            </intent-filter>
        </receiver>
            <activity android:name=".activities.StatusVideoTrimActivity" android:theme="@style/Theme.MaterialComponents.NoActionBar"/>
        <activity android:name=".activities.StatusCollageCreatorActivity" android:theme="@style/Theme.MaterialComponents.NoActionBar"/>
        <activity android:name=".activities.StatusTemplateActivity" android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"/>
        <activity android:name=".activities.StatusHighlightsActivity" android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"/>
        <activity android:name=".activities.StatusArchiveActivity" android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"/>
        <activity android:name=".activities.NewStatusActivity" android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".activities.StatusViewerActivity" android:theme="@style/Theme.MaterialComponents.NoActionBar" android:screenOrientation="portrait"/>
    </application>
</manifest>
