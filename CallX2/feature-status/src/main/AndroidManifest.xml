<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity android:name="com.callx.app.viewer.StatusViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CallX.Fullscreen">
            <intent-filter>
                <action android:name="com.callx.app.ACTION_OPEN_STATUS"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
        <activity android:name="com.callx.app.compose.NewStatusActivity"
            android:exported="false"/>
        <activity android:name="com.callx.app.highlights.StatusHighlightsActivity"
            android:exported="false"/>

        <!-- ── Channel Activities ──────────────────────────────────────── -->
        <activity android:name="com.callx.app.channel.ExploreChannelsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.channel.ChannelViewerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.channel.CreateChannelActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.channel.ChannelPostComposerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <!-- ──────────────────────────────────────────────────────────────── -->

        <service android:name="com.callx.app.services.StatusBackgroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false"/>
        <receiver android:name="com.callx.app.services.StatusExpiryReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.callx.app.STATUS_EXPIRY_REMINDER"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>
