<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:padding="10dp">
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_viewer_avatar"
        android:layout_width="44dp" android:layout_height="44dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView android:id="@+id/tv_viewer_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_viewer_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="#888888"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_viewer_reaction"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="22sp" android:layout_marginStart="8dp"/>
</LinearLayout>
