<?xml version="1.0" encoding="utf-8"?>
<!-- Create Channel screen — matches screenshot 5 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_create_channel"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:titleTextColor="#111111"
        app:navigationIconTint="#111111"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Channel icon picker -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_create_channel_icon"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_channel_broadcast"
                    android:background="#DDDDDD"/>

                <ImageView
                    android:id="@+id/iv_camera_badge"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_status_camera"
                    android:background="#25D366"
                    android:tint="@android:color/white"
                    android:padding="5dp"
                    android:elevation="2dp"/>
            </FrameLayout>

            <!-- Channel name input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintAnimationEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_channel_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Channel name"
                    android:inputType="text"
                    android:maxLength="40"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintAnimationEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_channel_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Describe your channel. Including a description is useful for your followers."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLength="200"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progress_create_channel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- Create button pinned at bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_create_channel_submit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="Create channel"
        android:textSize="15sp"
        android:backgroundTint="#25D366"
        android:textColor="@android:color/white"
        style="@style/Widget.MaterialComponents.Button"/>

</LinearLayout>
