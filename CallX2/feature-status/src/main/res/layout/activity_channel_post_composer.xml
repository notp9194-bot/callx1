<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_post_composer"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="#111111"
        app:titleTextColor="#111111"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <ProgressBar
        android:id="@+id/progress_composer"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:progressTint="#25D366"
        android:visibility="gone"/>

    <!-- Scrollable content area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Main text area -->
            <EditText
                android:id="@+id/et_post_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:gravity="top|start"
                android:background="@android:color/transparent"
                android:hint="What's the update?"
                android:textSize="16sp"
                android:textColorHint="#AAAAAA"
                android:inputType="textMultiLine|textCapSentences"/>

            <TextView
                android:id="@+id/tv_char_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="0/1000"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="4dp"/>

            <!-- Media preview (hidden until media selected) -->
            <FrameLayout
                android:id="@+id/layout_media_preview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_media_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#F0F0F0"/>

                <TextView
                    android:id="@+id/tv_media_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:background="#80000000"/>

                <ImageButton
                    android:id="@+id/btn_remove_media"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:background="#80000000"
                    android:contentDescription="Remove media"/>
            </FrameLayout>

            <!-- Link preview card (hidden until link added) -->
            <LinearLayout
                android:id="@+id/layout_link_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp"
                android:background="#F8F8F8"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_link_thumb"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:scaleType="centerCrop"
                    android:background="#EEEEEE"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_link_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_link_url_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:singleLine="true"
                        android:ellipsize="end"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_remove_link"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#AAAAAA"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Remove link"/>
            </LinearLayout>

            <!-- Poll section (hidden until poll mode) -->
            <LinearLayout
                android:id="@+id/layout_poll_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#F8F8F8"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_poll_question_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Poll question"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_poll_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ask a question..."
                    android:inputType="textCapSentences"
                    android:background="@android:color/white"
                    android:padding="10dp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Options"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:id="@+id/layout_poll_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_poll_option"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Add option"
                    android:textSize="13sp"
                    android:textColor="#25D366"
                    android:backgroundTint="@android:color/transparent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom attachment toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="#FAFAFA"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_attach_image"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_status_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#555555"
            android:contentDescription="Add image"/>

        <ImageButton
            android:id="@+id/btn_attach_video"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_play"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#555555"
            android:contentDescription="Add video"/>

        <ImageButton
            android:id="@+id/btn_attach_link"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_status_link"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#555555"
            android:contentDescription="Add link"/>

        <ImageButton
            android:id="@+id/btn_attach_poll"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#555555"
            android:contentDescription="Create poll"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_post_submit"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Post"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            app:backgroundTint="#25D366"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

</LinearLayout>
