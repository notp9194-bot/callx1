<?xml version="1.0" encoding="utf-8"?>
<!-- Explore-list channel row -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_channel_icon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/bg_channel_avatar_default"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_channel_followers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_channel_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_channel_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#25D366"
            android:background="#E8F8EF"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_follow_channel"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Follow"
        android:textSize="13sp"
        android:textColor="#1A773A"
        android:backgroundTint="#DCF5E7"
        android:paddingHorizontal="12dp"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

</LinearLayout>
