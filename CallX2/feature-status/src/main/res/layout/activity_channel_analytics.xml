<?xml version="1.0" encoding="utf-8"?>
<!-- activity_channel_analytics.xml — v4 upgrade with Canvas charts -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_analytics"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:titleTextColor="#111111"
        app:navigationIconTint="#111111"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Summary stat cards row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#F3FFF8"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:id="@+id/tv_analytics_total_posts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#25D366"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Posts"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#E3F2FD"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:id="@+id/tv_analytics_total_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#2196F3"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Views"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Summary stat cards row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#FFF8E1"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:id="@+id/tv_analytics_total_followers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Followers"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#FCE4EC"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:id="@+id/tv_analytics_engagement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#E91E63"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Engagement"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Post type bar chart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTENT MIX"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.callx.app.channel.ChannelAnalyticsActivity.BarChartView
                android:id="@+id/chart_post_types"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"/>

            <!-- Weekly growth line chart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOLLOWER GROWTH (7 DAYS)"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.callx.app.channel.ChannelAnalyticsActivity.LineChartView
                android:id="@+id/chart_weekly_growth"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="24dp"/>

            <!-- Peak hours bar chart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PEAK POSTING HOURS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.callx.app.channel.ChannelAnalyticsActivity.BarChartView
                android:id="@+id/chart_peak_hours"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp"/>

            <!-- Top posts -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOP POSTS BY VIEWS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/layout_top_posts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <!-- Export button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_analytics_export"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Export analytics"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#25D366"/>

        </LinearLayout>

        <!-- ── Stub views for IDs referenced by ChannelAnalyticsActivity (visibility=gone) ── -->
        <TextView android:id="@+id/tv_analytics_reach_7d"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <TextView android:id="@+id/tv_analytics_impressions_7d"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <TextView android:id="@+id/tv_analytics_forwards_7d"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <TextView android:id="@+id/tv_analytics_avg_views"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <TextView android:id="@+id/tv_analytics_best_type"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <TextView android:id="@+id/tv_analytics_optimal_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
        <View android:id="@+id/chart_reach_daily"
            android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/chart_impressions_daily"
            android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/chart_forwards_daily"
            android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/chart_sub_growth_30d"
            android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone"/>

    </ScrollView>

</LinearLayout>
