<?xml version="1.0" encoding="utf-8"?>
<!-- Poll post -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="10dp"
    android:background="@android:color/white">

    <!-- Author header (channel post author icon/name + pinned badge) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_post_author_icon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_verified"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_post_author_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_post_pinned_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📌 Pinned"
            android:textSize="11sp"
            android:textColor="#25D366"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Poll icon + question -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="#25D366"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_poll_question"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:maxLines="3"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Poll options container — populated at runtime -->
    <LinearLayout
        android:id="@+id/layout_poll_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="6dp"/>

    <!-- Vote count -->
    <TextView
        android:id="@+id/tv_poll_vote_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"/>

    <!-- Multi-select indicator -->
    <TextView
        android:id="@+id/tv_poll_multi_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select one or more options"
        android:textSize="11sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <!-- Poll expiry -->
    <TextView
        android:id="@+id/tv_poll_expiry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <!-- Reactions summary -->
    <TextView
        android:id="@+id/tv_post_reactions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:textSize="14sp"
        android:visibility="gone"/>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp">

        <TextView android:id="@+id/tv_post_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#AAAAAA"/>
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
        <TextView android:id="@+id/tv_post_replies"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#25D366"
            android:layout_marginEnd="8dp" android:visibility="gone"/>
        <ImageButton android:id="@+id/btn_post_react"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@android:drawable/btn_star_big_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#888888" android:contentDescription="React"/>
        <ImageButton android:id="@+id/btn_post_forward"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#888888" android:contentDescription="Forward"
            android:layout_marginStart="2dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F2F2F2" android:layout_marginTop="4dp"/>
</LinearLayout>
