<?xml version="1.0" encoding="utf-8"?>
<!-- Suggested channel row -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_channel_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/bg_channel_avatar_default"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_channel_verified"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ✓"
                android:textColor="#0075C9"
                android:textSize="13sp"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_channel_followers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"/>

        <!-- Muted indicator (hidden by default) -->
        <ImageView
            android:id="@+id/iv_channel_muted"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@android:drawable/ic_lock_silent_mode"
            android:tint="#AAAAAA"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Follow/Unfollow button -->
    <Button
        android:id="@+id/btn_channel_follow"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Follow"
        android:textSize="13sp"
        android:textColor="#1A773A"
        android:backgroundTint="#DCF5E7"
        android:paddingHorizontal="12dp"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

    <!-- Dismiss button (X) -->
    <ImageButton
        android:id="@+id/btn_channel_dismiss"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="4dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#AAAAAA"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Dismiss suggestion"
        android:visibility="gone"/>

</LinearLayout>
