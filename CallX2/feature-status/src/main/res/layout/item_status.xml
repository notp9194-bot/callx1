<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="1dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Ring + Avatar container -->
        <FrameLayout
            android:layout_width="54dp"
            android:layout_height="54dp">

            <!-- Ring border (green=unseen, grey=seen) -->
            <View
                android:id="@+id/view_status_ring"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/circle_ring_green"
                android:backgroundTint="#25D366"/>

            <!-- Avatar -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_contact_avatar"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_report_image"/>
        </FrameLayout>

        <!-- Text section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_contact_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:id="@+id/tv_status_caption_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <TextView
                android:id="@+id/tv_status_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Right: thumb + badge -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp">

            <ImageView
                android:id="@+id/iv_status_thumb"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <!-- Unseen count badge -->
            <TextView
                android:id="@+id/tv_unseen_badge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/badge_circle_green"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
