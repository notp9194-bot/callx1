<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:elevation="4dp"/>

    <!-- My status thumbnails row -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_statuses"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="?attr/colorSurface"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clipToPadding="false"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <!-- Seen by section -->
    <LinearLayout
        android:id="@+id/layout_seen_by"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_seen_by_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Seen by 0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_seen_by"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:nestedScrollingEnabled="true"/>
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layout_empty_status"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No status updates"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>
        <Button
            android:id="@+id/btn_add_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Add Status"
            style="@style/Widget.Material3.Button.TonalButton"/>
    </LinearLayout>

</LinearLayout>
