<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_followers"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <!-- Follower count badge + search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorSurface"
        android:padding="12dp"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_follower_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading followers…"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search followers"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_follower_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textFilter"
                android:imeOptions="actionSearch" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_followers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- bulk actions (hidden until multi-select) -->
    <LinearLayout android:id="@+id/layout_bulk_actions"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:visibility="gone">
        <TextView android:id="@+id/tv_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_bulk_remove"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Remove"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_cancel_selection"
            android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancel"/>
    </LinearLayout>
    <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_follower_filter"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:visibility="gone"/>
</LinearLayout>
