<?xml version="1.0" encoding="utf-8"?>
<!-- activity_channel_broadcast.xml — Admin broadcast to all followers -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_broadcast"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#25D366"
        android:elevation="2dp"
        app:titleTextColor="#FFFFFF"
        app:navigationIconTint="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#F3FFF8"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📢"
                    android:textSize="22sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="This message will be posted to the channel and all followers will be notified."
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Message input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Broadcast message"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_broadcast_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Write your broadcast message…"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="4"
                android:maxLines="12"
                android:gravity="top"
                android:padding="12dp"
                android:background="@drawable/bg_rounded_outline"/>

            <TextView
                android:id="@+id/tv_broadcast_char_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 500"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"/>

            <!-- Priority -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Priority"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <RadioGroup
                android:id="@+id/rg_broadcast_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_priority_normal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📢 Normal"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rb_priority_important"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟡 Important"/>

                <RadioButton
                    android:id="@+id/rb_priority_urgent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 Urgent"/>
            </RadioGroup>

            <!-- Notify all toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Push notification to all followers"
                    android:textSize="14sp"
                    android:textColor="#333333"/>

                <Switch
                    android:id="@+id/switch_notify_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <!-- Preview -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preview"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/layout_broadcast_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F3FFF8"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_broadcast_preview_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#25D366"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_broadcast_preview_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Progress + Send button -->
    <ProgressBar
        android:id="@+id/progress_broadcast"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true"
        android:visibility="gone"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_broadcast_send"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Send broadcast"
        android:textSize="16sp"
        android:backgroundTint="#25D366"
        android:textColor="#FFFFFF"
        android:enabled="false"
        android:layout_margin="16dp"/>

</LinearLayout>
