<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Toolbar with channel icon, name, followers, follow button -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_channel"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/white"
        app:navigationIconTint="#111111">

        <LinearLayout
            android:id="@+id/layout_channel_header_info"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_channel_viewer_icon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/bg_channel_avatar_default"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_channel_viewer_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:maxWidth="160dp"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_channel_viewer_verified"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ✓"
                        android:textColor="#0075C9"
                        android:textSize="13sp"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_channel_viewer_followers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Follow/Following toggle button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_follow_toggle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:layout_marginEnd="4dp"
            android:text="Follow"
            android:textSize="13sp"
            android:textColor="#1A773A"
            android:backgroundTint="#DCF5E7"
            android:paddingHorizontal="12dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </androidx.appcompat.widget.Toolbar>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <!-- ══════════════════════════════════════════════════
         PINNED POST BANNER — shown when a post is pinned
         ══════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_pinned_post"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="0dp"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        android:background="#FFF8E1"
        app:cardBackgroundColor="#FFF8E1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <!-- Pin icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pinned post"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#E65100"
                        android:layout_marginEnd="6dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/tv_pinned_post_type"
                        android:layout_width="wrap_content"
                        android:layout_height="22dp"
                        android:textSize="10sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_pinned_post_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Unpin button (admin only) -->
            <ImageButton
                android:id="@+id/btn_unpin_post"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:contentDescription="Unpin post"
                android:visibility="gone"
                android:tint="#888888"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Channel posts + FAB + empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channel_posts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>

        <!-- Empty state (non-owner / follower view) -->
        <LinearLayout
            android:id="@+id/layout_channel_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="24dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_channel_broadcast"
                android:tint="#CCCCCC"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No updates yet"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tv_channel_empty_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Updates from this channel will appear here"
                android:textSize="14sp"
                android:textColor="#999999"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════
             OWNER ONBOARDING CARD — shown to the owner/admin
             right after creating a channel (0 posts state)
             ══════════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/scroll_channel_onboarding"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layout_channel_onboarding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#EEEEEE"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="#FAFAFA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="28dp">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_onboarding_icon"
                            android:layout_width="76dp"
                            android:layout_height="76dp"
                            android:src="@drawable/bg_channel_avatar_default"/>

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="bottom|end"
                            android:padding="5dp"
                            android:background="@drawable/bg_channel_avatar_default"
                            android:backgroundTint="#25D366"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#FFFFFF"
                            android:contentDescription="Change channel icon"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_onboarding_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:gravity="center"
                        android:text="Start growing"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_onboarding_add_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Add description"
                        android:textAllCaps="false"
                        android:textColor="#1A773A"
                        app:icon="@android:drawable/ic_menu_edit"
                        app:iconTint="#1A773A"
                        app:iconGravity="textStart"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_onboarding_share_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Share to my status"
                        android:textAllCaps="false"
                        android:textColor="#1A773A"
                        android:backgroundTint="#DCF5E7"
                        app:icon="@drawable/ic_channel_broadcast"
                        app:iconTint="#1A773A"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_onboarding_invite_admins"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Invite admins"
                        android:textAllCaps="false"
                        android:textColor="#333333"
                        android:backgroundTint="#F0F0F0"
                        app:icon="@android:drawable/ic_menu_add"
                        app:iconTint="#333333"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        </ScrollView>

        <!-- New post FAB (owner/admin only, hidden once the inline composer bar is shown) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_new_post"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#25D366"
            android:tint="#FFFFFF"
            android:visibility="gone"
            android:contentDescription="New post"/>
    </FrameLayout>


    <com.google.android.material.chip.ChipGroup android:id="@+id/chip_group_topic_filter"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:visibility="gone"/>

    <!-- ══════════════════════════════════════════════════
         INLINE "WRITE AN UPDATE" COMPOSER BAR — owner/admin only
         ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_channel_composer_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_composer_emoji"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#777777"
            android:contentDescription="Emoji"/>

        <TextView
            android:id="@+id/tv_composer_write_update"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_channel_post_card"
            android:text="Write an update"
            android:textColor="#888888"
            android:textSize="15sp"/>

        <ImageButton
            android:id="@+id/btn_composer_attach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_attach"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#777777"
            android:contentDescription="Attach"/>

        <ImageButton
            android:id="@+id/btn_composer_camera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#777777"
            android:contentDescription="Camera"/>

        <ImageButton
            android:id="@+id/btn_composer_mic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/bg_channel_avatar_default"
            android:backgroundTint="#25D366"
            android:tint="#FFFFFF"
            android:padding="8dp"
            android:contentDescription="Record voice update"/>
    </LinearLayout>
</LinearLayout>
