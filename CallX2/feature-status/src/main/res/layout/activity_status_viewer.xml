<?xml version="1.0" encoding="utf-8"?>
  <FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/black">

      <!-- Full-screen content layers -->
      <ImageView
          android:id="@+id/iv_status"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:scaleType="centerCrop"
          android:visibility="gone"/>

      <androidx.media3.ui.PlayerView
          android:id="@+id/player_view"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:visibility="gone"/>

      <!-- Text status -->
      <FrameLayout
          android:id="@+id/fl_text_status"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:visibility="gone">
          <TextView
              android:id="@+id/tv_text_status"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center"
              android:padding="40dp"
              android:textColor="@color/white"
              android:textSize="28sp"
              android:textStyle="bold"
              android:gravity="center"
              android:lineSpacingMultiplier="1.2"/>
      </FrameLayout>

      <!-- ── Reshare attribution card overlay (reel_reshare / post_reshare) ── -->
      <FrameLayout
          android:id="@+id/fl_reshare_attribution_container"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom|center_horizontal"
          android:layout_marginBottom="100dp"
          android:visibility="gone">

          <LinearLayout
              android:id="@+id/ll_reshare_attribution_card"
              android:layout_width="280dp"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:background="@drawable/bg_reshare_card"
              android:padding="10dp"
              android:gravity="center_vertical">

              <ImageView
                  android:id="@+id/iv_reshare_thumb"
                  android:layout_width="56dp"
                  android:layout_height="56dp"
                  android:scaleType="centerCrop"
                  android:background="#CCCCCC"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="10dp">

                  <TextView
                      android:id="@+id/tv_reshare_type_badge"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Reel"
                      android:textSize="10sp"
                      android:textColor="#FFFFFF"
                      android:background="#C13584"
                      android:paddingStart="6dp"
                      android:paddingEnd="6dp"
                      android:paddingTop="2dp"
                      android:paddingBottom="2dp"/>

                  <TextView
                      android:id="@+id/tv_reshare_original_owner"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textSize="13sp"
                      android:textStyle="bold"
                      android:textColor="#1A1A1A"
                      android:layout_marginTop="4dp"
                      android:maxLines="1"
                      android:ellipsize="end"/>

                  <TextView
                      android:id="@+id/tv_view_original_btn"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="View Original →"
                      android:textSize="12sp"
                      android:textColor="#0095F6"
                      android:layout_marginTop="3dp"
                      android:clickable="true"
                      android:focusable="true"
                      android:background="?attr/selectableItemBackground"/>
              </LinearLayout>
          </LinearLayout>
      </FrameLayout>

      <!-- Touch capture layer -->
      <View
          android:id="@+id/touch_layer"
          android:layout_width="match_parent"
          android:layout_height="match_parent"/>

      <!-- Top chrome -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingTop="8dp">

          <!-- Progress bars -->
          <LinearLayout
              android:id="@+id/segments_container"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:paddingStart="8dp"
              android:paddingEnd="8dp"
              android:paddingTop="4dp"
              android:paddingBottom="4dp"
              android:gravity="center_vertical"/>

          <!-- Header row: avatar + name + expiry + more + close -->
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:paddingStart="12dp"
              android:paddingEnd="8dp"
              android:paddingTop="6dp"
              android:paddingBottom="8dp"
              android:gravity="center_vertical">

              <de.hdodenhof.circleimageview.CircleImageView
                  android:id="@+id/iv_owner"
                  android:layout_width="38dp"
                  android:layout_height="38dp"
                  android:src="@drawable/ic_person"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="10dp">

                  <TextView
                      android:id="@+id/tv_owner"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textColor="@color/white"
                      android:textStyle="bold"
                      android:textSize="15sp"
                      android:shadowColor="@color/black"
                      android:shadowRadius="2"
                      android:shadowDx="0"
                      android:shadowDy="1"/>

                  <LinearLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:orientation="horizontal"
                      android:gravity="center_vertical">

                      <TextView
                          android:id="@+id/tv_timestamp"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:textColor="#CCFFFFFF"
                          android:textSize="12sp"/>

                      <!-- FIX: expiry label — was findViewWithTag, now proper ID -->
                      <TextView
                          android:id="@+id/tv_expiry_label"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="6dp"
                          android:textColor="#AAFFFFFF"
                          android:textSize="11sp"
                          android:visibility="gone"/>

                  </LinearLayout>

              </LinearLayout>

              <!-- More options -->
              <ImageButton
                  android:id="@+id/btn_more"
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:src="@android:drawable/ic_menu_more"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"/>

              <!-- Close -->
              <ImageButton
                  android:id="@+id/btn_close_status"
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:src="@drawable/ic_back"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"/>

          </LinearLayout>

      </LinearLayout>

      <!-- Mute button (video only) -->
      <ImageButton
          android:id="@+id/btn_mute"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:layout_gravity="end|top"
          android:layout_marginTop="72dp"
          android:layout_marginEnd="12dp"
          android:src="@drawable/ic_volume_on"
          android:tint="@color/white"
          android:background="@drawable/bg_circle_dark"
          android:padding="8dp"
          android:visibility="gone"
          android:contentDescription="Mute"/>

      <!-- FIX: Download + Forward action row (was findViewWithTag, now proper IDs) -->
      <LinearLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="end|top"
          android:layout_marginTop="124dp"
          android:layout_marginEnd="12dp"
          android:orientation="vertical">

          <ImageButton
              android:id="@+id/btn_download"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:src="@android:drawable/ic_menu_save"
              android:tint="@color/white"
              android:background="@drawable/bg_circle_dark"
              android:padding="8dp"
              android:contentDescription="Download"
              android:visibility="gone"/>

          <ImageButton
              android:id="@+id/btn_forward"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:layout_marginTop="8dp"
              android:src="@drawable/ic_arrow_right"
              android:tint="@color/white"
              android:background="@drawable/bg_circle_dark"
              android:padding="8dp"
              android:contentDescription="Forward"
              android:visibility="gone"/>

      </LinearLayout>

      <!-- Bottom chrome -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom"
          android:orientation="vertical"
          android:background="@drawable/bg_status_reply_overlay"
          android:paddingTop="32dp"
          android:paddingBottom="12dp"
          android:paddingStart="12dp"
          android:paddingEnd="12dp">

          <!-- FIX: Location tag — was findViewWithTag("tv_location_tag"), now proper ID -->
          <TextView
              android:id="@+id/tv_location_tag"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#EEFFFFFF"
              android:textSize="13sp"
              android:paddingBottom="4dp"
              android:drawablePadding="4dp"
              android:visibility="gone"/>

          <!-- Caption -->
          <TextView
              android:id="@+id/tv_caption"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:textColor="@color/white"
              android:textSize="14sp"
              android:paddingBottom="8dp"
              android:shadowColor="@color/black"
              android:shadowRadius="4"
              android:shadowDx="0"
              android:shadowDy="1"
              android:visibility="gone"/>

          <!-- Seen-by info (owner only) -->
          <TextView
              android:id="@+id/tv_seen_by"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#CCFFFFFF"
              android:textSize="13sp"
              android:paddingBottom="8dp"
              android:drawablePadding="4dp"
              android:clickable="true"
              android:focusable="true"
              android:background="?attr/selectableItemBackground"
              android:visibility="gone"/>

          <!-- Reaction + reply row -->
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical">

              <com.google.android.material.textfield.TextInputLayout
                  style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:hint="Reply to status…"
                  app:boxCornerRadiusTopEnd="24dp"
                  app:boxCornerRadiusTopStart="24dp"
                  app:boxCornerRadiusBottomEnd="24dp"
                  app:boxCornerRadiusBottomStart="24dp"
                  app:hintTextColor="@color/white"
                  app:boxStrokeColor="@color/white">

                  <com.google.android.material.textfield.TextInputEditText
                      android:id="@+id/et_reply"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:textColor="@color/white"
                      android:maxLines="2"
                      android:inputType="textCapSentences"/>

              </com.google.android.material.textfield.TextInputLayout>

              <ImageButton
                  android:id="@+id/btn_react"
                  android:layout_width="44dp"
                  android:layout_height="44dp"
                  android:layout_marginStart="8dp"
                  android:src="@drawable/ic_status_notification"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"
                  android:contentDescription="React"/>

              <ImageButton
                  android:id="@+id/btn_send_reply"
                  android:layout_width="44dp"
                  android:layout_height="44dp"
                  android:layout_marginStart="4dp"
                  android:src="@drawable/ic_send_fill"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"
                  android:contentDescription="Send reply"/>

          </LinearLayout>

      </LinearLayout>

  </FrameLayout>