<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_notif_settings"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="#111111"
            app:titleTextColor="#111111"
            app:subtitle="Notification settings"
            app:subtitleTextColor="#888888"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mute section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MUTE"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingBottom="6dp"
                android:paddingTop="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Mute toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mute notifications"
                                android:textSize="15sp"
                                android:textColor="#111111"/>

                            <TextView
                                android:id="@+id/tv_mute_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Not muted"
                                android:textSize="12sp"
                                android:textColor="#888888"/>
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_mute_channel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Mute duration (visible when muted) -->
                    <RadioGroup
                        android:id="@+id/rg_mute_duration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:visibility="gone">

                        <RadioButton
                            android:id="@+id/rb_mute_8h"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="For 8 hours"
                            android:textSize="14sp"
                            android:textColor="#333333"/>

                        <RadioButton
                            android:id="@+id/rb_mute_1week"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="For 1 week"
                            android:textSize="14sp"
                            android:textColor="#333333"/>

                        <RadioButton
                            android:id="@+id/rb_mute_always"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="Always"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:checked="true"/>
                    </RadioGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notification settings section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOTIFICATIONS"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingBottom="6dp"
                android:paddingTop="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Show previews -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Show preview"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_show_preview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Sound -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Notification sound"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_notif_sound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Vibrate -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vibrate"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_vibrate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Post type filters section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOTIFY ME ABOUT"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:paddingBottom="6dp"
                android:paddingTop="16dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Text posts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Text posts"
                            android:textSize="14sp" android:textColor="#111111"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_text_posts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Image posts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Image posts"
                            android:textSize="14sp" android:textColor="#111111"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_image_posts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Poll posts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Poll posts"
                            android:textSize="14sp" android:textColor="#111111"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_poll_posts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Link posts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Link posts"
                            android:textSize="14sp" android:textColor="#111111"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_link_posts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Audio posts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Audio posts"
                            android:textSize="14sp" android:textColor="#111111"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_audio_posts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginHorizontal="16dp"/>

                    <!-- Document posts -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Document posts"
                            android:textSize="14sp" android:textColor="#111111"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_doc_posts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_notif_defaults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset to defaults"
                android:textColor="#E53935"
                android:backgroundTint="@android:color/transparent"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginTop="16dp"/>

            <!-- ── Stub switches for extended notification settings (visibility=gone) ── -->
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_all_posts"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_broadcasts"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_polls"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_new_follower"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_mention_only"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_milestone_alerts"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_event_reminders"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_poll_close_alerts"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
