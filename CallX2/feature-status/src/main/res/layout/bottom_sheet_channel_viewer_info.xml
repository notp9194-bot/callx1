<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_info_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_info_follower_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_info_channel_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Follow / Unfollow -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_follow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Follow"
            android:layout_marginBottom="8dp" />

        <!-- Mute -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_mute"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mute"
            android:layout_marginBottom="8dp" />

        <!-- Notifications -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_notifications"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification settings"
            android:layout_marginBottom="8dp" />

        <!-- NEW: QR Code button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_qr_code"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show QR code"
            android:layout_marginBottom="8dp" />

        <!-- QR code image (hidden initially, shown by button) -->
        <ImageView
            android:id="@+id/iv_info_qr_code"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- NEW: Share channel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_share_channel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Share channel"
            android:layout_marginBottom="8dp" />

        <!-- Report -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_report"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Report channel"
            android:textColor="@color/error" />

    </LinearLayout>
</ScrollView>
