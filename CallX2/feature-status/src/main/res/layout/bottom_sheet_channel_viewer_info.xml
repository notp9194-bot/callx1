<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp"
    android:background="@android:color/white">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#DDDDDD"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"/>

    <!-- Channel icon -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_channel_info_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/bg_channel_avatar_default"
        android:layout_marginBottom="12dp"/>

    <!-- Name + verified -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tv_channel_info_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111111"/>

        <TextView
            android:id="@+id/tv_channel_info_verified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" ✓"
            android:textColor="#0075C9"
            android:textSize="16sp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Follower count -->
    <TextView
        android:id="@+id/tv_channel_info_followers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="16dp"/>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#EEEEEE" android:layout_marginBottom="12dp"/>

    <!-- Description -->
    <TextView
        android:id="@+id/tv_channel_info_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:textSize="14sp"
        android:textColor="#444444"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="16dp"/>

    <!-- Info chips row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="20dp">

        <!-- Category chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tv_channel_info_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"/>

        <!-- Privacy chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tv_channel_info_privacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"/>

        <!-- Post count chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tv_channel_info_posts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Created date -->
    <TextView
        android:id="@+id/tv_channel_info_created"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="20dp"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_channel_info_share"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Share"
            android:textColor="#25D366"
            android:backgroundTint="#DCF5E7"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>

        <Button
            android:id="@+id/btn_channel_info_close"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Close"
            android:textColor="#555555"
            android:backgroundTint="#F2F2F2"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
    </LinearLayout>

</LinearLayout>
