<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Search bar (v25) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_status_search"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:hintAnimationEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_status_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search statuses…"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Status list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_status"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>

    </LinearLayout>

    <!-- FAB stack: WhatsApp-style — small pencil (edit/text status) above a larger camera FAB -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:gravity="end">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_edit_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:fabSize="mini"
            app:srcCompat="@drawable/ic_status_edit_pencil"
            app:backgroundTint="@android:color/white"
            app:tint="#4A4A4A"
            app:elevation="3dp"
            android:contentDescription="Text status"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_camera_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_status_camera"
            app:backgroundTint="#25D366"
            app:tint="@android:color/white"
            app:elevation="4dp"
            android:contentDescription="Camera status"/>

    </LinearLayout>

    <!-- Archive shortcut: subtle icon-only, WhatsApp keeps this understated -->
    <ImageButton
        android:id="@+id/btn_status_archive"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:src="@drawable/ic_status_archive"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:tint="?attr/colorOnSurfaceVariant"
        android:contentDescription="Archive"
        android:visibility="visible"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
