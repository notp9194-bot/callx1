<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_channel_post_card">

    <!-- Post header -->
    <LinearLayout
        android:id="@+id/layout_post_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_post_author_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_post_author_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_post_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/textSecondary" />
        </LinearLayout>
        <ImageButton
            android:id="@+id/btn_post_overflow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More" />
    </LinearLayout>

    <!-- Event banner image -->
    <ImageView
        android:id="@+id/iv_event_post_banner"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:layout_marginBottom="10dp"
        android:visibility="gone" />

    <!-- Event title -->
    <TextView
        android:id="@+id/tv_event_post_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Date/time -->
    <TextView
        android:id="@+id/tv_event_post_datetime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#FF25D366"
        android:layout_marginBottom="4dp" />

    <!-- Location -->
    <TextView
        android:id="@+id/tv_event_post_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="6dp"
        android:visibility="gone" />

    <!-- Description -->
    <TextView
        android:id="@+id/tv_event_post_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:layout_marginBottom="10dp" />

    <!-- RSVP buttons -->
    <LinearLayout
        android:id="@+id/layout_event_rsvp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <Button
            android:id="@+id/btn_event_rsvp_going"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Going"
            android:textSize="12sp"
            android:backgroundTint="#FF25D366"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp" />
        <Button
            android:id="@+id/btn_event_rsvp_maybe"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Maybe"
            android:textSize="12sp"
            android:backgroundTint="#FFFFA500"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="4dp" />
        <Button
            android:id="@+id/btn_event_rsvp_no"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Not going"
            android:textSize="12sp"
            android:backgroundTint="#FFDDDDDD"
            android:textColor="#333333" />
    </LinearLayout>

    <!-- Reactions row -->
    <include layout="@layout/layout_post_reactions_row" />
</LinearLayout>
