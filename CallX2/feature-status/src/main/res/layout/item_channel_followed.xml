<?xml version="1.0" encoding="utf-8"?>
<!-- Followed channel row — like a WhatsApp chat row with unread badge + muted icon -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_channel_icon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/bg_channel_avatar_default"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_channel_verified"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ✓"
                android:textColor="#0075C9"
                android:textSize="13sp"
                android:visibility="gone"/>

            <!-- Muted bell icon -->
            <ImageView
                android:id="@+id/iv_channel_muted"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_lock_silent_mode"
                android:tint="#AAAAAA"
                android:layout_marginStart="4dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_channel_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_channel_last_post"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textColor="#666666"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

            <!-- Unread count badge -->
            <TextView
                android:id="@+id/tv_channel_unread_badge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_unread_badge"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
