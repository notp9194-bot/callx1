<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp">

    <View android:layout_width="48dp" android:layout_height="4dp"
        android:background="#33000000" android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/tv_seen_by_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="👁 Seen By" android:textSize="17sp" android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView android:id="@+id/tv_reaction_summary"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="14sp" android:textColor="#888888"
        android:layout_marginBottom="12dp"/>

    <!-- FIX: Search bar (was missing) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_viewer_search"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Search viewers…" android:layout_marginBottom="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_viewer_search"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:imeOptions="actionSearch" android:singleLine="true"/>
    </com.google.android.material.textfield.TextInputLayout>

    <ProgressBar android:id="@+id/pb_viewers"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_viewers"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:nestedScrollingEnabled="true"/>

    <TextView android:id="@+id/tv_no_viewers"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="No viewers yet" android:gravity="center"
        android:textColor="#888888" android:visibility="gone"
        android:paddingTop="40dp" android:paddingBottom="40dp"/>
</LinearLayout>
