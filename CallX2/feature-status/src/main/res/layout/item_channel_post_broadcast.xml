<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_channel_post_card">

    <!-- Post header: author icon + name + time -->
    <LinearLayout
        android:id="@+id/layout_post_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_post_author_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="10dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_post_author_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_post_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/textSecondary" />
        </LinearLayout>
        <ImageButton
            android:id="@+id/btn_post_overflow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More" />
    </LinearLayout>

    <!-- Priority badge -->
    <TextView
        android:id="@+id/tv_broadcast_priority_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:text="📢 Broadcast"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp"
        android:background="#FF25D366"
        android:layout_marginBottom="8dp" />

    <!-- Broadcast text -->
    <TextView
        android:id="@+id/tv_broadcast_post_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.3" />

    <!-- Reactions row -->
    <include layout="@layout/layout_post_reactions_row" />
</LinearLayout>
