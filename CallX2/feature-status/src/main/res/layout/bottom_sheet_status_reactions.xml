<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="React to status"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Emoji row — 8 emojis matching StatusReactionBottomSheet.EMOJIS -->
    <LinearLayout
        android:id="@+id/emoji_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <LinearLayout android:id="@+id/cell_heart"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_heart"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="❤️" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_heart"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/cell_laugh"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_laugh"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="😂" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_laugh"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/cell_wow"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_wow"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="😮" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_wow"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/cell_sad"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_sad"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="😢" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_sad"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/cell_angry"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_angry"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="😡" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_angry"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/cell_thumbs"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_thumbs"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="👍" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_thumbs"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <!-- NEW: fire emoji -->
        <LinearLayout android:id="@+id/cell_fire"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_fire"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="🔥" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_fire"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

        <!-- NEW: clap emoji -->
        <LinearLayout android:id="@+id/cell_clap"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="4dp">
            <TextView android:id="@+id/react_clap"
                android:layout_width="wrap_content" android:layout_height="56dp"
                android:text="👏" android:textSize="28sp" android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:id="@+id/count_clap"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:gravity="center" android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Remove reaction row — shown only when user has already reacted -->
    <TextView
        android:id="@+id/btn_remove_reaction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="✕  Remove reaction"
        android:textSize="14sp"
        android:textColor="#E53935"
        android:paddingTop="16dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackground"/>

</LinearLayout>
