<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="#CC000000">
    <!-- Color palette -->
    <HorizontalScrollView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:scrollbars="none"
        android:padding="8dp">
        <LinearLayout android:id="@+id/color_palette"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>
    <!-- Tools row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:padding="8dp">
        <ImageButton android:id="@+id/btn_draw_brush"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Brush"/>
        <ImageButton android:id="@+id/btn_draw_eraser"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_crop"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eraser" android:layout_marginStart="16dp"/>
        <SeekBar android:id="@+id/sb_brush_size"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:max="50" android:progress="8"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>
        <ImageButton android:id="@+id/btn_draw_undo"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Undo"/>
        <ImageButton android:id="@+id/btn_draw_clear"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clear" android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
