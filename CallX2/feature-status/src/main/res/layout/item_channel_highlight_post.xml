<?xml version="1.0" encoding="utf-8"?>
<!-- Grid item for saved/bookmarked posts -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:margin="4dp"
    android:background="@android:color/white"
    android:elevation="2dp">

    <!-- Thumbnail / icon -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp">

        <ImageView
            android:id="@+id/iv_highlight_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"/>

        <!-- Video play icon overlay -->
        <ImageView
            android:id="@+id/iv_highlight_type_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_media_play"
            android:tint="#FFFFFFFF"
            android:background="#60000000"
            android:padding="8dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Type badge -->
    <TextView
        android:id="@+id/tv_highlight_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#25D366"
        android:textStyle="bold"
        android:paddingHorizontal="8dp"
        android:paddingTop="6dp"/>

    <!-- Preview text -->
    <TextView
        android:id="@+id/tv_highlight_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#555555"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingHorizontal="8dp"
        android:paddingBottom="2dp"/>

    <!-- Date -->
    <TextView
        android:id="@+id/tv_highlight_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#AAAAAA"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp"/>

</LinearLayout>
