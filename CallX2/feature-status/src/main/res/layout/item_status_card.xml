<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="112dp"
    android:layout_height="176dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="24dp"
    android:layout_marginBottom="8dp">

    <!-- Card body: status image + gradient scrim + name -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="22dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp"
        android:foreground="?attr/selectableItemBackground">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_card_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#3A3A3A"
                android:src="@drawable/ic_person"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_status_card_scrim"/>

            <TextView
                android:id="@+id/tv_card_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:paddingHorizontal="8dp"
                android:paddingBottom="8dp"
                android:paddingTop="4dp"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:shadowColor="#B0000000"
                android:shadowRadius="4"
                android:text="Name"/>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Avatar + ring, overlapping the top edge of the card -->
    <FrameLayout
        android:id="@+id/fl_avatar"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_gravity="center_horizontal|top">

        <ImageView
            android:id="@+id/ring"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/circle_status_unseen"/>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_card_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="center"
            app:civ_border_width="1.5dp"
            app:civ_border_color="@android:color/white"
            android:src="@drawable/ic_person"/>

        <!-- Add (+) badge, shown only on own "add status" tile -->
        <ImageView
            android:id="@+id/iv_card_add"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:src="@android:drawable/ic_input_add"
            android:tint="@android:color/white"
            android:padding="2dp"
            android:background="@drawable/bg_status_card_add_badge"
            android:visibility="gone"/>

    </FrameLayout>

</FrameLayout>
