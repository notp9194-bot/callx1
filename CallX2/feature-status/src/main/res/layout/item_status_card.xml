<?xml version="1.0" encoding="utf-8"?>
<!--
  Classic WhatsApp-style status tile: a circular thumbnail with a coloured ring
  (green = has an unseen update, grey = fully viewed) and the contact's name
  truncated to one line below it. Used inside the horizontal status carousel
  on the Updates screen, matching the reference "Updates" tab design.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="78dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingHorizontal="6dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Ring + circular thumbnail + add badge -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <ImageView
            android:id="@+id/ring"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/circle_status_ring_unseen"/>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_card_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            app:civ_border_width="2dp"
            app:civ_border_color="?attr/colorSurface"
            android:src="@drawable/ic_person"/>

        <!-- Kept for adapter compatibility; unused visually in the classic circle design. -->
        <ImageView
            android:id="@+id/iv_card_bg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- Add (+) badge, shown only on the own "Add status" tile -->
        <ImageView
            android:id="@+id/iv_card_add"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_status_add"
            android:background="@drawable/bg_status_card_add_badge"
            android:padding="2dp"
            android:visibility="gone"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tv_card_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:textColor="?attr/colorOnSurface"
        android:textSize="11.5sp"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Name"/>

</LinearLayout>
