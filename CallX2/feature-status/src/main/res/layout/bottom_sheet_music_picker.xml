<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="600dp"
    android:orientation="vertical" android:padding="16dp">
    <View android:layout_width="48dp" android:layout_height="4dp"
        android:background="#33000000" android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🎵 Add Music" android:textSize="17sp" android:textStyle="bold"
        android:layout_marginBottom="12dp"/>
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_music_search"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Search songs…" android:layout_marginBottom="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_music_search"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:imeOptions="actionSearch" android:singleLine="true"/>
    </com.google.android.material.textfield.TextInputLayout>
    <ProgressBar android:id="@+id/pb_music" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center_horizontal"
        android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_music_list"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:nestedScrollingEnabled="true"/>
</LinearLayout>
