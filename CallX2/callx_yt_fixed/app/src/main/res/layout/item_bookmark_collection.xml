<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="72dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="12dp">
    <ImageView android:id="@+id/iv_coll_cover" android:layout_width="56dp"
        android:layout_height="56dp" android:scaleType="centerCrop"
        android:background="#2A2A2A" android:layout_marginEnd="14dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_coll_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_coll_count" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#888888"
            android:textSize="13sp" android:layout_marginTop="2dp"/>
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="›" android:textColor="#555555" android:textSize="22sp"/>
</LinearLayout>
