<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="72dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="12dp">
    <ImageView android:id="@+id/iv_product_img" android:layout_width="50dp"
        android:layout_height="50dp" android:scaleType="centerCrop"
        android:background="#2A2A2A" android:layout_marginEnd="12dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_product_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"
            android:textSize="14sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end"/>
        <TextView android:id="@+id/tv_product_price" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FF3B5C"
            android:textSize="13sp" android:layout_marginTop="2dp"/>
    </LinearLayout>
    <Button android:id="@+id/btn_tag_product" android:layout_width="60dp"
        android:layout_height="32dp" android:text="Tag" android:textColor="#FFFFFF"
        android:backgroundTint="#FF3B5C" android:textSize="12sp"/>
</LinearLayout>
