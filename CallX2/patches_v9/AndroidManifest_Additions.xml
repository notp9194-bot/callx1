<!--
  AndroidManifest.xml Additions for Collab Repost Feature
  Add all entries below inside your <application> tag.
-->

<!-- ═══════════════════════════════════════════════════════
     REPOST ACTIVITIES
     ═══════════════════════════════════════════════════════ -->

<activity
    android:name=".repost.ViewRepostsActivity"
    android:exported="false"
    android:windowSoftInputMode="adjustResize"/>

<activity
    android:name=".repost.QuoteRepostActivity"
    android:exported="false"
    android:screenOrientation="portrait"
    android:windowSoftInputMode="adjustResize"/>

<activity
    android:name=".repost.RepostAnalyticsActivity"
    android:exported="false"/>

<activity
    android:name=".repost.RepostChainActivity"
    android:exported="false"/>

<!-- ═══════════════════════════════════════════════════════
     COLLAB ACTIVITIES
     ═══════════════════════════════════════════════════════ -->

<activity
    android:name=".collab.CollabInviteActivity"
    android:exported="false"
    android:windowSoftInputMode="adjustResize"/>

<activity
    android:name=".collab.CollabPendingActivity"
    android:exported="false"/>

<activity
    android:name=".collab.CollabSeriesActivity"
    android:exported="false"/>

<activity
    android:name=".collab.LiveCollabActivity"
    android:exported="false"
    android:screenOrientation="portrait"
    android:configChanges="keyboardHidden|orientation|screenSize"
    android:launchMode="singleTop"/>

<!-- ═══════════════════════════════════════════════════════
     WORKERS (WorkManager auto-discovers, but keep for clarity)
     ═══════════════════════════════════════════════════════ -->
<!--
  WorkManager discovers workers automatically via class scanning.
  No explicit manifest entries needed for:
    - RepostNotificationWorker
    - CollabNotificationWorker
    - ScheduledRepostWorker
-->

<!-- ═══════════════════════════════════════════════════════
     FCM NOTIFICATION CHANNELS (add in Application.onCreate)
     ═══════════════════════════════════════════════════════

  Add these channel IDs to your notification channel setup:

  "reel_social"      — Reposts, Collabs, Duets, Stitches
  "collab_invite"    — Collab invites (high priority)
  "live_collab"      — Live collab invites (max priority)
  "repost_milestone" — Viral badge milestones
-->
