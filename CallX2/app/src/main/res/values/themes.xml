<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- WhatsApp/Instagram style slide transition — right se aao, left ko jao -->
    <style name="ActivitySlideTransition">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.CallX" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Force pure white (phone's light-mode white) app-wide.
             Without these, Material3's baseline theme falls back to its
             default lavender-tinted surface color (~#FFFBFE) everywhere
             ?attr/colorSurface is used, giving the whole app a faint
             pink/purple cast in light mode. -->
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/white</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="colorSurfaceContainerHigh">@color/white</item>
        <item name="colorSurfaceContainerHighest">@color/white</item>
        <item name="colorSurfaceContainerLow">@color/white</item>
        <item name="colorSurfaceContainerLowest">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <!-- Transparent status/nav bar so edge-to-edge works correctly -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Global slide transition — every activity open/close will slide 50ms -->
        <item name="android:windowAnimationStyle">@style/ActivitySlideTransition</item>
    </style>

    <!-- Tab-level screens: instant open + close (0ms) — tab switch jaisa feel -->
    <style name="Theme.CallX.NoTransition" parent="Theme.CallX">
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.CallX.Fullscreen" parent="Theme.CallX">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>
    <style name="Theme.CallX.NoActionBar" parent="Theme.CallX" />
    <style name="Theme.CallX.Transparent" parent="Theme.CallX">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>

    <!-- ── feature-games themes (referenced in AndroidManifest) ── -->
    <style name="Theme.Games" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6C3CF7</item>
        <item name="colorPrimaryDark">#1A0A2E</item>
        <item name="colorAccent">#FF6B6B</item>
        <item name="android:windowBackground">#0D0221</item>
        <item name="android:statusBarColor">#1A0A2E</item>
        <item name="android:navigationBarColor">#1A0A2E</item>
    </style>

    <style name="Theme.Games.Fullscreen" parent="Theme.Games">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Theme.App — alias for Theme.CallX (used by feature-chat manifest entries) -->
    <style name="Theme.App" parent="Theme.CallX" />

    <!-- Theme.App.Immersive — used by feature-status manifest entries -->
    <style name="Theme.App.Immersive" parent="Theme.CallX.Fullscreen" />

</resources>
