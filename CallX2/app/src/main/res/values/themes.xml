<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ── Base App Theme ── -->
    <style name="Theme.CallX" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colours -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">#1E1B4B</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">#CCFBF1</item>
        <item name="colorTertiary">#8B5CF6</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorError">@color/colorError</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/surface_bg</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline</item>

        <!-- Status / Nav bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Edge-to-edge -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

        <!-- Activity transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/slide_right</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>

        <!-- Component styles -->
        <item name="bottomNavigationStyle">@style/Widget.CallX.BottomNav</item>
        <item name="textInputStyle">@style/Widget.CallX.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.CallX.Button</item>
        <item name="chipStyle">@style/Widget.CallX.Chip</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.CallX.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CallX.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.CallX.Large</item>
    </style>

    <!-- NoActionBar variant -->
    <style name="Theme.CallX.NoActionBar" parent="Theme.CallX"/>

    <!-- Transparent (for popup activities) -->
    <style name="Theme.CallX.Transparent" parent="Theme.CallX">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
    </style>

    <!-- Fullscreen (media viewer, status viewer) -->
    <style name="Theme.CallX.Fullscreen" parent="Theme.CallX">
        <item name="android:colorBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- ── Component Styles ── -->
    <style name="Widget.CallX.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemPaddingTop">8dp</item>
        <item name="itemPaddingBottom">8dp</item>
        <item name="elevation">0dp</item>
        <item name="backgroundTint">@color/surface_card</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.CallX.BottomNav.ActiveIndicator</item>
    </style>

    <style name="Widget.CallX.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">64dp</item>
        <item name="android:height">36dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.CallX.Large</item>
        <item name="android:color">@color/brand_primary_container</item>
    </style>

    <style name="Widget.CallX.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/surface_card</item>
    </style>

    <style name="Widget.CallX.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.CallX.Large</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CallX.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="shapeAppearance">@style/ShapeAppearance.CallX.Full</item>
    </style>
</resources>
