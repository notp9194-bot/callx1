<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/transparent"
            app:title="CallX"
            app:titleTextColor="@color/bar_on_background">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp">

                <ImageButton
                    android:id="@+id/btn_search_toolbar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/bar_on_background"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Search"/>

                <!-- Notification bell with badge -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="4dp">

                    <ImageButton
                        android:id="@+id/btn_notifications_toolbar"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        android:tint="@color/bar_on_background"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Notifications"/>

                    <TextView
                        android:id="@+id/tv_notif_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:minWidth="16dp"
                        android:minHeight="16dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:gravity="center"
                        android:background="@drawable/bg_unread_badge"
                        android:visibility="gone"/>
                </FrameLayout>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_avatar_menu"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="2dp"
                    app:civ_border_color="@color/brand_primary"/>
            </LinearLayout>

            <include
                android:id="@+id/include_x_entry"
                layout="@layout/layout_x_entry_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:layout_marginStart="4dp"/>

            <include
                android:id="@+id/include_yt_entry"
                layout="@layout/layout_youtube_entry_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:layout_marginStart="4dp"/>

            <include
                android:id="@+id/include_games_entry"
                layout="@layout/layout_games_entry_button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:layout_marginStart="4dp"/>
        </androidx.appcompat.widget.Toolbar>

        <!-- ══ Feature 1: Return to Call Banner ══════════════════════════════
             WhatsApp-style green strip jo tab dikhta hai jab call chal rahi ho
             aur user doosri screen pe chala gaya ho.
             Tap karo → CallActivity wapas khul jaata hai.
             Gone by default — onResume() mein show/hide hota hai.
        ════════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/banner_return_to_call"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#FF1FA855"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_phone"
                android:tint="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tv_return_to_call_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap to return to call"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_return_to_call_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_unread_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="58dp"/>

    <!-- Bottom nav -->
    <FrameLayout
        android:id="@+id/nav_container"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        android:elevation="8dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="wrap_content"
            android:layout_height="58dp"
            android:layout_gravity="center"
            android:minWidth="260dp"
            android:maxWidth="380dp"
            android:background="@color/transparent"
            app:itemIconTint="@color/brand_primary"
            app:itemTextColor="@color/brand_primary"
            app:itemIconSize="22dp"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"/>
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:src="@drawable/ic_status_add"
        android:contentDescription="Action"
        app:backgroundTint="@color/brand_primary"
        app:tint="@color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
