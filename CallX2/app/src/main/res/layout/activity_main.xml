<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:background="@color/surface_bg">

            <!-- Logo mark -->
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_primary">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="C"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CallX"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:letterSpacing="-0.02"/>

            <ImageButton
                android:id="@+id/btn_search_top"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_secondary"
                android:background="@drawable/card_rounded"
                android:contentDescription="Search"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar_menu"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_person"
                android:background="@color/surface_input"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/brand_primary"/>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- Floating bottom nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/card_rounded"
        android:elevation="12dp"
        app:itemIconTint="@color/brand_primary"
        app:itemTextColor="@color/brand_primary"
        app:itemActiveIndicatorColor="@color/nav_indicator"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="96dp"
        android:src="@drawable/ic_status_add"
        android:contentDescription="New chat"
        app:backgroundTint="@color/brand_primary"
        app:tint="@color/white"
        app:elevation="8dp"
        app:shapeAppearance="@style/ShapeLarge"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
