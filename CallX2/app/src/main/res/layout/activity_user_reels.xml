<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_user_reels.xml — SCROLLING FIX v2
    ============================================
    OLD (BROKEN): LinearLayout > NestedScrollView > LinearLayout > SwipeRefreshLayout > RecyclerView
      Problem: NestedScrollView + RecyclerView(nestedScrollingEnabled=false) fight over scroll events.
               fillViewport miscalculates height → RecyclerView gets 0 or wrong height → no scroll.

    NEW (FIXED):  LinearLayout (vertical)
                    ├── MultiSelect bar (fixed top)
                    ├── Top nav bar (fixed top)
                    ├── Profile header section (fixed — avatar, stats, bio, actions)
                    ├── TabLayout (fixed — sticky tabs)
                    └── SwipeRefreshLayout > RecyclerView (takes all remaining height via layout_weight=1)

    RecyclerView owns ALL scrolling.
    Pagination via RecyclerView.OnScrollListener (not NestedScrollView listener).
    SwipeRefreshLayout enabled/disabled by canScrollVertically(-1).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="false">

    <!-- ── Multi-select action bar (hidden by default) ── -->
    <LinearLayout
        android:id="@+id/layout_multi_select_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/brand_primary"
        android:elevation="6dp"
        android:visibility="gone">

        <ImageButton android:id="@+id/btn_cancel_select"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Cancel"/>

        <TextView android:id="@+id/tv_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:text="0 Selected" android:textColor="#FFFFFF"
            android:textSize="16sp" android:fontFamily="sans-serif-medium"/>

        <ImageButton android:id="@+id/btn_share_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_share_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Share"/>

        <ImageButton android:id="@+id/btn_delete_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Delete"/>
    </LinearLayout>

    <!-- ── Top navigation bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="?attr/colorSurface">

        <ImageButton android:id="@+id/btn_back"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="4dp">

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <TextView android:id="@+id/tv_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="User" android:textSize="17sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"
                    android:maxLines="1" android:ellipsize="end"/>

                <ImageView android:id="@+id/iv_verified"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    android:tint="@color/brand_primary"
                    android:contentDescription="Verified"
                    android:visibility="gone"/>
            </LinearLayout>


        </LinearLayout>

        <ImageButton android:id="@+id/btn_share_profile"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Send" android:padding="10dp"/>

        <Button android:id="@+id/btn_follow"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Follow" android:textSize="13sp"
            app:textAllCaps="false"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:background="@color/brand_primary"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

        <ImageButton android:id="@+id/btn_creator_hub"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_reel_creator"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Creator Hub"
            android:padding="8dp" android:visibility="gone"/>

        <ImageButton android:id="@+id/btn_settings"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Settings"
            android:padding="8dp" android:visibility="gone"/>

        <ImageButton android:id="@+id/btn_more"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="More options"/>
    </LinearLayout>

    <!-- ── Profile header: avatar + stats ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="14dp" android:paddingBottom="10dp">

        <!-- Avatar with story ring -->
        <FrameLayout android:layout_width="115dp" android:layout_height="115dp">

            <View android:id="@+id/view_story_ring"
                android:layout_width="115dp" android:layout_height="115dp"
                android:background="@drawable/bg_story_ring"
                android:visibility="gone"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar"
                android:layout_width="104dp" android:layout_height="104dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                app:civ_border_width="2.5dp"
                app:civ_border_color="@color/brand_primary"/>

            <View android:layout_width="16dp" android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="2dp" android:layout_marginBottom="2dp"
                android:background="@drawable/bg_story_ring"
                android:backgroundTint="@color/status_online"/>
        </FrameLayout>

        <!-- Stats: Followers | Following | Reels -->
        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center" android:layout_marginStart="8dp">

            <LinearLayout android:id="@+id/layout_followers_click"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_followers"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="19sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FOLLOWERS" android:textSize="10sp"
                    android:letterSpacing="0.04"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/layout_following_click"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_following"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="19sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FOLLOWING" android:textSize="10sp"
                    android:letterSpacing="0.04"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tv_reel_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="19sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="REELS" android:textSize="10sp"
                    android:letterSpacing="0.04"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Mutual followers — Instagram style (clickable) -->
    <LinearLayout android:id="@+id/layout_mutual_followers"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="12dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <!-- Overlapping avatars container -->
        <FrameLayout
            android:id="@+id/frame_mutual_avatars"
            android:layout_width="62dp"
            android:layout_height="30dp"
            android:layout_marginEnd="10dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_mutual_3"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="18dp"
                android:src="@drawable/ic_person"
                android:visibility="gone"
                app:civ_border_width="1.5dp"
                app:civ_border_color="?attr/colorSurface"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_mutual_2"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="9dp"
                android:src="@drawable/ic_person"
                android:visibility="gone"
                app:civ_border_width="1.5dp"
                app:civ_border_color="?attr/colorSurface"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_mutual_1"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="0dp"
                android:src="@drawable/ic_person"
                android:visibility="gone"
                app:civ_border_width="1.5dp"
                app:civ_border_color="?attr/colorSurface"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>
        </FrameLayout>

        <TextView android:id="@+id/tv_mutual_followers"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.2"/>

    </LinearLayout>

    <!-- Bio -->
    <!-- Bio (max 3 lines, tap to expand) -->
    <TextView android:id="@+id/tv_bio"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="4dp" android:paddingBottom="2dp"
        android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"
        android:maxLines="3" android:ellipsize="end"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"/>

    <!-- Phone number row -->
    <LinearLayout android:id="@+id/layout_phone"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_phone"
            android:tint="@color/brand_primary"
            android:contentDescription="Phone"/>

        <TextView android:id="@+id/tv_phone"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- WhatsApp row -->
    <LinearLayout android:id="@+id/layout_whatsapp"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_whatsapp"
            android:tint="#25D366"
            android:contentDescription="WhatsApp"/>

        <TextView android:id="@+id/tv_whatsapp"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="13sp"
            android:textColor="#25D366"
            android:singleLine="true"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- Instagram row -->
    <LinearLayout android:id="@+id/layout_instagram"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_instagram"
            android:tint="#E1306C"
            android:contentDescription="Instagram"/>

        <TextView android:id="@+id/tv_instagram"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="13sp"
            android:textColor="#E1306C"
            android:singleLine="true"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- YouTube row -->
    <LinearLayout android:id="@+id/layout_youtube"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_youtube"
            android:tint="#FF0000"
            android:contentDescription="YouTube"/>

        <TextView android:id="@+id/tv_youtube"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="13sp"
            android:textColor="#FF0000"
            android:singleLine="true"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- Other link row -->
    <LinearLayout android:id="@+id/layout_other_link"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_link"
            android:tint="@color/brand_primary"
            android:contentDescription="Link"/>

        <TextView android:id="@+id/tv_other_link"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="13sp"
            android:textColor="@color/brand_primary"
            android:singleLine="true"
            android:ellipsize="end"/>

        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Action buttons: Message | Call | Video | X | YouTube -->
    <LinearLayout android:id="@+id/layout_actions"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="12dp" android:paddingBottom="12dp">

        <!-- Chat / Message button with avatar peek animation -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <FrameLayout android:layout_width="60dp" android:layout_height="60dp"
                android:clipChildren="false" android:clipToPadding="false">
                <ImageButton android:id="@+id/btn_message"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/bg_circle_action"
                    android:tint="@color/brand_primary"
                    android:contentDescription="Message" android:padding="13dp"/>
                <!-- Avatar peeking out from top — user ki chat profile image -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_chat"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:elevation="6dp"
                    android:visibility="invisible"
                    app:civ_border_width="2.5dp"
                    app:civ_border_color="@color/brand_primary"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Message" android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Audio Call button -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageButton android:id="@+id/btn_audio_call"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/bg_circle_action"
                android:tint="@color/brand_primary"
                android:contentDescription="Audio Call" android:padding="13dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Call" android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Video Call button -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageButton android:id="@+id/btn_video_call"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@drawable/ic_video_call"
                android:background="@drawable/bg_circle_action"
                android:tint="@color/brand_primary"
                android:contentDescription="Video Call" android:padding="13dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Video" android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- X button with avatar peek animation -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <FrameLayout android:layout_width="60dp" android:layout_height="60dp"
                android:clipChildren="false" android:clipToPadding="false">
                <ImageButton android:id="@+id/btn_open_x"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_x_logo"
                    android:background="@drawable/bg_social_x_btn"
                    android:tint="@color/white"
                    android:contentDescription="View X Profile" android:padding="13dp"/>
                <!-- User ki X profile avatar -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_x"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:elevation="6dp"
                    android:visibility="invisible"
                    app:civ_border_width="2.5dp"
                    app:civ_border_color="#000000"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="X" android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- YouTube button with avatar peek animation -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <FrameLayout android:layout_width="60dp" android:layout_height="60dp"
                android:clipChildren="false" android:clipToPadding="false">
                <ImageButton android:id="@+id/btn_open_youtube"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_youtube"
                    android:background="@drawable/bg_social_youtube_btn"
                    android:tint="@color/white"
                    android:contentDescription="View YouTube Channel" android:padding="13dp"/>
                <!-- User ki YouTube channel avatar -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_youtube"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:elevation="6dp"
                    android:visibility="invisible"
                    app:civ_border_width="2.5dp"
                    app:civ_border_color="#FF0000"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YouTube" android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── Tabs: Reels | Liked | Saved | Reposts ── -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabSelectedTextColor="@color/brand_primary"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        app:tabIndicatorColor="@color/brand_primary"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Caption">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Reels" android:icon="@drawable/ic_reels"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Liked" android:icon="@drawable/ic_heart"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Saved" android:icon="@drawable/ic_bookmark"/>
    </com.google.android.material.tabs.TabLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!--
        ── SCROLLING FIX: SwipeRefreshLayout + RecyclerView fill remaining space ──
        layout_height="0dp" + layout_weight="1" makes RecyclerView take ALL remaining
        vertical space. RecyclerView scrolls independently — no NestedScrollView wrapper.
    -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Reel grid — RecyclerView owns scrolling -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reels"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:padding="1dp"/>

            <!-- Private account overlay -->
            <LinearLayout android:id="@+id/layout_private_account"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="40dp" android:background="?attr/colorSurface"
                android:visibility="gone">

                <ImageView android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_lock" android:alpha="0.6"
                    android:tint="?attr/colorOnSurface"
                    android:contentDescription="Private account"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="This account is private"
                    android:textSize="17sp" android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Follow this account to see their reels, followers and following."
                    android:textSize="13sp" android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:visibility="gone"/>

            <!-- Empty state -->
            <LinearLayout android:id="@+id/layout_empty"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="32dp" android:visibility="gone">

                <ImageView android:id="@+id/iv_empty_icon"
                    android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_reels" android:alpha="0.3"
                    android:contentDescription="Empty"/>

                <TextView android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" android:text="No Reels Yet"
                    android:textSize="18sp" android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView android:id="@+id/tv_empty_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="This creator hasn't posted any reels yet."
                    android:textSize="14sp" android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
