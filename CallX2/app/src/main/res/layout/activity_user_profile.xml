<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ── Collapsing Toolbar + Cover/Avatar ── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@drawable/gradient_brand"
            app:expandedTitleGravity="bottom|start"
            app:expandedTitleMarginStart="72dp"
            app:expandedTitleMarginBottom="72dp"
            app:expandedTitleTextAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            app:collapsedTitleTextAppearance="@style/TextAppearance.Material3.TitleMedium">

            <!-- Cover gradient background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_brand"
                app:layout_collapseMode="parallax"/>

            <!-- Large avatar centered -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar_large"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="56dp"
                android:src="@drawable/ic_person"
                android:clickable="true"
                android:focusable="true"
                app:civ_border_width="3dp"
                app:civ_border_color="#FFFFFF"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5"/>

            <!-- Toolbar (back button) -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_back"
                app:navigationIconTint="@color/white"
                app:titleTextColor="@color/white"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable content ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Name + About card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tv_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:text="Name"/>

                    <!-- Bio/tagline -->
                    <TextView
                        android:id="@+id/tv_bio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/brand_primary"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                    <!-- CallX ID -->
                    <TextView
                        android:id="@+id/tv_callx_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Action Buttons Row (Reel | X | YouTube | Call | Video) ── -->
            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Reel button with avatar peek animation -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageButton
                            android:id="@+id/btn_action_reel"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:src="@drawable/ic_reels"
                            android:background="@drawable/bg_social_reel_btn"
                            android:tint="@color/brand_primary"
                            android:contentDescription="View Reels"
                            android:padding="13dp"/>
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_anim_reel"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_gravity="center"
                            android:elevation="4dp"
                            android:visibility="invisible"
                            app:civ_border_width="2dp"
                            app:civ_border_color="@color/brand_primary"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reel"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- X button with avatar peek animation -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageButton
                            android:id="@+id/btn_action_x"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:src="@drawable/ic_x_logo"
                            android:background="@drawable/bg_social_x_btn"
                            android:tint="@color/white"
                            android:contentDescription="View X Profile"
                            android:padding="13dp"/>
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_anim_x"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_gravity="center"
                            android:elevation="4dp"
                            android:visibility="invisible"
                            app:civ_border_width="2dp"
                            app:civ_border_color="#000000"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="X"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- YouTube button with avatar peek animation -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">
                        <ImageButton
                            android:id="@+id/btn_action_youtube"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:src="@drawable/ic_youtube"
                            android:background="@drawable/bg_social_youtube_btn"
                            android:tint="@color/white"
                            android:contentDescription="View YouTube Channel"
                            android:padding="13dp"/>
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_anim_youtube"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_gravity="center"
                            android:elevation="4dp"
                            android:visibility="invisible"
                            app:civ_border_width="2dp"
                            app:civ_border_color="#FF0000"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YouTube"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- Audio Call button -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btn_action_voice"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_phone"
                        android:background="@drawable/bg_circle_action"
                        android:tint="@color/brand_primary"
                        android:contentDescription="Audio Call"
                        android:padding="13dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Call"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- Video Call button -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btn_action_video"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_video_call"
                        android:background="@drawable/bg_circle_action"
                        android:tint="@color/brand_primary"
                        android:contentDescription="Video Call"
                        android:padding="13dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Video"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginTop="5dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ── About section ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About"
                        android:textSize="12sp"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tv_about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Phone number row ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_phone"
                        android:tint="@color/brand_primary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tv_phone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="?android:attr/textColorPrimary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mobile"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Social links card ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_social"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Social"
                        android:textSize="12sp"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <!-- WhatsApp row -->
                    <LinearLayout
                        android:id="@+id/row_whatsapp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_whatsapp"
                            android:tint="#25D366"/>
                        <TextView
                            android:id="@+id/tv_whatsapp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorPrimary"/>
                    </LinearLayout>

                    <!-- Instagram row -->
                    <LinearLayout
                        android:id="@+id/row_instagram"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_instagram"
                            android:tint="#E1306C"/>
                        <TextView
                            android:id="@+id/tv_instagram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorPrimary"/>
                    </LinearLayout>

                    <!-- Other link row -->
                    <LinearLayout
                        android:id="@+id/row_other_link"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_link"
                            android:tint="@color/brand_primary"/>
                        <TextView
                            android:id="@+id/tv_other_link"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorPrimary"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Mute / Block / Report options ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Mute -->
                    <LinearLayout
                        android:id="@+id/btn_mute"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/tv_mute_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🔔  Mute Notifications"
                            android:textSize="15sp"
                            android:textColor="?android:attr/textColorPrimary"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider" android:layout_marginStart="16dp"/>

                    <!-- Block -->
                    <LinearLayout
                        android:id="@+id/btn_block"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/tv_block_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🚫  Block"
                            android:textSize="15sp"
                            android:textColor="#EF4444"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/divider" android:layout_marginStart="16dp"/>

                    <!-- Report -->
                    <LinearLayout
                        android:id="@+id/btn_report"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚠️  Report"
                            android:textSize="15sp"
                            android:textColor="#EF4444"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
