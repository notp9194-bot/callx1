<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Status dot -->
    <View
        android:id="@+id/view_analytics_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_dot"
        android:layout_marginEnd="12dp"/>

    <!-- Name + seen info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_analytics_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/broadcast_text_primary"/>

        <TextView
            android:id="@+id/tv_analytics_seen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_analytics_gap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/broadcast_text_secondary"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
