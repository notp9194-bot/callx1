<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Status"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Preview area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_glass_card">

        <ImageView
            android:id="@+id/iv_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <EditText
            android:id="@+id/et_text_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Kuch type karo..."
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:background="@color/transparent"
            android:padding="24dp"
            android:textSize="22sp"
            android:gravity="center"
            android:inputType="textMultiLine"/>
    </FrameLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="36dp"
        android:gravity="center_vertical"
        android:weightSum="3">

        <ImageButton
            android:id="@+id/btn_pick_photo"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:src="@drawable/ic_gallery"
            android:tint="@color/text_secondary"
            android:background="@drawable/bg_glass_card"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/btn_pick_video"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:src="@drawable/ic_video"
            android:tint="@color/text_secondary"
            android:background="@drawable/bg_glass_card"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/btn_post_status"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:src="@drawable/ic_send"
            android:tint="@color/white"
            android:background="@drawable/circle_primary"/>
    </LinearLayout>
</LinearLayout>
