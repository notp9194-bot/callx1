<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="4dp"
    android:gravity="end">

    <!-- Sent message bubble (right-aligned, sender's POV) -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="3dp"
        android:layout_marginStart="48dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/broadcast_msg_bubble">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:minWidth="120dp"
            android:maxWidth="280dp">

            <!-- ── Scheduled indicator ─────────────────────────────── -->
            <TextView
                android:id="@+id/tv_scheduled_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#FF9800"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <!-- ── Poll card ───────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/ll_poll_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_poll_question"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/broadcast_text_primary"
                    android:layout_marginBottom="6dp"/>

                <!-- Poll options injected programmatically into this container -->
                <LinearLayout
                    android:id="@+id/ll_poll_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView
                    android:id="@+id/tv_poll_total_votes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/broadcast_text_secondary"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- ── Link preview card ────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/ll_link_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/broadcast_banner_bg"
                android:padding="8dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_link_thumb"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_link_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/broadcast_text_primary"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_link_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/broadcast_text_secondary"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:id="@+id/tv_link_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/broadcast_accent"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Multi-media thumbnails strip ────────────────────── -->
            <LinearLayout
                android:id="@+id/ll_multi_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <!-- Thumbnails injected programmatically -->

            </LinearLayout>

            <!-- ── Message text ────────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_broadcast_msg_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/broadcast_text_primary"/>

            <!-- ── Auto-expiry countdown ───────────────────────────── -->
            <TextView
                android:id="@+id/tv_expiry_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#F44336"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>

            <!-- ── Reply count ─────────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_reply_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/broadcast_accent"
                android:layout_marginTop="3dp"
                android:visibility="gone"/>

            <!-- ── Footer: time + delivery ─────────────────────────── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_broadcast_delivery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/broadcast_accent"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tv_broadcast_msg_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/broadcast_text_secondary"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
