<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="12dp">

        <ImageButton
            android:id="@+id/btn_thumb_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Choose Cover"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btn_thumb_apply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Use This"
            android:textColor="#FF3B5C"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_reel_chip_selected"/>
    </RelativeLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tv_thumb_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingVertical="4dp"
        android:text="Select a cover frame"
        android:textColor="#AAAAAA"
        android:textSize="13sp"/>

    <!-- Large preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/iv_thumb_preview_large"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:background="#111111"/>

        <ProgressBar
            android:id="@+id/progress_thumb_extract"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="#FF3B5C"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Frame time label -->
    <TextView
        android:id="@+id/tv_thumb_frame_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:paddingVertical="6dp"
        android:text="0:00"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"/>

    <!-- Seekbar scrubber -->
    <SeekBar
        android:id="@+id/sb_thumb_scrub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:progressTint="#FF3B5C"
        android:thumbTint="#FF3B5C"/>

    <!-- Horizontal frame strip -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_frame_strip"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        android:orientation="horizontal"/>

</LinearLayout>
