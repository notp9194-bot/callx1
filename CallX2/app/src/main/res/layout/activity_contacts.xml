<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brand_primary"
        android:elevation="4dp"/>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:alpha="0.5"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_search_contacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search contacts…"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"/>
    </LinearLayout>

    <!-- Selection info bar (shows when contacts are selected) -->
    <LinearLayout
        android:id="@+id/ll_selection_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_send_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:paddingStart="16dp"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:background="@color/surface_input"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Contact list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_contacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="72dp"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No contacts found"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:visibility="gone"/>

    <!-- Send button — full width at bottom -->
    <Button
        android:id="@+id/btn_send_forward"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Send"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="@color/brand_primary"
        android:visibility="gone"
        android:elevation="4dp"/>

</LinearLayout>
