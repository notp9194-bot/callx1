<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:background="#1A1A1A"
      android:layout_marginBottom="8dp">

      <!-- ── Header ── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:padding="12dp">

          <FrameLayout
              android:layout_width="42dp"
              android:layout_height="42dp">

              <de.hdodenhof.circleimageview.CircleImageView
                  android:id="@+id/iv_post_avatar"
                  android:layout_width="38dp"
                  android:layout_height="38dp"
                  android:layout_gravity="center"
                  android:src="@drawable/ic_person"
                  app:civ_border_width="1.5dp"
                  app:civ_border_color="@color/brand_primary"/>

              <!-- [FEATURE 12] Close Friends badge -->
              <TextView
                  android:id="@+id/badge_close_friends"
                  android:layout_width="14dp"
                  android:layout_height="14dp"
                  android:layout_gravity="bottom|end"
                  android:background="#FF2EA354"
                  android:gravity="center"
                  android:text="★"
                  android:textColor="#FFFFFF"
                  android:textSize="8sp"
                  android:visibility="gone"/>
          </FrameLayout>

          <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:orientation="vertical"
              android:layout_marginStart="10dp">

              <!-- [FEATURE 13] Collab indicator "with @user" -->
              <LinearLayout
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  android:gravity="center_vertical">

                  <TextView
                      android:id="@+id/tv_post_owner"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="@username"
                      android:textColor="#FFFFFF"
                      android:textSize="13sp"
                      android:fontFamily="sans-serif-medium"/>

                  <TextView
                      android:id="@+id/tv_collab_with"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginStart="4dp"
                      android:text="with @collab"
                      android:textColor="#AAAAAA"
                      android:textSize="11sp"
                      android:visibility="gone"/>
              </LinearLayout>

              <LinearLayout
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  android:gravity="center_vertical">

                  <TextView
                      android:id="@+id/tv_post_time"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="2h ago"
                      android:textColor="#AAAAAA"
                      android:textSize="11sp"/>

                  <!-- [FEATURE 11] Location tag -->
                  <TextView
                      android:id="@+id/tv_post_location"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_marginStart="6dp"
                      android:drawablePadding="2dp"
                      android:drawableStart="@drawable/ic_location_on"
                      android:text="Location"
                      android:textColor="#AAAAAA"
                      android:textSize="11sp"
                      android:visibility="gone"/>
              </LinearLayout>
          </LinearLayout>

          <!-- [FEATURE 19] Creator view count chip (own posts) -->
          <TextView
              android:id="@+id/tv_creator_views"
              android:layout_width="wrap_content"
              android:layout_height="26dp"
              android:background="#22FFFFFF"
              android:gravity="center"
              android:paddingStart="8dp"
              android:paddingEnd="8dp"
              android:text="1.2K views"
              android:textColor="#CCCCCC"
              android:textSize="11sp"
              android:layout_marginEnd="6dp"
              android:visibility="gone"/>

          <ImageButton
              android:id="@+id/btn_post_more"
              android:layout_width="36dp"
              android:layout_height="36dp"
              android:src="@drawable/ic_more_vert"
              android:tint="#AAAAAA"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:contentDescription="More"/>
      </LinearLayout>

      <!-- ── Media area (thumbnail + inline video + double-tap) ── -->
      <FrameLayout
          android:id="@+id/frame_media"
          android:layout_width="match_parent"
          android:layout_height="280dp">

          <!-- Thumbnail -->
          <ImageView
              android:id="@+id/iv_post_thumb"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:scaleType="centerCrop"
              android:background="#222222"/>

          <!-- [FEATURE 3] Inline ExoPlayer for video autoplay -->
          <androidx.media3.ui.PlayerView
              android:id="@+id/player_view_feed"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              app:use_controller="false"
              app:resize_mode="zoom"
              android:visibility="gone"/>

          <!-- Mute/Unmute overlay -->
          <ImageView
              android:id="@+id/btn_feed_mute"
              android:layout_width="32dp"
              android:layout_height="32dp"
              android:layout_gravity="bottom|end"
              android:layout_margin="8dp"
              android:src="@drawable/ic_volume_off"
              android:tint="#CCFFFFFF"
              android:background="#66000000"
              android:padding="6dp"
              android:visibility="gone"/>

          <!-- Buffering indicator -->
          <ProgressBar
              android:id="@+id/pb_video_buffer"
              android:layout_width="36dp"
              android:layout_height="36dp"
              android:layout_gravity="center"
              android:indeterminateTint="#FFFFFF"
              android:visibility="gone"/>

          <!-- Play icon for non-autoplaying video posts -->
          <ImageView
              android:id="@+id/iv_video_badge"
              android:layout_width="44dp"
              android:layout_height="44dp"
              android:layout_gravity="center"
              android:src="@drawable/ic_play"
              android:tint="#CCFFFFFF"
              android:visibility="gone"/>

          <!-- [FEATURE 6] Double-tap like heart animation -->
          <ImageView
              android:id="@+id/iv_like_anim"
              android:layout_width="80dp"
              android:layout_height="80dp"
              android:layout_gravity="center"
              android:src="@drawable/ic_heart_filled"
              android:tint="#FF3B5BDB"
              android:alpha="0.0"
              android:scaleX="0.5"
              android:scaleY="0.5"
              android:visibility="gone"/>

          <!-- Repost badge -->
          <LinearLayout
              android:id="@+id/layout_repost_badge"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="top|start"
              android:layout_margin="8dp"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:background="#99000000"
              android:paddingStart="6dp"
              android:paddingEnd="6dp"
              android:paddingTop="3dp"
              android:paddingBottom="3dp"
              android:visibility="gone">

              <ImageView
                  android:layout_width="12dp"
                  android:layout_height="12dp"
                  android:src="@drawable/ic_repost"
                  android:tint="#FFFFFF"/>

              <TextView
                  android:id="@+id/tv_repost_by"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="4dp"
                  android:text="Reposted"
                  android:textColor="#FFFFFF"
                  android:textSize="10sp"/>
          </LinearLayout>

          <!-- [FEATURE 20] Seen bubble (bottom-start) -->
          <TextView
              android:id="@+id/tv_seen_count"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="bottom|start"
              android:layout_margin="8dp"
              android:background="#66000000"
              android:gravity="center"
              android:paddingStart="6dp"
              android:paddingEnd="6dp"
              android:paddingTop="2dp"
              android:paddingBottom="2dp"
              android:drawableStart="@drawable/ic_eye"
              android:drawablePadding="4dp"
              android:text="0"
              android:textColor="#CCFFFFFF"
              android:textSize="11sp"
              android:visibility="gone"/>
      </FrameLayout>

      <!-- ── Actions row ── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="48dp"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingStart="4dp"
          android:paddingEnd="4dp">

          <!-- [FEATURE 6,7] Like button — double tap + long press reactions -->
          <ImageButton
              android:id="@+id/btn_post_like"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:src="@drawable/ic_heart"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:contentDescription="Like"/>

          <TextView
              android:id="@+id/tv_post_likes"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0"
              android:textColor="#CCCCCC"
              android:textSize="12sp"
              android:layout_marginEnd="6dp"/>

          <ImageButton
              android:id="@+id/btn_post_comment"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:src="@drawable/ic_comment_reel"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:contentDescription="Comment"/>

          <TextView
              android:id="@+id/tv_post_comments"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0"
              android:textColor="#CCCCCC"
              android:textSize="12sp"
              android:layout_marginEnd="6dp"/>

          <ImageButton
              android:id="@+id/btn_post_share"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:src="@drawable/ic_share_reel"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:contentDescription="Share"/>

          <TextView
              android:id="@+id/tv_post_shares"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="0"
              android:textColor="#CCCCCC"
              android:textSize="12sp"
              android:layout_marginEnd="6dp"/>

          <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

          <!-- [FEATURE 17] Save / Bookmark — opens collection sheet -->
          <ImageButton
              android:id="@+id/btn_post_save"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:src="@drawable/ic_bookmark"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:contentDescription="Save"/>
      </LinearLayout>

      <!-- [FEATURE 7] Reaction display (shows chosen emoji) -->
      <LinearLayout
          android:id="@+id/layout_reactions_display"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:paddingStart="12dp"
          android:paddingBottom="4dp"
          android:visibility="gone">

          <TextView
              android:id="@+id/tv_reaction_emoji"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="❤️"
              android:textSize="16sp"/>

          <TextView
              android:id="@+id/tv_reaction_count"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="4dp"
              android:text="1"
              android:textColor="#CCCCCC"
              android:textSize="12sp"/>
      </LinearLayout>

      <!-- ── Caption area ── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingStart="12dp"
          android:paddingEnd="12dp"
          android:paddingBottom="10dp">

          <!-- [FEATURES 8,9,10] Caption with hashtags/mentions, see more -->
          <TextView
              android:id="@+id/tv_post_caption"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:text=""
              android:textColor="#DDDDDD"
              android:textSize="13sp"
              android:maxLines="2"
              android:ellipsize="end"
              android:lineSpacingExtra="2dp"/>

          <TextView
              android:id="@+id/btn_see_more_caption"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="2dp"
              android:text="more"
              android:textColor="#AAAAAA"
              android:textSize="13sp"
              android:visibility="gone"/>
      </LinearLayout>

  </LinearLayout>