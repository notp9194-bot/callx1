<?xml version="1.0" encoding="utf-8"?>
<!--
    Story item for the horizontal stories bar.
    Sizes bumped for the Reels home header (82dp outer → 68dp image).
    Layer order:
      1. iv_reel_story_gradient_ring  — gradient oval (outermost, 82dp)
      2. iv_story_gap                  — white/dark gap ring (76dp, always visible when gradient shown)
      3. iv_story_avatar               — CircleImageView photo (68dp)
      4. iv_story_seen_ring            — gray ring for seen state (78dp, shown only when seen)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="86dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="82dp"
        android:layout_height="82dp">

        <!-- 1. Outer Gradient Ring (pink → orange → yellow) — shown for unseen stories -->
        <ImageView
            android:id="@+id/iv_reel_story_gradient_ring"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_gravity="center"
            android:src="@drawable/gradient_story_ring"
            android:visibility="gone"
            android:contentDescription="Unseen story gradient ring"/>

        <!-- 2. Inner Gap ring (dark background circle to create gap between gradient and photo) -->
        <View
            android:id="@+id/iv_story_gap"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_gap_ring"
            android:visibility="gone"/>

        <!-- 3. Seen ring (gray outline) — shown for all-seen status -->
        <ImageView
            android:id="@+id/iv_story_seen_ring"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_gravity="center"
            android:src="@drawable/circle_status_seen"
            android:visibility="gone"/>

        <!-- 4. Profile image — center -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_story_avatar"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            app:civ_border_width="2.5dp"
            app:civ_border_color="@color/brand_primary"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tv_story_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="User"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"/>

</LinearLayout>
