<?xml version="1.0" encoding="utf-8"?>
<!--
    Story item for the Reels home header stories bar.
    Sizes bumped for header (82dp outer FrameLayout → 68dp photo).
    Gap between gradient ring and photo is baked into gradient_story_ring drawable (layer-list).
    Layer order in FrameLayout:
      1. iv_reel_story_gradient_ring (82dp) — gradient + gap oval, VISIBLE when unseen
      2. iv_story_seen_ring (74dp)           — gray ring, VISIBLE when all seen
      3. iv_story_avatar (68dp)              — CircleImageView photo (always on top)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="86dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="82dp"
        android:layout_height="82dp">

        <!-- 1. Gradient ring (pink→orange→yellow) with built-in dark gap — shown for unseen stories -->
        <ImageView
            android:id="@+id/iv_reel_story_gradient_ring"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_gravity="center"
            android:src="@drawable/gradient_story_ring"
            android:visibility="gone"
            android:contentDescription="Unseen story gradient ring"/>

        <!-- 2. Gray seen ring — shown when all stories are seen -->
        <ImageView
            android:id="@+id/iv_story_seen_ring"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_gravity="center"
            android:src="@drawable/circle_status_seen"
            android:visibility="gone"/>

        <!-- 3. Profile photo (always on top) -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_story_avatar"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            app:civ_border_width="2.5dp"
            app:civ_border_color="@color/brand_primary"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tv_story_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="User"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"/>

</LinearLayout>
