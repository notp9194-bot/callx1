<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_blocked"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Blocked Users"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>

    <TextView
        android:id="@+id/tv_blocked_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:text="0 blocked users"/>

    <ProgressBar
        android:id="@+id/pb_blocked_users"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_blocked_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No blocked users"
        android:gravity="center"
        android:padding="48dp"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_blocked_users"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"/>

</LinearLayout>
