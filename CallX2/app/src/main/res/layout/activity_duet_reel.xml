<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!--
        FIX: Horizontal split — left=original reel, right=camera (Instagram duet style)
        FIX: layout_height="match_parent" on LinearLayout ensures both halves fill screen height
        FIX: resize_mode="fill" on PlayerView so video fills its pane (no blank grey area)
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- LEFT: Original reel -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <!--
                FIX: app:resize_mode="fill" — video fills the entire half without blank bars
                use_controller="false" — no ExoPlayer controls shown
            -->
            <!--
                CRITICAL FIX: surface_type="texture_view" — SurfaceView conflicts with
                CameraX PreviewView (both fight for Z-layer ownership, one goes blank).
                TextureView renders in the same window layer — no conflict.
            -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/player_view_original"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="fill"
                app:surface_type="texture_view"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:text="Original"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="#66000000"/>
        </FrameLayout>

        <!-- Vertical divider -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@color/brand_primary"/>

        <!-- RIGHT: Camera live preview -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <!--
                FIX: scaleType="fillCenter" so portrait camera fills the pane correctly
            -->
            <androidx.camera.view.PreviewView
                android:id="@+id/preview_view_camera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:scaleType="fillCenter"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:text="You"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="#66000000"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom record controls overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp"
        android:paddingTop="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#66000000">

        <!-- Original audio volume slider -->
        <SeekBar
            android:id="@+id/seek_original_volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/brand_primary"
            android:thumbTint="@color/brand_primary"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tv_volume_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Original: 50%"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:layout_marginBottom="8dp"/>

        <!-- Mic gain slider -->
        <SeekBar
            android:id="@+id/seek_mic_gain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:progressTint="#FF4081"
            android:thumbTint="#FF4081"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tv_mic_gain_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic: 100%"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tv_duet_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/progress_duet"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="60"
            android:progress="0"
            android:progressTint="@color/brand_primary"
            android:progressBackgroundTint="#44FFFFFF"
            android:layout_marginBottom="16dp"/>

        <ImageButton
            android:id="@+id/btn_duet_record"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/circle_primary"
            android:tint="@color/white"
            android:padding="14dp"
            android:contentDescription="Record duet"/>
    </LinearLayout>

    <!-- Top controls overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingTop="36dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_duet_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Close"/>

        <TextView
            android:id="@+id/tv_duet_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Duet"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"/>

        <ImageButton
            android:id="@+id/btn_view_duets"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_reels"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="View Duets"/>

        <ImageButton
            android:id="@+id/btn_duet_flip"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Flip camera"/>
    </LinearLayout>

    <!-- Countdown overlay -->
    <TextView
        android:id="@+id/tv_duet_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="3"
        android:textColor="#FFFFFF"
        android:textSize="96sp"
        android:fontFamily="sans-serif-black"
        android:visibility="gone"/>

    <!-- Layout selector stub (IDs needed by Java) -->
    <LinearLayout
        android:id="@+id/layout_duet_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:background="#55000000"
        android:padding="6dp">

        <ImageButton
            android:id="@+id/btn_layout_side_by_side"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:alpha="1.0"/>

        <ImageButton
            android:id="@+id/btn_layout_top_bottom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:alpha="0.4"
            android:layout_marginTop="4dp"/>

        <ImageButton
            android:id="@+id/btn_layout_pip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:alpha="0.4"
            android:layout_marginTop="4dp"/>

        <!-- Reaction Bubble -->
        <ImageButton
            android:id="@+id/btn_layout_reaction_bubble"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FF4081"
            android:contentDescription="Reaction Bubble"
            android:alpha="0.4"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Reaction Bubble draggable overlay -->
    <FrameLayout
        android:id="@+id/view_bubble_overlay"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="200dp"
        android:background="@drawable/bg_bubble_circle"
        android:visibility="gone"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:elevation="8dp">

        <androidx.camera.view.PreviewView
            android:id="@+id/preview_view_bubble"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="6dp"
            android:text="drag"
            android:textColor="#CCFFFFFF"
            android:textSize="9sp"/>
    </FrameLayout>

</FrameLayout>
