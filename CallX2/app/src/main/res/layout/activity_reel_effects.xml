<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="12dp">

        <ImageButton
            android:id="@+id/btn_effects_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"/>

        <TextView
            android:id="@+id/tv_effect_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Normal"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_effects_reset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Reset"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/btn_effects_apply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Apply"
                android:textColor="#FF3B5C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reel_chip_selected"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Preview image (shows effect live) -->
    <ImageView
        android:id="@+id/iv_effects_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="centerCrop"
        android:background="#1A1A1A"
        android:src="@drawable/ic_reel_camera"/>

    <!-- Effect strip -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:text="EFFECTS"
        android:textColor="#888888"
        android:textSize="11sp"
        android:letterSpacing="0.1"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_effects_strip"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:clipToPadding="false"
        android:orientation="horizontal"/>

    <!-- Sticker strip -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:text="STICKERS"
        android:textColor="#888888"
        android:textSize="11sp"
        android:letterSpacing="0.1"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_sticker_strip"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:clipToPadding="false"
        android:orientation="horizontal"/>

    <!-- Fine-tune sliders -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brightness"
                android:textColor="#CCCCCC"
                android:textSize="13sp"/>
            <SeekBar
                android:id="@+id/sb_effects_brightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#FF3B5C"
                android:thumbTint="#FF3B5C"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Contrast"
                android:textColor="#CCCCCC"
                android:textSize="13sp"/>
            <SeekBar
                android:id="@+id/sb_effects_contrast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#FF3B5C"
                android:thumbTint="#FF3B5C"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Saturation"
                android:textColor="#CCCCCC"
                android:textSize="13sp"/>
            <SeekBar
                android:id="@+id/sb_effects_saturation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#FF3B5C"
                android:thumbTint="#FF3B5C"/>

            <TextView
                android:id="@+id/tv_beauty_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Beauty: 0%"
                android:textColor="#CCCCCC"
                android:textSize="13sp"/>
            <SeekBar
                android:id="@+id/sb_effects_beauty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#FF3B5C"
                android:thumbTint="#FF3B5C"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
