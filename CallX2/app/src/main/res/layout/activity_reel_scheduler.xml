<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="8dp" android:paddingEnd="12dp">
        <ImageButton android:id="@+id/btn_scheduler_back" android:layout_width="40dp"
            android:layout_height="40dp" android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Schedule Reel"
            android:textSize="18sp" android:fontFamily="sans-serif-medium" android:paddingStart="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- New schedule section -->
            <LinearLayout android:id="@+id/layout_new_schedule"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="REEL PREVIEW" android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                    android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                        <ImageView android:id="@+id/iv_sched_thumb" android:layout_width="60dp"
                            android:layout_height="80dp" android:scaleType="centerCrop"
                            android:background="#1A1A1A" android:src="@drawable/ic_video"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                            <TextView android:id="@+id/tv_sched_caption" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="No caption"
                                android:textSize="14sp" android:maxLines="2" android:ellipsize="end"/>
                            <TextView android:id="@+id/tv_sched_audience" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Audience: everyone"
                                android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="4dp"/>
                            <TextView android:id="@+id/tv_sched_music" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Music: None"
                                android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SCHEDULE TIME" android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                    android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">

                        <TextView android:id="@+id/tv_sched_datetime"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="—" android:textSize="16sp" android:fontFamily="sans-serif-medium"
                            android:gravity="center" android:padding="8dp" android:layout_marginBottom="12dp"/>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button android:id="@+id/btn_sched_pick_date"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_weight="1" android:text="Pick Date"
                                android:layout_marginEnd="8dp"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                            <Button android:id="@+id/btn_sched_pick_time"
                                android:layout_width="0dp" android:layout_height="44dp"
                                android:layout_weight="1" android:text="Pick Time"
                                android:layout_marginStart="8dp"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <ProgressBar android:id="@+id/progress_scheduler"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal" android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <Button android:id="@+id/btn_sched_save"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="Schedule Reel" android:textSize="15sp"
                    android:layout_marginBottom="24dp"/>
            </LinearLayout>

            <!-- Scheduled queue section -->
            <LinearLayout android:id="@+id/layout_sched_queue"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SCHEDULED QUEUE" android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                    android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sched_queue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
