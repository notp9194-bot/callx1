<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Full-screen remote video -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Local (PiP) video - top-right corner -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_video"
        android:layout_width="110dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:elevation="8dp"/>

    <!-- Subtle dark scrim for text readability -->
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#44000000"/>

    <!-- Caller name + status (top-center) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center"
        android:layout_marginTop="48dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_call_avatar"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_person"
            android:background="@color/surface_input"/>

        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tv_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D0E4FF"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Controls (bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingBottom="36dp"
        android:gravity="center">

        <!-- Row 1: Speaker | Switch Camera -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btn_toggle_speaker"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_audio"
                android:background="@drawable/circle_avatar_bg"
                android:alpha="0.4"
                android:layout_marginEnd="32dp"/>

            <ImageButton
                android:id="@+id/btn_switch_camera"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/circle_avatar_bg"/>
        </LinearLayout>

        <!-- Row 2: Mic | End Call | Camera -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_toggle_mic"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_mic"
                android:background="@drawable/circle_avatar_bg"
                android:layout_marginEnd="24dp"/>

            <ImageButton
                android:id="@+id/btn_end_call"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/circle_reject"
                android:tint="@color/white"
                android:layout_marginEnd="24dp"/>

            <ImageButton
                android:id="@+id/btn_toggle_camera"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_video"
                android:background="@drawable/circle_avatar_bg"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
