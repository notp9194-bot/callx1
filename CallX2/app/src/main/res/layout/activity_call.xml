<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_video"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"/>
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#33000000"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center"
        android:layout_marginTop="48dp">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_call_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_person"
            android:background="@color/surface_input"/>
        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>
        <TextView
            android:id="@+id/tv_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0E7FF"
            android:textSize="15sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="32dp"
        android:gravity="center">
        <ImageButton
            android:id="@+id/btn_toggle_mic"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/circle_avatar_bg"
            android:layout_marginEnd="20dp"/>
        <ImageButton
            android:id="@+id/btn_end_call"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:src="@drawable/ic_phone_off"
            android:background="@drawable/circle_reject"
            android:tint="@color/white"
            android:layout_marginEnd="20dp"/>
        <ImageButton
            android:id="@+id/btn_toggle_camera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_camera"
            android:background="@drawable/circle_avatar_bg"/>
    </LinearLayout>
</FrameLayout>
