<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <ImageView
        android:id="@+id/iv_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"/>

    <androidx.media3.ui.PlayerView
        android:id="@+id/player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Text status background -->
    <FrameLayout
        android:id="@+id/fl_text_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_call_bg"
        android:visibility="gone">
        <TextView
            android:id="@+id/tv_text_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="36dp"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingExtra="4dp"/>
    </FrameLayout>

    <!-- Top gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/gradient_top_dark"/>

    <!-- Progress bars row -->
    <LinearLayout
        android:id="@+id/ll_progress_bars"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="52dp"
        android:gravity="center_vertical"
        android:layout_gravity="top">

        <ProgressBar
            android:id="@+id/progress_status"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/white"
            android:backgroundTint="#44FFFFFF"/>
    </LinearLayout>

    <!-- Header row with avatar + name + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="68dp"
        android:gravity="center_vertical">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_owner"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_person"
            android:background="@color/surface_input"/>

        <TextView
            android:id="@+id/tv_owner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginStart="10dp"/>

        <ImageButton
            android:id="@+id/btn_close_status"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>
</FrameLayout>
