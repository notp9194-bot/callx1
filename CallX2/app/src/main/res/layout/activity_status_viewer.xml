<?xml version="1.0" encoding="utf-8"?>
  <FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/black">

      <!-- ── Full-screen content layers ── -->
      <ImageView
          android:id="@+id/iv_status"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:scaleType="centerCrop"
          android:visibility="gone"/>

      <androidx.media3.ui.PlayerView
          android:id="@+id/player_view"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:visibility="gone"/>

      <!-- Text / Poll / Question status background -->
      <FrameLayout
          android:id="@+id/fl_text_status"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:visibility="gone">

          <TextView
              android:id="@+id/tv_text_status"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_gravity="center"
              android:padding="40dp"
              android:textColor="@color/white"
              android:textSize="28sp"
              android:textStyle="bold"
              android:gravity="center"
              android:lineSpacingMultiplier="1.2"/>

          <!-- NEW: Poll container (shown inside fl_text_status when type=poll) -->
          <LinearLayout
              android:id="@+id/ll_poll_container"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_gravity="center"
              android:orientation="vertical"
              android:paddingStart="24dp"
              android:paddingEnd="24dp"
              android:visibility="gone">

              <TextView
                  android:id="@+id/tv_poll_question"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:textColor="@color/white"
                  android:textSize="22sp"
                  android:textStyle="bold"
                  android:gravity="center"
                  android:paddingBottom="20dp"/>

              <!-- Poll options injected here dynamically -->
              <LinearLayout
                  android:id="@+id/ll_poll_options"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"/>

              <TextView
                  android:id="@+id/tv_poll_total"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:textColor="#AAFFFFFF"
                  android:textSize="12sp"
                  android:gravity="center"
                  android:paddingTop="8dp"/>

          </LinearLayout>

          <!-- NEW: Question Box container (shown when type=question_box) -->
          <LinearLayout
              android:id="@+id/ll_question_box"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_gravity="center"
              android:orientation="vertical"
              android:paddingStart="24dp"
              android:paddingEnd="24dp"
              android:gravity="center"
              android:visibility="gone">

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="&#x2753;"
                  android:textSize="40sp"
                  android:paddingBottom="8dp"/>

              <TextView
                  android:id="@+id/tv_question_prompt"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:textColor="@color/white"
                  android:textSize="22sp"
                  android:textStyle="bold"
                  android:gravity="center"
                  android:paddingBottom="20dp"/>

              <com.google.android.material.textfield.TextInputLayout
                  style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:hint="Type your answer…"
                  app:boxCornerRadiusTopEnd="24dp"
                  app:boxCornerRadiusTopStart="24dp"
                  app:boxCornerRadiusBottomEnd="24dp"
                  app:boxCornerRadiusBottomStart="24dp"
                  app:hintTextColor="@color/white"
                  app:boxStrokeColor="@color/white">

                  <com.google.android.material.textfield.TextInputEditText
                      android:id="@+id/et_question_answer"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:textColor="@color/white"
                      android:maxLines="3"
                      android:inputType="textCapSentences"/>

              </com.google.android.material.textfield.TextInputLayout>

              <Button
                  android:id="@+id/btn_submit_answer"
                  android:layout_width="match_parent"
                  android:layout_height="48dp"
                  android:layout_marginTop="12dp"
                  android:text="Send Answer"
                  android:backgroundTint="#CC6200EE"/>

          </LinearLayout>

      </FrameLayout>

      <!-- ── Touch capture layer ── -->
      <View
          android:id="@+id/touch_layer"
          android:layout_width="match_parent"
          android:layout_height="match_parent"/>

      <!-- ── NEW: Floating emoji overlay (for double-tap ❤️ and reaction animation) ── -->
      <FrameLayout
          android:id="@+id/fl_emoji_overlay"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:importantForAccessibility="no"/>

      <!-- ── Top chrome ── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingTop="8dp">

          <!-- NEW: Music strip -->
          <LinearLayout
              android:id="@+id/ll_music_strip"
              android:layout_width="wrap_content"
              android:layout_height="32dp"
              android:layout_gravity="center_horizontal"
              android:layout_marginTop="4dp"
              android:layout_marginBottom="4dp"
              android:background="@drawable/bg_music_strip"
              android:paddingStart="12dp"
              android:paddingEnd="14dp"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              android:visibility="gone">

              <TextView
                  android:layout_width="12dp"
                  android:layout_height="wrap_content"
                  android:text="&#x266B;"
                  android:textColor="@color/white"
                  android:textSize="14sp"/>

              <TextView
                  android:id="@+id/tv_music_label"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="6dp"
                  android:textColor="@color/white"
                  android:textSize="12sp"
                  android:maxWidth="160dp"
                  android:maxLines="1"
                  android:ellipsize="marquee"
                  android:singleLine="true"
                  android:marqueeRepeatLimit="marquee_forever"
                  android:focusable="true"
                  android:focusableInTouchMode="true"
                  android:scrollHorizontally="true"/>

          </LinearLayout>

          <!-- Progress bars -->
          <LinearLayout
              android:id="@+id/segments_container"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:paddingStart="8dp"
              android:paddingEnd="8dp"
              android:paddingTop="4dp"
              android:paddingBottom="4dp"
              android:gravity="center_vertical"/>

          <!-- Header row -->
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:paddingStart="12dp"
              android:paddingEnd="8dp"
              android:paddingTop="6dp"
              android:paddingBottom="8dp"
              android:gravity="center_vertical">

              <de.hdodenhof.circleimageview.CircleImageView
                  android:id="@+id/iv_owner"
                  android:layout_width="38dp"
                  android:layout_height="38dp"
                  android:src="@drawable/ic_person"/>

              <LinearLayout
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:orientation="vertical"
                  android:layout_marginStart="10dp">

                  <TextView
                      android:id="@+id/tv_owner"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textColor="@color/white"
                      android:textStyle="bold"
                      android:textSize="15sp"
                      android:shadowColor="@color/black"
                      android:shadowRadius="2"
                      android:shadowDx="0"
                      android:shadowDy="1"/>

                  <LinearLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:orientation="horizontal"
                      android:gravity="center_vertical">

                      <TextView
                          android:id="@+id/tv_timestamp"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:textColor="#CCFFFFFF"
                          android:textSize="12sp"/>

                      <TextView
                          android:id="@+id/tv_expiry_label"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="6dp"
                          android:textColor="#AAFFFFFF"
                          android:textSize="11sp"
                          android:visibility="gone"/>

                      <!-- NEW: Privacy badge -->
                      <TextView
                          android:id="@+id/tv_privacy_viewer"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"
                          android:layout_marginStart="6dp"
                          android:textSize="11sp"
                          android:textColor="#AAFFFFFF"
                          android:visibility="gone"/>

                  </LinearLayout>

              </LinearLayout>

              <ImageButton
                  android:id="@+id/btn_more"
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:src="@android:drawable/ic_menu_more"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"/>

              <ImageButton
                  android:id="@+id/btn_close_status"
                  android:layout_width="40dp"
                  android:layout_height="40dp"
                  android:src="@drawable/ic_back"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"/>

          </LinearLayout>

      </LinearLayout>

      <!-- Mute button -->
      <ImageButton
          android:id="@+id/btn_mute"
          android:layout_width="44dp"
          android:layout_height="44dp"
          android:layout_gravity="end|top"
          android:layout_marginTop="72dp"
          android:layout_marginEnd="12dp"
          android:src="@drawable/ic_volume_on"
          android:tint="@color/white"
          android:background="@drawable/bg_circle_dark"
          android:padding="8dp"
          android:visibility="gone"
          android:contentDescription="Mute"/>

      <!-- Download + Forward -->
      <LinearLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="end|top"
          android:layout_marginTop="124dp"
          android:layout_marginEnd="12dp"
          android:orientation="vertical">

          <ImageButton
              android:id="@+id/btn_download"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:src="@android:drawable/ic_menu_save"
              android:tint="@color/white"
              android:background="@drawable/bg_circle_dark"
              android:padding="8dp"
              android:contentDescription="Download"
              android:visibility="gone"/>

          <ImageButton
              android:id="@+id/btn_forward"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:layout_marginTop="8dp"
              android:src="@drawable/ic_arrow_right"
              android:tint="@color/white"
              android:background="@drawable/bg_circle_dark"
              android:padding="8dp"
              android:contentDescription="Forward"
              android:visibility="gone"/>

      </LinearLayout>

      <!-- ── Bottom chrome ── -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom"
          android:orientation="vertical"
          android:background="@drawable/bg_status_reply_overlay"
          android:paddingTop="32dp"
          android:paddingBottom="12dp"
          android:paddingStart="12dp"
          android:paddingEnd="12dp">

          <!-- Location tag -->
          <TextView
              android:id="@+id/tv_location_tag"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#EEFFFFFF"
              android:textSize="13sp"
              android:paddingBottom="4dp"
              android:visibility="gone"/>

          <!-- NEW: Swipe-up link indicator -->
          <LinearLayout
              android:id="@+id/ll_swipe_up"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:gravity="center_horizontal"
              android:paddingBottom="6dp"
              android:visibility="gone">

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="&#x2B06;"
                  android:textColor="@color/white"
                  android:textSize="18sp"
                  android:id="@+id/tv_swipe_up_arrow"/>

              <TextView
                  android:id="@+id/tv_swipe_up_label"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:textColor="@color/white"
                  android:textSize="13sp"
                  android:text="Swipe up"/>

          </LinearLayout>

          <!-- Caption -->
          <TextView
              android:id="@+id/tv_caption"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:textColor="@color/white"
              android:textSize="14sp"
              android:paddingBottom="8dp"
              android:shadowColor="@color/black"
              android:shadowRadius="4"
              android:shadowDx="0"
              android:shadowDy="1"
              android:visibility="gone"/>

          <!-- Seen-by (owner only) -->
          <TextView
              android:id="@+id/tv_seen_by"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#CCFFFFFF"
              android:textSize="13sp"
              android:paddingBottom="8dp"
              android:clickable="true"
              android:focusable="true"
              android:background="?attr/selectableItemBackground"
              android:visibility="gone"/>

          <!-- Reply + react row -->
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical">

              <com.google.android.material.textfield.TextInputLayout
                  style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                  android:layout_width="0dp"
                  android:layout_height="wrap_content"
                  android:layout_weight="1"
                  android:hint="Reply to status…"
                  app:boxCornerRadiusTopEnd="24dp"
                  app:boxCornerRadiusTopStart="24dp"
                  app:boxCornerRadiusBottomEnd="24dp"
                  app:boxCornerRadiusBottomStart="24dp"
                  app:hintTextColor="@color/white"
                  app:boxStrokeColor="@color/white">

                  <com.google.android.material.textfield.TextInputEditText
                      android:id="@+id/et_reply"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:textColor="@color/white"
                      android:maxLines="2"
                      android:inputType="textCapSentences"/>

              </com.google.android.material.textfield.TextInputLayout>

              <ImageButton
                  android:id="@+id/btn_react"
                  android:layout_width="44dp"
                  android:layout_height="44dp"
                  android:layout_marginStart="8dp"
                  android:src="@drawable/ic_status_notification"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"
                  android:contentDescription="React"/>

              <ImageButton
                  android:id="@+id/btn_send_reply"
                  android:layout_width="44dp"
                  android:layout_height="44dp"
                  android:layout_marginStart="4dp"
                  android:src="@drawable/ic_send_fill"
                  android:tint="@color/white"
                  android:background="?attr/selectableItemBackgroundBorderless"
                  android:contentDescription="Send reply"/>

          </LinearLayout>

      </LinearLayout>

  </FrameLayout>