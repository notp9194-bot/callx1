<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Image viewer with pinch-to-zoom (single-media mode) -->
    <com.github.chrisbanes.photoview.PhotoView
        android:id="@+id/iv_full"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:scaleType="fitCenter"/>

    <!-- Video player (single-media mode) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Swipeable gallery (multi-media / grouped messages mode) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/media_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- "2 / 5" page counter — only shown in gallery mode -->
    <TextView
        android:id="@+id/tv_page_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="76dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#99000000"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:visibility="gone"
        android:contentDescription="Page position"/>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/pb_loading"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/white"
        android:visibility="gone"
        android:contentDescription="Loading"/>

    <!-- Top bar — tap image to toggle visibility -->
    <LinearLayout
        android:id="@+id/ll_top_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#99000000"
        android:layout_gravity="top">

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btn_save"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_save"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save to gallery"/>

        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_share"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"/>

        <ImageButton
            android:id="@+id/btn_more_options"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_info"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"/>
    </LinearLayout>

    <!-- #1 fix — selection-mode toolbar: shown instead of ll_top_bar while
         the user has long-pressed into multi-select mode inside the gallery.
         Lets them forward/delete/star several images/videos from the group
         together, instead of only ever acting on one at a time. -->
    <LinearLayout
        android:id="@+id/ll_select_toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#CC000000"
        android:layout_gravity="top"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_select_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel selection"/>

        <TextView
            android:id="@+id/tv_select_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:text="1 selected"/>

        <ImageButton
            android:id="@+id/btn_select_star"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/btn_star_big_off"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Star selected"/>

        <ImageButton
            android:id="@+id/btn_select_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete selected"/>

        <ImageButton
            android:id="@+id/btn_select_forward"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Forward selected"/>
    </LinearLayout>

</FrameLayout>
