<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_brand">

    <!-- Group icon / avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/ivIncomingGroupIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="80dp"
        android:src="@drawable/ic_group"
        app:civ_border_color="#80FFFFFF"
        app:civ_border_width="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Group name -->
    <TextView
        android:id="@+id/tvIncomingGroupName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:text="Group Name"
        app:layout_constraintTop_toBottomOf="@id/ivIncomingGroupIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Call type label -->
    <TextView
        android:id="@+id/tvIncomingGroupCallType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#CCFFFFFF"
        android:textSize="15sp"
        android:gravity="center"
        android:text="Incoming Group Voice Call"
        app:layout_constraintTop_toBottomOf="@id/tvIncomingGroupName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Caller info -->
    <TextView
        android:id="@+id/tvIncomingGroupCallerInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#AAFFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:text="Someone is calling…"
        app:layout_constraintTop_toBottomOf="@id/tvIncomingGroupCallType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Animated ring indicator (decorative) -->
    <View
        android:id="@+id/ringIndicator"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/circle_avatar_bg"
        android:alpha="0.3"
        app:layout_constraintTop_toBottomOf="@id/tvIncomingGroupCallerInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Action buttons row -->
    <LinearLayout
        android:id="@+id/llIncomingGroupCallActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Decline -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="40dp">

            <ImageButton
                android:id="@+id/btnGroupDeclineCall"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/circle_reject"
                android:contentDescription="Decline call"
                android:scaleType="centerInside"
                android:padding="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:text="Decline"/>
        </LinearLayout>

        <!-- Accept -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="40dp">

            <ImageButton
                android:id="@+id/btnGroupAcceptCall"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/circle_accept"
                android:contentDescription="Accept call"
                android:scaleType="centerInside"
                android:padding="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:text="Join"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
