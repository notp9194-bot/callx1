<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_small_window.xml
    Floating small window — draggable overlay that shows chat/call info.
    Screenshot 2 jaisa: top bar (minimize + close), content area.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="180dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="#1C1C1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Top drag-bar ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="4dp"
            android:background="#2C2C2E">

            <!-- Drag handle indicator -->
            <View
                android:layout_width="32dp"
                android:layout_height="3dp"
                android:background="#48484A"
                android:layout_gravity="center_vertical"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/tv_sw_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Name"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_sw_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online"
                    android:textColor="#8E8E93"
                    android:textSize="10sp"
                    android:maxLines="1"/>
            </LinearLayout>

            <!-- Minimize button -->
            <ImageButton
                android:id="@+id/btn_sw_minimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_pause"
                android:tint="#AEAEB2"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Minimize"/>

            <!-- Close button -->
            <ImageButton
                android:id="@+id/btn_sw_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:tint="#FF453A"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"/>

        </LinearLayout>

        <!-- ── Content area ──────────────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">

            <!-- Background gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_call_dark_scrim"/>

            <!-- Center content — avatar + status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iv_sw_avatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_person"
                    android:tint="#FFFFFF"
                    android:background="@drawable/circle_avatar_bg"
                    android:padding="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Small Window"
                    android:textColor="#AEAEB2"
                    android:textSize="10sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
