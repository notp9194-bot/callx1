<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_privacy_direct.xml
    PrivacyDirectDialog — screenshot 1 jaisa quick action popup.
    Options: Lock | App Info | Privacy Settings | Small Window
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- ── Lock ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/row_pd_lock"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_lock"
            android:tint="@color/text_primary"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lock"
            android:textColor="@color/text_primary"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- ── App Info ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/row_pd_app_info"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_info"
            android:tint="@color/text_primary"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="App info"
            android:textColor="@color/text_primary"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- ── Privacy Settings ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/row_pd_privacy"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_shield"
            android:tint="@color/text_primary"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Privacy settings"
            android:textColor="@color/text_primary"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- ── Small Window ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/row_pd_small_window"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_picture_in_picture"
            android:tint="@color/brand_primary"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Small window"
            android:textColor="@color/brand_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
