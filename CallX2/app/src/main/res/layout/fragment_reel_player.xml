<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen video surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        app:use_controller="false"
        app:resize_mode="zoom"
        app:surface_type="surface_view"/>

    <!-- Thumbnail placeholder (shown before video loads) -->
    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Reel thumbnail"/>

    <!-- Double tap like overlay -->
    <ImageView
        android:id="@+id/iv_like_anim"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_heart_filled"
        android:visibility="gone"
        android:alpha="0"
        android:contentDescription="Like animation"/>

    <!-- Play / Pause center overlay — fades in/out on tap -->
    <ImageView
        android:id="@+id/iv_play_pause_indicator"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_pause"
        android:alpha="0"
        android:background="#66000000"
        android:padding="14dp"
        android:contentDescription="Play/Pause indicator"/>

    <!-- Top row: mute button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="8dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_volume_on"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mute"/>
    </LinearLayout>

    <!-- Right action bar: Avatar · Like · Comment · Share · More -->
    <LinearLayout
        android:id="@+id/right_actions"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="80dp"
        android:paddingEnd="4dp">

        <!-- Owner avatar with follow badge -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_owner_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|center_horizontal"
                android:src="@drawable/ic_person"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/white"/>

            <!--
                CRITICAL: This is a TextView (NOT ImageButton).
                Any field binding this view MUST use type View or TextView.
                Using ImageButton causes ClassCastException → crash.
            -->
            <TextView
                android:id="@+id/btn_follow_overlay"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="bottom|center_horizontal"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:gravity="center"
                android:background="@color/brand_primary"
                android:visibility="visible"/>
        </FrameLayout>

        <!-- Like -->
        <ImageButton
            android:id="@+id/btn_like"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_heart"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like"/>
        <TextView
            android:id="@+id/tv_likes_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Comment -->
        <ImageButton
            android:id="@+id/btn_comment"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_comment_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Comment"/>
        <TextView
            android:id="@+id/tv_comments_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Share -->
        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_share_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"/>
        <TextView
            android:id="@+id/tv_shares_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>


        <!-- Repost -->
        <ImageButton
            android:id="@+id/btn_repost"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_repost"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Repost"/>
        <TextView
            android:id="@+id/tv_repost_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- 3-dot More — Repost / Save / Speed / Download / Report inside -->
        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"/>
    </LinearLayout>

    <!-- Bottom info strip -->
    <LinearLayout
        android:id="@+id/bottom_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="72dp"
        android:paddingBottom="18dp">

        <!-- Owner name + inline follow button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_owner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@user"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:id="@+id/tv_follow_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Follow"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/bg_reel_follow_btn"
                android:visibility="visible"/>
        </LinearLayout>

        <!-- Caption -->
        <TextView
            android:id="@+id/tv_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#FFFFFFEE"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- Hashtag chips row -->
        <HorizontalScrollView
            android:id="@+id/scroll_hashtags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="4dp"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/container_hashtags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Music name -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_music_note"
                android:contentDescription="Music"/>
            <TextView
                android:id="@+id/tv_music_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Original Audio"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Views count -->
        <TextView
            android:id="@+id/tv_views"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0 views"
            android:textColor="#AAFFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Video progress bar -->
    <ProgressBar
        android:id="@+id/progress_video"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:max="1000"
        android:progress="0"
        android:progressTint="@color/white"
        android:progressBackgroundTint="#44FFFFFF"
        android:layout_marginBottom="0dp"/>

    <!-- Buffering indicator -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone"/>

    <!-- Emoji reaction panel -->
    <LinearLayout
        android:id="@+id/layout_reactions"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@drawable/bg_reaction_panel"
        android:elevation="10dp"
        android:visibility="gone">

        <TextView android:id="@+id/react_fire"  android:layout_width="40dp" android:layout_height="40dp" android:text="🔥" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_heart" android:layout_width="40dp" android:layout_height="40dp" android:text="❤️" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_wow"   android:layout_width="40dp" android:layout_height="40dp" android:text="😮" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_laugh" android:layout_width="40dp" android:layout_height="40dp" android:text="😂" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_sad"   android:layout_width="40dp" android:layout_height="40dp" android:text="😢" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_clap"  android:layout_width="40dp" android:layout_height="40dp" android:text="👏" android:textSize="22sp" android:gravity="center"/>
    </LinearLayout>

</FrameLayout>
