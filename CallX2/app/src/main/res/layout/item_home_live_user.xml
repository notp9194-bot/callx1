<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="90dp" android:layout_height="wrap_content"
      android:orientation="vertical" android:gravity="center" android:padding="4dp" android:layout_marginEnd="8dp">
      <FrameLayout android:layout_width="76dp" android:layout_height="100dp">
          <ImageView android:id="@+id/iv_live_thumb" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="#333333"/>
          <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/gradient_reel_bottom" android:alpha="0.6"/>
          <TextView android:layout_width="wrap_content" android:layout_height="20dp" android:layout_gravity="top|start" android:layout_margin="4dp" android:background="#FFFF0000" android:gravity="center" android:paddingStart="6dp" android:paddingEnd="6dp" android:text="LIVE" android:textColor="#FFFFFF" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
          <TextView android:id="@+id/tv_live_viewers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:layout_margin="4dp" android:text="0" android:textColor="#FFFFFF" android:textSize="9sp"/>
      </FrameLayout>
      <de.hdodenhof.circleimageview.CircleImageView android:id="@+id/iv_live_avatar" android:layout_width="36dp" android:layout_height="36dp" android:layout_marginTop="-18dp" android:src="@drawable/ic_person" app:civ_border_width="2dp" app:civ_border_color="#FF0000"/>
      <TextView android:id="@+id/tv_live_name" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@user" android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="center" android:singleLine="true" android:ellipsize="end"/>
  </LinearLayout>