<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:background="?attr/selectableItemBackground">

    <!-- Cover art -->
    <ImageView
        android:id="@+id/iv_sound_cover"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_note"
        android:background="@drawable/bg_icon_semi"
        android:padding="8dp"/>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_sound_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sound Title"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_sound_artist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_sound_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Play/Pause -->
    <ImageButton
        android:id="@+id/btn_sound_play_pause"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play/Pause"/>

    <!-- Use in Camera -->
    <ImageButton
        android:id="@+id/btn_use_camera"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_camera"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Use in Camera"
        android:layout_marginStart="4dp"/>

    <!-- Use in Gallery -->
    <ImageButton
        android:id="@+id/btn_use_gallery"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_gallery"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Use in Gallery"
        android:layout_marginStart="4dp"/>
</LinearLayout>
