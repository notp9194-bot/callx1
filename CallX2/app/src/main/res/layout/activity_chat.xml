<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_chat_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_brand"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/transparent"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/white"
            app:titleTextColor="@color/white"
            app:subtitleTextColor="#C7D2FE"
            app:menu="@menu/chat_menu"/>

        <!-- Search bar (hidden by default) -->
        <LinearLayout
            android:id="@+id/ll_search_bar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@color/surface_card"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="12dp"
                android:alpha="0.4"/>
            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search messages…"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:background="@android:color/transparent"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
            <ImageButton
                android:id="@+id/btn_close_search"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close search"/>
        </LinearLayout>

        <!-- Pinned message banner -->
        <LinearLayout
            android:id="@+id/ll_pinned_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFF3E0"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌 Pinned Message"
                    android:textColor="#E65100"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_pinned_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>
            <ImageButton
                android:id="@+id/btn_unpin"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Unpin"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <ProgressBar
        android:id="@+id/upload_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:progressTint="@color/brand_primary"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"/>

    <!-- Bottom input area -->
    <LinearLayout
        android:id="@+id/ll_bottom_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@color/surface_card"
        android:elevation="8dp">

        <!-- Reply preview bar -->
        <LinearLayout
            android:id="@+id/ll_reply_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/surface_input"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <View
                android:layout_width="3dp"
                android:layout_height="36dp"
                android:background="@color/brand_primary"
                android:layout_marginEnd="12dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_reply_bar_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_reply_bar_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>
            <ImageButton
                android:id="@+id/btn_cancel_reply"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cancel reply"/>
        </LinearLayout>

        <!-- Input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_attach"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_attach"
                android:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Attach"/>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/rounded_input_bg"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="8dp"
                android:paddingStart="14dp"
                android:paddingEnd="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <EditText
                        android:id="@+id/et_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Message…"
                        android:textColorHint="@color/text_muted"
                        android:textColor="@color/text_primary"
                        android:background="@color/transparent"
                        android:padding="12dp"
                        android:maxLines="5"/>
                    <ImageButton
                        android:id="@+id/btn_camera"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_camera"
                        android:tint="@color/text_secondary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Camera"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Mic button (default) -->
            <ImageButton
                android:id="@+id/btn_mic"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_mic"
                android:tint="@color/white"
                android:background="@drawable/circle_primary"
                android:contentDescription="Voice message"
                android:padding="13dp"/>

            <!-- Send button (shown when text entered) -->
            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_send"
                android:tint="@color/white"
                android:background="@drawable/circle_primary"
                android:layout_marginStart="0dp"
                android:visibility="gone"
                android:contentDescription="Send"
                android:padding="13dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
