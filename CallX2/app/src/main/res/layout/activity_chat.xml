<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_chat_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient_brand"
        app:navigationIcon="@drawable/ic_back"
        app:titleTextColor="@color/white"
        app:subtitleTextColor="#C7D2FE"
        app:menu="@menu/chat_menu"
        app:elevation="0dp" />

    <!-- Search bar - Modern MD3 style -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface_card"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_muted" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:hint="Search messages..."
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@null"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_close_search"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Close search" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Pinned message banner - Modern elevated style -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_pinned_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="#FFF8E1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_pin"
                android:tint="#E65100"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pinned Message"
                    android:textColor="#E65100"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_pinned_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_unpin"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Unpin" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <ProgressBar
        android:id="@+id/upload_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:progressTint="@color/brand_primary"
        android:visibility="gone" />

    <!-- Reply preview bar - MD3 Surface style -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_reply_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="40dp"
                android:background="@color/brand_primary"
                android:layout_marginEnd="12dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.CornerSmall" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_reply_bar_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_reply_bar_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_reply"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Cancel reply" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Input section - Modern bottom sheet style -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/surface_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingTop="8dp"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_attach"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_attach"
                    android:contentDescription="Attach"
                    app:iconTint="@color/brand_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_camera"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_camera"
                    android:contentDescription="Camera"
                    app:iconTint="@color/brand_primary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopEnd="24dp"
                    app:boxCornerRadiusTopStart="24dp"
                    app:boxCornerRadiusBottomEnd="24dp"
                    app:boxCornerRadiusBottomStart="24dp"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Type a message..."
                        android:textColorHint="@color/text_muted"
                        android:textColor="@color/text_primary"
                        android:paddingVertical="12dp"
                        android:paddingHorizontal="16dp"
                        android:maxLines="5"
                        android:inputType="textCapSentences|textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mic"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="Voice message"
                    app:iconTint="@color/white"
                    android:backgroundTint="@color/brand_primary"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.CornerFull" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_send"
                    android:visibility="gone"
                    android:contentDescription="Send"
                    app:iconTint="@color/white"
                    android:backgroundTint="@color/brand_primary"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.CornerFull" />
            </LinearLayout>

            <!-- Typing indicator space -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/surface_card" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>