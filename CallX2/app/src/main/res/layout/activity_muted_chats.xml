<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="#111111">

      <!-- Toolbar -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="56dp"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:paddingStart="4dp"
          android:paddingEnd="12dp"
          android:background="#1A1A1A">

          <ImageButton
              android:id="@+id/btn_mc_back"
              android:layout_width="48dp"
              android:layout_height="48dp"
              android:src="@drawable/ic_arrow_back"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:tint="#FFFFFF"
              android:contentDescription="Back"/>

          <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:text="Muted Chats"
              android:textColor="#FFFFFF"
              android:textSize="18sp"
              android:textStyle="bold"
              android:paddingStart="8dp"/>

          <TextView
              android:id="@+id/btn_unmute_all"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="Unmute All"
              android:textColor="#FF3B5C"
              android:textSize="13sp"
              android:paddingStart="8dp"
              android:paddingEnd="4dp"
              android:background="?attr/selectableItemBackgroundBorderless"/>
      </LinearLayout>

      <ProgressBar
          android:id="@+id/progress_muted"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center_horizontal"
          android:visibility="gone"
          android:layout_marginTop="8dp"/>

      <TextView
          android:id="@+id/tv_muted_empty"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="No muted chats"
          android:textColor="#666666"
          android:textSize="15sp"
          android:gravity="center"
          android:paddingTop="64dp"
          android:visibility="gone"/>

      <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_muted_chats"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          android:clipToPadding="false"
          android:paddingBottom="16dp"/>
  </LinearLayout>
  