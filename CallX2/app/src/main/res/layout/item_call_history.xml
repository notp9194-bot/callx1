<?xml version="1.0" encoding="utf-8"?>
<!-- Google Phone style — flat row, no card, simple right-side phone icon -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="11dp"
    android:paddingBottom="11dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar + Story ring -->
    <FrameLayout
        android:layout_width="50dp"
        android:layout_height="50dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            android:clickable="true"
            android:focusable="true"
            app:civ_border_width="0dp"/>

        <ImageView
            android:id="@+id/iv_story_ring"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_status_unseen"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Name + direction + meta -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="13dp">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <ImageView
                android:id="@+id/iv_direction"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_phone"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tv_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Right side: simple phone icon only (Google Phone style) -->
    <!-- btn_video_call kept as 0dp hidden for adapter compatibility -->
    <ImageButton
        android:id="@+id/btn_video_call"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="@null"
        android:contentDescription="Video call"/>

    <ImageButton
        android:id="@+id/btn_call_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_phone"
        android:tint="@color/text_secondary"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:contentDescription="Voice call"/>

</LinearLayout>
