<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_brand"
    android:gravity="center_horizontal"
    android:padding="32dp">

    <!-- App logo/icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_phone"
        android:tint="@color/white"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CallX"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_lock_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App is locked"
        android:textColor="#D0E4FF"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"/>

    <!-- PIN dots -->
    <LinearLayout
        android:id="@+id/layout_pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/pin_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp"/>

        <GridLayout
            android:id="@+id/grid_numpad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4"/>
    </LinearLayout>

    <!-- Pattern -->
    <LinearLayout
        android:id="@+id/layout_pattern"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <com.andrognito.patternlockview.PatternLockView
            android:id="@+id/pattern_lock_view"
            android:layout_width="260dp"
            android:layout_height="260dp"
            app:correctStateColor="@color/white"
            app:normalStateColor="#A0C4FF"
            app:wrongStateColor="@color/action_danger"
            app:dotCount="3"
            app:dotNormalSize="10dp"
            app:dotSelectedSize="14dp"
            app:pathWidth="3dp"/>

        <TextView
            android:id="@+id/tv_pattern_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draw pattern to unlock"
            android:textColor="#D0E4FF"
            android:textSize="14sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <!-- Fingerprint -->
    <LinearLayout
        android:id="@+id/layout_fingerprint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_biometric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unlock with Fingerprint"
            app:backgroundTint="@color/white"
            android:textColor="@color/brand_primary"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tv_fp_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Touch the sensor to unlock"
            android:textColor="#D0E4FF"
            android:textSize="14sp"/>
    </LinearLayout>
</LinearLayout>
