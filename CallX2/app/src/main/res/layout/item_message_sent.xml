<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:padding="3dp">

    <TextView
        android:id="@+id/tv_pinned_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📌 Pinned"
        android:textSize="10sp"
        android:textColor="#E65100"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↪ Forwarded"
        android:textSize="11sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/ll_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_sent"
        android:minWidth="80dp"
        android:maxWidth="280dp">

        <LinearLayout
            android:id="@+id/ll_reply_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33000000"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_margin="4dp"
            android:minWidth="120dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_reply_sender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD54F"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_reply_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DDFFFFFF"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:textColor="@color/bubble_sent_text"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_edited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  edited"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:textStyle="italic"
            android:paddingStart="14dp"
            android:paddingBottom="4dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="240dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <FrameLayout
            android:id="@+id/fl_video"
            android:layout_width="240dp"
            android:layout_height="220dp"
            android:visibility="gone">
            <ImageView android:id="@+id/iv_video_thumb"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <ImageView android:layout_width="52dp" android:layout_height="52dp"
                android:layout_gravity="center" android:src="@drawable/ic_play"
                android:background="@drawable/circle_primary" android:padding="14dp"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/ll_audio"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <ImageButton android:id="@+id/btn_play_audio"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_play" android:background="@drawable/circle_avatar_bg"/>
            <SeekBar android:id="@+id/seek_audio"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginHorizontal="8dp"/>
            <TextView android:id="@+id/tv_audio_dur"
                android:layout_width="40dp" android:layout_height="wrap_content"
                android:textColor="@color/bubble_sent_text" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_file"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/file_card_bg"
            android:visibility="gone">
            <ImageView android:id="@+id/iv_file_icon" android:layout_width="36dp"
                android:layout_height="36dp" android:src="@drawable/ic_pdf"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
                <TextView android:id="@+id/tv_file_name" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="@color/bubble_sent_text"
                    android:textSize="13sp" android:textStyle="bold"
                    android:maxLines="1" android:ellipsize="middle"/>
                <TextView android:id="@+id/tv_file_meta" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#CCFFFFFF"
                    android:textSize="11sp" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#22000000"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:layout_margin="4dp"
            android:visibility="gone">
            <TextView android:id="@+id/tv_reactions"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="end"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:paddingStart="4dp">
            <TextView android:id="@+id/tv_starred_icon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⭐" android:textSize="10sp" android:layout_marginEnd="3dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tv_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF" android:textSize="10sp"/>
            <TextView android:id="@+id/tv_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="11sp" android:layout_marginStart="4dp"
                android:text="✓" android:textColor="#AAFFFFFF"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
