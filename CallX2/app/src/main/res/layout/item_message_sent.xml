<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp"
    android:gravity="end">

    <!-- Reply preview -->
    <LinearLayout
        android:id="@+id/ll_reply_preview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#22000000"
        android:padding="6dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/tv_reply_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1976D2" />
        <TextView
            android:id="@+id/tv_reply_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Forwarded label -->
    <TextView
        android:id="@+id/tv_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#888"
        android:visibility="gone" />

    <!-- Main bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bubble_sent"
        android:padding="8dp"
        android:orientation="vertical"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/tv_sender_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1976D2"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_media"
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_play"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_message_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:visibility="visible" />

        <!-- F12: Voice transcript -->
        <TextView
            android:id="@+id/tv_transcript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="#555"
            android:visibility="gone" />

        <!-- F08: Expiry -->
        <TextView
            android:id="@+id/tv_expiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#E53935"
            android:visibility="gone" />

        <!-- Edited label -->
        <TextView
            android:id="@+id/tv_edited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="edited"
            android:textSize="10sp"
            android:textColor="#888"
            android:visibility="gone" />

        <!-- Pinned label -->
        <TextView
            android:id="@+id/tv_pinned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📌 Pinned"
            android:textSize="10sp"
            android:textColor="#888"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">
            <!-- Starred icon -->
            <ImageView
                android:id="@+id/iv_star"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_send"
                android:visibility="gone" />
            <!-- Seen-by (group) -->
            <ImageView
                android:id="@+id/iv_seen_by"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_person"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#888"
                android:layout_marginStart="4dp" />
            <ImageView
                android:id="@+id/iv_status"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_send"
                android:layout_marginStart="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- F13: Reactions pill -->
    <TextView
        android:id="@+id/tv_reactions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#33000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
