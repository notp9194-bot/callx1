<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="?attr/colorPrimary"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnGroupCallSettingsBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="#FFFFFF"/>

        <TextView
            android:id="@+id/tvGroupCallSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:text="Group Call Settings"/>
    </LinearLayout>

    <!-- Active call note -->
    <TextView
        android:id="@+id/tvGroupCallSettingsNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#FFF3E0"
        android:textColor="#E65100"
        android:textSize="12sp"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── AUDIO QUALITY ──────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="AUDIO QUALITY"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Noise Suppression"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Reduce background noise"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCNoiseSuppression"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="16dp" android:background="#1F000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Echo Cancellation"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Remove echo from calls"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCEchoCancellation"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="16dp" android:background="#1F000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Auto Gain Control"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Normalize microphone volume"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCAutoGainControl"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ── VIDEO QUALITY ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="VIDEO QUALITY"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"
                android:textSize="14sp" android:text="Resolution"/>
            <RadioGroup android:id="@+id/rgGCVideoQuality"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">
                <RadioButton android:id="@+id/rbGCQualityHD"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HD (1280×720) — Best quality"/>
                <RadioButton android:id="@+id/rbGCQualitySD"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SD (640×480) — Save data"/>
                <RadioButton android:id="@+id/rbGCQualityAuto"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Auto — Adapt to network"/>
            </RadioGroup>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"
                android:textSize="14sp" android:text="Frame Rate"/>
            <RadioGroup android:id="@+id/rgGCFrameRate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">
                <RadioButton android:id="@+id/rbGCFps30"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="30 fps — Smooth"/>
                <RadioButton android:id="@+id/rbGCFps24"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="24 fps — Balanced"/>
                <RadioButton android:id="@+id/rbGCFps15"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="15 fps — Save battery"/>
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Default Front Camera"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Start calls with front-facing camera"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCFrontCamera"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ── AUDIO ROUTING ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="AUDIO ROUTING"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"
                android:textSize="14sp" android:text="Default Audio Output"/>
            <RadioGroup android:id="@+id/rgGCDefaultSpeaker"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">
                <RadioButton android:id="@+id/rbGCRoutingSpeaker"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Speaker (Loudspeaker)"/>
                <RadioButton android:id="@+id/rbGCRoutingEarpiece"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Earpiece (In-ear)"/>
                <RadioButton android:id="@+id/rbGCRoutingBluetooth"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Bluetooth (if connected)"/>
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Auto-Speaker on Video Call"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Automatically switch to speaker when video is on"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCAutoSpeakerVideo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ── NOTIFICATIONS ─────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="NOTIFICATIONS"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Missed Call Notifications"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Alert when you miss a group call"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCMissedCallNotif"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="16dp" android:background="#1F000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Show Caller Name on Lock Screen"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Display group name on incoming call notification"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCLockScreenName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="16dp" android:background="#1F000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Silent Ringtone"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Vibrate only, no ringtone sound"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCSilentRingtone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ── PRIVACY ───────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="PRIVACY AND SECURITY"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"
                android:textSize="14sp" android:text="Allow Group Calls From"/>
            <RadioGroup android:id="@+id/rgGCAllowCallFrom"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">
                <RadioButton android:id="@+id/rbGCAllowEveryone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Everyone"/>
                <RadioButton android:id="@+id/rbGCAllowContacts"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="My contacts only"/>
                <RadioButton android:id="@+id/rbGCAllowNobody"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nobody (off)"/>
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Show In-Call Status"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Let others see when you're in a group call"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCShowCallStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="16dp" android:background="#1F000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Block Unknown Callers"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Block group calls from non-contacts"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCBlockUnknown"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ── ADVANCED ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="ADVANCED"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp" android:paddingBottom="4dp"
                android:textSize="14sp" android:text="Max Participants in View"/>
            <RadioGroup android:id="@+id/rgGCMaxParticipants"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="16dp">
                <RadioButton android:id="@+id/rbGCMax2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="2 participants"/>
                <RadioButton android:id="@+id/rbGCMax4"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4 participants"/>
                <RadioButton android:id="@+id/rbGCMax6"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="6 participants"/>
                <RadioButton android:id="@+id/rbGCMax8"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="8 participants (max)"/>
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Data Saver Mode"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Limit video bitrate to save mobile data"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCDataSaver"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginHorizontal="16dp" android:background="#1F000000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="15sp" android:text="Keep Screen On"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"
                        android:text="Prevent screen from dimming during calls"/>
                </LinearLayout>
                <Switch android:id="@+id/switchGCKeepScreenOn"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
