<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="48dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">
    <TextView android:id="@+id/tv_keyword" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="15sp"/>
    <ImageButton android:id="@+id/btn_keyword_remove" android:layout_width="32dp" android:layout_height="32dp"
        android:src="@drawable/ic_close" android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#FF3B5C"/>
</LinearLayout>
