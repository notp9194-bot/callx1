<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_incoming_call_screen"
    android:fitsSystemWindows="false">

    <!-- ── LAYER 1: Blurred caller photo as full background ── -->
    <ImageView
        android:id="@+id/iv_bg_blur"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_person"
        android:scaleType="centerCrop"
        android:contentDescription=""
        android:alpha="0.35"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── LAYER 2: Aurora gradient scrim ── -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_call_dark_scrim"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Animated ripple rings (behind avatar) ── -->
    <!-- Outermost: purple -->
    <View
        android:id="@+id/ripple_ring_3"
        android:layout_width="290dp"
        android:layout_height="290dp"
        android:background="@drawable/bg_ripple_ring_purple"
        android:alpha="0.20"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/glass_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42"/>

    <!-- Middle: pink -->
    <View
        android:id="@+id/ripple_ring_2"
        android:layout_width="235dp"
        android:layout_height="235dp"
        android:background="@drawable/bg_ripple_ring_pink"
        android:alpha="0.30"
        app:layout_constraintTop_toTopOf="@id/ripple_ring_3"
        app:layout_constraintBottom_toBottomOf="@id/ripple_ring_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Inner: cyan -->
    <View
        android:id="@+id/ripple_ring_1"
        android:layout_width="185dp"
        android:layout_height="185dp"
        android:background="@drawable/bg_ripple_ring_glow"
        android:alpha="0.50"
        app:layout_constraintTop_toTopOf="@id/ripple_ring_3"
        app:layout_constraintBottom_toBottomOf="@id/ripple_ring_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Call type badge pill (top-center) ── -->
    <LinearLayout
        android:id="@+id/layout_call_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_call_type_pill"
        android:paddingHorizontal="18dp"
        android:paddingVertical="8dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_call_type_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_phone"
            android:tint="#E0CFFF"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/tv_caller_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0CFFF"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:text="Incoming voice call"/>
    </LinearLayout>

    <!-- ── Caller avatar ── -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_caller_avatar"
        android:layout_width="158dp"
        android:layout_height="158dp"
        android:src="@drawable/ic_person"
        app:civ_border_color="#FF00E5FF"
        app:civ_border_width="3.5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/glass_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42"/>

    <!-- ── Glassmorphism caller info card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/glass_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="#00000000"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/layout_quick_replies"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_glass_card"
            android:paddingVertical="20dp"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tv_caller_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:gravity="center"
                android:shadowColor="#AA7B2FFF"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12"
                android:text="Caller"/>

            <TextView
                android:id="@+id/tv_ringing_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CC00E5FF"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                android:layout_marginTop="6dp"
                android:text="Ringing..."/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Quick reply chips row ── -->
    <LinearLayout
        android:id="@+id/layout_quick_replies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/layout_reject_note_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btn_quick_reply_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Can't talk"
            android:textColor="#E0CFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_quick_reply_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_quick_reply_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call later"
            android:textColor="#E0CFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_quick_reply_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_quick_reply_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="On my way"
            android:textColor="#E0CFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_quick_reply_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ── Reject with Note row ── -->
    <LinearLayout
        android:id="@+id/layout_reject_note_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toTopOf="@id/tv_swipe_hint_up"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reject with Voice Note -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="20dp">

            <ImageButton
                android:id="@+id/btn_reject_voice_note"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:src="@drawable/ic_mic"
                android:background="@drawable/bg_quick_reply_chip"
                android:tint="#FF9EFF"
                android:elevation="4dp"
                android:contentDescription="Reject with Voice Note"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice Note"
                android:textColor="#CC9EFF"
                android:textSize="10sp"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Reject with Video Note -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_reject_video_note"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:src="@drawable/ic_video"
                android:background="@drawable/bg_quick_reply_chip"
                android:tint="#FFB347"
                android:elevation="4dp"
                android:contentDescription="Reject with Video Note"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Note"
                android:textColor="#CCFFB347"
                android:textSize="10sp"
                android:layout_marginTop="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Swipe hint UP label ── -->
    <TextView
        android:id="@+id/tv_swipe_hint_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▲   Swipe up to Accept"
        android:textColor="#64FF9A"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:alpha="0.85"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/swipe_rail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Swipe rail track ── -->
    <FrameLayout
        android:id="@+id/swipe_rail"
        android:layout_width="72dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_swipe_rail"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/tv_swipe_hint_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- swipe phone button inside the rail -->
        <FrameLayout
            android:id="@+id/swipe_phone_container"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_gravity="center_horizontal|center_vertical"
            android:background="@drawable/bg_swipe_phone_btn"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/iv_swipe_phone"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_phone"
                android:tint="#FFFFFF"
                android:layout_gravity="center"/>
        </FrameLayout>
    </FrameLayout>

    <!-- ── Swipe hint DOWN label ── -->
    <TextView
        android:id="@+id/tv_swipe_hint_down"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▼   Swipe down to Decline"
        android:textColor="#FF6D6D"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:alpha="0.85"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/layout_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Bottom action row: Reject | Message | Accept ── -->
    <LinearLayout
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reject -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_reject"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/bg_btn_reject_gradient"
                android:tint="@color/white"
                android:elevation="8dp"
                android:contentDescription="Decline call"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decline"
                android:textColor="#FF6D6D"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Message (decline with reply) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_message"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/bg_btn_message"
                android:tint="@color/white"
                android:elevation="4dp"
                android:contentDescription="Message"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message"
                android:textColor="#88E5FF"
                android:textSize="11sp"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Accept -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_accept"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/bg_btn_accept_gradient"
                android:tint="@color/white"
                android:elevation="8dp"
                android:contentDescription="Accept call"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accept"
                android:textColor="#64FF9A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
