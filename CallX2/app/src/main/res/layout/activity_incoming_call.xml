<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_call_bg">

    <!-- Decorative glow circles -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-80dp"
        android:background="@drawable/bg_glow_purple"
        android:alpha="0.25"/>

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/bg_glow_cyan"
        android:alpha="0.2"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Incoming label -->
        <TextView
            android:id="@+id/tv_caller_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:text="INCOMING CALLX"
            android:layout_marginTop="72dp"/>

        <!-- Avatar with ring animation indicator -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="36dp"
            android:gravity="center">

            <!-- Outer ring pulse -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_ring_pulse_outer"
                android:layout_gravity="center"/>

            <!-- Middle ring -->
            <View
                android:layout_width="138dp"
                android:layout_height="138dp"
                android:background="@drawable/bg_ring_pulse_mid"
                android:layout_gravity="center"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_caller_avatar"
                android:layout_width="116dp"
                android:layout_height="116dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                android:background="@color/surface_elevated"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:layout_marginTop="24dp"
            android:text="Caller"/>

        <TextView
            android:id="@+id/tv_call_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_accent"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:layout_marginTop="8dp"
            android:text="Audio Call"/>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="60dp">

            <!-- Reject -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_reject"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_phone_off"
                    android:background="@drawable/circle_reject"
                    android:tint="@color/white"
                    android:padding="18dp"
                    android:contentDescription="Reject"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Decline"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- Accept -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_accept"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_phone"
                    android:background="@drawable/circle_accept"
                    android:tint="@color/white"
                    android:padding="18dp"
                    android:contentDescription="Accept"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accept"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
