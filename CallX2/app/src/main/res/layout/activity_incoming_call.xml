<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_brand"
    android:gravity="center"
    android:padding="32dp">
    <TextView
        android:id="@+id/tv_caller_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#E0E7FF"
        android:textSize="16sp"
        android:layout_marginTop="64dp"
        android:text="Incoming CallX..."/>
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_caller_avatar"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_person"
        android:background="@color/white"/>
    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:text="Caller"/>
    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="64dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btn_reject"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/circle_reject"
                android:tint="@color/white"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Reject" android:textColor="@color/white"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btn_accept"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/circle_accept"
                android:tint="@color/white"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Accept" android:textColor="@color/white"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
