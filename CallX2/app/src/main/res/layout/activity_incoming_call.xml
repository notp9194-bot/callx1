<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_brand">

    <!-- ── Animated ripple rings behind avatar ── -->
    <View
        android:id="@+id/ripple_ring_3"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_ripple_ring"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <View
        android:id="@+id/ripple_ring_2"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:background="@drawable/bg_ripple_ring"
        android:alpha="0.25"
        app:layout_constraintTop_toTopOf="@id/ripple_ring_3"
        app:layout_constraintBottom_toBottomOf="@id/ripple_ring_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/ripple_ring_1"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_ripple_ring"
        android:alpha="0.4"
        app:layout_constraintTop_toTopOf="@id/ripple_ring_3"
        app:layout_constraintBottom_toBottomOf="@id/ripple_ring_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Call type badge (top-center) ── -->
    <LinearLayout
        android:id="@+id/layout_call_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#33FFFFFF"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_call_type_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_phone"
            android:tint="#E0E7FF"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tv_caller_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E0E7FF"
            android:textSize="13sp"
            android:text="Incoming voice call"/>
    </LinearLayout>

    <!-- ── Caller avatar ── -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_caller_avatar"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_person"
        android:background="?attr/colorSurface"
        app:civ_border_color="#80FFFFFF"
        app:civ_border_width="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <!-- ── Caller name ── -->
    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:text="Caller"
        app:layout_constraintTop_toBottomOf="@id/iv_caller_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Ringing... animated text ── -->
    <TextView
        android:id="@+id/tv_ringing_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:text="Ringing..."
        app:layout_constraintTop_toBottomOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Quick reply buttons row ── -->
    <LinearLayout
        android:id="@+id/layout_quick_replies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_ringing_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btn_quick_reply_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Can&#39;t talk"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#33FFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_quick_reply_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call later"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#33FFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_quick_reply_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="On my way"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#33FFFFFF"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ── Bottom action row: Reject | Accept ── -->
    <LinearLayout
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reject -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_reject"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/circle_reject"
                android:tint="@color/white"
                android:contentDescription="Reject call"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reject"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Accept -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_accept"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/circle_accept"
                android:tint="@color/white"
                android:contentDescription="Accept call"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accept"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
