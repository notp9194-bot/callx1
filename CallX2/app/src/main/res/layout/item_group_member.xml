<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginEnd="12dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_person"
            android:background="@color/surface_input"/>

        <!-- Online dot -->
        <View
            android:id="@+id/online_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/circle_status_seen"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Name + role + status -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_member_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Member Name"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Admin / Creator badge -->
            <TextView
                android:id="@+id/tv_role_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin"
                android:textSize="10sp"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:background="@drawable/bg_unread_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_member_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="last seen recently"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- More options (3-dot) — only visible when tapped -->
    <ImageView
        android:id="@+id/btn_member_options"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_send"
        android:tint="@color/text_muted"
        android:rotation="90"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Member options"/>

</LinearLayout>
