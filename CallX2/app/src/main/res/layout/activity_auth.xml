<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_auth.xml — Screenshot-matched login UI v2
    ===================================================
    All ViewBinding IDs preserved from AuthActivity.java:
      btn_login (AppCompatButton — supports setText())
      btn_signup (TextView — supports setText())
      btn_google, btn_phone, btn_biometric_login (preserved)
      til_name, til_mobile (hidden TextInputLayouts — setVisibility only)
      et_email, et_password (bare EditTexts — getText/setText/requestFocus)
      tv_forgot_password, tv_error
      fl_avatar_picker, iv_avatar_preview, tv_avatar_hint
      layout_remember_me, cb_remember_me
      layout_password_strength, progress_password_strength, tv_password_strength_label

    Layout structure:
      FrameLayout (full screen, purple→pink gradient)
        ├── Plants (bottom-left, bottom-right) from generated PNG
        ├── Floating 3D sparkles, lock, profile bubble, checkmark
        ├── ScrollView (full screen, transparent)
        │   └── LinearLayout
        │       ├── [Spacer — room for character above card]
        │       └── White rounded card
        │           ├── [Top spacer — character overlaps into card]
        │           ├── "Welcome Back!" + subtitle
        │           ├── Signup-only hidden fields (til_name, til_mobile, avatar)
        │           ├── Username field (et_email, custom styled)
        │           ├── Password field (et_password, toggle eye)
        │           ├── Forgot Password | Error
        │           ├── Progress bar (layout_password_strength, hidden)
        │           ├── Remember Me row (layout_remember_me, shown on login)
        │           ├── LOGIN button (AppCompatButton, gradient)
        │           ├── Biometric button (hidden by default)
        │           ├── Phone button (hidden by default)
        │           ├── "or continue with" divider
        │           ├── Google · Apple · Facebook circular buttons
        │           └── "Don't have an account? Sign Up"
        └── Character image (floats on top, overlapping card)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_gradient">

    <!-- ── Plant: bottom-left ── -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="124dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-6dp"
        android:src="@drawable/img_auth_plant"
        android:scaleType="fitEnd"
        android:contentDescription="@null"/>

    <!-- ── Plant: bottom-right (mirrored) ── -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="124dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-6dp"
        android:src="@drawable/img_auth_plant"
        android:scaleType="fitEnd"
        android:scaleX="-1"
        android:contentDescription="@null"/>

    <!-- ── Floating sparkle top-left (beside character) ── -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="40dp"
        android:layout_marginTop="96dp"
        android:src="@drawable/ic_auth_sparkle"
        android:alpha="0.9"
        android:contentDescription="@null"/>

    <!-- ── Floating sparkle top-center ── -->
    <ImageView
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginStart="80dp"
        android:layout_marginTop="46dp"
        android:src="@drawable/ic_auth_sparkle"
        android:alpha="0.75"
        android:contentDescription="@null"/>

    <!-- ── Floating sparkle right ── -->
    <ImageView
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="136dp"
        android:src="@drawable/ic_auth_sparkle"
        android:alpha="0.85"
        android:contentDescription="@null"/>

    <!-- ── Floating profile bubble (top-left, beside character) ── -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="26dp"
        android:layout_marginTop="116dp"
        android:src="@drawable/ic_auth_float_profile"
        android:contentDescription="@null"/>

    <!-- ── Floating padlock (top-right) ── -->
    <ImageView
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="68dp"
        android:src="@drawable/ic_auth_float_lock"
        android:contentDescription="@null"/>

    <!-- ── Floating checkmark circle (right side) ── -->
    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="168dp"
        android:src="@drawable/ic_auth_float_check"
        android:contentDescription="@null"/>

    <!-- ══════════════════════════════════════════════════
         Scrollable content
         ══════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp">

            <!-- Spacer: pushes card down so character image floats above card -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="196dp"/>

            <!-- ══════════════════════════════════════════
                 WHITE ROUNDED CARD
                 ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_login_card"
                android:elevation="10dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingBottom="28dp"
                android:paddingTop="96dp">

                <!-- ═══════════════════════════════════════
                     SIGNUP-ONLY HIDDEN FIELDS
                     (setVisibility() called by AuthActivity)
                     ═══════════════════════════════════════ -->

                <!-- Avatar picker (signup only) -->
                <FrameLayout
                    android:id="@+id/fl_avatar_picker"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone">
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_person"
                        android:background="@color/surface_input"/>
                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/circle_primary">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_camera"
                            android:tint="@color/white"/>
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_avatar_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Profile photo lagao"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone"/>

                <!-- Name — signup only -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_name"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Naam (signup ke liye)"
                    android:layout_marginBottom="12dp"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusTopStart="28dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:importantForAutofill="no"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Mobile — signup only -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_mobile"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mobile number (CallX ID banega)"
                    android:layout_marginBottom="12dp"
                    app:prefixText="+"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusTopStart="28dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_mobile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:maxLength="15"
                        android:importantForAutofill="no"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Welcome Back title ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Welcome Back!"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"
                    android:textColor="#1E0A3C"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Login to continue"
                    android:textSize="14sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginBottom="28dp"/>

                <!-- ── Username / Email field (custom styled) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_auth_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        android:tint="#9CA3AF"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"/>

                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Username / Email"
                        android:textColor="#1E0A3C"
                        android:textSize="14sp"
                        android:background="@null"
                        android:inputType="textEmailAddress"
                        android:importantForAutofill="no"/>
                </LinearLayout>

                <!-- ── Password field (custom styled, eye toggle) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_auth_input_field"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        android:tint="#9CA3AF"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@null"/>

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Password"
                        android:textColor="#1E0A3C"
                        android:textSize="14sp"
                        android:background="@null"
                        android:inputType="textPassword"
                        android:importantForAutofill="no"/>

                    <ImageButton
                        android:id="@+id/btn_toggle_password"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_visibility_off"
                        android:tint="#C4B5FD"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Toggle password visibility"/>
                </LinearLayout>

                <!-- ── Forgot Password (right aligned) ── -->
                <TextView
                    android:id="@+id/tv_forgot_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="Forgot Password?"
                    android:textColor="#9333EA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- ── Error message ── -->
                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/action_danger"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"/>

                <!-- ── Password strength meter (signup mode only) ── -->
                <LinearLayout
                    android:id="@+id/layout_password_strength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_password_strength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        app:trackCornerRadius="4dp"
                        app:trackThickness="6dp"
                        app:trackColor="@color/divider"/>
                    <TextView
                        android:id="@+id/tv_password_strength_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:text="Password strength"/>
                </LinearLayout>

                <!-- ── Remember Me row (login mode only) ── -->
                <LinearLayout
                    android:id="@+id/layout_remember_me"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">
                    <CheckBox
                        android:id="@+id/cb_remember_me"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Yaad rakho"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="#9333EA"/>
                </LinearLayout>

                <!-- ── LOGIN BUTTON (AppCompatButton — gradient background, supports setText) ── -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Login"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"
                    android:background="@drawable/bg_auth_login_btn"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="14dp"/>

                <!-- ── Biometric Login (hidden by default, shown by AuthActivity) ── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_biometric_login"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp"
                    android:text="Fingerprint se login karo"
                    android:textColor="?android:attr/textColorPrimary"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/ic_shield"
                    app:iconGravity="textStart"
                    android:visibility="gone"/>

                <!-- ── Phone OTP (hidden by default) ── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_phone"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp"
                    android:text="Phone OTP se login karo"
                    android:textColor="?android:attr/textColorPrimary"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/ic_phone"
                    app:iconGravity="textStart"
                    android:visibility="gone"/>

                <!-- ── "or continue with" divider ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  or continue with  "
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"/>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"/>
                </LinearLayout>

                <!-- ── Social buttons: Google · Apple · Facebook ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">

                    <!-- Google -->
                    <FrameLayout
                        android:id="@+id/btn_google"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_social_circle_auth"
                        android:elevation="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="24dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_google"
                            android:contentDescription="Google"/>
                    </FrameLayout>

                    <!-- Apple -->
                    <FrameLayout
                        android:id="@+id/btn_apple"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_social_circle_auth"
                        android:elevation="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginEnd="24dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_apple_logo"
                            android:contentDescription="Apple"/>
                    </FrameLayout>

                    <!-- Facebook -->
                    <FrameLayout
                        android:id="@+id/btn_facebook"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_social_circle_auth"
                        android:elevation="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_facebook_logo"
                            android:contentDescription="Facebook"/>
                    </FrameLayout>
                </LinearLayout>

                <!-- ── Don't have an account? Sign Up ── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textColor="#9CA3AF"
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/btn_signup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Up"
                        android:textColor="#9333EA"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"/>
                </LinearLayout>

            </LinearLayout>
            <!-- End white card -->

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════════
         CHARACTER IMAGE — drawn last = highest Z-order
         Floats on top of everything, overlaps card top
         ════════════════════════════════════════════════ -->
    <ImageView
        android:id="@+id/iv_auth_character"
        android:layout_width="240dp"
        android:layout_height="256dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:src="@drawable/img_auth_character"
        android:scaleType="fitCenter"
        android:contentDescription="@null"/>

</FrameLayout>
