<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <!-- Top gradient splash -->
    <View
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:background="@drawable/gradient_brand"
        android:alpha="0.12"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- Hero -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="64dp"
                android:background="@drawable/circle_primary"
                android:elevation="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="C"
                    android:textColor="@color/white"
                    android:textSize="48sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CallX"
                android:textSize="38sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:textColor="@color/text_primary"
                android:layout_marginTop="18dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect. Call. Chat."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:letterSpacing="0.04"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="40dp"/>

            <!-- Avatar picker (signup) -->
            <FrameLayout
                android:id="@+id/fl_avatar_picker"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_avatar_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person"
                    android:background="@color/surface_input"
                    app:civ_border_width="3dp"
                    app:civ_border_color="@color/brand_primary"/>
                <FrameLayout
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/circle_primary">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera"
                        android:tint="@color/white"/>
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_avatar_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile photo lagao"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- Name field (signup) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_name"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Naam (signup ke liye)"
                android:layout_marginBottom="14dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mobile field -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_mobile"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mobile number (10 digit)"
                android:layout_marginBottom="14dp"
                app:prefixText="+"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_mobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:maxLength="15"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:layout_marginBottom="14dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:layout_marginBottom="8dp"
                app:passwordToggleEnabled="true"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/action_danger"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <!-- Login CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Login"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                android:backgroundTint="@color/brand_primary"
                android:layout_marginTop="20dp"/>

            <!-- Signup CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_signup"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Naya account banao"
                android:textSize="15sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="18dp"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
