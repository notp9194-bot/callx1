<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp"
        android:gravity="center_horizontal">

        <!-- Glow orb background effect top -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="-60dp"
            android:layout_marginBottom="-80dp"
            android:background="@drawable/bg_auth_glow_orb"
            android:alpha="0.35"/>

        <!-- Logo -->
        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginTop="72dp"
            android:background="@drawable/bg_auth_logo">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="C"
                android:textColor="@color/white"
                android:textSize="44sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CallX"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="0.05"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect. Call. Chat."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:letterSpacing="0.08"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="36dp"/>

        <!-- Signup avatar picker -->
        <FrameLayout
            android:id="@+id/fl_avatar_picker"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person"
                android:background="@color/surface_input"/>
            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/circle_primary">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera"
                    android:tint="@color/white"/>
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_avatar_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile photo lagao"
            android:textColor="@color/brand_accent"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- Name field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_name"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Naam (signup ke liye)"
            android:layout_marginBottom="14dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@color/divider"
            app:hintTextColor="@color/text_secondary"
            app:boxBackgroundColor="@color/surface_input">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textPersonName"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mobile field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_mobile"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mobile number (10 digit)"
            android:layout_marginBottom="14dp"
            app:prefixText="+"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@color/divider"
            app:hintTextColor="@color/text_secondary"
            app:boxBackgroundColor="@color/surface_input">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_mobile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="phone"
                android:maxLength="15"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Email field -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email"
            android:layout_marginBottom="14dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@color/divider"
            app:hintTextColor="@color/text_secondary"
            app:boxBackgroundColor="@color/surface_input">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textEmailAddress"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password field -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            app:passwordToggleEnabled="true"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@color/divider"
            app:hintTextColor="@color/text_secondary"
            app:boxBackgroundColor="@color/surface_input">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/action_danger"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <!-- Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Login"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:cornerRadius="28dp"
            android:backgroundTint="@color/brand_primary"
            android:layout_marginTop="28dp"/>

        <!-- Signup Outlined Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_signup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Naya account banao"
            android:textSize="15sp"
            android:textColor="@color/brand_primary"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="28dp"
            app:strokeColor="@color/brand_primary"
            app:strokeWidth="1.5dp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</ScrollView>
