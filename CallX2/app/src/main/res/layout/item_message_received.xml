<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:padding="3dp">

    <!-- Feature 8: Pinned label -->
    <TextView
        android:id="@+id/tv_pinned_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📌 Pinned"
        android:textSize="10sp"
        android:textColor="#E65100"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <!-- Feature 6: Forwarded label -->
    <TextView
        android:id="@+id/tv_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↪ Forwarded"
        android:textSize="11sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <!-- Group sender name -->
    <TextView
        android:id="@+id/tv_sender_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/brand_primary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="2dp"/>

    <!-- Bubble -->
    <LinearLayout
        android:id="@+id/ll_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_received"
        android:minWidth="80dp"
        android:maxWidth="280dp">

        <!-- Feature 2: Quoted reply preview -->
        <LinearLayout
            android:id="@+id/ll_reply_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33000000"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_margin="4dp"
            android:minWidth="120dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_reply_sender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_reply_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/bubble_received_text"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Text message -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp"
            android:textColor="@color/bubble_received_text"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            android:visibility="gone"/>

        <!-- Feature 4: Edited label -->
        <TextView
            android:id="@+id/tv_edited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  edited"
            android:textSize="10sp"
            android:textColor="#88000000"
            android:textStyle="italic"
            android:paddingStart="12dp"
            android:paddingBottom="4dp"
            android:visibility="gone"/>

        <!-- Image -->
        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="240dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <!-- Video -->
        <FrameLayout
            android:id="@+id/fl_video"
            android:layout_width="240dp"
            android:layout_height="220dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/iv_video_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:background="@drawable/circle_primary"
                android:padding="14dp"/>
        </FrameLayout>

        <!-- Audio -->
        <LinearLayout
            android:id="@+id/ll_audio"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btn_play_audio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/circle_primary"/>
            <SeekBar
                android:id="@+id/seek_audio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/tv_audio_dur"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:textColor="@color/bubble_received_text"
                android:textSize="11sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- File -->
        <LinearLayout
            android:id="@+id/ll_file"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/file_card_bg"
            android:visibility="gone">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_pdf"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <TextView
                    android:id="@+id/tv_file_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/bubble_received_text"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="middle"/>
                <TextView
                    android:id="@+id/tv_file_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Feature 3: Reactions bar -->
        <LinearLayout
            android:id="@+id/ll_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#22000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_margin="4dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_reactions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Footer: time -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingBottom="4dp"
            android:paddingEnd="8dp">
            <!-- Feature 7: Star icon -->
            <TextView
                android:id="@+id/tv_starred_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐"
                android:textSize="10sp"
                android:layout_marginEnd="3dp"
                android:visibility="gone"/>
            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="10sp"/>
            <!-- No status ticks for received -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
