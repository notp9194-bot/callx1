<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Brand (same) -->
    <color name="brand_primary">#5B5BF6</color>
    <color name="brand_primary_dark">#3B3BD9</color>
    <color name="brand_accent">#22D3A6</color>
    <color name="brand_gradient_start">#5B5BF6</color>
    <color name="brand_gradient_end">#7F4FFB</color>

    <!-- Surfaces — AMOLED TRUE BLACK = OLED pixels OFF = zero GPU/power
         Pure #000000 = OLED pixel completely off = lowest GPU load possible -->
    <color name="surface_bg">#000000</color>
    <color name="surface_card">#111B21</color>
    <!-- Chat bg: WhatsApp dark = #0B141A, very dark = near-black OLED optimal -->
    <color name="surface_chat_bg">#0B141A</color>
    <!-- Input bar bg: solid, matches card exactly = zero overdraw -->
    <color name="surface_input">#1F2C34</color>

    <!-- Bar colors — solid flat dark = header & bottom nav 1 draw pass -->
    <color name="bar_background">#1F2C34</color>
    <color name="bar_on_background">#E9EDEF</color>

    <!-- Text -->
    <color name="text_primary">#E9EDEF</color>
    <color name="text_secondary">#8696A0</color>
    <color name="text_muted">#3C4B52</color>
    <color name="chat_time_color">#8696A0</color>
    <color name="text_on_primary">#FFFFFF</color>

    <!-- Bubbles — SOLID flat, NO gradient = minimum GPU load
         Sent:     WhatsApp dark green #005C4B (1 color, solid)
         Received: Dark slate #1F2C34 (1 color, solid)
         Result:   1 GPU draw pass only, zero overdraw -->
    <color name="bubble_sent">#005C4B</color>
    <color name="bubble_sent_end">#005C4B</color>
    <color name="bubble_sent_text">#E9EDEF</color>
    <color name="bubble_received">#1F2C34</color>
    <color name="bubble_received_end">#1F2C34</color>
    <color name="bubble_received_text">#E9EDEF</color>

    <!-- Status / actions -->
    <color name="status_online">#22C55E</color>
    <color name="status_typing">#22C55E</color>
    <color name="action_call_accept">#22C55E</color>
    <color name="action_call_reject">#EF4444</color>
    <color name="action_danger">#EF4444</color>
    <color name="divider">#1F2C34</color>

    <!-- Password strength indicator -->
    <color name="strength_weak">#EF4444</color>
    <color name="strength_fair">#F97316</color>
    <color name="strength_good">#EAB308</color>
    <color name="strength_strong">#22C55E</color>

    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
    <color name="transparent">#00000000</color>
</resources>
