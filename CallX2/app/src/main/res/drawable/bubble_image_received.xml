<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="-4dp" android:top="-4dp" android:right="-4dp" android:bottom="-4dp">
        <shape>
            <gradient android:type="linear" android:angle="135"
                android:startColor="#88FF006E" android:endColor="#888B00FF"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape>
            <gradient android:type="linear" android:angle="135"
                android:startColor="#FF006E" android:endColor="#8B00FF"/>
            <corners android:topLeftRadius="10dp" android:topRightRadius="26dp"
                android:bottomLeftRadius="26dp" android:bottomRightRadius="26dp"/>
        </shape>
    </item>
    <item android:left="7dp" android:top="7dp" android:right="7dp" android:bottom="7dp">
        <shape>
            <solid android:color="#00000000"/>
            <corners android:topLeftRadius="6dp" android:topRightRadius="22dp"
                android:bottomLeftRadius="22dp" android:bottomRightRadius="22dp"/>
        </shape>
    </item>
</layer-list>
