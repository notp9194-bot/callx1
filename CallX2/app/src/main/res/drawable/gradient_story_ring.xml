<?xml version="1.0" encoding="utf-8"?>
<!-- Instagram-style gradient story ring — shown for unseen stories in the Reels home header -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="sweep"
        android:startColor="#FF3CAC"
        android:centerColor="#FF8B00"
        android:endColor="#FBDB61"
        android:centerX="0.5"
        android:centerY="0.5"/>
</shape>
