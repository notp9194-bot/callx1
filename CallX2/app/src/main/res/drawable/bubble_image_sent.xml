<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow layer (outermost, slightly bigger, low opacity) -->
    <item android:left="-4dp" android:top="-4dp" android:right="-4dp" android:bottom="-4dp">
        <shape>
            <gradient android:type="linear" android:angle="135"
                android:startColor="#8800F5FF" android:endColor="#88AAFF00"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <!-- Gradient border layer -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape>
            <gradient android:type="linear" android:angle="135"
                android:startColor="#00F5FF" android:endColor="#AAFF00"/>
            <corners android:topLeftRadius="26dp" android:topRightRadius="26dp"
                android:bottomLeftRadius="26dp" android:bottomRightRadius="10dp"/>
        </shape>
    </item>
    <!-- Transparent inner (5dp border width) -->
    <item android:left="7dp" android:top="7dp" android:right="7dp" android:bottom="7dp">
        <shape>
            <solid android:color="#00000000"/>
            <corners android:topLeftRadius="22dp" android:topRightRadius="22dp"
                android:bottomLeftRadius="22dp" android:bottomRightRadius="6dp"/>
        </shape>
    </item>
</layer-list>
