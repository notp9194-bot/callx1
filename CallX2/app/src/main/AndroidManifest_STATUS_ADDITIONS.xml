<!-- ── StatusBackgroundService: keeps status Firebase listener alive
         even when the app process is killed, via DATA_SYNC foreground type.
         stopWithTask="false" ensures it survives task removal.          ── -->
<service
    android:name=".services.StatusBackgroundService"
    android:exported="false"
    android:foregroundServiceType="dataSync"
    android:stopWithTask="false"/>

