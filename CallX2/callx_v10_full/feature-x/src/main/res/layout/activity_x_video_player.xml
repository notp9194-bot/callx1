<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!--
        ExoPlayer PlayerView — VideoView ki jagah.
        use_controller="true" → play/pause/seek controls show honge.
        resize_mode="fit" → video aspect ratio maintain hoga.
    -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/pv_x_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:use_controller="true"
        app:resize_mode="fit"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <ImageButton
        android:id="@+id/btn_x_player_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_x_close_btn"
        android:src="@drawable/ic_x_close"
        android:contentDescription="Close" />

</FrameLayout>
