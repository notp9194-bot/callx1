<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btn_mod_back" android:layout_width="40dp"
            android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Comment Moderation" android:textColor="#FFFFFF"
            android:textSize="18sp" android:textStyle="bold" android:paddingStart="12dp"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progress_mod_load" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Enable Moderation" android:textColor="#FFFFFF" android:textSize="16sp"/>
        <Switch android:id="@+id/switch_mod_enabled" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_mod_hidden_count" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Auto-hidden comments: 0"
        android:textColor="#AAAAAA" android:textSize="13sp" android:paddingHorizontal="16dp" android:paddingBottom="8dp"/>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Blocked Keywords" android:textColor="#FFFFFF" android:textSize="15sp"
        android:textStyle="bold" android:paddingHorizontal="16dp" android:paddingVertical="12dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:paddingBottom="8dp">
        <EditText android:id="@+id/et_mod_keyword" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:hint="Add keyword..." android:textColor="#FFFFFF"
            android:textColorHint="#666666" android:background="@drawable/bg_search_field"
            android:paddingHorizontal="12dp" android:inputType="text"/>
        <ImageButton android:id="@+id/btn_mod_add_keyword" android:layout_width="44dp"
            android:layout_height="44dp" android:src="@drawable/ic_add_reels"
            android:background="@drawable/bg_btn_primary" android:tint="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_mod_keywords"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:paddingHorizontal="16dp"/>
</LinearLayout>
