<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <TextView
            android:id="@+id/btn_tools_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Creator Tools"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/btn_tools_apply"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Apply"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_reel_upload_btn"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Countdown timer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COUNTDOWN TIMER"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <ImageButton
                    android:id="@+id/btn_countdown_minus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="−"
                    android:src="@drawable/ic_volume_off"
                    android:background="@drawable/bg_speed_chip"
                    android:tint="@color/text_primary"
                    android:contentDescription="Decrease countdown"/>

                <TextView
                    android:id="@+id/tv_countdown_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Off"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"/>

                <ImageButton
                    android:id="@+id/btn_countdown_plus"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_volume_on"
                    android:background="@drawable/bg_speed_chip"
                    android:tint="@color/text_primary"
                    android:contentDescription="Increase countdown"/>
            </LinearLayout>

            <!-- Tools section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TOOLS"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Green screen -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingTop="12dp" android:paddingBottom="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Green Screen" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Replace background with your video" android:textColor="@color/text_muted" android:textSize="12sp"/>
                        </LinearLayout>
                        <Switch android:id="@+id/sw_green_screen" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_green_screen_hint"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Tip: Use a solid colored background for best results"
                        android:textColor="@color/brand_primary" android:textSize="11sp"
                        android:layout_marginBottom="4dp" android:visibility="gone"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <!-- Align tool -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:paddingTop="12dp" android:paddingBottom="8dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Align Tool" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ghost overlay for seamless transitions" android:textColor="@color/text_muted" android:textSize="12sp"/>
                        </LinearLayout>
                        <Switch android:id="@+id/sw_align_tool" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_align_hint"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Ghost image of last clip will appear as guide"
                        android:textColor="@color/brand_primary" android:textSize="11sp"
                        android:layout_marginBottom="4dp" android:visibility="gone"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <!-- Grid overlay -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Grid Overlay" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rule-of-thirds guide" android:textColor="@color/text_muted" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/sw_grid_overlay" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <!-- Level guide -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Level Indicator" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Horizon guide for straight shots" android:textColor="@color/text_muted" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/sw_level_guide" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Interactive -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="INTERACTIVE"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Q&amp;A Mode" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Add Q&amp;A sticker to your reel" android:textColor="@color/text_muted" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/sw_qa_mode" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Poll" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Add a poll sticker to your reel" android:textColor="@color/text_muted" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/sw_poll_mode" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Text-to-Speech" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Auto voiceover from caption" android:textColor="@color/text_muted" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch android:id="@+id/sw_tts" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="32dp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
