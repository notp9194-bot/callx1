<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_deep_analytics_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reel Insights"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_deep_analytics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/brand_primary"
        android:visibility="visible"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/layout_deep_analytics_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Overview stats -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="OVERVIEW" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <include layout="@layout/card_analytics_stat" android:id="@+id/card_plays"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp"/>
                <include layout="@layout/card_analytics_stat" android:id="@+id/card_unique"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <include layout="@layout/card_analytics_stat" android:id="@+id/card_reach"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp"/>
                <include layout="@layout/card_analytics_stat" android:id="@+id/card_follows"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            </LinearLayout>

            <!-- Core engagement -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="ENGAGEMENT" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface_card"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="❤️  Likes" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_likes" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="💬  Comments" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_comments" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="📤  Shares" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_shares" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="🔖  Saves" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_saves" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="📊  Engagement Rate" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_engagement" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/brand_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="⏱  Avg Watch %" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_avg_watch" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/brand_accent" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Reach & Discovery -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="REACH &amp; DISCOVERY" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface_card"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Total Plays" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_plays" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Unique Views" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_unique_views" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Reach" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_reach" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Profile Visits" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_profile_visits" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_primary" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="New Follows" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_follows" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/brand_accent" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Traffic sources -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="TRAFFIC SOURCES" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface_card"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="🏠  Home Feed" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_da_source_home" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="👤  Profile" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_da_source_profile" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="#  Hashtag" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_da_source_hashtag" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="🎵  Sound" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_da_source_sound" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="🔍  Explore" android:textColor="@color/text_primary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_da_source_explore" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Audience -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="AUDIENCE" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface_card"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Followers" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_audience_followers" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="New Viewers" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_audience_new" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Peak Time" android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_da_peak_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Reactions -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="REACTIONS" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_da_reactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_card"
                android:padding="16dp"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:layout_marginBottom="16dp"/>

            <!-- 7-day trend -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="7-DAY TREND" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_da_trend_7day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_card"
                android:padding="16dp"
                android:text="—"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
