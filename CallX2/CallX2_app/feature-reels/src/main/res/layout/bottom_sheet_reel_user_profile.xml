<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingBottom="28dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Avatar + online dot -->
    <FrameLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar_sheet"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:civ_border_width="0dp"/>

        <View
            android:id="@+id/view_online_dot_sheet"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="4dp"
            android:background="@drawable/circle_accept"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Name -->
    <TextView
        android:id="@+id/tv_name_sheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Status -->
    <TextView
        android:id="@+id/tv_status_sheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="3dp"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"/>

    <!-- 3 Action buttons: Message / Voice / Video -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="22dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Message -->
        <LinearLayout
            android:id="@+id/btn_message_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_action_btn_circle">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_send"
                    android:tint="@color/brand_primary"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Message"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Voice Call -->
        <LinearLayout
            android:id="@+id/btn_voice_call_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_action_btn_circle_green">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_phone"
                    android:tint="@color/white"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Voice Call"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Video Call -->
        <LinearLayout
            android:id="@+id/btn_video_call_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_action_btn_circle_purple">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_video_call"
                    android:tint="@color/white"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Video Call"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        android:layout_marginTop="18dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <!-- Social Platforms label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"
        android:text="Social Platforms"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:textAllCaps="true"
        android:letterSpacing="0.1"/>

    <!-- 3 Social buttons: X / Reels / YouTube -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- X -->
        <LinearLayout
            android:id="@+id/btn_x_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_social_x_btn">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_x_logo"/>
                </FrameLayout>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_x_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:visibility="invisible"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="#000000"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="X"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Reels -->
        <LinearLayout
            android:id="@+id/btn_reels_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_social_reel_btn">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_reels"
                        android:tint="@android:color/white"/>
                </FrameLayout>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_reel_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:visibility="invisible"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="#DD2A7B"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Reels"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- YouTube -->
        <LinearLayout
            android:id="@+id/btn_youtube_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_social_youtube_btn">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_youtube"/>
                </FrameLayout>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_youtube_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:visibility="invisible"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="#FF0000"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="YouTube"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- X Follow row -->
    <LinearLayout
        android:id="@+id/layout_x_follow_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_x_logo"
            android:background="@drawable/bg_social_x_btn"
            android:padding="2dp"/>

        <TextView
            android:id="@+id/tv_x_followers_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="0 Followers"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>

        <Button
            android:id="@+id/btn_x_follow_action"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Follow"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#000000"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <!-- Reels Follow row -->
    <LinearLayout
        android:id="@+id/layout_reels_follow_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_reels"
            android:tint="@android:color/white"
            android:background="@drawable/bg_social_reel_btn"
            android:padding="2dp"/>

        <TextView
            android:id="@+id/tv_reels_followers_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="0 Followers"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>

        <Button
            android:id="@+id/btn_reels_follow_action"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Follow"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#DD2A7B"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         YouTube Channel Description Section
         Sirf tab visible hoga jab hideYoutube=true (YouTube channel se open)
         Java mein: layout_yt_desc_section.setVisibility(VISIBLE)
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_yt_desc_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- Section Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp"
            android:text="CHANNEL DESCRIPTION"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:textAllCaps="true"
            android:letterSpacing="0.1"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:maxHeight="460dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Channel Title (bold) -->
                <TextView
                    android:id="@+id/tv_yt_desc_sheet_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginBottom="12dp"/>

                <!-- Stats row: Subscribers | Videos | Joined -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Subscribers box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#2A2A2A"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tv_yt_desc_sheet_subs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Subscribers"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Videos box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#2A2A2A"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tv_yt_desc_sheet_videos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Videos"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Views box -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#2A2A2A">

                        <TextView
                            android:id="@+id/tv_yt_desc_sheet_views"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Views"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Description body (dark box) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tv_yt_desc_sheet_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:hint="No description"
                        android:textColorHint="#555555"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A2A"
                    android:layout_marginBottom="12dp"/>

                <!-- Channel action chips row: Videos | About -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Videos chip — opens YouTubeChannelActivity -->
                        <TextView
                            android:id="@+id/btn_yt_desc_sheet_videos_chip"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="▶  Videos"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:background="@drawable/bg_yt_profile_chip"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <!-- About chip — opens YouTubeEditChannelActivity (view-only) -->
                        <TextView
                            android:id="@+id/btn_yt_desc_sheet_about_chip"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="About"
                            android:gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:background="@drawable/bg_yt_profile_chip"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Video details heading -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Channel details"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Handle row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        android:tint="#AAAAAA"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Handle"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tv_yt_desc_detail_handle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Subscribers detail row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_youtube"
                        android:tint="#AAAAAA"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Subscribers"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tv_yt_desc_detail_subs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Videos detail row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_reels"
                        android:tint="#AAAAAA"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Videos"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tv_yt_desc_detail_videos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- YouTube Subscribe row -->
    <LinearLayout
        android:id="@+id/layout_youtube_subscribe_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="4dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_youtube"
            android:background="@drawable/bg_social_youtube_btn"
            android:padding="2dp"/>

        <TextView
            android:id="@+id/tv_youtube_subs_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="0 Subscribers"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>

        <Button
            android:id="@+id/btn_youtube_subscribe_action"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Subscribe"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#FF0000"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

</LinearLayout>
