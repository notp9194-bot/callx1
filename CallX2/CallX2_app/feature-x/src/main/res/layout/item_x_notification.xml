<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_xn_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="top"
    android:background="?attr/selectableItemBackground">

    <!-- Left unread accent bar -->
    <View
        android:id="@+id/v_xn_unread_bar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="@color/x_accent"
        android:layout_marginEnd="10dp"
        android:visibility="gone" />

    <!-- Type icon with tinted background -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp">

        <ImageView
            android:id="@+id/iv_xn_type_bg"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_x_notif_type_bg"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/iv_xn_type"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_x_heart_filled" />
    </FrameLayout>

    <!-- Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_xn_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/ic_person" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_xn_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/x_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_xn_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/x_text_secondary"
                android:textSize="12sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_xn_snippet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/x_text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
