<?xml version="1.0" encoding="utf-8"?>
<!--
  YouTube Entry Button — animated strip that slides out from the avatar in CallX header.
  Mirrors the same pattern as layout_x_entry_button.xml.
  The red strip slides out to the right from behind the avatar on first load.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/yt_entry_root"
    android:layout_width="wrap_content"
    android:layout_height="44dp"
    android:layout_marginStart="8dp">

    <!-- Avatar circle — user's YouTube channel avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_yt_entry_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical|start"
        android:elevation="4dp"
        android:src="@drawable/ic_person"
        app:civ_border_width="2dp"
        app:civ_border_color="@color/yt_red"/>

    <!--
      Animated red strip — slides RIGHT from behind avatar.
      Initially translationX = -80dp → animates to 0.
    -->
    <LinearLayout
        android:id="@+id/ll_yt_entry_strip"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_yt_entry_stripe"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:elevation="2dp"
        android:clipToPadding="false">

        <!-- YouTube logo icon (white on red) -->
        <ImageView
            android:id="@+id/iv_yt_entry_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_youtube_logo"
            android:contentDescription="YouTube"/>

    </LinearLayout>

    <!--
      Notification badge — shows unread YouTube notification count.
      Positioned at top-right of the YouTube icon area.
    -->
    <TextView
        android:id="@+id/tv_yt_entry_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="34dp"
        android:layout_marginTop="2dp"
        android:minWidth="14dp"
        android:minHeight="14dp"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:textColor="#FFFFFF"
        android:textSize="8sp"
        android:gravity="center"
        android:elevation="6dp"
        android:background="@drawable/bg_yt_badge"
        android:visibility="gone"/>

</FrameLayout>
