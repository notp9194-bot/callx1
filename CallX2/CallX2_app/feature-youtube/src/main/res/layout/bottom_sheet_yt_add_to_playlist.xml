<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/yt_surface"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Playlist mein Save karo"
            android:textColor="@color/yt_text_primary"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_atpl_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_yt_back"
            android:rotation="270"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"
            android:contentDescription="Close"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <!-- New Playlist Button -->
    <LinearLayout
        android:id="@+id/btn_atpl_new_playlist"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_yt_upload"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="+ Nayi Playlist Banao"
            android:textColor="@color/yt_text_primary"
            android:textSize="15sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <!-- Existing Playlists -->
    <LinearLayout
        android:id="@+id/ll_yt_playlist_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxHeight="300dp"/>

    <!-- Save Button -->
    <Button
        android:id="@+id/btn_atpl_save"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:text="Save"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF0000"/>

</LinearLayout>
