<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night theme inherits from day theme — all transitions same -->
    <style name="Theme.CallX" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:windowBackground">@color/surface_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowAnimationStyle">@style/ActivitySlideTransition</item>
    </style>

    <!-- ── feature-games themes ── -->
    <style name="Theme.Games" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6C3CF7</item>
        <item name="colorPrimaryDark">#1A0A2E</item>
        <item name="colorAccent">#FF6B6B</item>
        <item name="android:windowBackground">#0D0221</item>
        <item name="android:statusBarColor">#1A0A2E</item>
        <item name="android:navigationBarColor">#1A0A2E</item>
    </style>

    <style name="Theme.Games.Fullscreen" parent="Theme.Games">
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
