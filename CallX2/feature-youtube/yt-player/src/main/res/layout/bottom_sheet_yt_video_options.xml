<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/yt_surface"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Video preview row -->
    <LinearLayout
        android:id="@+id/ll_yt_sheet_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <ImageView
            android:id="@+id/iv_yt_sheet_thumb"
            android:layout_width="120dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_yt_thumb_placeholder"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_yt_sheet_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/yt_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_yt_sheet_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/yt_text_secondary"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/yt_divider"/>


    <!-- Option: In-App Download (Offline — Library me dikhega) -->
    <LinearLayout
        android:id="@+id/btn_yt_option_download"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_download"
            android:tint="@color/yt_text_primary"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In-App Download"
                android:textColor="@color/yt_text_primary"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Library me save — offline dekho"
                android:textColor="@color/yt_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFFLINE"
            android:textColor="@color/yt_red"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/bg_yt_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>

    </LinearLayout>

    <!-- Option: Gallery Download (Phone ki Gallery me save) -->
    <LinearLayout
        android:id="@+id/btn_yt_option_download_gallery"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_download_done"
            android:tint="@color/yt_text_primary"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gallery me Save karo"
                android:textColor="@color/yt_text_primary"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone ki Gallery / Photos me dikhega"
                android:textColor="@color/yt_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GALLERY"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/bg_yt_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>

    </LinearLayout>

    <!-- Option: Watch Later -->
    <LinearLayout
        android:id="@+id/btn_yt_option_watch_later"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_library"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Watch Later me Save karo"
            android:textColor="@color/yt_text_primary"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Option: Add to Playlist -->
    <LinearLayout
        android:id="@+id/btn_yt_option_playlist"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_like"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Playlist me add karo"
            android:textColor="@color/yt_text_primary"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Option: Share -->
    <LinearLayout
        android:id="@+id/btn_yt_option_share"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_share"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Share karo"
            android:textColor="@color/yt_text_primary"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Option: Go to Channel -->
    <LinearLayout
        android:id="@+id/btn_yt_option_channel"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_subscriptions"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Channel dekho"
            android:textColor="@color/yt_text_primary"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Option: Not Interested -->
    <LinearLayout
        android:id="@+id/btn_yt_option_not_interested"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_dislike"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Pasand nahi"
            android:textColor="@color/yt_text_primary"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Option: Report -->
    <LinearLayout
        android:id="@+id/btn_yt_option_report"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_notifications"
            android:tint="#FF4444"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Report karo"
            android:textColor="#FF4444"
            android:textSize="14sp"/>
    </LinearLayout>
    <!-- Option: Delete Video (owner only — hidden by default) -->
    <LinearLayout
        android:id="@+id/btn_yt_option_delete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_dislike"
            android:tint="#FF4444"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Video delete karo"
            android:textColor="#FF4444"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>