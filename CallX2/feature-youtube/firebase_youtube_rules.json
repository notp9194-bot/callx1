{
  "rules": {
    "youtube": {
      "videos": {
        ".read": true,
        "$videoId": {
          ".write": "auth != null && (data.child('uploaderUid').val() == auth.uid || !data.exists())",
          ".validate": "newData.hasChildren(['videoId','uploaderUid','title','videoUrl','uploadedAt'])"
        }
      },
      "global_feed": {
        ".read": true,
        "$videoId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['videoId','uploaderUid'])"
        }
      },
      "category_feeds": {
        ".read": true,
        "$category": {
          "$videoId": {
            ".write": "auth != null"
          }
        }
      },
      "shorts": {
        ".read": true,
        "$shortId": {
          ".write": "auth != null && (data.child('uploaderUid').val() == auth.uid || !data.exists())"
        }
      },
      "channels": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          "subscriberCount": {
            ".write": "auth != null"
          },
          "videoCount": {
            ".write": "auth != null"
          },
          "totalViews": {
            ".write": "auth != null"
          },
          "totalLikes": {
            ".write": "auth != null"
          }
        }
      },
      "subscriptions": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "subscribers": {
        ".read": true,
        "$channelUid": {
          ".write": "auth != null"
        }
      },
      "comments": {
        "$videoId": {
          ".read": true,
          ".write": "auth != null",
          "$commentId": {
            ".validate": "newData.hasChildren(['commentId','videoId','authorUid','text'])",
            "likeCount": {
              ".write": "auth != null"
            },
            "replyCount": {
              ".write": "auth != null"
            },
            "isPinned": {
              ".write": "auth != null"
            },
            "isHearted": {
              ".write": "auth != null"
            }
          }
        }
      },
      "comment_replies": {
        "$videoId": {
          ".read": true,
          "$commentId": {
            ".write": "auth != null"
          }
        }
      },
      "comment_likes": {
        "$videoId": {
          ".read": true,
          "$commentId": {
            "$uid": {
              ".write": "auth != null && auth.uid == $uid"
            }
          }
        }
      },
      "comment_dislikes": {
        "$videoId": {
          "$commentId": {
            "$uid": {
              ".read": "auth != null && auth.uid == $uid",
              ".write": "auth != null && auth.uid == $uid"
            }
          }
        }
      },
      "video_likes": {
        "$videoId": {
          ".read": true,
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      },
      "video_dislikes": {
        "$videoId": {
          "$uid": {
            ".read": "auth != null && auth.uid == $uid",
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      },
      "video_shares": {
        "$videoId": {
          ".read": true,
          ".write": "auth != null"
        }
      },
      "playlists": {
        "$uid": {
          ".read": true,
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "playlist_videos": {
        "$uid": {
          ".read": true,
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "saved_playlists": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "watch_history": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "watch_later": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "liked_videos": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "disliked_videos": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "shared_videos": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "notifications": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null"
        }
      },
      "search_history": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "not_interested": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "downloads": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "reports": {
        "$videoId": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      },
      "creator_analytics": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null"
        }
      },
      "video_analytics": {
        "$videoId": {
          ".read": true,
          ".write": "auth != null"
        }
      },
      "trending_scores": {
        ".read": true,
        ".write": "auth != null"
      },
      "trending": {
        ".read": true,
        ".write": "auth != null"
      },
      "live_streams": {
        ".read": true,
        "$streamId": {
          ".write": "auth != null"
        }
      },
      "live_chat": {
        "$streamId": {
          ".read": true,
          ".write": "auth != null"
        }
      },
      "user_videos": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "user_shorts": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      },
      "user_feeds": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null"
        }
      }
    }
  }
}
