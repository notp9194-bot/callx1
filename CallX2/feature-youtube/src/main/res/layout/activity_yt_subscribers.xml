<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:background="@color/yt_bg">

        <ImageButton
            android:id="@+id/btn_yt_subs_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:id="@+id/tv_yt_subs_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Subscribers"
            android:textColor="@color/yt_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_yt_subs_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abhi tak koi subscriber nahi hai"
        android:textColor="#888888"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_yt_subscribers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
