<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btn_yt_create_pl_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Playlist"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <EditText
                android:id="@+id/et_yt_pl_title"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Playlist title"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="textCapSentences"/>
            <EditText
                android:id="@+id/et_yt_pl_desc"
                android:layout_width="match_parent" android:layout_height="80dp"
                android:hint="Description (optional)"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:gravity="top" android:inputType="textMultiLine"
                android:layout_marginBottom="16dp"/>
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Visibility"
                android:textColor="#AAAAAA" android:textSize="13sp"
                android:layout_marginBottom="8dp"/>
            <RadioGroup
                android:id="@+id/rg_yt_pl_visibility"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <RadioButton
                    android:id="@+id/rb_yt_pl_public"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Public" android:textColor="#FFFFFF"
                    android:buttonTint="@color/yt_red" android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb_yt_pl_unlisted"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Unlisted" android:textColor="#FFFFFF"
                    android:buttonTint="@color/yt_red"/>
                <RadioButton
                    android:id="@+id/rb_yt_pl_private"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Private" android:textColor="#FFFFFF"
                    android:buttonTint="@color/yt_red"/>
            </RadioGroup>
        </LinearLayout>
    </ScrollView>
    <Button
        android:id="@+id/btn_yt_create_pl_confirm"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:text="Create Playlist"
        android:textColor="#FFFFFF" android:backgroundTint="@color/yt_red"/>
</LinearLayout>
