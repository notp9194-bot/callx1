<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btn_yt_schedule_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Schedule Upload"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <Button
                android:id="@+id/btn_yt_pick_video_schedule"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Pick Video"
                android:textColor="#FFFFFF" android:backgroundTint="@color/yt_surface"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:id="@+id/tv_yt_schedule_video"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="No video selected"
                android:textColor="#717171" android:textSize="12sp"
                android:layout_marginBottom="16dp"/>
            <EditText
                android:id="@+id/et_yt_schedule_title"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Title (required)"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="textCapSentences"/>
            <EditText
                android:id="@+id/et_yt_schedule_desc"
                android:layout_width="match_parent" android:layout_height="80dp"
                android:hint="Description"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:gravity="top" android:inputType="textMultiLine"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_yt_schedule_tags"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Tags (comma separated)"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_yt_schedule_category"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Category"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"/>
            <Button
                android:id="@+id/btn_yt_pick_date"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Pick Date &amp; Time"
                android:textColor="#FFFFFF" android:backgroundTint="@color/yt_surface"
                android:layout_marginBottom="8dp"/>
            <TextView
                android:id="@+id/tv_yt_schedule_date"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#3EA6FF" android:textSize="14sp"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </ScrollView>
    <ProgressBar
        android:id="@+id/pb_yt_schedule"
        android:layout_width="match_parent" android:layout_height="4dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:visibility="gone"
        android:progressTint="@color/yt_red"/>
    <Button
        android:id="@+id/btn_yt_schedule_confirm"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:text="Schedule Video"
        android:textColor="#FFFFFF" android:backgroundTint="@color/yt_red"/>
</LinearLayout>
