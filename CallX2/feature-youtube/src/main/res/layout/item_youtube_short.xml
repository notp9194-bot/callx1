<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen video player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/pv_short_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="zoom"
        app:use_controller="false"
        app:surface_type="texture_view"/>

    <!-- Thumbnail (shown while buffering) -->
    <ImageView
        android:id="@+id/iv_short_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#000000"/>

    <!-- Heart animation on double-tap like -->
    <ImageView
        android:id="@+id/iv_short_heart_anim"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_yt_like_filled"
        android:tint="#FF0000"
        android:visibility="gone"
        android:elevation="20dp"/>

    <!-- Right side action buttons -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingEnd="8dp"
        android:paddingBottom="80dp"
        android:elevation="10dp">

        <!-- Like -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <ImageButton
                android:id="@+id/btn_short_like"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_yt_like"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Like"/>
            <TextView
                android:id="@+id/tv_short_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Dislike -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <ImageButton
                android:id="@+id/btn_short_dislike"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_yt_dislike"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Dislike"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dislike"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Comment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <ImageButton
                android:id="@+id/btn_short_comment"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_yt_comments"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Comments"/>
            <TextView
                android:id="@+id/tv_short_comments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comment"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Share -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <ImageButton
                android:id="@+id/btn_short_share"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_yt_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Share"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- More -->
        <ImageButton
            android:id="@+id/btn_short_more"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="More"/>

    </LinearLayout>

    <!-- Bottom info overlay: channel avatar + title + follow button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingBottom="80dp"
        android:elevation="10dp"
        android:background="@drawable/bg_short_gradient_bottom">

        <!-- Channel row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_short_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_person"
                app:civ_border_color="#FFFFFF"
                app:civ_border_width="1.5dp"/>

            <TextView
                android:id="@+id/tv_short_channel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/btn_short_follow"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Subscribe"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="#FFFF0000"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>

        </LinearLayout>

        <!-- Video title -->
        <TextView
            android:id="@+id/tv_short_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="60dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

</FrameLayout>
