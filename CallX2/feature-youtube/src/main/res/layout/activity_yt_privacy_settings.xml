<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/yt_bg">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar_yt_privacy"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/yt_bg" android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="24dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Keep these private" android:textColor="#AAAAAA" android:textSize="12sp"
                android:paddingStart="16dp" android:paddingTop="16dp" android:paddingBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Subscriptions" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_private_subscriptions"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Liked videos" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_private_liked"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Saved playlists" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_private_saved"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Public playlists" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_private_playlists"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
