<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <ImageButton
        android:id="@+id/iv_suggestion_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_yt_search"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/yt_text_secondary"
        android:contentDescription="History"/>

    <TextView
        android:id="@+id/tv_suggestion_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:textColor="@color/yt_text_primary"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <ImageButton
        android:id="@+id/btn_suggestion_remove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_yt_back"
        android:rotation="45"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/yt_text_secondary"
        android:contentDescription="Remove"/>

</LinearLayout>
