<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:padding="0dp">

    <!-- Thumbnail with duration badge -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp">

        <ImageView
            android:id="@+id/iv_yt_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_yt_thumb_placeholder"/>

        <!-- Duration badge -->
        <TextView
            android:id="@+id/tv_yt_video_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#CC000000"/>
    </FrameLayout>

    <!-- Video info row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- Channel avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_yt_video_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_person"/>

        <!-- Text info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_yt_video_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_yt_video_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tv_yt_video_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#717171"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- More options -->
        <ImageButton
            android:id="@+id/btn_yt_video_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top"
            android:padding="4dp"
            android:src="@drawable/ic_yt_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"/>
    </LinearLayout>

</LinearLayout>
