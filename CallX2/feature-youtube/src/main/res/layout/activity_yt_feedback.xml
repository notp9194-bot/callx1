<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_yt_feedback"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/yt_bg"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feedback type"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/sp_yt_feedback_type"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_rounded_outline"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Describe your feedback"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_yt_feedback_desc"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:hint="Aapki problem ya suggestion detail mein likhein..."
                android:textColorHint="#555555"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top|start"
                android:padding="12dp"
                android:background="@drawable/bg_rounded_outline"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Aapki feedback anonymous nahi hai — account linked rahega\n• Specific steps batayein jo problem reproduce karte hain\n• Screenshots attach karne ke liye Settings > Screenshots use karein"
                android:textColor="#888888"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="12dp"/>

            <ProgressBar
                android:id="@+id/pb_yt_feedback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_yt_feedback_submit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Submit Feedback"
                android:textColor="#000000"
                android:backgroundTint="#FF0000"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
