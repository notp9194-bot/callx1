<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yt_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Video Player -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/yt_player_bg">

            <androidx.media3.ui.PlayerView
                android:id="@+id/yt_player_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:surface_type="texture_view"
                app:resize_mode="fit"
                app:use_controller="true"
                app:show_buffering="when_playing"
                app:controller_layout_id="@layout/yt_custom_player_controls"/>

            <ProgressBar
                android:id="@+id/pb_yt_player"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:visibility="visible"/>

            <LinearLayout
                android:id="@+id/ll_yt_player_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CC000000"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_yt_play"
                    android:alpha="0.5"
                    android:contentDescription="Error"/>

                <TextView
                    android:id="@+id/tv_yt_player_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Video load nahi ho raha"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_yt_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:src="@drawable/ic_yt_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"/>
        </FrameLayout>

        <!-- Scrollable video info + related videos -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Title row with 3-dot -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_yt_video_title"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="3"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.2"/>

                    <ImageButton
                        android:id="@+id/btn_yt_player_more"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_yt_more"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="More options"
                        android:tint="@color/yt_text_primary"/>

                </LinearLayout>

                <!--
                    REAL YOUTUBE STYLE:
                    "4,452 views  1h ago  ...more" — ek hi line mein
                    Poori row tap karne pe Description Bottom Sheet open hogi
                -->
                <LinearLayout
                    android:id="@+id/ll_yt_desc_trigger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <!-- "4,452 views · 1h ago" -->
                    <TextView
                        android:id="@+id/tv_yt_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <!-- "  ...more" — bold, primary color -->
                    <TextView
                        android:id="@+id/tv_yt_show_more"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="  ...more"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- hidden — sirf Java me data hold karne ke liye, UI me nahi dikhta -->
                <TextView
                    android:id="@+id/tv_yt_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>

                <!-- Channel row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_yt_channel_avatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_person"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tv_yt_channel_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/yt_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_yt_subscribe"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Subscribe"
                        android:textSize="13sp"
                        android:textColor="@color/yt_subscribe_text"
                        android:background="@drawable/bg_yt_subscribe_btn"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </LinearLayout>

                <!-- Actions row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageButton
                            android:id="@+id/btn_yt_like"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_yt_like"
                            android:background="?attr/selectableItemBackgroundBorderless"/>

                        <TextView
                            android:id="@+id/tv_yt_likes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="@color/yt_text_primary"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_yt_dislike"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:src="@drawable/ic_yt_dislike"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageButton
                            android:id="@+id/btn_yt_share"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_yt_share"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Share"
                            android:textColor="@color/yt_text_secondary"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageButton
                            android:id="@+id/btn_yt_comments"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_yt_comments"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Comments"
                            android:textColor="@color/yt_text_secondary"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageButton
                            android:id="@+id/btn_yt_watch_later"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_yt_library"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Save"
                            android:textColor="@color/yt_text_secondary"
                            android:textSize="10sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageButton
                            android:id="@+id/btn_yt_download"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_yt_download"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Download"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download"
                            android:textColor="@color/yt_text_secondary"
                            android:textSize="10sp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    android:background="@color/yt_divider"/>

                <!-- Up Next -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Up Next"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_yt_related"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
