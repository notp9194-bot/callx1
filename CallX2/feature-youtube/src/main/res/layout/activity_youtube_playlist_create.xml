<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_yt_plcreate_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Nayi Playlist Banao"
            android:textColor="@color/yt_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlist ka naam *"
                android:textColor="@color/yt_text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_yt_playlist_title"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Playlist title likhein"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="text"
                android:maxLength="150"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description (optional)"
                android:textColor="@color/yt_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_yt_playlist_desc"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Playlist ke baare mein likhein"
                android:textColorHint="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLength="500"/>

            <!-- Visibility -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Visibility"
                android:textColor="@color/yt_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <RadioGroup
                android:id="@+id/rg_yt_playlist_visibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_yt_public"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🌐  Public — Sab dekh sakte hain"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"
                    android:checked="true"
                    android:buttonTint="@color/yt_text_primary"/>

                <RadioButton
                    android:id="@+id/rb_yt_unlisted"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔗  Unlisted — Link wale dekh sakte hain"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"
                    android:buttonTint="@color/yt_text_primary"/>

                <RadioButton
                    android:id="@+id/rb_yt_private"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔒  Private — Sirf aap dekh sakte hain"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"
                    android:buttonTint="@color/yt_text_primary"/>

            </RadioGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Create button -->
    <Button
        android:id="@+id/btn_yt_create_playlist"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:margin="16dp"
        android:text="Playlist Banao"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#FF0000"/>

</LinearLayout>
