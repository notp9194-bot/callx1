<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btn_yt_report_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Report"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>
    <RadioGroup
        android:id="@+id/rg_yt_report_reason"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">
        <RadioButton android:id="@+id/rb_yt_report_spam"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Spam or misleading"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_hate"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Hateful or abusive content"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_violent"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Violent or repulsive content"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_sexual"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Sexual content"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_copyright"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Copyright infringement"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_dangerous"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Dangerous or harmful acts"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_child"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Child safety"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_privacy"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Privacy violation"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
        <RadioButton android:id="@+id/rb_yt_report_other"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="Other"
            android:textColor="#FFFFFF" android:buttonTint="@color/yt_red"/>
    </RadioGroup>
    <EditText
        android:id="@+id/et_yt_report_details"
        android:layout_width="match_parent" android:layout_height="80dp"
        android:hint="Additional details (optional)"
        android:textColorHint="#717171" android:textColor="#FFFFFF"
        android:background="@color/yt_surface"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:gravity="top" android:inputType="textMultiLine"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"/>
    <Button
        android:id="@+id/btn_yt_report_submit"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:text="Submit Report"
        android:textColor="#FFFFFF" android:backgroundTint="@color/yt_red"/>
</LinearLayout>
