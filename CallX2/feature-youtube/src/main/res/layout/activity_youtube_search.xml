<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/yt_bg">

        <ImageButton
            android:id="@+id/btn_yt_search_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <EditText
            android:id="@+id/et_yt_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Search YouTube"
            android:textColorHint="@color/yt_text_muted"
            android:textColor="@color/yt_text_primary"
            android:background="@color/yt_surface"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_yt_search_results"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
