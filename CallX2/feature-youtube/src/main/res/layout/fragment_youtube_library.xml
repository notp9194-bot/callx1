<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yt_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Library"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>


        <!-- Downloads — first entry, real YouTube style -->
        <LinearLayout
            android:id="@+id/btn_yt_downloads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_yt_download"
                android:tint="#AAAAAA"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Downloads"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Offline dekho — internet ke bina"
                    android:textColor="#888888"
                    android:textSize="12sp"/>
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_yt_back"
                android:rotation="180"
                android:tint="#666666"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/yt_divider"
            android:layout_marginBottom="8dp"/>

        <!-- Watch Later -->
        <LinearLayout
            android:id="@+id/btn_yt_watch_later"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_yt_library"
                android:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Watch Later"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Watch History -->
        <LinearLayout
            android:id="@+id/btn_yt_history"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:layout_marginBottom="4dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_yt_subscriptions"
                android:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Watch History"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Liked Videos -->
        <LinearLayout
            android:id="@+id/btn_yt_liked"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_yt_like"
                android:tint="#AAAAAA"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Liked Videos"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Liked Videos ends above — divider before Playlists section -->
        <View android:layout_width="match_parent" android:layout_height="8dp"
            android:background="#111111" android:layout_marginTop="8dp"/>

        <!-- Playlists Section Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Playlists"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/btn_yt_new_playlist"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="+ New"
                android:textColor="#FF4444"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/yt_divider" android:layout_marginBottom="4dp"/>

        <!-- Empty playlists message -->
        <TextView
            android:id="@+id/tv_yt_no_playlists"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Koi playlist nahi hai. + New se banao."
            android:textColor="#555555"
            android:textSize="13sp"
            android:padding="12dp"
            android:visibility="gone"/>

        <!-- Playlist rows inserted dynamically by YouTubeLibraryFragment -->
        <LinearLayout
            android:id="@+id/ll_yt_playlists_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</ScrollView>
