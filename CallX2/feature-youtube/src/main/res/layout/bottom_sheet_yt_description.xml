<?xml version="1.0" encoding="utf-8"?>
<!-- Real YouTube-style Description Bottom Sheet -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Drag handle (screenshot me top me bar dikhta hai) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="#555555"
        android:backgroundTint="#555555"/>

    <!-- ═══════════════════════════════════════════════════════════════════
         Social Profile Section (from ReelUserProfileSheet)
         Channel owner ka avatar, name, online status, action buttons,
         aur social platform rows
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Avatar + online dot -->
    <FrameLayout
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_desc_social_avatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <View
            android:id="@+id/view_desc_online_dot"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="3dp"
            android:background="@drawable/circle_accept"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Name -->
    <TextView
        android:id="@+id/tv_desc_social_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/yt_text_primary"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Status / last seen -->
    <TextView
        android:id="@+id/tv_desc_social_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:textSize="12sp"
        android:textColor="@color/yt_text_secondary"/>

    <!-- 3 Action buttons: Message / Voice Call / Video Call -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="18dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Message -->
        <LinearLayout
            android:id="@+id/btn_desc_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#1E1E1E">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_yt_message"
                    android:tint="#AAAAAA"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Message"
                android:textSize="11sp"
                android:textColor="@color/yt_text_secondary"/>
        </LinearLayout>

        <!-- Voice Call -->
        <LinearLayout
            android:id="@+id/btn_desc_voice_call"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#1A3A1A">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_yt_call"
                    android:tint="#00C853"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Voice Call"
                android:textSize="11sp"
                android:textColor="@color/yt_text_secondary"/>
        </LinearLayout>

        <!-- Video Call -->
        <LinearLayout
            android:id="@+id/btn_desc_video_call"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#1A1A3A">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_yt_video_call"
                    android:tint="#7C4DFF"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Video Call"
                android:textSize="11sp"
                android:textColor="@color/yt_text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#2A2A2A"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>

    <!-- Social Platforms label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:text="SOCIAL PLATFORMS"
        android:textSize="10sp"
        android:textColor="@color/yt_text_secondary"
        android:textAllCaps="true"
        android:letterSpacing="0.1"/>

    <!-- 3 Social buttons: X / Reels / YouTube -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- X -->
        <LinearLayout
            android:id="@+id/btn_desc_x_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp">
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_social_x_btn">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_x_logo"/>
                </FrameLayout>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_desc_anim_x"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:visibility="invisible"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="X"
                android:textSize="11sp"
                android:textColor="@color/yt_text_secondary"/>
        </LinearLayout>

        <!-- Reels -->
        <LinearLayout
            android:id="@+id/btn_desc_reels_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <FrameLayout
                android:layout_width="50dp"
                android:layout_height="50dp">
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_social_reel_btn">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_reels"
                        android:tint="@android:color/white"/>
                </FrameLayout>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_desc_anim_reels"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:visibility="invisible"/>
            </FrameLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Reels"
                android:textSize="11sp"
                android:textColor="@color/yt_text_secondary"/>
        </LinearLayout>

        <!-- YouTube (hidden since we're already on YouTube) -->
        <LinearLayout
            android:id="@+id/btn_desc_youtube_sheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone">
        </LinearLayout>
    </LinearLayout>

    <!-- X Follow row -->
    <LinearLayout
        android:id="@+id/layout_desc_x_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="8dp"
        android:visibility="gone">
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_x_logo"
            android:background="@drawable/bg_social_x_btn"
            android:padding="2dp"/>
        <TextView
            android:id="@+id/tv_desc_x_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="0 Followers"
            android:textSize="13sp"
            android:textColor="@color/yt_text_secondary"/>
        <Button
            android:id="@+id/btn_desc_x_follow"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Follow"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <!-- Reels Follow row -->
    <LinearLayout
        android:id="@+id/layout_desc_reels_row"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="4dp"
        android:visibility="gone">
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_reels"
            android:tint="@android:color/white"
            android:background="@drawable/bg_social_reel_btn"
            android:padding="2dp"/>
        <TextView
            android:id="@+id/tv_desc_reels_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="0 Followers"
            android:textSize="13sp"
            android:textColor="@color/yt_text_secondary"/>
        <Button
            android:id="@+id/btn_desc_reels_follow"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Follow"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#DD2A7B"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <!-- Divider before existing description content -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"/>


    <!-- Header: "Description" title + X button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/yt_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_yt_desc_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"
            android:contentDescription="Close"/>

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="520dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Video Title (bold — screenshot jaisa) -->
            <TextView
                android:id="@+id/tv_desc_sheet_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/yt_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="12dp"/>

            <!-- Stats row: Likes | Views | Age — screenshot jaisa 3 boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Likes box -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2A2A2A"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_desc_sheet_likes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Likes"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Views box -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2A2A2A"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_desc_sheet_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Views"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Date box -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2A2A2A">

                    <TextView
                        android:id="@+id/tv_desc_sheet_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ago"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Description text inside a rounded dark box (screenshot jaisa) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_desc_sheet_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/yt_divider"
                android:layout_marginBottom="16dp"/>

            <!-- Channel row (screenshot jaisa — avatar + name + arrow) -->
            <LinearLayout
                android:id="@+id/ll_desc_sheet_channel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp"
                android:layout_marginBottom="12dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_desc_sheet_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_person"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tv_desc_sheet_channel_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_desc_sheet_subs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Arrow ">" jaise screenshot mein hai -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_yt_more"
                    android:tint="@color/yt_text_secondary"
                    android:rotation="90"/>

            </LinearLayout>

            <!-- Channel action buttons: Videos | About | Instagram | Facebook -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_desc_sheet_videos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶  Videos"
                        android:gravity="center"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_yt_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btn_desc_sheet_about"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="About"
                        android:gravity="center"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_yt_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/yt_divider"
                android:layout_marginBottom="16dp"/>

            <!-- Video details section (screenshot jaisa) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video details"
                android:textColor="@color/yt_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Date row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_yt_library"
                    android:tint="@color/yt_text_secondary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_desc_detail_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Views row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_yt_play"
                    android:tint="@color/yt_text_secondary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Views"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_desc_detail_views"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Likes row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_yt_like"
                    android:tint="@color/yt_text_secondary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Likes"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_desc_detail_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
