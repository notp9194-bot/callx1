<?xml version="1.0" encoding="utf-8"?>
<!-- Real YouTube-style Description Bottom Sheet -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Drag handle (screenshot me top me bar dikhta hai) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="#555555"
        android:backgroundTint="#555555"/>

    <!-- Header: "Description" title + X button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/yt_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_yt_desc_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"
            android:contentDescription="Close"/>

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="520dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Video Title (bold — screenshot jaisa) -->
            <TextView
                android:id="@+id/tv_desc_sheet_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/yt_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginBottom="12dp"/>

            <!-- Stats row: Likes | Views | Age — screenshot jaisa 3 boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Likes box -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2A2A2A"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_desc_sheet_likes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Likes"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Views box -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2A2A2A"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_desc_sheet_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Views"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Date box -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#2A2A2A">

                    <TextView
                        android:id="@+id/tv_desc_sheet_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ago"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Description text inside a rounded dark box (screenshot jaisa) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tv_desc_sheet_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/yt_divider"
                android:layout_marginBottom="16dp"/>

            <!-- Channel row (screenshot jaisa — avatar + name + arrow) -->
            <LinearLayout
                android:id="@+id/ll_desc_sheet_channel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp"
                android:layout_marginBottom="12dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_desc_sheet_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_person"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tv_desc_sheet_channel_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_desc_sheet_subs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/yt_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Arrow ">" jaise screenshot mein hai -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_yt_more"
                    android:tint="@color/yt_text_secondary"
                    android:rotation="90"/>

            </LinearLayout>

            <!-- Channel action buttons: Videos | About | Instagram | Facebook -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_desc_sheet_videos"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="▶  Videos"
                        android:gravity="center"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_yt_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btn_desc_sheet_about"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="About"
                        android:gravity="center"
                        android:textColor="@color/yt_text_primary"
                        android:textSize="13sp"
                        android:background="@drawable/bg_yt_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/yt_divider"
                android:layout_marginBottom="16dp"/>

            <!-- Video details section (screenshot jaisa) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video details"
                android:textColor="@color/yt_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Date row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_yt_library"
                    android:tint="@color/yt_text_secondary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_desc_detail_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Views row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_yt_play"
                    android:tint="@color/yt_text_secondary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Views"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_desc_detail_views"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Likes row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_yt_like"
                    android:tint="@color/yt_text_secondary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Likes"
                    android:textColor="@color/yt_text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tv_desc_detail_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/yt_text_primary"
                    android:textSize="14sp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
