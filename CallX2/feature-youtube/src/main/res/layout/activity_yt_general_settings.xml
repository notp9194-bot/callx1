<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_yt_general"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/yt_bg"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="24dp">

            <!-- Remind me to take a break -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Remind me to take a break"
                        android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Every 45 minutes"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_yt_remind_break"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Remind me when it's bedtime -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Remind me when it's bedtime"
                        android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Off"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_yt_bedtime"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF"/>

            <!-- Appearance -->
            <LinearLayout android:id="@+id/row_yt_appearance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="16dp" android:paddingBottom="16dp"
                android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Appearance" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Choose your light or dark theme preference"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_yt_appearance_val"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="System default" android:textColor="#AAAAAA" android:textSize="12sp"/>
            </LinearLayout>

            <!-- App language -->
            <LinearLayout android:id="@+id/row_yt_app_language"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="16dp" android:paddingBottom="16dp"
                android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="App language" android:textColor="#FFFFFF" android:textSize="14sp"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_yt_language_val"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="English (United States)" android:textColor="#AAAAAA" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Playback in feeds -->
            <LinearLayout android:id="@+id/row_yt_playback_feeds"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="16dp" android:paddingBottom="16dp"
                android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Playback in feeds" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Choose whether videos play as you browse"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_yt_playback_feeds_val"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="On" android:textColor="#AAAAAA" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Location -->
            <LinearLayout android:id="@+id/row_yt_location"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="16dp" android:paddingBottom="16dp"
                android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Location" android:textColor="#FFFFFF" android:textSize="14sp"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_yt_location_val"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="India" android:textColor="#AAAAAA" android:textSize="12sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF"/>

            <!-- Restricted Mode -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="4dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Restricted Mode" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="This helps hide potentially mature videos. No filter is 100% accurate. This setting only applies to this app on this device"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_yt_restricted_mode"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Enable stats for nerds -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable stats for nerds"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_yt_stats_nerds"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Earn badges -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Earn badges" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Receive badges across all YouTube apps"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_yt_earn_badges"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
