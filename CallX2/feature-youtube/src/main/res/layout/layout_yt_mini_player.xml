<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:layout_gravity="bottom"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/yt_surface"
    android:elevation="12dp"
    android:padding="4dp">

    <!-- Mini video preview -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/pv_mini_player"
        android:layout_width="100dp"
        android:layout_height="60dp"
        app:use_controller="false"
        app:surface_type="texture_view"
        app:resize_mode="fill"/>

    <!-- Title + Channel -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tv_mini_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/yt_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_mini_channel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/yt_text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Play/Pause -->
    <ImageButton
        android:id="@+id/btn_mini_play_pause"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_yt_play"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/yt_text_primary"
        android:contentDescription="Play/Pause"/>

    <!-- Close -->
    <ImageButton
        android:id="@+id/btn_mini_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_yt_back"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/yt_text_primary"
        android:contentDescription="Close"
        android:rotation="270"/>

    <!-- Progress bar at the very bottom -->

</LinearLayout>
