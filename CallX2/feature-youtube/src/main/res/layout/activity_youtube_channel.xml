<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/yt_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/yt_bg"
        app:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="12dp">

            <ImageButton
                android:id="@+id/btn_yt_channel_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_yt_back"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Channel"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner -->
            <ImageView
                android:id="@+id/iv_yt_channel_banner"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:background="#1A1A1A"/>

            <!-- Avatar + channel info row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_yt_channel_avatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_person"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tv_yt_channel_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_yt_channel_handle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_yt_channel_subs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" · "
                            android:textColor="#717171"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_yt_video_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Subscribe / Edit buttons -->
                <Button
                    android:id="@+id/btn_yt_channel_subscribe"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Subscribe"
                    android:textSize="13sp"
                    android:textColor="@color/yt_subscribe_text"
                    android:background="@drawable/bg_yt_subscribe_btn"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:visibility="visible"/>

                <Button
                    android:id="@+id/btn_yt_edit_channel"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Edit"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_yt_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Bio -->
            <TextView
                android:id="@+id/tv_yt_channel_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:maxLines="3"
                android:ellipsize="end"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/yt_divider"/>

            <!-- Video grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_yt_channel_videos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
