<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_yt_comment_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_person"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp">

        <!-- Pinned badge -->
        <TextView
            android:id="@+id/tv_yt_comment_pinned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pinned by creator"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:visibility="gone"
            android:layout_marginBottom="2dp"/>

        <!-- Author + time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_yt_comment_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_yt_comment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="#717171"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Comment text -->
        <TextView
            android:id="@+id/tv_yt_comment_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3"/>

        <!-- Like + Reply row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_yt_like"
                android:tint="#717171"/>

            <TextView
                android:id="@+id/tv_yt_comment_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="#717171"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/btn_yt_comment_reply"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Reply"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 3-dot more options for comment -->
    <ImageButton
        android:id="@+id/btn_yt_comment_more"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top"
        android:src="@drawable/ic_yt_more"
        android:tint="@color/yt_text_muted"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Comment options"
        android:padding="4dp"/>

</LinearLayout>
