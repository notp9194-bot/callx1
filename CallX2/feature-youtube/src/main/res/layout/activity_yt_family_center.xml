<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_yt_family_center"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/yt_bg"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- Hero card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Family Center" android:textColor="#FFFFFF"
                    android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Family Center parents ko apne bachchon ke YouTube use monitor karne aur manage karne ki suvidha deta hai, jab woh Google Family Link se connected hon."
                    android:textColor="#CCCCCC" android:textSize="14sp" android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp"/>

                <Button android:id="@+id/btn_yt_family_link"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="Link Family Account" android:textColor="#000000"
                    android:backgroundTint="#FF0000"/>
            </LinearLayout>

            <!-- Features list -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FAMILY CENTER SE KYA KAR SAKTE HAIN:"
                android:textColor="#AAAAAA" android:textSize="11sp" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#1A1A1A" android:padding="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Bacche kya dekh rahe hain monitor karo"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Screen time limits set karo"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  Restricted Mode enable karo"
                    android:textColor="#DDDDDD" android:textSize="14sp" android:layout_marginBottom="10dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✅  YouTube Kids pe switch karo"
                    android:textColor="#DDDDDD" android:textSize="14sp"/>
            </LinearLayout>

            <Button android:id="@+id/btn_yt_kids_app"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="YouTube Kids App Download Karo"
                android:textColor="#FFFFFF" android:backgroundTint="#3D3D3D"
                android:layout_marginTop="16dp"/>

            <Button android:id="@+id/btn_yt_parental_controls"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Parental Controls Manage Karo"
                android:textColor="#FFFFFF" android:backgroundTint="#3D3D3D"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
