<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_yt_upload_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Upload Video"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thumbnail preview -->
            <ImageView
                android:id="@+id/iv_yt_thumb_preview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="@color/yt_surface"
                android:layout_marginBottom="12dp"/>

            <!-- Pick video button -->
            <Button
                android:id="@+id/btn_yt_pick_video"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Pick Video"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/yt_surface"
                android:layout_marginBottom="8dp"/>

            <!-- Pick thumbnail button -->
            <Button
                android:id="@+id/btn_yt_pick_thumb"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Pick Thumbnail (optional)"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/yt_surface"
                android:layout_marginBottom="16dp"/>

            <!-- Title -->
            <EditText
                android:id="@+id/et_yt_title"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Title (required)"
                android:hintTextColor="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="textCapSentences"/>

            <!-- Description -->
            <EditText
                android:id="@+id/et_yt_description"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Description"
                android:hintTextColor="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="top"
                android:layout_marginBottom="8dp"
                android:inputType="textMultiLine"/>

            <!-- Tags -->
            <EditText
                android:id="@+id/et_yt_tags"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Tags (comma separated)"
                android:hintTextColor="@color/yt_text_muted"
                android:textColor="@color/yt_text_primary"
                android:background="@color/yt_surface"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="8dp"/>

            <!-- Category -->
            <Spinner
                android:id="@+id/sp_yt_category"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/yt_surface"
                android:entries="@array/yt_categories"
                android:layout_marginBottom="8dp"/>

            <!-- Visibility -->
            <Spinner
                android:id="@+id/sp_yt_visibility"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/yt_surface"
                android:entries="@array/yt_visibility_options"
                android:layout_marginBottom="8dp"/>

            <!-- Is Short checkbox -->
            <CheckBox
                android:id="@+id/cb_yt_is_short"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This is a YouTube Short (vertical ≤60s)"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="16dp"
                android:buttonTint="@color/yt_red"/>

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/pb_yt_upload"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        style="?attr/progressBarStyleHorizontal"
        android:max="100"
        android:visibility="gone"
        android:progressTint="@color/yt_red"/>

    <Button
        android:id="@+id/btn_yt_upload_submit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Upload Video"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/yt_red"
        android:textSize="16sp"/>

</LinearLayout>
