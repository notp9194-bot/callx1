<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_yt_comment_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_person"/>
            <ImageView
                android:id="@+id/iv_yt_comment_heart"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_yt_like_filled"
                android:tint="@color/yt_red"
                android:visibility="gone"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_yt_comment_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tv_yt_comment_owner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:paddingStart="6dp" android:paddingEnd="6dp"
                    android:paddingTop="1dp" android:paddingBottom="1dp"
                    android:text="Creator"
                    android:textColor="@color/yt_red" android:textSize="10sp"
                    android:background="@drawable/bg_yt_badge"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_yt_comment_pinned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="📌 Pinned"
                    android:textColor="#717171" android:textSize="10sp"
                    android:visibility="gone"/>
                <TextView
                    android:id="@+id/tv_yt_comment_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:textColor="#717171" android:textSize="11sp"
                    android:gravity="end"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_yt_comment_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#E0E0E0" android:textSize="13sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">
                <ImageButton
                    android:id="@+id/btn_yt_comment_like"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_yt_like"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <TextView
                    android:id="@+id/tv_yt_comment_likes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA" android:textSize="12sp"
                    android:layout_marginEnd="12dp"/>
                <ImageButton
                    android:id="@+id/btn_yt_comment_reply"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_yt_send"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <TextView
                    android:id="@+id/tv_yt_reply_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:textColor="#3EA6FF" android:textSize="12sp"/>
                <ImageButton
                    android:id="@+id/btn_yt_comment_options"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_yt_more"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_yt_comment_replies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

</LinearLayout>
