<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/pv_yt_short"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Right-side action buttons -->
    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="80dp">
        <ImageButton
            android:id="@+id/btn_yt_short_like"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_like"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>
        <TextView
            android:id="@+id/tv_yt_short_likes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="11sp"
            android:gravity="center" android:layout_marginBottom="16dp"/>
        <ImageButton
            android:id="@+id/btn_yt_short_dislike"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_dislike"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>
        <View android:layout_width="0dp" android:layout_height="16dp"/>
        <ImageButton
            android:id="@+id/btn_yt_short_comment"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_comments"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>
        <TextView
            android:id="@+id/tv_yt_short_comments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="11sp"
            android:gravity="center" android:layout_marginBottom="16dp"/>
        <ImageButton
            android:id="@+id/btn_yt_short_share"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>
        <View android:layout_width="0dp" android:layout_height="16dp"/>
        <ImageButton
            android:id="@+id/btn_yt_short_follow"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_subscriptions"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"/>
    </LinearLayout>

    <!-- Bottom title / channel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp"
        android:background="#66000000">
        <TextView
            android:id="@+id/tv_yt_short_channel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>
        <TextView
            android:id="@+id/tv_yt_short_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#E0E0E0" android:textSize="13sp"
            android:maxLines="2" android:ellipsize="end"/>
    </LinearLayout>
</FrameLayout>
