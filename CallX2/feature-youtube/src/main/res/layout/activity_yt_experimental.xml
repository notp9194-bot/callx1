<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_yt_experimental"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/yt_bg"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ Ye features abhi beta mein hain. Bugs ho sakte hain. Enable karo apni responsibility pe."
        android:textColor="#FF9800"
        android:textSize="12sp"
        android:padding="12dp"
        android:background="#1A1200"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Each experimental toggle row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="New Comments UI" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Threaded replies naye design mein" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_new_comments_ui"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Higher Shorts Quality" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shorts 1080p mein stream honge" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_shorts_quality" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ambient Mode" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Player background video ka color reflect karega" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_ambient_mode" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Precise Seeking" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Timeline pe slow-mo preview while scrubbing" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_precise_seeking" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chapter Markers" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Video description se chapters auto detect" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_chapters" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Live Chat Replay" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Old live streams ka chat replay" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_live_chat_replay" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Player Controls" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Redesigned video player" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_new_player_controls" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shorts Camera" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="In-app Shorts recording" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_shorts_camera" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Offline Subtitles" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Captions downloaded ke saath" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_offline_subtitles" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Auto Chapters" android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI se automatic chapter detection" android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_exp_auto_chapters" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/yt_divider"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
