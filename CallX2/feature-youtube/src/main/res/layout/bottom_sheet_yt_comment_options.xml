<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/yt_surface"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_drag_handle"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comment Options"
        android:textColor="@color/yt_text_secondary"
        android:textSize="12sp"
        android:paddingStart="16dp"
        android:paddingBottom="8dp"/>

    <!-- Like Comment -->
    <LinearLayout
        android:id="@+id/btn_yt_comment_like"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_like"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Like karo"
            android:textColor="@color/yt_text_primary"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Report Comment -->
    <LinearLayout
        android:id="@+id/btn_yt_comment_report"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_notifications"
            android:tint="#FF4444"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Report karo"
            android:textColor="#FF4444"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Delete Comment (owner only - shown always, activity will hide if not owner) -->
    <LinearLayout
        android:id="@+id/btn_yt_comment_delete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_yt_dislike"
            android:tint="#FF4444"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="Delete karo"
            android:textColor="#FF4444"
            android:textSize="14sp"/>
    </LinearLayout>

</LinearLayout>
