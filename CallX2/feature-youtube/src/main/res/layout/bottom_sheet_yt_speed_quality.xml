<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/yt_surface"
    android:paddingBottom="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Playback Settings"
            android:textColor="@color/yt_text_primary"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_sq_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_yt_back"
            android:rotation="270"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"
            android:contentDescription="Close"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <!-- Playback Speed -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏱  Playback Speed"
        android:textColor="@color/yt_text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:id="@+id/ll_speed_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
        android:background="@color/yt_divider"/>

    <!-- Video Quality -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📺  Video Quality"
        android:textColor="@color/yt_text_secondary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:id="@+id/ll_quality_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

</LinearLayout>
