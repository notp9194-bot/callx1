<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_yt_shorts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"/>

    <!-- Top bar overlay -->
    <LinearLayout
        android:id="@+id/ll_shorts_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="@drawable/bg_shorts_top_gradient"
        android:elevation="12dp">

        <ImageButton
            android:id="@+id/btn_shorts_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Shorts"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="4dp"/>

        <ImageButton
            android:id="@+id/btn_shorts_search"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Search"/>

        <ImageButton
            android:id="@+id/btn_shorts_camera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_upload"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Upload Short"/>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/pb_shorts_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone"
        android:elevation="14dp"/>

</FrameLayout>
