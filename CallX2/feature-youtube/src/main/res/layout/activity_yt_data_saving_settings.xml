<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_yt_data_saving"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/yt_bg"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="24dp">

            <!-- Data saving mode -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="16dp" android:paddingBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Data saving mode"
                        android:textColor="#FFFFFF" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Automatically adjusts settings to save mobile data"
                        android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_yt_data_saving_mode"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Default settings"
                android:textColor="#AAAAAA" android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="16dp" android:paddingTop="16dp" android:paddingBottom="8dp"/>

            <!-- Reduce video quality -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Reduce video quality"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_reduce_video_quality"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Reduce download quality -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Reduce download quality"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_reduce_download_quality"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Reduce Smart downloads quality -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Reduce Smart downloads quality"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_reduce_smart_downloads"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Only download over Wi-Fi -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Only download over Wi-Fi and unrestricted mobile data"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_wifi_only_downloads"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Upload over Wi-Fi only -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Upload over Wi-Fi only"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_wifi_only_upload"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Muted playback in feeds -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Muted playback in feeds over Wi-Fi only"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_muted_playback_wifi"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#1AFFFFFF"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Data monitoring &amp; control"
                android:textColor="#AAAAAA" android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="16dp" android:paddingTop="16dp" android:paddingBottom="8dp"/>

            <!-- Select quality for every video -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Select quality for every video"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_select_quality_every"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Mobile data usage reminder -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Mobile data usage reminder"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/sw_yt_data_usage_reminder"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
