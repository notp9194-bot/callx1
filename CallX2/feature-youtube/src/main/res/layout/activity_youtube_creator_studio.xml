<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btn_yt_studio_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Creator Studio"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@color/yt_surface"
                    android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tv_yt_studio_views"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Views" android:textColor="#AAAAAA" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@color/yt_surface"
                    android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tv_yt_studio_subs"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Subscribers" android:textColor="#AAAAAA" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@color/yt_surface"
                    android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tv_yt_studio_videos"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Videos" android:textColor="#AAAAAA" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Stats row 2: watch time + likes -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@color/yt_surface"
                    android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/tv_yt_studio_watchtime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0h" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Watch Time" android:textColor="#AAAAAA" android:textSize="11sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@color/yt_surface"
                    android:layout_marginStart="4dp">
                    <TextView android:id="@+id/tv_yt_studio_likes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Likes" android:textColor="#AAAAAA" android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>
            <!-- Quick actions -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Button android:id="@+id/btn_yt_studio_upload"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Upload" android:textColor="#FFFFFF" android:backgroundTint="@color/yt_red"
                    android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_yt_studio_schedule"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Schedule" android:textColor="#FFFFFF" android:backgroundTint="@color/yt_surface"
                    android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_yt_studio_go_live"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Live" android:textColor="#FFFFFF" android:backgroundTint="@color/yt_surface"
                    android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btn_yt_studio_community"
                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                    android:text="Community" android:textColor="#FFFFFF" android:backgroundTint="@color/yt_surface"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Your Videos"
                android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_yt_studio_videos"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
