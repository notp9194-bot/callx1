<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/yt_bg">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_yt_studio_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_yt_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/yt_text_primary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Creator Studio"
            android:textColor="@color/yt_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_yt_studio_upload"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Upload"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/yt_red"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="13sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="4">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:id="@+id/tv_yt_studio_views"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/yt_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Views"
                android:textColor="@color/yt_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:id="@+id/tv_yt_studio_subs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/yt_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subs"
                android:textColor="@color/yt_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A"
            android:padding="10dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:id="@+id/tv_yt_studio_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/yt_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Likes"
                android:textColor="@color/yt_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A"
            android:padding="10dp">
            <TextView
                android:id="@+id/tv_yt_studio_video_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/yt_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Videos"
                android:textColor="@color/yt_text_secondary"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Weekly chart placeholder -->
    <LinearLayout
        android:id="@+id/ll_yt_studio_week_chart"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:gravity="bottom"
        android:weightSum="7"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/yt_divider"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your Videos"
        android:textColor="@color/yt_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:padding="12dp"/>

    <ProgressBar
        android:id="@+id/pb_yt_studio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_yt_studio_videos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
