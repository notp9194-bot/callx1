    <style name="YouTubeActivity.Theme.Player">
        <item name="android:windowBackground">@color/yt_player_bg</item>
        <item name="android:statusBarColor">@color/yt_player_bg</item>
        <item name="android:navigationBarColor">@color/yt_player_bg</item>
    </style>
