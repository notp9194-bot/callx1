<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>

    <application>

        <activity android:name="com.callx.app.home.YouTubeActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize"/>

        <activity android:name="com.callx.app.player.YouTubePlayerActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="sensor"
            android:supportsPictureInPicture="true"
            android:parentActivityName="com.callx.app.home.YouTubeActivity"/>

        <activity android:name="com.callx.app.channel.YouTubeChannelActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:parentActivityName="com.callx.app.home.YouTubeActivity"/>

        <activity android:name="com.callx.app.search.YouTubeSearchActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:windowSoftInputMode="adjustPan"/>

        <activity android:name="com.callx.app.upload.YouTubeUploadActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity android:name="com.callx.app.player.YouTubeCommentsActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <activity android:name="com.callx.app.playlist.YouTubePlaylistActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:parentActivityName="com.callx.app.home.YouTubeActivity"/>

        <!-- NEW: Playlist Create Activity -->
        <activity android:name="com.callx.app.playlist.YouTubePlaylistCreateActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName="com.callx.app.home.YouTubeActivity"/>

        <activity android:name="com.callx.app.channel.YouTubeEditChannelActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName="com.callx.app.channel.YouTubeChannelActivity"/>

        <activity android:name="com.callx.app.downloads.YouTubeDownloadsActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:parentActivityName="com.callx.app.home.YouTubeActivity"/>

        <activity android:name="com.callx.app.library.YouTubeHistoryActivity"
            android:theme="@style/YouTubeActivity.Theme" android:exported="false"
            android:parentActivityName="com.callx.app.home.YouTubeActivity"/>

        <activity android:name="com.callx.app.library.YouTubeLikedVideosActivity"
