<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:background="@color/surface_card"
      android:paddingBottom="24dp">

      <View android:layout_width="40dp" android:layout_height="4dp"
          android:layout_gravity="center_horizontal" android:layout_marginTop="12dp"
          android:layout_marginBottom="16dp" android:background="@drawable/bg_drag_handle"/>

      <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="Disappearing Messages" android:textSize="18sp" android:textStyle="bold"
          android:textColor="?android:attr/textColorPrimary"
          android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="4dp"/>

      <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="Messages will auto-delete after the selected time"
          android:textSize="13sp" android:textColor="?android:attr/textColorSecondary"
          android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="16dp"/>

      <!-- Off -->
      <LinearLayout android:id="@+id/opt_off"
          android:layout_width="match_parent" android:layout_height="52dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:paddingStart="20dp" android:paddingEnd="20dp"
          android:background="?attr/selectableItemBackground">
          <ImageView android:layout_width="24dp" android:layout_height="24dp"
              android:src="@drawable/ic_close" android:tint="#888"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:text="Off" android:textSize="15sp"
              android:textColor="?android:attr/textColorPrimary" android:layout_marginStart="16dp"/>
          <ImageView android:id="@+id/check_off" android:layout_width="20dp" android:layout_height="20dp"
              android:src="@drawable/ic_close" android:visibility="gone"/>
      </LinearLayout>

      <!-- 24 hours -->
      <LinearLayout android:id="@+id/opt_24h"
          android:layout_width="match_parent" android:layout_height="52dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:paddingStart="20dp" android:paddingEnd="20dp"
          android:background="?attr/selectableItemBackground">
          <ImageView android:layout_width="24dp" android:layout_height="24dp"
              android:src="@drawable/ic_info" android:tint="#4CAF50"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:text="24 Hours" android:textSize="15sp"
              android:textColor="?android:attr/textColorPrimary" android:layout_marginStart="16dp"/>
          <ImageView android:id="@+id/check_24h" android:layout_width="20dp" android:layout_height="20dp"
              android:src="@drawable/ic_close" android:visibility="gone"/>
      </LinearLayout>

      <!-- 7 days -->
      <LinearLayout android:id="@+id/opt_7d"
          android:layout_width="match_parent" android:layout_height="52dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:paddingStart="20dp" android:paddingEnd="20dp"
          android:background="?attr/selectableItemBackground">
          <ImageView android:layout_width="24dp" android:layout_height="24dp"
              android:src="@drawable/ic_info" android:tint="#FF9800"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:text="7 Days" android:textSize="15sp"
              android:textColor="?android:attr/textColorPrimary" android:layout_marginStart="16dp"/>
          <ImageView android:id="@+id/check_7d" android:layout_width="20dp" android:layout_height="20dp"
              android:src="@drawable/ic_close" android:visibility="gone"/>
      </LinearLayout>

      <!-- 90 days -->
      <LinearLayout android:id="@+id/opt_90d"
          android:layout_width="match_parent" android:layout_height="52dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:paddingStart="20dp" android:paddingEnd="20dp"
          android:background="?attr/selectableItemBackground">
          <ImageView android:layout_width="24dp" android:layout_height="24dp"
              android:src="@drawable/ic_info" android:tint="#F44336"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:text="90 Days" android:textSize="15sp"
              android:textColor="?android:attr/textColorPrimary" android:layout_marginStart="16dp"/>
          <ImageView android:id="@+id/check_90d" android:layout_width="20dp" android:layout_height="20dp"
              android:src="@drawable/ic_close" android:visibility="gone"/>
      </LinearLayout>
  </LinearLayout>