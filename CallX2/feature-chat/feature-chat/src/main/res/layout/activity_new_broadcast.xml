<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:orientation="vertical">
      <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:background="@drawable/gradient_brand" android:elevation="4dp"
          android:paddingStart="4dp" android:paddingEnd="12dp">
          <ImageButton android:id="@+id/btn_back"
              android:layout_width="44dp" android:layout_height="44dp"
              android:src="@drawable/ic_back" android:tint="#FFFFFF"
              android:background="?attr/selectableItemBackgroundBorderless"/>
          <TextView android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:text="New Broadcast List"
              android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF"
              android:layout_marginStart="4dp"/>
          <Button android:id="@+id/btn_create"
              android:layout_width="wrap_content" android:layout_height="36dp"
              android:text="Create" android:textColor="#FFFFFF"
              android:background="@drawable/bg_rounded_outline"/>
      </LinearLayout>
      <EditText android:id="@+id/et_list_name"
          android:layout_width="match_parent" android:layout_height="52dp"
          android:hint="List ka naam..." android:textSize="15sp"
          android:paddingStart="16dp" android:paddingEnd="16dp"
          android:background="@color/surface_card"
          android:layout_marginBottom="1dp"/>
      <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="Contacts Select Karein" android:textSize="12sp" android:textStyle="bold"
          android:textColor="?android:attr/textColorSecondary"
          android:paddingStart="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"/>
      <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_contacts"
          android:layout_width="match_parent" android:layout_height="0dp"
          android:layout_weight="1"/>
  </LinearLayout>