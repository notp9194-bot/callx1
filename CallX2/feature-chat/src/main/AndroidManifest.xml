<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity android:name="com.callx.app.conversation.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.group.GroupChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.group.GroupInfoActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.group.GroupSettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name="com.callx.app.group.NewGroupActivity"
            android:exported="false"/>
        <activity android:name="com.callx.app.starred.StarredMessagesActivity"
            android:exported="false"
            android:parentActivityName="com.callx.app.conversation.ChatActivity"/>
        <activity android:name="com.callx.app.settings.MutedChatsActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- Feature 13: View Once viewer — FLAG_SECURE, no history -->
        <activity
            android:name=".conversation.ViewOnceViewerActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"
            android:excludeFromRecents="true"
            android:noHistory="true"/>

        <!-- Contact share picker -->
        <activity android:name="com.callx.app.chat.ContactSharePickerActivity"
            android:exported="false"/>

        <!-- Location share picker -->
        <activity android:name="com.callx.app.chat.LocationSharePickerActivity"
            android:exported="false"/>

        <!-- GIF picker (Tenor search) -->
        <activity android:name="com.callx.app.chat.ChatGifPickerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:label="Choose GIF"/>

        <!-- ──────────────────────────────────────────────────────────────
             MEDIA EDITING SYSTEM — comprehensive production-level editors
             ────────────────────────────────────────────────────────────── -->

        <!-- Main photo/video editor: rotate, crop, stickers, text, draw, filters, video trim -->
        <activity android:name="com.callx.app.conversation.controllers.MediaEditActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait"/>

        <!-- Dedicated video trim screen: dual-handle range selector + MediaMuxer trim -->
        <activity android:name="com.callx.app.conversation.controllers.ChatVideoTrimActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"
            android:label="Trim Video"/>

        <!-- Dedicated image crop screen: drag-handle crop + aspect-ratio presets -->
        <activity android:name="com.callx.app.conversation.controllers.ChatImageCropActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:screenOrientation="portrait"
            android:label="Crop Image"/>

        <!-- Full sticker/emoji/text/GIF picker: tabbed, searchable, font picker -->
        <activity android:name="com.callx.app.conversation.controllers.ChatStickerPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait"
            android:label="Add Sticker"/>

    </application>
</manifest>
