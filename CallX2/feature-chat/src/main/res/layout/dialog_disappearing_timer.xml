<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_disappearing_timer.xml
  Bottom sheet: pick disappearing message timer duration.
  Radio group with Off / 5s / 30s / 1min / 1hr / 24hr / 7days
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp"
    android:background="@color/surface">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/handle_bar"
        android:layout_marginBottom="16dp"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Disappearing Messages"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Messages will be deleted after being read"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="20dp"/>

    <!-- Timer options -->
    <RadioGroup
        android:id="@+id/rg_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_off"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Off"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <RadioButton
            android:id="@+id/rb_5s"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="5 seconds  (testing)"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <RadioButton
            android:id="@+id/rb_30s"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="30 seconds"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <RadioButton
            android:id="@+id/rb_1min"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="1 minute"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <RadioButton
            android:id="@+id/rb_1hr"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="1 hour"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <RadioButton
            android:id="@+id/rb_24hr"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="24 hours  ✨ Recommended"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <RadioButton
            android:id="@+id/rb_7days"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="7 days"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:buttonTint="@color/brand_primary"
            android:gravity="center_vertical"
            android:paddingStart="4dp"/>

    </RadioGroup>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/btn_cancel_timer"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="CANCEL"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_set_timer"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="SET"
            android:textColor="@color/brand_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="4dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>
