<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_card"
    android:orientation="vertical"
    android:padding="20dp">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bhejo"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp"/>
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="2">
        <LinearLayout android:id="@+id/opt_gallery" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
            android:padding="12dp" android:background="?attr/selectableItemBackground">
            <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/circle_primary">
                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:layout_gravity="center" android:src="@drawable/ic_gallery"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Photo" android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" android:layout_marginTop="6dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/opt_video" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
            android:padding="12dp" android:background="?attr/selectableItemBackground">
            <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/circle_primary">
                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:layout_gravity="center" android:src="@drawable/ic_video"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Video" android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" android:layout_marginTop="6dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/opt_audio" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
            android:padding="12dp" android:background="?attr/selectableItemBackground">
            <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/circle_primary">
                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:layout_gravity="center" android:src="@drawable/ic_audio"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Audio" android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" android:layout_marginTop="6dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/opt_file" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
            android:padding="12dp" android:background="?attr/selectableItemBackground">
            <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/circle_primary">
                <ImageView android:layout_width="28dp" android:layout_height="28dp"
                    android:layout_gravity="center" android:src="@drawable/ic_file"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="File" android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary" android:layout_marginTop="6dp"/>
        </LinearLayout>
    </GridLayout>
</LinearLayout>
