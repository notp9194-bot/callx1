<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_attach.xml — Premium attach sheet (WhatsApp-style)

    v2: replaced the plain "Bhejo" grid (flat circle_primary icons, no
    depth) with a proper premium layout: drag handle, per-category
    colored icon badges (Gallery/Location/Contact/Document/Poll/Payment
    /Event/AI images) in rounded chip cells, and a full-width Camera
    row at the bottom — matching the reference attach-sheet design.
    Same view IDs kept (opt_gallery, opt_location, opt_contact,
    opt_poll) plus new ones (opt_document, opt_payment, opt_event,
    opt_ai_images, opt_camera) so ChatActivity's existing click
    listeners keep working; opt_audio/opt_multi/opt_sticker/opt_gif
    were folded into Gallery/Document per the new design — wire up
    opt_document to the same file-picker flow opt_file used, and
    opt_camera to the existing camera launcher.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_round"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <!--
        top_content = everything visible in the COLLAPSED state (peekHeight
        is measured off this container's height in ChatMediaController, so
        the sheet opens compact — strip + icon grid + camera row — exactly
        like the reference screenshot). The Recents grid below it only
        becomes visible once the user drags the sheet up past that peek.
    -->
    <LinearLayout
        android:id="@+id/top_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_drag_handle"/>

    <!--
        Recent-media strip: camera tile (position 0, code-side) + last ~30
        gallery thumbnails, horizontal-scroll. Populated by
        RecentMediaStripAdapter off a background MediaStore query — see
        ChatMediaController#showAttachSheet(). Tapping a thumbnail sends
        it straight away (same upload path as the Gallery picker); tapping
        the camera tile opens the camera, same as opt_camera below.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recent_media_strip"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:overScrollMode="never"/>

    <!-- Row 1: Gallery / Location / Contact / Document -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout android:id="@+id/opt_gallery" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_blue">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_gallery"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gallery" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_location" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_green">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_location_pin"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Location" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_contact" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_lightblue">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_person"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Contact" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_document" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_indigo">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_document"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Document" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Row 2: Poll / Payment / Event / AI images -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="4dp">

        <LinearLayout android:id="@+id/opt_poll" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_orange">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_poll"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Poll" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_payment" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_teal">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_payment"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Payment" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_event" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_pink">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_event"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Event" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_ai_images" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_indigo">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_ai_images"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AI images" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Camera — full-width row -->
    <LinearLayout
        android:id="@+id/opt_camera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_attach_camera_row">

        <FrameLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/circle_attach_blue">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:layout_gravity="center" android:src="@drawable/ic_camera"/>
        </FrameLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Camera" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:layout_marginStart="14dp"/>

    </LinearLayout>

    </LinearLayout>
    <!-- /top_content — collapsed (peek) state ends here -->

    <!--
        Expanded "Recents" section — sits below the peek line, so it's
        clipped out of view until the sheet is dragged up past top_content's
        height (peekHeight is set to that in code). GridLayoutManager(4)
        RecyclerView, lazily fed the full recent-media list already loaded
        for the strip above (no second MediaStore query). Plain View cells
        on purpose — this list only lives while the sheet is open, so
        Canvas rendering wouldn't pay for its own complexity here (unlike
        the persistent chat message list, which IS canvas-rendered).
    -->
    <TextView
        android:id="@+id/recents_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:text="Recents"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recents_grid"
        android:layout_width="match_parent"
        android:layout_height="560dp"
        android:clipToPadding="false"
        android:paddingStart="1dp"
        android:paddingEnd="1dp"
        android:overScrollMode="never"/>

    <TextView
        android:id="@+id/recents_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="No recent photos or videos"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone"/>

</LinearLayout>
