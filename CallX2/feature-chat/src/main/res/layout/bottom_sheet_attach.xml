<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_attach.xml — Premium attach sheet (WhatsApp-style)

    v2: replaced the plain "Bhejo" grid (flat circle_primary icons, no
    depth) with a proper premium layout: drag handle, per-category
    colored icon badges (Gallery/Location/Contact/Document/Poll/Payment
    /Event/AI images) in rounded chip cells, and a full-width Camera
    row at the bottom — matching the reference attach-sheet design.
    Same view IDs kept (opt_gallery, opt_location, opt_contact,
    opt_poll) plus new ones (opt_document, opt_payment, opt_event,
    opt_ai_images, opt_camera) so ChatActivity's existing click
    listeners keep working; opt_audio/opt_multi/opt_sticker/opt_gif
    were folded into Gallery/Document per the new design — wire up
    opt_document to the same file-picker flow opt_file used, and
    opt_camera to the existing camera launcher.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_round">

    <LinearLayout
        android:id="@+id/sheet_scroll_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="12dp">

    <!--
        top_content = everything visible in the COLLAPSED state (peekHeight
        is measured off this container's height in ChatMediaController, so
        the sheet opens compact — strip + icon grid + camera row — exactly
        like the reference screenshot). The Recents grid below it only
        becomes visible once the user drags the sheet up past that peek.
    -->
    <LinearLayout
        android:id="@+id/top_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_drag_handle"/>

    <!--
        expanded_header — crossfades IN as the icon grid / strip crossfade
        OUT (see ChatMediaController#setupRecentMedia's BottomSheetBehavior
        BottomSheetCallback). Gone at rest so it takes no space at peek.
    -->
    <LinearLayout
        android:id="@+id/expanded_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        android:alpha="0">

        <ImageView
            android:id="@+id/btn_close_sheet"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"/>

        <!--
            recents_dropdown_row — tapping anywhere on "Recents ▾" opens the
            folder picker popup (see AttachSheetFolderPicker) listing every
            on-device folder (Camera/Videos/Screenshots/Downloads/WhatsApp/…),
            matching the reference screenshot's dropdown. recents_title's text
            is swapped to the picked folder's name once one is chosen.
        -->
        <LinearLayout
            android:id="@+id/recents_dropdown_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingEnd="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/recents_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recents"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Choose folder"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_hd_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HD"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_hd_toggle_inactive"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!--
        icon_grid_section = Row1+Row2 of category chips. Faded out (alpha)
        and collapsed (GONE, to reclaim space for the Recents grid) as the
        sheet is dragged up past peek — see the BottomSheetCallback in
        ChatMediaController. Crossfades against expanded_header above.
    -->
    <LinearLayout
        android:id="@+id/icon_grid_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- Row 1: Gallery / Location / Contact / Document -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout android:id="@+id/opt_gallery" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_blue">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_gallery"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gallery" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_location" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_green">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_location_pin"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Location" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_contact" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_lightblue">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_person"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Contact" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_document" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_indigo">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_document"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Document" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Row 2: Poll / Payment / Event / AI images -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="4dp">

        <LinearLayout android:id="@+id/opt_poll" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_orange">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_poll"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Poll" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_payment" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_teal">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_payment"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Payment" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_event" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginEnd="4dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_pink">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_event"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Event" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/opt_ai_images" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:background="@drawable/bg_attach_chip">
            <FrameLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_attach_indigo">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_ai_images"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AI images" android:textSize="11sp"
                android:textColor="@color/text_primary" android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

    </LinearLayout>
    <!-- /icon_grid_section -->

    </LinearLayout>
    <!-- /top_content — collapsed (peek) state ends here. Peek height is
         computed in code as top_content's height PLUS ~1.5 rows of the
         Recents grid below (see AttachSheetRecentMediaBinder), so the
         collapsed sheet always peeks one full row of thumbnails + half of
         the next row, matching the reference screenshot. -->

    <!--
        Recents grid — camera tile (position 0, added in
        RecentMediaGridAdapter) + recent gallery thumbnails, 4-column
        GridLayoutManager. Sits directly below top_content so the first
        1-2 rows are already visible at the collapsed peek height; dragging
        the sheet up reveals the rest (and pages in more via MediaStore —
        see AttachSheetRecentMediaBinder's infinite-scroll listener).
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recents_grid"
        android:layout_width="match_parent"
        android:layout_height="560dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingStart="1dp"
        android:paddingEnd="1dp"
        android:overScrollMode="never"/>

    <TextView
        android:id="@+id/recents_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="No recent photos or videos"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone"/>

    </LinearLayout>
    <!-- /sheet_scroll_content -->

    <!--
        Selection caption/send bar — floats pinned to the bottom of the
        sheet, over the Recents grid, exactly like WhatsApp/Telegram's
        multi-select bar. GONE + alpha 0 at rest; AttachSheetRecentMediaBinder
        fades/slides it in as soon as MediaSelectionState goes non-empty
        (from either the strip or the grid) and keeps the count badge live.
    -->
    <LinearLayout
        android:id="@+id/selection_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/bg_selection_bar_card"
        android:elevation="8dp"
        android:visibility="gone"
        android:alpha="0">

        <EditText
            android:id="@+id/selection_caption_input"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_selection_caption_pill"
            android:hint="Add a caption…"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"/>

        <!--
            Edit — opens the full-screen photo editor (MediaEditActivity)
            for the current selection before it's sent: rotate/crop,
            stickers, text, freehand draw, and the swipe-up filter carousel
            (None/Pop/B&W/Cool/Chrome/Film). Sits right before the
            view-once/send controls, same position WhatsApp uses for its
            own pencil-edit affordance.
        -->
        <ImageView
            android:id="@+id/btn_selection_edit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit"
            android:clickable="true"
            android:focusable="true"/>

        <!--
            View-once toggle — WhatsApp-style "1-in-a-circle" icon that marks
            the whole selection to be sent as a view-once message (single
            image/video → opens once then deletes; multiple items → grouped
            multi_media message, still one-shot). GONE for surfaces that
            don't support view-once (e.g. group chat — see
            AttachSheetRecentMediaBinder#bind's supportsViewOnce param).
            Tint flips between idle grey and active purple exactly like
            ChatActivity's own btn_view_once input-bar toggle, so the same
            feature reads identically whether triggered from the input bar
            or from here.
        -->
        <ImageView
            android:id="@+id/btn_selection_view_once"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:src="@drawable/ic_view_once"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Send as view once"
            android:clickable="true"
            android:focusable="true"/>

        <FrameLayout
            android:id="@+id/btn_selection_send"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/circle_attach_green">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_send"
                android:contentDescription="Send"/>

            <FrameLayout
                android:id="@+id/selection_send_count_holder"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:layout_margin="-3dp"
                android:background="@drawable/bg_selection_badge">

                <TextView
                    android:id="@+id/selection_send_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>

</FrameLayout>
