<?xml version="1.0" encoding="utf-8"?>
<!--
    Cell in the expanded "Recents" grid (GridLayoutManager, 4 columns).
    The border/line lives on the ROOT FrameLayout, and the thumbnail
    ImageView is inset by 1dp on each side — this matters: if the border
    sat on the ImageView itself, its own centerCrop image content fully
    covers the view's background and the "line" is invisible (this was
    the bug — media looked stuck together with no visible grid). Insetting
    the image lets the root's background color show through the 1dp gap
    on every side, which is what actually reads as a grid line once cells
    sit edge-to-edge.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#33FFFFFF">

    <ImageView
        android:id="@+id/thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="1dp"
        android:background="#2A2A2A"
        android:scaleType="centerCrop"/>

    <TextView
        android:id="@+id/video_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:background="@drawable/bg_video_duration_pill"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:visibility="gone"/>
</FrameLayout>
