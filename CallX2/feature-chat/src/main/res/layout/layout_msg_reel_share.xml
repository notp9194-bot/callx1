<?xml version="1.0" encoding="utf-8"?>
<!-- layout_msg_reel_share.xml — Rich Instagram Reel share card -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_reel_share"
    android:layout_width="@dimen/msg_bubble_max_width"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/bg_reply_preview_sent"
    android:layout_margin="6dp">

    <!-- Header: Instagram logo + username -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <!-- Instagram gradient icon placeholder (a colored circle) -->
        <TextView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text="▶"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#CC000000"
            android:padding="2dp"/>

        <TextView
            android:id="@+id/tv_reel_share_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="7dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="instagram"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reel"
            android:textColor="#E1306C"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="#22E1306C"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>

    </LinearLayout>

    <!-- Reel thumbnail with play button overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp">

        <ImageView
            android:id="@+id/iv_reel_share_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A1A"/>

        <!-- Play button overlay -->
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:text="▶"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#99000000"
            android:padding="4dp"/>

        <!-- "Reel" watermark at bottom-right -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="8dp"
            android:text="⬡  Reels"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"/>

    </FrameLayout>

    <!-- Caption -->
    <TextView
        android:id="@+id/tv_reel_share_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="7dp"
        android:paddingBottom="8dp"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:visibility="gone"/>

</LinearLayout>
