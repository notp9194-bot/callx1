<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_msg_reel_share.xml — Compact bubbleless reel card (Instagram/WhatsApp style).

    • No bubble background — ll_bubble bg is set to null at runtime for reel_share type.
    • 165dp wide × 237dp tall — similar aspect ratio to a vertical reel thumbnail.
    • Rounded corners (12dp) via bg_media_card + clipToOutline.
    • Timestamp + tick overlays from the parent ll_msg_footer (bottom|end in FrameLayout).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_reel_share"
    android:layout_width="165dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/bg_media_card"
    android:clipToOutline="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="237dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/iv_reel_share_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A1A"/>

        <!-- Top gradient — fades thumbnail so avatar/username is readable -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="top"
            android:background="@drawable/gradient_reel_top"/>

        <!-- Bottom gradient — fades thumbnail so caption/label is readable -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_reel_bottom"/>

        <!-- Header: avatar + username -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="7dp">

            <!-- Circular avatar -->
            <ImageView
                android:id="@+id/iv_reel_share_avatar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_avatar_placeholder"
                android:clipToOutline="true"
                android:outlineProvider="bounds"/>

            <TextView
                android:id="@+id/tv_reel_share_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="username"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

        </LinearLayout>

        <!-- Play icon — centered, no background box -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="▶"
            android:textSize="28sp"
            android:textColor="#DDFFFFFF"
            android:shadowColor="#AA000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"/>

        <!-- Bottom: caption + Reels label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="36dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/tv_reel_share_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EEFFFFFF"
                android:textSize="10sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="⬡  Reels"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
