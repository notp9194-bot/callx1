<?xml version="1.0" encoding="utf-8"?>
<!-- layout_msg_reel_share.xml — Compact Instagram-DM style reel bubble -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_reel_share"
    android:layout_width="165dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/bg_reply_preview_sent"
    android:layout_margin="4dp"
    android:clipToOutline="true">

    <!-- Reel thumbnail — tall 9:16 style, compact width -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="225dp">

        <ImageView
            android:id="@+id/iv_reel_share_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A1A"/>

        <!-- Dark gradient overlay at top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="top"
            android:background="@drawable/gradient_reel_top"/>

        <!-- Dark gradient overlay at bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_reel_bottom"/>

        <!-- Username at top-left -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:text="▶"
                android:textSize="7sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="#CC000000"/>

            <TextView
                android:id="@+id/tv_reel_share_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="username"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

        </LinearLayout>

        <!-- Play button center -->
        <TextView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="center"
            android:text="▶"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#88000000"
            android:padding="4dp"/>

        <!-- Caption + Reels watermark at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_reel_share_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#EEFFFFFF"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="⬡  Reels"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
