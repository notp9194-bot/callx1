<?xml version="1.0" encoding="utf-8"?>
<!-- layout_msg_reel_share.xml — Instagram-style bubbleless reel card v6 -->
<!-- No bubble background. Card = thumbnail + overlays. Time+tick = corner overlay. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_reel_share"
    android:layout_width="160dp"
    android:layout_height="220dp"
    android:clickable="true"
    android:focusable="true"
    android:clipToOutline="true"
    android:outlineProvider="background"
    android:elevation="2dp"
    android:background="@drawable/bg_reel_card_shape">

    <!-- Thumbnail fills entire card -->
    <ImageView
        android:id="@+id/iv_reel_share_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#1A1A1A"/>

    <!-- Top gradient for header legibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_reel_top"/>

    <!-- Bottom gradient for caption + time legibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_reel_bottom"/>

    <!-- Header: avatar + username (top-left) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="7dp">

        <ImageView
            android:id="@+id/iv_reel_share_avatar"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_avatar_placeholder"
            android:clipToOutline="true"
            android:outlineProvider="bounds"/>

        <TextView
            android:id="@+id/tv_reel_share_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="username"
            android:shadowColor="#BB000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3"/>

    </LinearLayout>

    <!-- Center play icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="▶"
        android:textSize="26sp"
        android:textColor="#DDFFFFFF"
        android:shadowColor="#AA000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="6"/>

    <!-- Bottom section: caption + Reels label + time+tick row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tv_reel_share_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#EEFFFFFF"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"
            android:shadowColor="#AA000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3"/>

        <!-- Reels label + time+tick in one row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⬡  Reels"
                android:textColor="#CCFFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"/>

            <!-- Time + tick overlay (Instagram style: bottom-right corner of card) -->
            <LinearLayout
                android:id="@+id/ll_reel_time_tick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_time_pill"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/tv_reel_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"/>

                <TextView
                    android:id="@+id/tv_reel_tick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textSize="9sp"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
