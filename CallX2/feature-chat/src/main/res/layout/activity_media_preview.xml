<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_media_preview.xml
  Full-screen media preview before sending.
  Layout adapts based on media type (image / video / audio).
  keyboard: adjustResize so caption bar stays above keyboard.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ═══ TOP TOOLBAR ═══ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="#CC000000"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tv_send_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send to"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_media_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BBBBBB"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Compress toggle (image only) -->
        <TextView
            android:id="@+id/btn_compress"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⚡ Compressed"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"
            android:background="@drawable/bg_rounded_outline"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ═══ IMAGE CONTAINER ═══ -->
    <FrameLayout
        android:id="@+id/image_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_bar"
        android:layout_below="@id/toolbar"
        android:visibility="gone">

        <!-- PhotoView would be used here for pinch-zoom.
             Fallback: standard ImageView with CENTER_INSIDE scaling.
             Add 'com.github.chrisbanes:PhotoView:2.3.0' for pinch-zoom. -->
        <ImageView
            android:id="@+id/iv_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"/>

    </FrameLayout>

    <!-- ═══ VIDEO CONTAINER ═══ -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_bar"
        android:layout_below="@id/toolbar"
        android:visibility="gone">

        <VideoView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"/>

        <!-- Play/pause overlay icon -->
        <ImageView
            android:id="@+id/iv_play_overlay"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            android:tint="#CCFFFFFF"
            android:visibility="gone"/>

        <!-- Video controls bar (bottom of video) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#88000000"
            android:padding="8dp">

            <SeekBar
                android:id="@+id/seek_video"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/brand_primary"
                android:thumbTint="@color/brand_primary"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:id="@+id/tv_video_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:text="0:00 / 0:00"/>

                <ImageButton
                    android:id="@+id/btn_mute_video"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_volume_on"
                    android:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Mute/Unmute"/>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ═══ AUDIO CONTAINER ═══ -->
    <LinearLayout
        android:id="@+id/audio_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_bar"
        android:layout_below="@id/toolbar"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <!-- Mic icon -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_mic"
            android:tint="@color/brand_primary"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tv_audio_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <SeekBar
            android:id="@+id/seek_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/brand_primary"
            android:thumbTint="@color/brand_primary"
            android:layout_marginBottom="24dp"/>

        <ImageButton
            android:id="@+id/btn_play_audio"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_play"
            android:tint="@color/white"
            android:background="@drawable/circle_primary"
            android:padding="16dp"
            android:contentDescription="Play/Pause"/>

    </LinearLayout>

    <!-- ═══ BOTTOM BAR (Reply preview + Caption + Send) ═══ -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="#CC000000">

        <!-- Reply preview (shown only when replying) -->
        <LinearLayout
            android:id="@+id/layout_reply_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#33FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <!-- Left accent bar -->
            <View
                android:layout_width="3dp"
                android:layout_height="36dp"
                android:background="@color/brand_primary"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_reply_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_reply_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_close_reply"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:tint="#AAFFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Remove reply"/>

        </LinearLayout>

        <!-- Caption input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Caption field -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_comment_input"
                android:paddingStart="12dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginEnd="8dp">

                <EditText
                    android:id="@+id/et_caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Add a caption..."
                    android:hintTextColor="#88FFFFFF"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:background="@null"
                    android:maxLines="4"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="actionNone"/>

                <TextView
                    android:id="@+id/tv_caption_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AA888888"
                    android:textSize="10sp"
                    android:layout_gravity="end"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Send button -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <ImageButton
                    android:id="@+id/btn_send"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_send_fill"
                    android:tint="@color/white"
                    android:background="@drawable/circle_primary"
                    android:padding="14dp"
                    android:contentDescription="Send"/>

                <ProgressBar
                    android:id="@+id/progress_send"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    android:progressTint="@color/white"/>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
