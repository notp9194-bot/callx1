<?xml version="1.0" encoding="utf-8"?>
<!-- Compact row in the "/" suggestion strip shown above the keyboard -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:minWidth="80dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true" android:focusable="true">

    <TextView android:id="@+id/tv_bot_cmd"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="/help" android:textColor="@color/brand_primary"
        android:textSize="13sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tv_bot_desc"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Show commands"
        android:textColor="@color/text_muted" android:textSize="11sp"
        android:maxLines="1" android:ellipsize="end"/>
</LinearLayout>
