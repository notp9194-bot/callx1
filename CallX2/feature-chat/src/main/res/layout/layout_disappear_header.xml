<?xml version="1.0" encoding="utf-8"?>
<!--
  layout_disappear_header.xml
  Subtle banner shown below chat toolbar when disappearing messages are ON.

  Shows: ⏳ [timer label]   (e.g. "⏳ 24 hours")
  Tap → opens DisappearingTimerDialog to change/disable

  Include in activity_chat.xml below the main toolbar:
    <include layout="@layout/layout_disappear_header"
             android:id="@+id/disappear_header"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:visibility="gone"/>
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_disappear_header"
    android:layout_width="match_parent"
    android:layout_height="32dp"
    android:orientation="horizontal"
    android:gravity="center"
    android:background="#FFF3CD"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <!-- Animated hourglass icon -->
    <ImageView
        android:id="@+id/iv_hourglass"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_hourglass"
        android:tint="#856404"
        android:layout_marginEnd="6dp"/>

    <TextView
        android:id="@+id/tv_disappear_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disappearing messages: 24 hours"
        android:textColor="#856404"
        android:textSize="12sp"
        android:textStyle="bold"/>

    <ImageView
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/ic_edit"
        android:tint="#856404"
        android:layout_marginStart="6dp"
        android:alpha="0.7"/>

</LinearLayout>
