<?xml version="1.0" encoding="utf-8"?>
<!-- Small popup chat window — opened from a notification tap when the user
     is NOT already on that chat's ChatActivity. Sits centered/bottom over
     whatever screen they were on, lets them read + reply right there,
     with a button to jump into the full ChatActivity if they want more. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_popup_card"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="18dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header: avatar + name + close + expand-to-full-chat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/brand_primary"
                android:padding="12dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_popup_avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person"/>

                <TextView
                    android:id="@+id/tv_popup_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <ImageButton
                    android:id="@+id/btn_popup_expand"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="135"
                    app:tint="#FFFFFF"
                    android:contentDescription="Open full chat"/>

                <ImageButton
                    android:id="@+id/btn_popup_close"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    android:rotation="180"
                    app:tint="#FFFFFF"
                    android:contentDescription="Close"/>
            </LinearLayout>

            <!-- Mini message list — last N messages, both directions -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_popup_messages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <!-- Mini input bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <EditText
                    android:id="@+id/et_popup_message"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Message"
                    android:maxLines="3"
                    android:background="@drawable/bg_search_field"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:textSize="14sp"/>

                <ImageButton
                    android:id="@+id/btn_popup_send"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_btn_primary"
                    android:src="@drawable/ic_send"
                    app:tint="#FFFFFF"
                    android:contentDescription="Send"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
