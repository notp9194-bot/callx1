<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Selection action bar (visible on long-press) -->
        <LinearLayout
            android:id="@+id/ll_selection_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/brand_primary"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <!-- Cancel button -->
            <TextView
                android:id="@+id/btn_cancel_selection_chats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:paddingStart="4dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Selected count -->
            <TextView
                android:id="@+id/tv_selected_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="0 selected"/>

            <!-- Select All -->
            <TextView
                android:id="@+id/btn_select_all_chats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Delete selected -->
            <ImageView
                android:id="@+id/btn_delete_selected_chats"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_delete"
                android:tint="#FFCDD2"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Delete selected"/>

        </LinearLayout>

        <!-- Request banner (hidden by default) -->
        <LinearLayout
            android:id="@+id/banner_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_request_banner"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_person_add"
                android:padding="8dp"
                android:background="@drawable/bg_circle_white"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_request_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Naye contact requests"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_request_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap karke dekho"
                    android:textColor="#E0E7FF"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_request_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="28dp"
                android:gravity="center"
                android:padding="6dp"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:background="@drawable/bg_circle_white"/>
        </LinearLayout>

        <!-- New broadcast entry row (WhatsApp-style, always visible above chat list) -->
        <LinearLayout
            android:id="@+id/row_new_broadcast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_status_notification"
                android:padding="8dp"
                android:background="@drawable/circle_primary"
                app:tint="@color/white"
                android:contentDescription="New broadcast"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="New broadcast"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chats"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abhi koi chat nahi hai"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Niche FAB se naye contact ko search karke jodo"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</FrameLayout>
