<?xml version="1.0" encoding="utf-8"?>
<!-- Poll feature (modernized) — one editable option row in the Create Poll
     sheet. Bordered field to match bg_poll_input_field used elsewhere in
     the sheet; remove button is a quiet circular icon rather than a bare X. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <EditText
        android:id="@+id/et_poll_option"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="Option"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:maxLines="1"
        android:inputType="textCapSentences"
        android:background="@drawable/bg_poll_input_field"
        android:padding="11dp"/>

    <ImageView
        android:id="@+id/btn_remove_poll_option"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="6dp"
        android:padding="8dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/bg_poll_icon_badge"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Remove option"/>

</LinearLayout>
