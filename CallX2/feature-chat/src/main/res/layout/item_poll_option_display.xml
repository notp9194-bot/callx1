<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fl_poll_option_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_poll_option"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Fill bar showing vote percentage; width set programmatically -->
    <View
        android:id="@+id/v_poll_option_fill"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_poll_option_fill"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_poll_option_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\u2713"
            android:textColor="@color/brand_primary"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginEnd="6dp"
            android:visibility="invisible"/>

        <TextView
            android:id="@+id/tv_poll_option_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorPrimary"/>

        <TextView
            android:id="@+id/tv_poll_option_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</FrameLayout>
