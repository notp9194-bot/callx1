<?xml version="1.0" encoding="utf-8"?>
<!-- activity_message_info.xml — Message Info screen (v22) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bar_background"
        android:elevation="4dp"
        android:title="Message Info"
        android:titleTextColor="@color/bar_on_background"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── Message Preview Card ──────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Message"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="6dp"/>

                    <!-- Message text preview -->
                    <TextView
                        android:id="@+id/tv_preview_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="2dp"
                        android:visibility="gone"/>

                    <!-- Media preview (image/video) -->
                    <ImageView
                        android:id="@+id/iv_preview_media"
                        android:layout_width="120dp"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        android:background="#1A000000"
                        android:visibility="gone"/>

                    <!-- Audio/File preview label -->
                    <TextView
                        android:id="@+id/tv_preview_media_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:drawablePadding="8dp"
                        android:visibility="gone"/>

                    <!-- Sent time -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sent"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/tv_sent_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─── Status Summary Row ────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="16dp">

                    <!-- Sent tick -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_single_tick"
                            android:scaleType="fitCenter"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sent"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Delivered tick -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_double_tick"
                            android:scaleType="fitCenter"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivered"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:id="@+id/tv_delivered_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Read tick -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_double_tick_blue"
                            android:scaleType="fitCenter"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Read"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="4dp"/>
                        <TextView
                            android:id="@+id/tv_read_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="#4FC3F7"
                            android:layout_marginTop="2dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ─── Read By section (group chats) ─────────────────────── -->
            <TextView
                android:id="@+id/tv_read_by_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="READ BY"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:paddingStart="4dp"
                android:paddingBottom="8dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_read_by"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- ─── Delivered To section (group chats) ─────────────────── -->
            <TextView
                android:id="@+id/tv_delivered_by_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DELIVERED TO"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:paddingStart="4dp"
                android:paddingBottom="8dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_delivered_to"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- Empty state (1:1 chat, not yet delivered/read) -->
            <LinearLayout
                android:id="@+id/ll_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_double_tick"
                    android:alpha="0.3"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not yet delivered"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
