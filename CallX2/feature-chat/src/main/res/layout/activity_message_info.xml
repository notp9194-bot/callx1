<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_message_info.xml  (v2 — performance-optimised)
  ─────────────────────────────────────────────────────────
  CHANGES from v1:
  • Root LinearLayout kept (minimal change for build safety) but all
    unnecessary nesting in the status-row card replaced with a flat
    ConstraintLayout, reducing the measure/layout pass count from 2-3
    nested LinearLayout passes to a single flat pass for that section.
  • android:saveEnabled="false" on the ScrollView and its direct child —
    skips the O(n) child-state traversal at onSaveInstanceState time;
    scroll position is managed programmatically.
  • android:layerType="none" on the status card LinearLayout — ensures no
    stray software layer (the theme can sometimes inject one for elevation).
  • fillViewport="true" on the ScrollView so the body fills the screen
    on short chats (no "floating" status card on a large phone).
  • Visible views set VISIBLE by default where possible; GONE only when the
    Java logic hides them.  This avoids a measure pass before the first
    visibility change fires.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <!-- ── Toolbar ──────────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_msg_info"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bar_background"
        android:elevation="4dp"
        android:saveEnabled="false"
        app:title="Message info"
        app:titleTextColor="@color/bar_on_background"
        app:navigationIcon="@drawable/ic_back"
        app:navigationContentDescription="Back" />

    <!-- ── Scrollable body ──────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:saveEnabled="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:saveEnabled="false">

            <!-- ── Message preview (chat-wallpaper tinted area) ─────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_chat_bg"
                android:paddingTop="24dp"
                android:paddingBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minHeight="140dp"
                android:saveEnabled="false">

                <!--
                  Text / Audio / File bubble — shown for non-media types.
                  android:visibility="gone" here; showTextBubble() makes it VISIBLE.
                -->
                <LinearLayout
                    android:id="@+id/ll_text_bubble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:maxWidth="280dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_msg_info_text_bubble"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:saveEnabled="false"
                    android:visibility="gone">

                    <!-- Forwarded label (gone by default) -->
                    <TextView
                        android:id="@+id/tv_forwarded_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↪ Forwarded"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:textColor="#888888"
                        android:layout_marginBottom="4dp"
                        android:saveEnabled="false"
                        android:visibility="gone" />

                    <!-- File / Audio icon row (gone by default) -->
                    <LinearLayout
                        android:id="@+id/ll_file_row"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp"
                        android:saveEnabled="false"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_file_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📎"
                            android:textSize="28sp"
                            android:saveEnabled="false" />

                        <TextView
                            android:id="@+id/tv_file_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/bubble_sent_text"
                            android:textSize="13sp"
                            android:maxWidth="200dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:saveEnabled="false"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Message body text (gone by default) -->
                    <TextView
                        android:id="@+id/tv_msg_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bubble_sent_text"
                        android:textSize="15sp"
                        android:lineSpacingExtra="2dp"
                        android:saveEnabled="false"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Image / Video / Sticker / Media-group preview (gone by default) -->
                <FrameLayout
                    android:id="@+id/fl_media_preview"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_media_card"
                    android:clipToOutline="true"
                    android:saveEnabled="false"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/iv_msg_media"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Media preview"
                        android:saveEnabled="false" />

                    <!-- Video play-icon overlay (gone by default) -->
                    <ImageView
                        android:id="@+id/iv_play_overlay"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play"
                        android:alpha="0.85"
                        android:saveEnabled="false"
                        android:visibility="gone"
                        android:contentDescription="Play video" />

                    <!-- Media-group count badge, e.g. "+3" (gone by default) -->
                    <TextView
                        android:id="@+id/tv_media_count_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_media_timestamp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:saveEnabled="false"
                        android:visibility="gone" />

                    <!-- Forwarded badge over media (gone by default) -->
                    <TextView
                        android:id="@+id/tv_media_forwarded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_media_timestamp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="↪ Forwarded"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:saveEnabled="false"
                        android:visibility="gone" />

                </FrameLayout>

            </FrameLayout>

            <!-- Full-width divider between preview and status rows -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:saveEnabled="false" />

            <!-- ── Status rows ─────────────────────────────────────────
                 Flat ConstraintLayout replaces the old nested LinearLayout
                 card.  A single measure pass now covers all three rows +
                 their dividers, vs. 2-3 passes in the old structure.
            ─────────────────────────────────────────────────────────── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_card"
                android:layerType="none"
                android:saveEnabled="false">

                <!-- ── Seen row (blue ✓✓) — gone until status = read ── -->
                <LinearLayout
                    android:id="@+id/ll_row_seen"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical"
                    android:saveEnabled="false"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_info_double_tick_blue"
                        android:contentDescription="Seen"
                        android:saveEnabled="false" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="18dp"
                        android:saveEnabled="false">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seen"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:saveEnabled="false" />

                        <TextView
                            android:id="@+id/tv_seen_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp"
                            android:saveEnabled="false" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Seen / Delivered divider (gone by default) -->
                <View
                    android:id="@+id/divider_seen_delivered"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="60dp"
                    android:background="@color/divider"
                    android:saveEnabled="false"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/ll_row_seen"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- ── Delivered row (grey ✓✓) — gone by default ── -->
                <LinearLayout
                    android:id="@+id/ll_row_delivered"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical"
                    android:saveEnabled="false"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/divider_seen_delivered"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_info_double_tick_grey"
                        android:contentDescription="Delivered"
                        android:saveEnabled="false" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="18dp"
                        android:saveEnabled="false">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivered"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:saveEnabled="false" />

                        <TextView
                            android:id="@+id/tv_delivered_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp"
                            android:saveEnabled="false" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Delivered / Sent divider (gone by default) -->
                <View
                    android:id="@+id/divider_delivered_sent"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginStart="60dp"
                    android:background="@color/divider"
                    android:saveEnabled="false"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/ll_row_delivered"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- ── Sent row (grey ✓) — always visible ─────────── -->
                <LinearLayout
                    android:id="@+id/ll_row_sent"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:gravity="center_vertical"
                    android:saveEnabled="false"
                    app:layout_constraintTop_toBottomOf="@id/divider_delivered_sent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_info_single_tick_grey"
                        android:contentDescription="Sent"
                        android:saveEnabled="false" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="18dp"
                        android:saveEnabled="false">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sent"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:saveEnabled="false" />

                        <TextView
                            android:id="@+id/tv_sent_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="1dp"
                            android:saveEnabled="false" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bottom divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:saveEnabled="false" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
