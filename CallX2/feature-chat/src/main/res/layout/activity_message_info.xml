<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_message_info.xml
    Dedicated Message Info Screen — shows sent/delivered/read timestamps,
    edit history, media details, and group read receipts.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── SENT TIME ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:elevation="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENT"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_sent_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── STATUS ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── DELIVERED AT (1-on-1 only) ─────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_delivered_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DELIVERED"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_delivered_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── READ AT (1-on-1 only) ──────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_read_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READ"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_read_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── MESSAGE TYPE ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:layout_marginTop="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:elevation="1dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TYPE"
                    android:textSize="11sp"
                    android:textColor="#9E9E9E"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tv_msg_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ── MEDIA META (size + duration) ──────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_media_meta_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDIA DETAILS"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_media_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── EDITED AT ──────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_edited_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:layout_marginTop="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDITED AT"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_edited_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textColor="#212121"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── GROUP SECTION: Delivered To + Read By ─────────────────── -->
        <LinearLayout
            android:id="@+id/ll_group_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Read By -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READ BY"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_read_by_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No one has read this yet"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:background="@android:color/white"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_read_by"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

            <!-- Delivered To -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DELIVERED TO"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_delivered_to_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not delivered yet"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:background="@android:color/white"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_delivered_to"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
