<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/brand_primary"
        android:title="New Post"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Announcement toggle -->
            <CheckBox
                android:id="@+id/cb_announcement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post as announcement"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <!-- Post text -->
            <EditText
                android:id="@+id/et_post_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:hint="What's on your mind? Use @ to mention someone"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top|start"
                android:background="@color/surface_card"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_primary"/>

            <!-- @mention suggestions popup -->
            <LinearLayout
                android:id="@+id/layout_mention_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_card"
                android:elevation="4dp"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_mention_suggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="200dp"/>

            </LinearLayout>

            <!-- Selected media preview -->
            <LinearLayout
                android:id="@+id/layout_selected_media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp">

                    <ImageView
                        android:id="@+id/iv_media_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@color/surface_input"
                        android:contentDescription="Media preview"
                        android:visibility="gone"/>

                </FrameLayout>

            </LinearLayout>

            <!-- Attach row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btn_add_media"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷 Add Media"
                    android:textColor="@color/colorPrimary"
                    style="?attr/borderlessButtonStyle"/>

                <Button
                    android:id="@+id/btn_add_poll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Add Poll"
                    android:textColor="@color/colorPrimary"
                    style="?attr/borderlessButtonStyle"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Submit row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_schedule"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Schedule"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_post"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Post"/>

    </LinearLayout>

</LinearLayout>
