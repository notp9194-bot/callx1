<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_chat_bg"
    android:orientation="vertical">

    <!-- WhatsApp-style Chat Header -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bar_background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <!-- Avatar (clickable to open profile) -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_partner_avatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_person"
            android:layout_marginStart="2dp"
            android:clickable="true"
            android:focusable="true"
            app:civ_border_width="1.5dp"
            app:civ_border_color="#80FFFFFF"/>

        <!-- Name + status/typing (fills remaining space) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_partner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Name"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Online / last-seen status only — typing no longer shown here,
                 see ll_typing_strip floating banner over the message list. -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C7D2FE"
                android:textSize="10sp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Reel button — patli rassi se latakta hua, hawa mein jhulta -->
        <!-- Pura container: rassi + button ek saath upar se neeche -->
        <LinearLayout
            android:id="@+id/ll_reel_hanging"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="3dp"
            android:translationY="-4dp">

            <!-- Patli rassi (thin string from top of header) -->
            <View
                android:id="@+id/view_reel_thread"
                android:layout_width="1.5dp"
                android:layout_height="8dp"
                android:background="@drawable/ic_reel_thread"
                android:layout_gravity="center_horizontal"/>

            <!-- Reel button itself — jhulta hua -->
            <ImageButton
                android:id="@+id/btn_toolbar_reel"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_reels"
                android:tint="@color/white"
                android:background="@drawable/bg_social_reel_btn"
                android:padding="6dp"
                android:contentDescription="View Reels Profile"/>

        </LinearLayout>

        <!-- X button -->
        <ImageButton
            android:id="@+id/btn_toolbar_x"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_x_logo"
            android:tint="@color/white"
            android:background="@drawable/bg_social_x_btn"
            android:padding="6dp"
            android:layout_marginEnd="3dp"
            android:contentDescription="View X Profile"/>

        <!-- YouTube button -->
        <ImageButton
            android:id="@+id/btn_toolbar_youtube"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_youtube"
            android:tint="@color/white"
            android:background="@drawable/bg_social_youtube_btn"
            android:padding="6dp"
            android:layout_marginEnd="1dp"
            android:contentDescription="View YouTube Channel"/>

        <!-- Video call button -->
        <ImageButton
            android:id="@+id/btn_toolbar_video_call"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_video_call"
            android:tint="@color/white"
            android:background="@null"
            android:padding="6dp"
            android:contentDescription="Video call"/>

        <!-- Voice call button -->
        <ImageButton
            android:id="@+id/btn_toolbar_voice_call"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_phone"
            android:tint="@color/white"
            android:background="@null"
            android:padding="7dp"
            android:contentDescription="Voice call"/>

        <!-- More options (3-dot menu) -->
        <ImageButton
            android:id="@+id/btn_more_options"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"/>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         MULTI-SELECT TOOLBAR (WhatsApp style) — visibility=gone by default
         Shows on top replacing normal toolbar feel when messages selected
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_selection_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bar_background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <!-- Cancel / Close selection -->
        <ImageButton
            android:id="@+id/btn_selection_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel selection"/>

        <!-- Selected count -->
        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <!-- Reply -->
        <ImageButton
            android:id="@+id/btn_selection_reply"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_reply"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Reply"/>

        <!-- Star -->
        <ImageButton
            android:id="@+id/btn_selection_star"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Star"/>

        <!-- Info — single select only -->
        <ImageButton
            android:id="@+id/btn_selection_info"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_info"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Info"/>

        <!-- Delete -->
        <ImageButton
            android:id="@+id/btn_selection_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Delete"/>

        <!-- Forward -->
        <ImageButton
            android:id="@+id/btn_selection_forward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_forward"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Forward"/>

    </LinearLayout>

    <!-- Offline banner -->
    <TextView
        android:id="@+id/tv_offline_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No internet — showing cached messages"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#CC5500"
        android:visibility="gone"/>

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/ll_search_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="8dp"/>
        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search messages…"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"/>
        <TextView
            android:id="@+id/tv_search_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone"/>
        <ImageButton
            android:id="@+id/btn_search_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="90"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous result"
            android:visibility="gone"/>
        <ImageButton
            android:id="@+id/btn_search_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="270"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next result"
            android:visibility="gone"/>
        <ImageButton
            android:id="@+id/btn_close_search"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close search"/>
    </LinearLayout>

    <!-- Pinned message banner -->
    <LinearLayout
        android:id="@+id/ll_pinned_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 Pinned Message"
                android:textColor="#E65100"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_pinned_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
        <ImageButton
            android:id="@+id/btn_unpin"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Unpin"/>
    </LinearLayout>

    <!-- Scheduled messages banner — shows count of pending scheduled sends -->
    <LinearLayout
        android:id="@+id/ll_scheduled_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ Scheduled"
                android:textColor="#1565C0"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_scheduled_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#555555"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_timer"
            app:tint="#1565C0"/>
    </LinearLayout>

    <!-- FrameLayout wraps shimmer + RecyclerView + FAB "back to latest" -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Chat Wallpaper Background Image -->
        <ImageView
            android:id="@+id/iv_chat_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Chat wallpaper"/>

        <!-- Shimmer skeleton -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <include layout="@layout/layout_skeleton_chat"/>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- Messages list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- FIX [P3-4]: Empty chat state — no messages yet -->
        <LinearLayout
            android:id="@+id/ll_empty_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👋"
                android:textSize="56sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Say hello!"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No messages yet. Send the first one!"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             SCREENSHOT BANNER — Snapchat-style red pill that slides in
             from the top when the partner takes a screenshot of this chat.
             Shows: [avatar] "Rahul ne screenshot liya 📸"
             Auto-hides after 3 s with a slide-up + fade-out.
             Driven by ChatScreenshotNotifier#showScreenshotBanner.
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/ll_screenshot_banner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_screenshot_banner"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:visibility="gone">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_screenshot_avatar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                app:civ_border_width="1.5dp"
                app:civ_border_color="#FFCCCC"/>

            <!-- Camera flash icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="📸"
                android:textSize="13sp"
                android:importantForAccessibility="no"/>

            <TextView
                android:id="@+id/tv_screenshot_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="200dp"
                android:text="ne screenshot liya"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             PARTNER / MEMBERS "WATCHING" BANNER — appears when someone
             currently has THIS chat screen open &amp; foregrounded. Avatar(s)
             zoom in 0dp → 48dp, name(s) shown below in a vibrant highlight
             strip. Does NOT touch the normal online/last-seen status line.
             Floats ON TOP of the message list (instead of its own row above
             it) so the chat area behind it stays full height — messages
             don't get squeezed when the banner pops in/out.

             1:1 chats (ChatPresenceController) only ever touch
             iv_watching_avatar + tv_watching_name — iv_watching_avatar2 and
             tv_watching_more stay gone, so the banner looks identical to
             before. Group chats (GroupWatchingController) additionally use
             iv_watching_avatar2 (2nd watcher, overlapping) and
             tv_watching_more ("+N" badge) for 3+ watchers, e.g.
             "Asha, Ravi aur 2 others dekh rahe hain".
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/ll_watching_banner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:foreground="?attr/selectableItemBackground"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/ll_watching_avatars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_watching_avatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="2dp"
                    app:civ_border_color="#22C55E"/>

                <!-- Group only: 2nd watcher's avatar, overlaps 1st -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_watching_avatar2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="-14dp"
                    android:src="@drawable/ic_person"
                    android:visibility="gone"
                    app:civ_border_width="2dp"
                    app:civ_border_color="#22C55E"/>

                <!-- Group only: "+N" badge when 3+ members are watching -->
                <TextView
                    android:id="@+id/tv_watching_more"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="-14dp"
                    android:background="@drawable/bg_watching_more_badge"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_watching_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_watching_strip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="aapko dekh rha hai"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             TYPING STRIP — floats bottom-left over the message list while
             the partner (1:1) or any member (group) is typing. Same vibrant
             gradient pill language as ll_watching_banner above, but anchored
             bottom|start instead of top|center so it never collides with it,
             and carries its own avatar + animated 3-dot indicator instead of
             reusing the toolbar's old plain-text tv_typing line.

             1:1 chats: iv_typing_avatar + tv_typing_name show the partner.
             Group chats: same views, but tv_typing_name renders either
             "Asha typing…" (1 typer) or "Asha, Ravi typing…" (2+, names
             joined — GroupTypingController truncates/pluralizes for 3+).
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/ll_typing_strip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_watching_strip"
            android:paddingStart="6dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_typing_avatar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                app:civ_border_width="1dp"
                app:civ_border_color="#80FFFFFF"/>

            <TextView
                android:id="@+id/tv_typing_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="180dp"
                android:text="typing"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <!-- Animated 3-dot indicator — each dot's alpha/translationY is
                 pulsed on a staggered loop from TypingDotsAnimator. -->
            <LinearLayout
                android:id="@+id/ll_typing_dots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/dot_typing_1"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

                <View
                    android:id="@+id/dot_typing_2"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginStart="3dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

                <View
                    android:id="@+id/dot_typing_3"
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:layout_marginStart="3dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             VOICE RECORDING INDICATOR — "Rahul is recording a voice
             message 🎙️" — the audio-version of the typing strip. Shows
             when the partner is actively holding the mic button and
             recording a voice note. Uses the same pill style as
             ll_typing_strip but with a pulsing mic icon + waveform bar
             instead of the three bouncing dots.
             Driven by ChatPresenceController#watchPartnerRecording.
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/ll_voice_recording_strip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="10dp"
            android:layout_marginBottom="54dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_watching_strip"
            android:paddingStart="6dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_recording_avatar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_person"
                app:civ_border_width="1dp"
                app:civ_border_color="#80FFFFFF"/>

            <!-- Pulsing mic icon (alpha-animated by ChatPresenceController) -->
            <ImageView
                android:id="@+id/iv_recording_mic"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="7dp"
                android:src="@drawable/ic_mic"
                android:tint="#FFFFFF"
                android:importantForAccessibility="no"/>

            <TextView
                android:id="@+id/tv_recording_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="160dp"
                android:text="recording…"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <!-- Mini waveform: 5 bars of alternating heights, alpha-looped -->
            <LinearLayout
                android:id="@+id/ll_recording_waveform"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/bar_wave_1"
                    android:layout_width="3dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

                <View
                    android:id="@+id/bar_wave_2"
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

                <View
                    android:id="@+id/bar_wave_3"
                    android:layout_width="3dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

                <View
                    android:id="@+id/bar_wave_4"
                    android:layout_width="3dp"
                    android:layout_height="13dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

                <View
                    android:id="@+id/bar_wave_5"
                    android:layout_width="3dp"
                    android:layout_height="6dp"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="#FFFFFF"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             LIVE TYPING PREVIEW BOX — bottom-left, shows the partner's
             in-progress message text EXACTLY as they type/delete it,
             character by character, before they hit send. Sits just above
             the input bar so it never overlaps ll_typing_strip's avatar
             pill (that one shows WHO is typing; this one shows WHAT).
             Driven by ChatLiveTypingController. ══════════════════════════ -->
        <LinearLayout
            android:id="@+id/ll_live_typing_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="70dp"
            android:layout_marginBottom="66dp"
            android:orientation="vertical"
            android:background="@drawable/bg_watching_strip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_live_typing_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="typing live"
                android:textColor="#C7D2FE"
                android:textSize="9sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_live_typing_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxWidth="220dp"
                android:maxLines="3"
                android:ellipsize="none"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             EMOJI BURST OVERLAY — when the partner sends an emoji-only
             message, it pops up HUGE in the center, overlapping the chat
             area, with a scale+fade animation, then auto-vanishes after a
             short delay. Driven by ChatEmojiBurstController, which also
             enforces a 4-second cooldown so the partner can't spam it.
             Centered + ignores touches so it never blocks the chat list. ─ -->
        <TextView
            android:id="@+id/tv_emoji_burst"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textSize="96sp"
            android:gravity="center"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone"/>

        <!-- New Messages floating indicator chip (WhatsApp style).
             Appears above the FAB when user is scrolled up and new messages arrive. -->
        <TextView
            android:id="@+id/tv_new_messages_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="56dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:text="↓ new messages"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_new_msg_chip"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"/>

        <!-- Back to latest FAB — shown when navigating to original message -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_back_to_latest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="270"
            android:contentDescription="Back to latest"
            app:backgroundTint="@color/brand_primary"
            app:tint="@color/white"
            app:fabSize="mini"
            android:visibility="gone"
            android:alpha="0"/>

    </FrameLayout>

    <ProgressBar
        android:id="@+id/upload_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:progressTint="@color/brand_primary"
        android:visibility="gone"/>

    <!-- ═══════════════════════════════════════════════════════════════
         REPLY BAR — Upgraded: media thumbnail + animated slide-up
         ═══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_reply_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_reply_bar"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Left accent stripe -->
        <View
            android:id="@+id/view_reply_accent"
            android:layout_width="3dp"
            android:layout_height="44dp"
            android:background="@color/brand_primary"
            android:layout_marginEnd="10dp"/>

        <!-- Media thumbnail (image/video preview) -->
        <ImageView
            android:id="@+id/iv_reply_bar_thumb"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:layout_marginEnd="8dp"
            android:background="@color/divider"
            android:visibility="gone"/>

        <!-- Sender name + content text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_reply_bar_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/tv_reply_bar_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Cancel button -->
        <ImageButton
            android:id="@+id/btn_cancel_reply"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel reply"/>
    </LinearLayout>

    <!-- Block banner — shown when YOU have blocked this person -->
    <LinearLayout
        android:id="@+id/ll_block_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1AFF3B30"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_block_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFF3B30"
            android:textSize="13sp"
            android:drawablePadding="8dp"
            android:text="You have blocked this person"/>

        <Button
            android:id="@+id/btn_permanent_block"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Permanent Block"
            android:textSize="12sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FFFF3B30"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

    <!-- Input row -->
    <LinearLayout
        android:id="@+id/ll_input_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="3dp"
        android:background="@color/bar_background"
        android:gravity="center_vertical">
        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="6dp"
            android:src="@drawable/ic_attach"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Attach"/>
        <ImageButton
            android:id="@+id/btn_camera"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="6dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Camera"/>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_input_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <com.callx.app.chat.ui.GifAwareEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_message"
                android:textColorHint="@color/text_muted"
                android:textColor="?android:attr/textColorPrimary"
                android:background="@color/transparent"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textSize="14sp"
                android:maxLines="4"
                android:maxLength="4000"/>
        </FrameLayout>
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/circle_primary"
            android:contentDescription="Voice message"/>
        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/circle_primary"
            android:layout_marginStart="6dp"
            android:visibility="gone"
            android:contentDescription="Send"/>
    </LinearLayout>

</LinearLayout>
