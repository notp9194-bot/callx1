<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    android:orientation="vertical">

    <!-- ═══════════════════════════════════════════
         MODERN TOOLBAR — gradient with elevation
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_chat_toolbar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="8dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_partner_avatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_person"
            android:layout_marginStart="2dp"
            android:clickable="true"
            android:focusable="true"
            app:civ_border_width="2dp"
            app:civ_border_color="#CCFFFFFF"/>

        <!-- Online green dot -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_partner_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Name"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DDEEFF"
                    android:textSize="12sp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_typing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="typing…"
                    android:textColor="#DDEEFF"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:visibility="gone"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Social buttons (compact) -->
        <ImageButton
            android:id="@+id/btn_toolbar_reel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_reels"
            android:tint="@color/white"
            android:background="@drawable/bg_social_reel_btn"
            android:padding="7dp"
            android:layout_marginEnd="3dp"
            android:contentDescription="View Reels Profile"/>

        <ImageButton
            android:id="@+id/btn_toolbar_x"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_x_logo"
            android:tint="@color/white"
            android:background="@drawable/bg_social_x_btn"
            android:padding="7dp"
            android:layout_marginEnd="3dp"
            android:contentDescription="View X Profile"/>

        <ImageButton
            android:id="@+id/btn_toolbar_youtube"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_youtube"
            android:tint="@color/white"
            android:background="@drawable/bg_social_youtube_btn"
            android:padding="7dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="View YouTube Channel"/>

        <ImageButton
            android:id="@+id/btn_toolbar_video_call"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_video_call"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="7dp"
            android:contentDescription="Video call"/>

        <ImageButton
            android:id="@+id/btn_toolbar_voice_call"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_phone"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Voice call"/>

        <ImageButton
            android:id="@+id/btn_more_options"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"/>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         MULTI-SELECT TOOLBAR
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_selection_toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_chat_toolbar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="8dp"
        android:elevation="8dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_selection_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel selection"/>

        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"/>

        <ImageButton
            android:id="@+id/btn_selection_reply"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_reply"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Reply"/>

        <ImageButton
            android:id="@+id/btn_selection_star"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Star"/>

        <ImageButton
            android:id="@+id/btn_selection_info"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_info"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Info"/>

        <ImageButton
            android:id="@+id/btn_selection_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Delete"/>

        <ImageButton
            android:id="@+id/btn_selection_forward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_forward"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="Forward"/>
    </LinearLayout>

    <!-- Offline banner -->
    <TextView
        android:id="@+id/tv_offline_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No internet — showing cached messages"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="#CC5500"
        android:visibility="gone"/>

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/ll_search_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:gravity="center_vertical"
        android:elevation="2dp"
        android:visibility="gone">
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:layout_marginEnd="10dp"
            android:alpha="0.45"/>
        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search messages…"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"/>
        <TextView
            android:id="@+id/tv_search_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone"/>
        <ImageButton
            android:id="@+id/btn_search_prev"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="90"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous result"
            android:visibility="gone"/>
        <ImageButton
            android:id="@+id/btn_search_next"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="270"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next result"
            android:visibility="gone"/>
        <ImageButton
            android:id="@+id/btn_close_search"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close search"/>
    </LinearLayout>

    <!-- Pinned message banner -->
    <LinearLayout
        android:id="@+id/ll_pinned_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:visibility="gone">
        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="#A855F7"
            android:layout_marginEnd="10dp"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 Pinned Message"
                android:textColor="#7C3AED"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_pinned_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
        <ImageButton
            android:id="@+id/btn_unpin"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Unpin"/>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         MESSAGE LIST AREA
         ═══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/iv_chat_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Chat wallpaper"/>

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">
            <include layout="@layout/layout_skeleton_chat"/>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_messages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/ll_empty_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👋"
                android:textSize="56sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Say hello!"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No messages yet. Send the first one!"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                android:gravity="center"/>
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_back_to_latest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            android:src="@drawable/ic_arrow_back"
            android:rotation="270"
            android:contentDescription="Back to latest"
            app:backgroundTint="@color/brand_primary"
            app:tint="@color/white"
            app:fabSize="mini"
            android:visibility="gone"
            android:alpha="0"/>
    </FrameLayout>

    <ProgressBar
        android:id="@+id/upload_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:progressTint="@color/brand_primary"
        android:visibility="gone"/>

    <!-- ═══════════════════════════════════════════
         REPLY BAR — modern style
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_reply_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:elevation="3dp">

        <View
            android:id="@+id/view_reply_accent"
            android:layout_width="3dp"
            android:layout_height="40dp"
            android:background="#A855F7"
            android:layout_marginEnd="12dp"/>

        <ImageView
            android:id="@+id/iv_reply_bar_thumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"
            android:background="#F0F2F8"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_reply_bar_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7C3AED"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/tv_reply_bar_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_cancel_reply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel reply"/>
    </LinearLayout>

    <!-- Block banner -->
    <LinearLayout
        android:id="@+id/ll_block_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1AFF3B30"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_block_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFF3B30"
            android:textSize="13sp"
            android:text="You have blocked this person"/>

        <Button
            android:id="@+id/btn_permanent_block"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Permanent Block"
            android:textSize="12sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FFFF3B30"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         MODERN INPUT BAR
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_input_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:elevation="6dp">

        <!-- Attach button -->
        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_attach"
            android:tint="#A855F7"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Attach"/>

        <!-- Camera button -->
        <ImageButton
            android:id="@+id/btn_camera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:tint="#A855F7"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Camera"
            android:layout_marginEnd="4dp"/>

        <!-- Text input field — pill style -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_bar"
            android:paddingStart="16dp"
            android:paddingEnd="12dp">
            <com.callx.app.chat.ui.GifAwareEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_message"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:background="@color/transparent"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxLines="5"
                android:maxLength="4000"/>
        </FrameLayout>

        <!-- Voice/Send button (pill with gradient) -->
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_mic"
            android:tint="@color/white"
            android:background="@drawable/bg_send_btn"
            android:padding="11dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Voice message"/>

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:tint="@color/white"
            android:background="@drawable/bg_send_btn"
            android:padding="11dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:contentDescription="Send"/>
    </LinearLayout>

</LinearLayout>
