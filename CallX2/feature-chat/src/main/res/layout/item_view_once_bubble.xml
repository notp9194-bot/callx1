<?xml version="1.0" encoding="utf-8"?>
<!--
  item_view_once_bubble.xml
  View-Once "tap to open" bubble — shown to RECEIVER before opening.

  PERFORMANCE NOTES:
  - ConstraintLayout: zero nesting, single layout pass.
  - Solid color background only — no gradient, no shadow, no blur.
  - Hardware layer NOT set — no overdraw, no GPU layer cost.
  - No shimmer, no animation loops in this layout.
  - Footer anchored via constraints — no nested LinearLayouts.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="3dp">

    <!--
      Bubble card — solid teal background.
      No shadow (elevation=0), no gradient → zero GPU overdraw.
    -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_bubble"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_view_once_bubble"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Lock icon — indicates secret/private -->
        <TextView
            android:id="@+id/tv_vo_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="22sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Label: "View Once" -->
        <TextView
            android:id="@+id/tv_vo_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="View Once"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toEndOf="@id/tv_vo_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_vo_icon"
            app:layout_constraintBottom_toTopOf="@id/tv_vo_sublabel"/>

        <!-- Sublabel: media type hint -->
        <TextView
            android:id="@+id/tv_vo_sublabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tap to open"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toEndOf="@id/tv_vo_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_vo_label"/>

        <!-- Time — anchored bottom-end, no nested footer layout -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAFFFFFF"
            android:textSize="9sp"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_vo_sublabel"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
