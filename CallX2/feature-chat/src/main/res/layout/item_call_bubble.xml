<?xml version="1.0" encoding="utf-8"?>
<!-- item_call_bubble.xml — Call entry shown inside chat bubble -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <!-- Call info row: icon + text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/iv_call_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_phone"
            android:tint="#FFFFFF"
            android:alpha="0.85"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_call_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice call"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_call_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No answer"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="1dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"/>

    <!-- Action buttons: Record Audio Note + Record Video Note -->
    <LinearLayout
        android:id="@+id/ll_call_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_record_audio_note"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🎤 Audio note"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"/>

        <TextView
            android:id="@+id/btn_record_video_note"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🎬 Video note"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>
    </LinearLayout>

</LinearLayout>
