<?xml version="1.0" encoding="utf-8"?>
<!-- item_call_bubble.xml — Call entry shown inside chat bubble -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_call"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="visible">

    <!-- Call info row: icon + text + date/time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <ImageView
            android:id="@+id/iv_call_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_phone"
            android:tint="@android:color/black"
            android:alpha="0.85"/>

        <!-- Call type + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_call_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice call"
                android:textColor="@android:color/black"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_call_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No answer"
                android:textColor="@android:color/black"
                android:textSize="11sp"
                android:layout_marginTop="1dp"/>

        </LinearLayout>

        <!-- Date + Time (right side) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="6dp">

            <TextView
                android:id="@+id/tv_call_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textColor="@android:color/black"
                android:textSize="10sp"
                android:alpha="0.7"/>

            <TextView
                android:id="@+id/tv_call_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textColor="@android:color/black"
                android:textSize="10sp"
                android:alpha="0.7"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22000000"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"/>

    <!-- Action buttons row: Call Back + Audio Note + Video Note -->
    <LinearLayout
        android:id="@+id/ll_call_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Call Back button (always shown in actions row) -->
        <TextView
            android:id="@+id/btn_call_back"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📞 Call back"
            android:textColor="@android:color/black"
            android:textSize="11sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#22000000"/>

        <TextView
            android:id="@+id/btn_record_audio_note"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🎤 Audio"
            android:textColor="@android:color/black"
            android:textSize="11sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#22000000"/>

        <TextView
            android:id="@+id/btn_record_video_note"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🎬 Video"
            android:textColor="@android:color/black"
            android:textSize="11sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"/>

    </LinearLayout>

    <!-- Call Back button (always visible, below divider, for completed calls too) -->
    <TextView
        android:id="@+id/btn_call_back_solo"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="📞 Call back"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone"/>

</LinearLayout>
