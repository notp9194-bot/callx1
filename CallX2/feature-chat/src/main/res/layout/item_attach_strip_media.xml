<?xml version="1.0" encoding="utf-8"?>
<!--
    Single tile in the compact recent-media strip that sits above the
    icon grid in bottom_sheet_attach.xml (WhatsApp-style: camera tile is
    prepended in code as position 0, everything else is a MediaStore
    thumbnail). Kept tiny/flat on purpose — this row is rendered for
    every attach-sheet open, so no nested view hierarchies.

    Border lives on the ROOT FrameLayout with the thumb ImageView inset by
    1dp — same reasoning as item_attach_grid_media.xml: a border painted
    directly behind a centerCrop image is fully covered by that image and
    never shows.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="76dp"
    android:layout_height="76dp"
    android:layout_marginEnd="8dp"
    android:background="@drawable/bg_media_thumb_border_rounded">

    <ImageView
        android:id="@+id/thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="1dp"
        android:background="@drawable/bg_media_thumb_camera"
        android:scaleType="centerCrop"/>

    <ImageView
        android:id="@+id/camera_icon"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_camera"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/video_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:background="@drawable/bg_video_duration_pill"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:visibility="gone"/>
</FrameLayout>
