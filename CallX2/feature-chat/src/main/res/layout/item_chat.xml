<?xml version="1.0" encoding="utf-8"?>
<!-- Modern chat list item — Telegram/Signal inspired clean row -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_chat_list_item"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Avatar with Story Ring -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            app:civ_border_width="0dp"
            app:civ_border_color="@color/brand_primary"/>

        <ImageView
            android:id="@+id/iv_story_ring"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_status_unseen"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Name + last message -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="6dp">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/tv_last_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:text="Tap to chat"/>
    </LinearLayout>

    <!-- Right side: time + badge + call buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end|top">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tv_unread_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="20dp"
            android:minHeight="20dp"
            android:gravity="center"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_unread_badge"
            android:layout_marginTop="4dp"
            android:layout_gravity="end"
            android:visibility="gone"/>

        <!-- Call buttons row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_video_call"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_video_call"
                android:tint="@color/brand_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="Video call"/>

            <ImageButton
                android:id="@+id/btn_call"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_phone"
                android:tint="@color/brand_primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:contentDescription="Voice call"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
