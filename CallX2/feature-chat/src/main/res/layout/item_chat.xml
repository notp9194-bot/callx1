<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <!-- Avatar with Story Ring + Selection Overlay -->
            <FrameLayout
                android:layout_width="58dp"
                android:layout_height="58dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="@color/brand_primary"/>

                <ImageView
                    android:id="@+id/iv_story_ring"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_status_unseen"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"/>

                <!-- Online-status dot — bound/unbound live via a per-row Firebase
                     listener scoped to the ViewHolder (see ChatListAdapter), NOT
                     via notifyItemChanged/DiffUtil, so a presence flip never
                     triggers a list rebind or touches scroll performance. -->
                <View
                    android:id="@+id/v_online_dot"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="1dp"
                    android:background="@drawable/circle_online_dot"
                    android:visibility="gone"/>

                <!-- Selection checkmark overlay (visible only in selection mode) -->
                <FrameLayout
                    android:id="@+id/fl_select_overlay"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:background="#99000000"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/iv_check"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_close"
                        android:tint="#FFFFFF"
                        android:visibility="invisible"/>

                    <!-- Green checkmark circle for selected state -->
                    <View
                        android:id="@+id/v_check_ring"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_accept"
                        android:visibility="gone"/>

                </FrameLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tv_last_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Tap karke chat karo"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_meta_normal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end|center_vertical">

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"/>

                <!-- Mute icon — same live-per-row-listener pattern as v_online_dot -->
                <ImageView
                    android:id="@+id/iv_mute_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/ic_mute_small"
                    android:tint="@color/text_muted"
                    android:visibility="gone"
                    android:contentDescription="Muted"/>

                <TextView
                    android:id="@+id/tv_unread_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="20dp"
                    android:minHeight="20dp"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_unread_badge"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>

                <!-- Voice + Video call buttons -->
                <LinearLayout
                    android:id="@+id/ll_call_btns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageButton
                        android:id="@+id/btn_video_call"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_video_call"
                        android:tint="@color/brand_primary"
                        android:background="@null"
                        android:padding="8dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="Video call"/>

                    <ImageButton
                        android:id="@+id/btn_call"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_phone"
                        android:tint="@color/brand_primary"
                        android:background="@null"
                        android:padding="8dp"
                        android:contentDescription="Voice call"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
