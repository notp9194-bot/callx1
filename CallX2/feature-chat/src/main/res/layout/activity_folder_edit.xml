<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/brand_primary"/>

        <!-- Emoji preview + name row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_selected_emoji"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:textSize="32sp"
                android:text="📁"
                android:background="@drawable/bg_circle_light"
                android:clickable="true"
                android:focusable="true"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_folder_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Folder Name"
                    android:maxLength="20"
                    android:inputType="text"/>

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Emoji picker grid -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose Icon"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_emoji_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:nestedScrollingEnabled="false"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/dividerHorizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Filter options -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Include in folder"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"/>

        <CheckBox
            android:id="@+id/cb_include_contacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Personal chats (contacts)"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/cb_include_groups"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Groups"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/cb_include_unread"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unread only"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="15sp"/>

        <CheckBox
            android:id="@+id/cb_include_muted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Include muted chats"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textSize="15sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/dividerHorizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Save button -->
        <Button
            android:id="@+id/btn_save_folder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:text="Save Folder"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="@color/brand_primary"
            android:textColor="@color/white"/>

        <!-- Delete button (visible only when editing) -->
        <Button
            android:id="@+id/btn_delete_folder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp"
            android:text="Delete Folder"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="#FFEBEE"
            android:textColor="#D32F2F"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
