<?xml version="1.0" encoding="utf-8"?>
<!--
  item_view_once_sent_waiting.xml
  Shown to the SENDER after sending a view-once message, while receiver has NOT yet opened it.
  Displays a lock icon + "Waiting to be opened" to indicate the message is pending.
  Once receiver opens it, Firebase pushes viewOnceState="opened" → adapter rebinds
  this row to TYPE_VIEW_ONCE_EXPIRED ("Opened").

  PERFORMANCE: ConstraintLayout, single pass, solid color, no hardware layer.
  Aligned to the END (sender side) to match all other sent message bubbles.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_bubble"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_view_once_sent_waiting"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Lock icon: message locked until receiver opens -->
        <TextView
            android:id="@+id/tv_waiting_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Label: "Waiting to be opened" -->
        <TextView
            android:id="@+id/tv_waiting_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Waiting to be opened"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/tv_waiting_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_time"/>

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="9sp"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_waiting_label"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
