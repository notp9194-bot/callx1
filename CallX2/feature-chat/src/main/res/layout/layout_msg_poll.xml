<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_poll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_poll_card"
    android:layout_margin="5dp"
    android:padding="14dp">

    <!-- Header: icon badge + label + status chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <ImageView
            android:id="@+id/iv_poll_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:padding="5dp"
            android:background="@drawable/bg_poll_icon_badge"
            android:src="@drawable/ic_poll"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tv_poll_icon_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="POLL"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>

        <TextView
            android:id="@+id/tv_poll_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_poll_chip_neutral"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="#FFFFFFFF"
            android:textSize="9.5sp"
            android:textStyle="bold"
            android:visibility="gone"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_poll_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:lineSpacingExtra="2dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tv_poll_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select one answer"
        android:textColor="#AAFFFFFF"
        android:textSize="11sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:id="@+id/ll_poll_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <TextView
        android:id="@+id/tv_poll_total_votes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#B3FFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="6dp"/>

</LinearLayout>
