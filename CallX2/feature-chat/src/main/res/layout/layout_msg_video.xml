<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_msg_video.xml — Compact video thumbnail card (bubbleless style).
    Width is set by the ViewStub (180dp). Height fixed 160dp.
    Rounded corners (12dp) via bg_media_card + clipToOutline.
    Timestamp + tick overlays from the parent ll_msg_footer (bottom|end in FrameLayout).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fl_video"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="@drawable/bg_media_card"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/iv_video_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#1A1A1A"/>

    <!-- Subtle dark scrim over bottom so play button/duration are visible -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="#55000000"/>

    <!-- Play button (centered) -->
    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play"
        android:background="@drawable/circle_primary"
        android:padding="12dp"/>

    <!-- Duration badge (bottom-left) -->
    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="6dp"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:text="0:00"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:background="#88000000"
        android:visibility="gone"/>

    <!-- Upload progress bar -->
    <ProgressBar
        android:id="@+id/progress_upload"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:max="100"
        android:progress="0"
        android:visibility="gone"/>

</FrameLayout>
