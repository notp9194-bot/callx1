<?xml version="1.0" encoding="utf-8"?>
<!--
  Location share bubble — purple themed.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_location_card"
    android:layout_width="165dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clipToOutline="true"
    android:clickable="true"
    android:focusable="true">

    <!-- Map thumbnail area — deep purple header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#4A148C">

        <ImageView
            android:id="@+id/ivMapThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#4A148C"/>

        <!-- Pin icon centered -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location_pin"
            android:tint="#EF9A9A"/>

    </FrameLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#7B1FA2"/>

    <!-- Address row -->
    <TextView
        android:id="@+id/tvLocationAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:textColor="#F3E5F5"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:background="#6A1B9A"
        android:text="Loading address…"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#7B1FA2"/>

    <!-- "Open in Maps" action -->
    <TextView
        android:id="@+id/btnOpenMaps"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="Open in Maps"
        android:textColor="#CE93D8"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="#6A1B9A"/>

</LinearLayout>
