<?xml version="1.0" encoding="utf-8"?>
<!--
  Location share bubble — bubbleless, 165dp wide, rounded 12dp corners.
  Matches reel share card style. Map thumbnail on top, address + action row below.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_location_card"
    android:layout_width="165dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_media_card"
    android:clipToOutline="true"
    android:clickable="true"
    android:focusable="true">

    <!-- Map thumbnail area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#2A2A2E">

        <!-- Static map image (loaded by Glide) or placeholder -->
        <ImageView
            android:id="@+id/ivMapThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#2A2A2E"/>

        <!-- Pin icon centered overlay -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location_pin"
            android:tint="#E53935"/>

    </FrameLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#33FFFFFF"/>

    <!-- Address row -->
    <TextView
        android:id="@+id/tvLocationAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:textColor="#CCFFFFFF"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:background="#1C1C1E"
        android:text="Loading address…"/>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#33FFFFFF"/>

    <!-- "Open in Maps" action -->
    <TextView
        android:id="@+id/btnOpenMaps"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="Open in Maps"
        android:textColor="#4FC3F7"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="#1C1C1E"/>

</LinearLayout>
