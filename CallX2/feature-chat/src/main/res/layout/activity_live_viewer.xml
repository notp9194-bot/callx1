<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Stream view placeholder (Agora remote view here) -->
    <View
        android:id="@+id/live_viewer_stream"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A2E"/>

    <!-- Top bar: host name + LIVE badge + leave -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:layout_gravity="top">

        <TextView
            android:id="@+id/tv_live_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" LIVE "
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="#E53935"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <TextView
            android:id="@+id/tv_live_host_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Host LIVE hai 🔴"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btn_leave_live"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="#99000000"
            android:src="@drawable/ic_close"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Bottom: chat + input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="8dp">

        <!-- Chat messages -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_live_viewer_chat"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:overScrollMode="never"/>

        <!-- Message input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#88000000"
            android:padding="6dp">

            <EditText
                android:id="@+id/et_live_viewer_message"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="#44FFFFFF"
                android:hint="Comment karo..."
                
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:imeOptions="actionSend"
                android:singleLine="true"/>

            <ImageButton
                android:id="@+id/btn_live_viewer_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="#5B5BF6"
                android:src="@drawable/ic_send"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
