<?xml version="1.0" encoding="utf-8"?>
<!-- layout_recording_ui.xml — Replaced input row while recording voice message -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_recording_ui"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical"
    android:background="@color/surface_card"
    android:elevation="4dp"
    android:visibility="gone">

    <!-- Cancel recording button -->
    <ImageButton
        android:id="@+id/btn_recording_cancel"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_delete"
        android:tint="#FF5252"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Cancel recording"/>

    <!-- Waveform + timer -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp">

        <!-- Timer -->
        <TextView
            android:id="@+id/tv_recording_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#FF5252"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <!-- Live waveform -->
        <com.callx.app.chat.ui.WaveformView
            android:id="@+id/waveform_recording"
            android:layout_width="match_parent"
            android:layout_height="32dp"/>
    </LinearLayout>

    <!-- Mic indicator dot (pulsing) -->
    <View
        android:id="@+id/view_rec_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_action_btn_circle"
        android:layout_marginEnd="8dp"/>

    <!-- Send recording button -->
    <ImageButton
        android:id="@+id/btn_recording_send"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@drawable/ic_send"
        android:background="@drawable/circle_primary"
        android:padding="14dp"
        android:contentDescription="Send voice message"/>

</LinearLayout>
