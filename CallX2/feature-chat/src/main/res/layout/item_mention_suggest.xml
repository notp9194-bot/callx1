<?xml version="1.0" encoding="utf-8"?>
<!--
    item_mention_suggest.xml
    Row layout for the @mention suggestion dropdown.
    Height: 48dp — comfortable tap target, fits 4 rows in 192dp max height.
    v2 — Canvas row (perf): avatar + name + "@" badge draw in a single
    MentionRowCanvasView.onDraw() instead of 3 separate child Views — see
    that view's class doc (matters here because filter() re-binds every
    visible row on every keystroke).
-->
<com.callx.app.mention.canvas.MentionRowCanvasView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/view_mention_row"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="?attr/selectableItemBackground"/>
