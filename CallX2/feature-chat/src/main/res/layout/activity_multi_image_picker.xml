<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_multi_image_picker.xml
  Multi-image preview + caption screen before sending.

  Layout (top to bottom):
    1. Toolbar (back, "Send to X", compress toggle)
    2. Counter badge ("2 / 5")
    3. Focused image preview (full-width, ~60% height, swipeable)
    4. Reply preview bar (optional)
    5. Caption input + "Add more" + Send button
    6. Horizontal thumbnail strip
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ═══ 1. TOOLBAR ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tv_send_to"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BBBBBB"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Compress toggle -->
        <TextView
            android:id="@+id/btn_compress"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="⚡ Compressed"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"
            android:background="@drawable/bg_rounded_outline"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ═══ 2. FOCUSED IMAGE PREVIEW ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/iv_focused"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="#000000"/>

        <!-- Swipe hint arrows (fade in on first use) -->
        <ImageView
            android:id="@+id/iv_arrow_left"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_back"
            android:tint="#88FFFFFF"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/iv_arrow_right"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_forward"
            android:tint="#88FFFFFF"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- ═══ 3. REPLY PREVIEW ═══ -->
    <LinearLayout
        android:id="@+id/layout_reply_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#33FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="@color/brand_primary"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_reply_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_reply_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_close_reply"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:tint="#AAFFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove reply"/>

    </LinearLayout>

    <!-- ═══ 4. CAPTION + SEND ROW ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Add more images button -->
        <ImageButton
            android:id="@+id/btn_add_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_add"
            android:tint="@color/white"
            android:background="@drawable/circle_outline"
            android:layout_marginEnd="8dp"
            android:contentDescription="Add more images"/>

        <!-- Caption input -->
        <EditText
            android:id="@+id/et_caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Add a caption..."
            android:hintTextColor="#88FFFFFF"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:background="@drawable/bg_comment_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:maxLines="3"
            android:inputType="textMultiLine|textCapSentences"
            android:layout_marginEnd="8dp"/>

        <!-- Send button with count badge -->
        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_send_fill"
            android:tint="@color/white"
            android:background="@drawable/circle_primary"
            android:padding="14dp"
            android:contentDescription="Send"/>

    </LinearLayout>

    <!-- ═══ 5. THUMBNAIL STRIP ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_strip"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#111111"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

</LinearLayout>
