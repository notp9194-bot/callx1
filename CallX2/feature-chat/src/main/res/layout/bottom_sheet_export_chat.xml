<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tv_export_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Export chat"
        android:textColor="#212121"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/tv_export_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="Messages will be exported as a text file"
        android:textColor="#757575"
        android:textSize="12sp"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <TextView android:id="@+id/action_export_with_media"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:gravity="center_vertical" android:paddingStart="20dp"
        android:text="📎  Include media (attach files)"
        android:textSize="15sp" android:textColor="#212121"
        android:background="?attr/selectableItemBackground"/>

    <TextView android:id="@+id/action_export_without_media"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:gravity="center_vertical" android:paddingStart="20dp"
        android:text="📄  Without media (text only)"
        android:textSize="15sp" android:textColor="#212121"
        android:background="?attr/selectableItemBackground"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="#E0E0E0"/>

    <TextView android:id="@+id/action_export_cancel"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:gravity="center_vertical" android:paddingStart="20dp"
        android:text="✕  Cancel"
        android:textSize="15sp" android:textColor="#757575"
        android:background="?attr/selectableItemBackground"/>

</LinearLayout>
