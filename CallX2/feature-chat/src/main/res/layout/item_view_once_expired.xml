<?xml version="1.0" encoding="utf-8"?>
<!--
  item_view_once_expired.xml
  Shown after message has been opened (receiver) OR for sender's own view-once.
  Minimal — just a greyed-out pill. No media, no content.

  PERFORMANCE: ConstraintLayout, single pass, solid color, no hardware layer.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_bubble"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_view_once_expired"
        android:padding="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_expired_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁"
            android:textSize="18sp"
            android:alpha="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tv_expired_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Opened"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/tv_expired_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_time"/>

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#66FFFFFF"
            android:textSize="9sp"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_expired_label"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
