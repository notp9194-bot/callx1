<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface_card"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡 Chat Privacy"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_privacy_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This chat"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Section: Timer Controls -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MESSAGE TIMERS"
        android:textColor="@color/brand_primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="6dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1: Disappearing Messages -->
            <LinearLayout
                android:id="@+id/row_disappearing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="⏳"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disappearing Messages"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New messages vanish after set time"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_disappearing_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_muted"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginStart="54dp"/>

            <!-- Row 2: Message Timer -->
            <LinearLayout
                android:id="@+id/row_msg_timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="⏱"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Message Timer"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-delete after recipient reads"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_msg_timer_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Off"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:layout_marginEnd="4dp"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="@color/text_muted"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Section: Auto-Delete -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="STORAGE &amp; HISTORY"
        android:textColor="@color/brand_primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="6dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp">

        <!-- Row 3: Auto-Delete Old Messages -->
        <LinearLayout
            android:id="@+id/row_auto_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🗑"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-Delete Old Messages"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remove messages older than selected period"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_auto_delete_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Never"
                android:textColor="@color/brand_primary"
                android:textSize="13sp"
                android:layout_marginEnd="4dp"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/text_muted"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Info note -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ These settings apply only to this conversation on your device."
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"/>

</LinearLayout>
