<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_reaction_popup"
    android:elevation="8dp"
    android:padding="6dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tv_react_like"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="👍"
        android:textSize="26sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <TextView
        android:id="@+id/tv_react_love"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="❤️"
        android:textSize="26sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <TextView
        android:id="@+id/tv_react_haha"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="😂"
        android:textSize="26sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <TextView
        android:id="@+id/tv_react_wow"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="😮"
        android:textSize="26sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <TextView
        android:id="@+id/tv_react_sad"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="😢"
        android:textSize="26sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <TextView
        android:id="@+id/tv_react_angry"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="😡"
        android:textSize="26sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless"/>

</LinearLayout>
