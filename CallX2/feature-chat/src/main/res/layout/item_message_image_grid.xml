<?xml version="1.0" encoding="utf-8"?>
<!--
  item_message_image_grid.xml
  Chat bubble for multi-image messages (2–10 images).

  Layout logic (handled in adapter bindMultiImage()):
    1 image  → use existing item_message_image.xml (single full-width)
    2 images → 2-column row (each 50%)
    3 images → 1 large left + 2 small stacked right
    4 images → 2×2 grid
    5–10     → 3-col mosaic (first image double-wide)
                + "+N more" overlay on last visible cell if > 4 shown

  Tap any image → opens full-screen viewer (ImageViewerActivity / Pager)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_bubble_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bubble_sent"
    android:padding="3dp"
    android:minWidth="200dp"
    android:maxWidth="280dp">

    <!-- Dynamic image grid — injected by adapter -->
    <GridLayout
        android:id="@+id/grid_images"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"/>

    <!-- Caption (shown if ANY image has caption, or a shared caption) -->
    <TextView
        android:id="@+id/tv_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#111111"
        android:textSize="13sp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone"/>

    <!-- Timestamp + status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="10sp"/>

        <ImageView
            android:id="@+id/iv_status"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_double_tick"
            android:tint="#4FC3F7"
            android:layout_marginStart="3dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
