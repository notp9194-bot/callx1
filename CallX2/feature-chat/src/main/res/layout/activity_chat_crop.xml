<?xml version="1.0" encoding="utf-8"?>
<!--
  WhatsApp-grade crop screen.

  Layout stack (back → front):
   1. CropOverlayView — fills remaining space, renders image + dim overlay
      + rule-of-thirds grid + corner/edge handles. Handles all touch:
        • Near a handle → resize crop box
        • Elsewhere     → pan / pinch-zoom the image under the box
   2. Top bar: Cancel | "Crop" title | Rotate icon | Done
   3. Bottom bar: aspect-ratio chip strip + current aspect label
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- ── Top bar ────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="10dp"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:background="#CC000000">

        <!-- Cancel -->
        <TextView
            android:id="@+id/chat_crop_btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#AAAAAA"
            android:textSize="15sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Crop"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"/>

        <!-- Rotate 90° button -->
        <ImageButton
            android:id="@+id/chat_crop_btn_rotate"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_media_edit_rotate"
            android:scaleType="center"
            android:padding="9dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:layout_marginEnd="6dp"
            android:contentDescription="Rotate 90°"/>

        <!-- Done -->
        <TextView
            android:id="@+id/chat_crop_btn_done"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Done"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#40C060"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ── Crop canvas — fills all remaining space ────────────────── -->
    <com.callx.app.conversation.controllers.CropOverlayView
        android:id="@+id/chat_crop_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Bottom bar: aspect chips + label ──────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111111"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <!-- Current aspect ratio label -->
        <TextView
            android:id="@+id/chat_crop_aspect_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Free"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <!-- Aspect ratio chip scroll strip -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/chat_crop_aspect_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>
        </HorizontalScrollView>
    </LinearLayout>

</LinearLayout>
