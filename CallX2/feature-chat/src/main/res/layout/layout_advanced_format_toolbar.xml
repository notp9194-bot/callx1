<?xml version="1.0" encoding="utf-8"?>
<!--
    v169 — layout_advanced_format_toolbar.xml
    Second toolbar row — shown BELOW the v168 basic toolbar when input is expanded.
    This row contains the 7 advanced format controls managed by AdvancedRichTextController.

    Button IDs used by AdvancedRichTextController.bindAdvancedToolbar():
      @id/btnFmtTextColor      — Text colour (shows colour dot)
      @id/btnFmtHighlight      — Highlight / background colour
      @id/btnFmtSize           — Text size (shows current sp)
      @id/btnFmtAlign          — Paragraph alignment (cycles L→C→R→J)
      @id/btnFmtFont           — Font family
      @id/btnFmtLetterSpacing  — Letter spacing slider
      @id/btnFmtLineHeight     — Line height slider
      @id/btnFmtPresentation   — Open PresentationMessageEditor (slide editor)
-->
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:scrollbars="none"
    android:fillViewport="false"
    android:background="@drawable/bg_advanced_toolbar">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- ─── Text Color ──────────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/btnFmtTextColor"
            android:layout_width="38dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/bg_format_btn_inactive"
            android:clickable="true"
            android:focusable="true">

            <!-- "A" letter -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FF222222"
                android:paddingBottom="6dp"/>

            <!-- Colour indicator strip at the bottom of A -->
            <View
                android:id="@+id/vTextColorStrip"
                android:tag="colorIndicator"
                android:layout_width="18dp"
                android:layout_height="3dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="4dp"
                android:background="#FF000000"/>
        </FrameLayout>

        <!-- ─── Highlight Color ─────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/btnFmtHighlight"
            android:layout_width="38dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/bg_format_btn_inactive"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="A"
                android:textSize="14sp"
                android:textColor="#FF222222"
                android:paddingBottom="6dp"/>

            <!-- Highlighted swatch strip -->
            <View
                android:id="@+id/vHighlightStrip"
                android:tag="colorIndicator"
                android:layout_width="18dp"
                android:layout_height="5dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="3dp"
                android:background="#FFFFFF00"/>
        </FrameLayout>

        <!-- ─── Vertical divider ─────────────────────────────────────────── -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="4dp"
            android:background="#22000000"/>

        <!-- ─── Text Size ───────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/btnFmtSize"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:minWidth="36dp"
            android:gravity="center"
            android:text="14sp"
            android:textSize="11sp"
            android:textColor="#FF333333"
            android:background="@drawable/bg_format_btn_inactive"
            android:paddingHorizontal="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- ─── Alignment ───────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/btnFmtAlign"
            android:layout_width="38dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:gravity="center"
            android:text="≡L"
            android:textSize="13sp"
            android:textColor="#FF333333"
            android:background="@drawable/bg_format_btn_inactive"
            android:clickable="true"
            android:focusable="true"/>

        <!-- ─── Vertical divider ─────────────────────────────────────────── -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="4dp"
            android:background="#22000000"/>

        <!-- ─── Font Family ─────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/btnFmtFont"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:minWidth="40dp"
            android:gravity="center"
            android:text="Sans"
            android:textSize="11sp"
            android:textColor="#FF333333"
            android:background="@drawable/bg_format_btn_inactive"
            android:paddingHorizontal="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- ─── Letter Spacing ──────────────────────────────────────────── -->
        <ImageButton
            android:id="@+id/btnFmtLetterSpacing"
            android:layout_width="38dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:src="@drawable/ic_letter_spacing"
            android:background="@drawable/bg_format_btn_inactive"
            android:contentDescription="Letter spacing"
            android:scaleType="centerInside"
            android:padding="6dp"/>

        <!-- ─── Line Height ─────────────────────────────────────────────── -->
        <ImageButton
            android:id="@+id/btnFmtLineHeight"
            android:layout_width="38dp"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:src="@drawable/ic_line_height"
            android:background="@drawable/bg_format_btn_inactive"
            android:contentDescription="Line height"
            android:scaleType="centerInside"
            android:padding="6dp"/>

        <!-- ─── Vertical divider ─────────────────────────────────────────── -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="4dp"
            android:background="#22000000"/>

        <!-- ─── Presentation / Slide mode ───────────────────────────────── -->
        <LinearLayout
            android:id="@+id/btnFmtPresentation"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginHorizontal="2dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:background="@drawable/bg_presentation_btn"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_presentation"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Slide"
                android:textSize="11sp"
                android:textColor="#FF1976D2"/>
        </LinearLayout>

    </LinearLayout>
</HorizontalScrollView>
