<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_notification_settings.xml
  Per-chat notification settings screen.

  Sections (top → bottom):
    Toolbar
    ─── Mute ───
    ─── Sound ───
    ─── Vibration ───
    ─── LED ───
    ─── Preview ───
    Reset button
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ═══ TOOLBAR ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/gradient_brand"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ═══ SECTION: MUTE ═══ -->
            <TextView
                style="@style/SectionHeader"
                android:text="NOTIFICATIONS"/>

            <!-- Mute row -->
            <LinearLayout
                android:id="@+id/row_mute"
                style="@style/SettingsRow">

                <ImageView
                    style="@style/SettingsIcon"
                    android:src="@drawable/ic_notifications_off"
                    android:tint="@color/text_secondary"/>

                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView
                        style="@style/SettingsTitle"
                        android:text="Mute Notifications"/>
                    <TextView
                        android:id="@+id/tv_mute_value"
                        style="@style/SettingsSubtitle"
                        android:text="Notifications on"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_mute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/brand_primary"
                    android:trackTint="@color/brand_light"/>

            </LinearLayout>

            <View style="@style/Divider"/>

            <!-- ═══ SECTION: SOUND ═══ -->
            <TextView
                style="@style/SectionHeader"
                android:text="SOUND"/>

            <!-- Ringtone row -->
            <LinearLayout
                android:id="@+id/row_ringtone"
                style="@style/SettingsRow">

                <ImageView
                    style="@style/SettingsIcon"
                    android:src="@drawable/ic_ringtone"
                    android:tint="@color/brand_primary"/>

                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView
                        style="@style/SettingsTitle"
                        android:text="Ringtone"/>
                    <TextView
                        android:id="@+id/tv_ringtone_value"
                        style="@style/SettingsSubtitle"
                        android:text="Default"/>
                </LinearLayout>

                <ImageView
                    style="@style/ChevronIcon"/>

            </LinearLayout>

            <View style="@style/Divider"/>

            <!-- ═══ SECTION: VIBRATION ═══ -->
            <TextView
                style="@style/SectionHeader"
                android:text="VIBRATION"/>

            <LinearLayout
                android:id="@+id/row_vibrate"
                style="@style/SettingsRow">

                <ImageView
                    style="@style/SettingsIcon"
                    android:src="@drawable/ic_vibration"
                    android:tint="@color/brand_primary"/>

                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView
                        style="@style/SettingsTitle"
                        android:text="Vibration"/>
                    <TextView
                        android:id="@+id/tv_vibrate_value"
                        style="@style/SettingsSubtitle"
                        android:text="Default"/>
                </LinearLayout>

                <ImageView
                    style="@style/ChevronIcon"/>

            </LinearLayout>

            <View style="@style/Divider"/>

            <!-- ═══ SECTION: LED ═══ -->
            <TextView
                style="@style/SectionHeader"
                android:text="NOTIFICATION LIGHT"/>

            <LinearLayout
                android:id="@+id/row_led"
                style="@style/SettingsRow">

                <ImageView
                    style="@style/SettingsIcon"
                    android:src="@drawable/ic_light"
                    android:tint="@color/brand_primary"/>

                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView
                        style="@style/SettingsTitle"
                        android:text="LED Color"/>
                    <TextView
                        android:id="@+id/tv_led_value"
                        style="@style/SettingsSubtitle"
                        android:text="Default"/>
                </LinearLayout>

                <ImageView
                    style="@style/ChevronIcon"/>

            </LinearLayout>

            <View style="@style/Divider"/>

            <!-- ═══ SECTION: PREVIEW ═══ -->
            <TextView
                style="@style/SectionHeader"
                android:text="PRIVACY"/>

            <LinearLayout
                android:id="@+id/row_preview"
                style="@style/SettingsRow">

                <ImageView
                    style="@style/SettingsIcon"
                    android:src="@drawable/ic_preview"
                    android:tint="@color/brand_primary"/>

                <LinearLayout style="@style/SettingsTextBlock">
                    <TextView
                        style="@style/SettingsTitle"
                        android:text="Show Message Preview"/>
                    <TextView
                        android:id="@+id/tv_preview_sub"
                        style="@style/SettingsSubtitle"
                        android:text="Message text shown in notification"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/brand_primary"
                    android:trackTint="@color/brand_light"/>

            </LinearLayout>

            <View style="@style/Divider"/>

            <!-- ═══ RESET BUTTON ═══ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="24dp"
                android:text="Reset to Default"
                android:textColor="@color/error"
                app:backgroundTint="@color/surface"
                app:strokeColor="@color/error"
                app:strokeWidth="1dp"
                app:cornerRadius="10dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
