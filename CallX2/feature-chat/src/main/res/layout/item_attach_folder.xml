<?xml version="1.0" encoding="utf-8"?>
<!--
    One row in the "Recents ▾" folder-picker popup (see AttachSheetFolderPicker /
    AttachFolderAdapter) — cover thumbnail, folder name + item count, and a
    checkmark shown only on the currently-active folder. Mirrors the reference
    screenshot's Recents/Camera/Videos/Screenshots/Downloads/WhatsApp list.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/folder_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/folder_thumb_card"
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/folder_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#2A2A2A"
            android:scaleType="centerCrop"/>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/folder_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:text="Recents"
        android:textColor="@color/text_primary"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/folder_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="0 items"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"/>

    <ImageView
        android:id="@+id/folder_check"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="10dp"
        android:src="@drawable/ic_check_green"
        android:contentDescription="Selected"
        android:visibility="invisible"/>

    <!--
        Right-pointing accessory chevron — GONE for real folder rows, shown
        only for the two action rows appended after WhatsApp ("More apps" /
        "See more"), matching the reference screenshot exactly (those two
        don't filter the grid, they hand off to the system content chooser /
        Photos picker instead — see AttachFolderAdapter#onBindViewHolder).
    -->
    <ImageView
        android:id="@+id/folder_chevron"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="10dp"
        android:src="@drawable/ic_chevron_right"
        android:visibility="gone"/>

</LinearLayout>
