<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_brand"
        app:elevation="2dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/transparent"
            app:titleTextColor="@color/white"
            app:subtitleTextColor="@color/white_70"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Closed topic banner -->
    <LinearLayout
        android:id="@+id/banner_topic_closed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="10dp"
        android:background="#FFFDE7"
        android:visibility="gone">
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_lock"
            android:tint="#F57F17"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This topic is closed — only admins can post"
            android:textColor="#F57F17"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Anonymous status banner -->
    <TextView
        android:id="@+id/tv_anon_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎭 Posting anonymously — your identity is hidden"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@color/brand_primary"
        android:visibility="gone"/>

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_topic_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"/>

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <!-- Anonymous toggle -->
        <ImageButton
            android:id="@+id/btn_anon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_anon"
            android:background="@drawable/circle_grey_light"
            android:padding="6dp"
            android:alpha="0.4"
            android:layout_marginEnd="6dp"
            android:visibility="gone"
            android:contentDescription="Toggle anonymous posting"/>

        <!-- Message input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            android:hint="Message…"
            android:layout_marginEnd="6dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="5"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="actionSend"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Send button -->
        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/circle_primary"
            android:padding="10dp"
            android:contentDescription="Send message"/>
    </LinearLayout>

</LinearLayout>
