<?xml version="1.0" encoding="utf-8"?>
<!-- item_message_received.xml — SwipeReplySystem v1: translationX-safe wrapper -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:padding="3dp">

    <!-- Date header separator — shown when this message is the first of a new day -->
    <TextView
        android:id="@+id/tv_date_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_date_chip"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Row: avatar + bubble (this whole view gets translationX during swipe) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical">

        <!-- Group sender avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_sender_avatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="6dp"
            android:layout_marginBottom="2dp"
            android:layout_gravity="bottom"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Group sender name -->
            <TextView
                android:id="@+id/tv_sender_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="2dp"/>

            <!-- Bubble row: bubble(75%) + spacer(25%) keeps received bubble left-aligned -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/ll_bubble"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:background="@drawable/bubble_received"
                    android:minWidth="80dp">

                <!-- ═══ UPGRADED REPLY PREVIEW — left border + clickable ═══ -->
                <LinearLayout
                    android:id="@+id/ll_reply_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_reply_preview_received"
                    android:layout_margin="4dp"
                    android:minWidth="120dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:visibility="gone">

                    <!-- Left border indicator -->
                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/brand_primary"
                        android:minHeight="36dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <TextView
                            android:id="@+id/tv_reply_sender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/brand_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                        <TextView
                            android:id="@+id/tv_reply_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/bubble_received_text"
                            android:textSize="12sp"
                            android:maxLines="2"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <!-- Reply media thumbnail -->
                    <ImageView
                        android:id="@+id/iv_reply_thumb"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:scaleType="centerCrop"
                        android:layout_margin="4dp"
                        android:visibility="gone"/>

                </LinearLayout>
                <!-- ═══ END REPLY PREVIEW ═══ -->

                <!-- ═══ OVERLAY GROUP: media/text + time+tick pill floating on bottom-right ═══ -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="58dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/bubble_received_text"
                    android:textSize="15sp"
                    android:lineSpacingExtra="2dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_edited"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  edited"
                    android:textSize="10sp"
                    android:textColor="#88000000"
                    android:textStyle="italic"
                    android:paddingStart="12dp"
                    android:paddingBottom="4dp"
                    android:visibility="gone"/>

                <!-- POLISH: Link preview card — visible only for text messages with URLs -->
                <LinearLayout
                    android:id="@+id/ll_link_preview"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_reply_preview_received"
                    android:layout_margin="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:visibility="gone">

                    <!-- OG image thumbnail -->
                    <ImageView
                        android:id="@+id/iv_link_thumb"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <!-- Domain label -->
                        <TextView
                            android:id="@+id/tv_link_domain"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#1565C0"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <!-- Page title -->
                        <TextView
                            android:id="@+id/tv_link_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/bubble_received_text"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginTop="2dp"/>

                        <!-- Page description -->
                        <TextView
                            android:id="@+id/tv_link_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/bubble_received_text"
                            android:textSize="11sp"
                            android:alpha="0.7"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:layout_marginTop="2dp"
                            android:visibility="gone"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- FIX: was hardcoded 240×220dp — portrait photos cropped, landscape squeezed.
                     adjustViewBounds + wrap_content lets the image keep its natural aspect ratio. -->
                <ImageView
                    android:id="@+id/iv_image"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:maxHeight="320dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>

                <FrameLayout
                    android:id="@+id/fl_video"
                    android:layout_width="240dp"
                    android:layout_height="160dp"
                    android:visibility="gone">
                    <ImageView
                        android:id="@+id/iv_video_thumb"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="#1A1A1A"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_gravity="bottom"
                        android:background="#66000000"/>
                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play"
                        android:background="@drawable/circle_primary"
                        android:padding="14dp"/>
                    <TextView
                        android:id="@+id/tv_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="6dp"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:text="0:00"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="#88000000"
                        android:visibility="gone"/>
                    <ProgressBar
                        android:id="@+id/progress_upload"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="bottom"
                        android:max="100"
                        android:progress="0"
                        android:visibility="gone"/>
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/ll_audio"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">
                    <ImageButton
                        android:id="@+id/btn_play_pause"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_play"
                        android:background="@drawable/circle_primary"/>
                    <SeekBar
                        android:id="@+id/seek_audio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tv_audio_dur"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bubble_received_text"
                        android:textSize="11sp"
                        android:gravity="end"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_file"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/file_card_bg"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_pdf"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">
                        <TextView
                            android:id="@+id/tv_file_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/bubble_received_text"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="middle"/>
                        <TextView
                            android:id="@+id/tv_file_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <ImageButton
                        android:id="@+id/btn_download"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_file"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Download"/>
                </LinearLayout>

                <!-- Footer: star + time + status — floats as a pill over bottom-right corner -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="4dp"
                    android:layout_marginTop="-20dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_time_pill"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp">
                    <TextView
                        android:id="@+id/tv_expiry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFCC00"
                        android:textSize="9sp"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/tv_starred_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="9sp"
                        android:layout_marginEnd="3dp"
                        android:visibility="gone"/>
                    <TextView
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="9sp"
                        android:visibility="gone"/>
                </LinearLayout>
                </FrameLayout>

                <!-- Reactions -->
                <LinearLayout
                    android:id="@+id/ll_reactions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#22000000"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_margin="4dp"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/tv_reactions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
</LinearLayout>

