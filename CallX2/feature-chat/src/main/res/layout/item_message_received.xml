<?xml version="1.0" encoding="utf-8"?>
<!--
  item_message_received.xml – ConstraintLayout Flattened (v33 perf pass)

  PERF: was 7 levels of nested LinearLayout (root > avatarRow > nameStack >
  bubbleRow > ll_bubble > contentFrame > footer/reply-column) — each level
  is its own measure+layout pass, repeated for every visible row on every
  scroll frame. Flattened to 2 ConstraintLayouts (root, ll_bubble) + the
  content FrameLayout (kept as-is on purpose — see note below). All IDs,
  visibilities, margins, colors unchanged from the original.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="4dp"
    android:paddingEnd="48dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Group sender avatar — bottom-aligned to the bubble, like the old layout_gravity="bottom" -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_sender_avatar"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/ic_person"
        android:layout_marginBottom="2dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/ll_bubble"/>

    <!-- Group sender name -->
    <TextView
        android:id="@+id/tv_sender_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/brand_primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginStart="13dp"
        android:layout_marginBottom="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_sender_avatar"
        app:layout_goneMarginStart="8dp"/>

    <!-- Forwarded label -->
    <TextView
        android:id="@+id/tv_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↪ Forwarded"
        android:textSize="11sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:layout_marginStart="13dp"
        android:layout_marginBottom="1dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_sender_name"
        app:layout_constraintStart_toEndOf="@id/iv_sender_avatar"
        app:layout_goneMarginStart="8dp"/>

    <!-- Bubble container — was a nested vertical LinearLayout, now flat -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ll_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bubble_received"
        android:minWidth="60dp"
        app:layout_constraintTop_toBottomOf="@id/tv_forwarded"
        app:layout_constraintStart_toEndOf="@id/iv_sender_avatar"
        app:layout_goneMarginStart="0dp"
        android:layout_marginStart="5dp">

        <!-- Reply Preview -->
        <LinearLayout
            android:id="@+id/ll_reply_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_reply_preview_received"
            android:layout_margin="4dp"
            android:minWidth="120dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@color/brand_primary"
                android:minHeight="36dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tv_reply_sender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_reply_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/bubble_received_text"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_reply_thumb"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:layout_margin="4dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!--
            Overlay group: all message content types + footer.
            Kept as a real FrameLayout (not replaced by a Barrier):
            ViewStub.inflate() swaps stub_* IDs out of the tree for the
            inflated layout's own root ID, so a Barrier referencing
            stub_video/stub_audio/etc. would silently stop tracking the
            correct bottom edge the moment a stub inflates. FrameLayout's
            "tallest visible child" auto-sizing handles that transparently.
        -->
        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/ll_reply_preview"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!--
                TEXT MESSAGE
                paddingEnd reserves space for time on last line (WhatsApp style).
                paddingBottom reserves height so footer doesn't cover last line.
            -->
            <TextView
                android:id="@+id/tv_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/msg_bubble_max_width"
                android:paddingStart="8dp"
                android:paddingEnd="6dp"
                android:paddingTop="4dp"
                android:paddingBottom="2dp"
                android:textColor="@color/bubble_received_text"
                android:textSize="15sp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="0dp"
                android:visibility="gone"/>

            <!-- Edited label -->
            <TextView
                android:id="@+id/tv_edited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  edited"
                android:textSize="10sp"
                android:textColor="#88000000"
                android:textStyle="italic"
                android:paddingStart="10dp"
                android:paddingBottom="2dp"
                android:visibility="gone"/>

            <!--
                IMAGE — Compact 180×180dp card.
            -->
            <ImageView
                android:id="@+id/iv_image"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_media_card"
                android:clipToOutline="true"
                android:visibility="gone"/>

            <!--
                MANUAL DOWNLOAD OVERLAY (WhatsApp-style) — sits on top of
                iv_image, same 180x180 footprint. Shown for RECEIVED images
                that haven't been downloaded yet. Bubble shows only the
                blurred low-res thumbnail underneath (already loaded into
                iv_image); user must tap the pill to fetch the full-res file.
                While downloading, icon is swapped for a small spinner and
                tv_download_size shows live percentage instead of the size.
            -->
            <FrameLayout
                android:id="@+id/fl_download_overlay"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="#26000000"
                android:clipToOutline="true"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ll_download_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_download_pill"
                    android:paddingStart="14dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iv_download_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_download_reel"/>

                    <ProgressBar
                        android:id="@+id/pb_download_spinner"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tv_download_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Photo"
                        android:textColor="#FFFFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </FrameLayout>

            <!-- Multi Media Group -->
            <LinearLayout
                android:id="@+id/ll_media_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_media_card"
                android:clipToOutline="true"
                android:padding="2dp"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Video player -->
            <ViewStub
                android:id="@+id/stub_video"
                android:layout="@layout/layout_msg_video"
                android:layout_width="180dp"
                android:layout_height="160dp"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Audio player -->
            <ViewStub
                android:id="@+id/stub_audio"
                android:layout="@layout/layout_msg_audio"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- VIEWSTUB: File card -->
            <ViewStub
                android:id="@+id/stub_file"
                android:layout="@layout/layout_msg_file"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Poll card -->
            <ViewStub
                android:id="@+id/stub_poll"
                android:layout="@layout/layout_msg_poll"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Link preview card -->
            <ViewStub
                android:id="@+id/stub_link_preview"
                android:layout="@layout/layout_msg_link_preview"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- REEL SHARE -->
            <ViewStub
                android:id="@+id/stub_reel_share"
                android:layout="@layout/layout_msg_reel_share"
                android:layout_width="165dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:visibility="gone"/>

            <!-- CONTACT SHARE -->
            <ViewStub
                android:id="@+id/stub_contact"
                android:layout="@layout/item_msg_contact"
                android:layout_width="165dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:visibility="gone"/>

            <!-- LOCATION SHARE -->
            <ViewStub
                android:id="@+id/stub_location"
                android:layout="@layout/item_msg_location"
                android:layout_width="165dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:visibility="gone"/>

            <!--
                FOOTER: time — inline at bottom-end of bubble (WhatsApp style).
                Sits on same visual row as text end. No separate row.
            -->
            <LinearLayout
                android:id="@+id/ll_msg_footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="5dp"
                android:layout_marginBottom="3dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_expiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFCC00"
                    android:textSize="9sp"
                    android:layout_marginEnd="2dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_starred_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="9sp"
                    android:layout_marginEnd="2dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAFFFFFF"
                    android:textSize="9sp"/>

                <!-- tv_status stub — always GONE for received -->
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Watching dot -->
            <View
                android:id="@+id/view_seen_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="-3dp"
                android:layout_marginStart="-3dp"
                android:background="@drawable/dot_watching_msg"
                android:visibility="gone"/>

            <!-- Live playback badge -->
            <TextView
                android:id="@+id/tv_listening_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_listening_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="🎧 listening…"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- Reactions -->
        <LinearLayout
            android:id="@+id/ll_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#22000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_margin="3dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/content_frame"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_reactions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Quick Forward Button -->
    <ImageButton
        android:id="@+id/btn_quick_forward"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_forward_msg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginStart="4dp"
        android:contentDescription="Forward"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/ll_bubble"
        app:layout_constraintTop_toTopOf="@id/ll_bubble"
        app:layout_constraintBottom_toBottomOf="@id/ll_bubble"/>

</androidx.constraintlayout.widget.ConstraintLayout>
