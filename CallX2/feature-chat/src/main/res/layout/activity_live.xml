<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera preview placeholder (integrate Agora SurfaceView here) -->
    <View
        android:id="@+id/live_camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A2E"/>

    <!-- LIVE badge + viewer count — top row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_gravity="top">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" LIVE "
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="#E53935"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <TextView
            android:id="@+id/tv_live_viewer_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="0 viewers"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="#66000000"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Switch Camera -->
        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#66000000"
            android:src="@drawable/ic_switch_camera"
            android:padding="8dp"
            android:layout_marginEnd="8dp"/>

        <!-- End Live -->
        <ImageButton
            android:id="@+id/btn_end_live"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#CCE53935"
            android:src="@drawable/ic_close"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Bottom area: chat + message input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:padding="8dp">

        <!-- Live chat messages -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_live_chat"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:overScrollMode="never"/>

        <!-- Message input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#88000000"
            android:padding="6dp">

            <EditText
                android:id="@+id/et_live_message"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="#44FFFFFF"
                android:hint="Message bhejo..."
                
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:imeOptions="actionSend"
                android:singleLine="true"/>

            <ImageButton
                android:id="@+id/btn_live_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="#5B5BF6"
                android:src="@drawable/ic_send"
                android:padding="8dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
