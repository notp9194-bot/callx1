<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-screen chat media editor — comprehensive production-level layout.

  Structure (back to front):
   - mediaContainer: photo/video preview + sticker layer + draw overlay
   - topToolbar: Close / Download / HD / Rotate / Crop / Sticker / Aa / Pencil / [Trim for videos]
   - drawToolsRow: color swatches + brush size slider + Undo + Done
   - emojiRow: (legacy quick-row, kept hidden; main picker is ChatStickerPickerActivity)
   - tvSwipeHint: "Swipe up for filters" hint
   - bottomBar: delete + thumb strip / caption + send
   - filterPanel: slides up from below when filter carousel is open
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootMediaEdit"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- ── Photo / Video + overlay layers ───────────────────────────── -->
    <FrameLayout
        android:id="@+id/mediaContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@null"
            tools:src="@android:color/darker_gray"/>

        <!-- Video play badge — shown for video items -->
        <ImageView
            android:id="@+id/ivVideoPlayBadge"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:padding="16dp"
            android:background="@drawable/bg_media_edit_video_badge"
            android:src="@drawable/ic_media_edit_send"
            android:visibility="gone"
            android:contentDescription="@null"/>

        <!-- Sticker / text overlay layer -->
        <FrameLayout
            android:id="@+id/stickerLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Freehand draw overlay -->
        <com.callx.app.conversation.controllers.DrawOverlayView
            android:id="@+id/drawOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </FrameLayout>

    <!-- ── Top toolbar ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="10dp"
        android:paddingTop="36dp"
        android:paddingBottom="10dp"
        android:background="#88000000">

        <!-- Close -->
        <ImageButton
            android:id="@+id/btnEditClose"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_close"
            android:scaleType="center"
            android:padding="9dp"
            android:contentDescription="Close"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Download -->
        <ImageButton
            android:id="@+id/btnEditDownload"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_download"
            android:scaleType="center"
            android:padding="10dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Save to gallery"/>

        <!-- HD toggle -->
        <TextView
            android:id="@+id/btnEditHd"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="HD"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_hd_toggle_inactive"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Rotate (image only) -->
        <ImageButton
            android:id="@+id/btnEditRotate"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_rotate"
            android:scaleType="center"
            android:padding="9dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Rotate"/>

        <!-- Crop (image only) -->
        <ImageButton
            android:id="@+id/btnEditCrop"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_crop"
            android:scaleType="center"
            android:padding="9dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Crop"/>

        <!-- Trim (video only — toggled via visibility in code) -->
        <TextView
            android:id="@+id/btnEditTrim"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="✂ Trim"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_hd_toggle_inactive"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Sticker picker -->
        <ImageButton
            android:id="@+id/btnEditSticker"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_sticker"
            android:scaleType="center"
            android:padding="9dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Add sticker"/>

        <!-- Text overlay -->
        <ImageButton
            android:id="@+id/btnEditText"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_text"
            android:scaleType="center"
            android:padding="9dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="Add text"/>

        <!-- Freehand draw -->
        <ImageButton
            android:id="@+id/btnEditDraw"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_media_edit_toolbtn"
            android:src="@drawable/ic_media_edit_draw"
            android:scaleType="center"
            android:padding="9dp"
            android:contentDescription="Draw"/>
    </LinearLayout>

    <!-- ── Emoji quick-row (legacy / hidden) ────────────────────────── -->
    <HorizontalScrollView
        android:id="@+id/emojiRow"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="120dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/emojiRowContent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════════════════════════════
         Draw tools panel — slides up from BOTTOM, fully replaces bottomBar
         while pencil/draw mode is active. Contains:
           Row 1 : color palette (horizontal scroll of circles)
           Row 2 : eraser toggle | brush size label | SeekBar | brush preview dot
           Row 3 : Undo  ·  spacer  ·  Done
         All rows are always visible — no marginBottom hack needed because
         bottomBar is hidden programmatically when this panel shows.
         ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/drawToolsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#EE111111"
        android:paddingBottom="20dp"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- ── Row 0: thin top drag handle indicator ── -->
        <View
            android:layout_width="36dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:background="#55FFFFFF"/>

        <!-- ── Row 1: Color swatches (horizontal scroll) ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:scrollbars="none"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/drawColorRow"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>
        </HorizontalScrollView>

        <!-- ── Row 2: Eraser + Size label + SeekBar + preview dot ── -->
        <LinearLayout
            android:id="@+id/brushSizeRow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginTop="4dp">

            <!-- Eraser toggle -->
            <TextView
                android:id="@+id/btnDrawEraser"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⌫"
                android:textSize="18sp"
                android:textColor="#CCFFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_media_edit_toolbtn"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Eraser"/>

            <!-- Small brush preview dot (left) -->
            <View
                android:id="@+id/dotBrushSmall"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:background="#AAFFFFFF"
                android:layout_marginEnd="8dp"/>

            <!-- Brush size SeekBar -->
            <SeekBar
                android:id="@+id/sbBrushSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="44"
                android:progress="8"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF"/>

            <!-- Large brush preview dot (right) -->
            <View
                android:id="@+id/dotBrushLarge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="#AAFFFFFF"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- ── Row 3: Undo · Eraser hint · Done ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="2dp">

            <!-- Undo button -->
            <LinearLayout
                android:id="@+id/btnDrawUndo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_media_edit_toolbtn"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↩"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Undo"
                    android:textColor="#DDDDDD"
                    android:textSize="13sp"/>
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <!-- Clear all strokes -->
            <TextView
                android:id="@+id/btnDrawClear"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Clear"
                android:textColor="#FF6666"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_media_edit_toolbtn"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Done drawing -->
            <TextView
                android:id="@+id/btnDrawDone"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Done"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#40C060"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Swipe hint ────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSwipeHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="122dp"
        android:text="↑ Swipe for filters"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        android:background="#44000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"/>

    <!-- ── Bottom bar (delete + thumbs / caption + send) ────────────── -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#EE000000">

        <!-- Top row: delete button + thumbnail strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Delete current item -->
            <ImageButton
                android:id="@+id/btnEditDelete"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_delete"
                android:scaleType="center"
                android:padding="10dp"
                android:background="@drawable/circle_media_edit_delete"
                android:contentDescription="Delete"/>

            <!-- Thumbnail scroll strip -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/thumbStripContent"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"/>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- Bottom row: caption + send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="16dp">

            <!-- Caption input -->
            <EditText
                android:id="@+id/etCaption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_media_edit_caption_pill"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="9dp"
                android:paddingBottom="9dp"
                android:hint="Add a caption…"
                android:textColorHint="#77FFFFFF"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:maxLines="3"
                android:inputType="text|textMultiLine"
                android:imeOptions="actionDone"/>

            <!-- Send button -->
            <ImageButton
                android:id="@+id/btnEditSend"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_send"
                android:scaleType="center"
                android:padding="10dp"
                android:background="@drawable/bg_btn_accept_gradient"
                android:contentDescription="Send"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Filter panel (slides up from below) ──────────────────────── -->
    <LinearLayout
        android:id="@+id/filterPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#EE111111"
        android:visibility="gone">

        <!-- Collapse handle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnFilterCollapse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Filters"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Filter strip -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:scrollbars="none"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:id="@+id/filterStripContent"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp"/>
        </HorizontalScrollView>
    </LinearLayout>

</FrameLayout>
