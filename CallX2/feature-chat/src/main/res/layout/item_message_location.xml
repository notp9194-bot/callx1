<?xml version="1.0" encoding="utf-8"?>
<!--
  item_message_location.xml
  Location message bubble — shows static map thumbnail + address + open button.
  Tapping opens Google Maps at the pinned coordinates.

  Usage: Inflate from MessagePagingAdapter when msg.type == "location"
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="3dp">

    <!-- Date header (reused pattern from other bubbles) -->
    <TextView
        android:id="@+id/tv_date_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_date_chip"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Bubble (gravity set in code for sent=end / received=start) -->
    <LinearLayout
        android:id="@+id/ll_location_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_sent"
        android:minWidth="220dp"
        android:maxWidth="260dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Static map thumbnail -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_map_thumb"
            android:layout_width="260dp"
            android:layout_height="130dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_map_placeholder"
            app:shapeAppearanceOverlay="@style/MapThumbShape"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <!-- Address + "Open Maps" row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_pin"
                android:tint="@color/brand_primary"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tv_location_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location"
                android:textColor="#111111"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"/>

        </LinearLayout>

        <!-- "Open in Maps" link row -->
        <TextView
            android:id="@+id/tv_open_maps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Open in Maps →"
            android:textColor="@color/brand_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"/>

        <!-- Timestamp + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="10sp"/>

            <ImageView
                android:id="@+id/iv_status"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_single_tick"
                android:tint="#888888"
                android:layout_marginStart="3dp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
