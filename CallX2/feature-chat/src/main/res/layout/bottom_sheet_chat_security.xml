<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="#CCCCCC"
        android:layout_margin="10dp"/>

    <!-- Header with gradient background -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tv_shield_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="🔒"
            android:textSize="22sp"
            android:background="@drawable/bg_security_icon_circle"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy Settings"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick controls for this chat"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" android:layout_marginBottom="8dp"/>

    <!-- ── Toggle Rows ─────────────────────────────────────────────────── -->

    <!-- Read Receipts -->
    <LinearLayout
        android:id="@+id/row_read_receipts"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="✅"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_blue"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read Receipts"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blue tick when message is read"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_read_receipts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Incognito Mode -->
    <LinearLayout
        android:id="@+id/row_incognito"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="🕶️"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_purple"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incognito Mode"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hide typing &amp; online status"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_incognito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Ghost Mode -->
    <LinearLayout
        android:id="@+id/row_ghost"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="👻"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_dark"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ghost Mode"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete invisibility — no last seen, typing"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_ghost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Screenshot Lock -->
    <LinearLayout
        android:id="@+id/row_screenshot"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="📵"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_red"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screenshot Lock"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Block screenshots inside CallX"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_screenshot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

    <!-- ── Visibility Rows (tappable) ─────────────────────────────────── -->

    <!-- Last Seen -->
    <LinearLayout
        android:id="@+id/row_last_seen"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="🕐"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_orange"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Seen"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_last_seen_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everyone"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- Profile Photo -->
    <LinearLayout
        android:id="@+id/row_profile_photo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="🖼️"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_green"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile Photo"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_profile_photo_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everyone"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>


    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

    <!-- Status Updates -->
    <LinearLayout
        android:id="@+id/row_status_privacy"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="📡"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_blue"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Updates"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_status_privacy_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everyone"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- About / Bio -->
    <LinearLayout
        android:id="@+id/row_about_privacy"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="📝"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_purple"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About / Bio"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_about_privacy_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everyone"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- Who Can Call Me -->
    <LinearLayout
        android:id="@+id/row_call_permission"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="📞"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_green"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Who Can Call Me"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_call_permission_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everyone"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- Who Can Add Me to Groups -->
    <LinearLayout
        android:id="@+id/row_group_add"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="👥"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_orange"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Who Can Add Me to Groups"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_group_add_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Everyone"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

    <!-- Disappearing Messages -->
    <LinearLayout
        android:id="@+id/row_disappearing"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="⏳"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_red"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disappearing Messages"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:id="@+id/tv_disappearing_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Off"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="22sp"
            android:textColor="#CCCCCC"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- Silence Unknown Callers -->
    <LinearLayout
        android:id="@+id/row_silence_unknown"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="🔕"
            android:textSize="20sp"
            android:background="@drawable/bg_sec_row_dark"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silence Unknown Callers"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-reject calls from non-contacts"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_silence_unknown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#F0F0F0" android:layout_marginTop="4dp" android:layout_marginBottom="12dp"/>

    <!-- Full Settings Button -->
    <LinearLayout
        android:id="@+id/btn_open_full_settings"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_security_full_btn">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️  Open Full Privacy &amp; Security"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>

</ScrollView>
