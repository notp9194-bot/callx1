<?xml version="1.0" encoding="utf-8"?>
<!--
  item_message_sent.xml – Flattened outer row + deterministic bubble (v39)

  PERF: outer row was root > bubbleRow > ll_bubble (3 LinearLayout levels)
  — flattened to a single root ConstraintLayout that positions the bubble
  directly, no wrapper row needed.

  ll_bubble itself is a plain vertical LinearLayout (wrap_content), NOT
  ConstraintLayout — an earlier version made it ConstraintLayout with
  0dp/MATCH_CONSTRAINT children, which caused a real bug: ConstraintLayout
  resolves that combination in two measure passes, and the wrongly-sized
  first-pass render could stay visible alongside the corrected one
  (cold-open oversized bubbles, "double bubble" ghosting, bubbles
  shrinking on any forced rebind). Plain LinearLayout wrap_content has
  exactly one deterministic measure pass — this is also how WhatsApp
  itself builds the bubble container. All IDs, visibilities, margins
  unchanged from the original.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="48dp"
    android:paddingEnd="4dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Pinned label -->
    <TextView
        android:id="@+id/tv_pinned_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📌 Pinned"
        android:textSize="10sp"
        android:textColor="#E65100"
        android:layout_marginBottom="1dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Forwarded label -->
    <TextView
        android:id="@+id/tv_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↪ Forwarded"
        android:textSize="11sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:layout_marginBottom="1dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_pinned_label"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Quick Forward Button -->
    <ImageButton
        android:id="@+id/btn_quick_forward"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_forward_msg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="4dp"
        android:contentDescription="Forward"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/ll_bubble"
        app:layout_constraintTop_toTopOf="@id/ll_bubble"
        app:layout_constraintBottom_toBottomOf="@id/ll_bubble"/>

    <!--
        Bubble container — WhatsApp-style: plain vertical LinearLayout,
        wrap_content. Deterministic single-pass sizing — no
        MATCH_CONSTRAINT/0dp children, so there is no "first pass
        estimates wrong, second pass corrects it" ambiguity. That
        ambiguity (previously here as a ConstraintLayout) was the actual
        cause of both the cold-open-oversized-bubble bug AND the
        double-bubble ghosting: a stale, wrongly-sized first-pass render
        was staying on screen alongside the corrected second-pass one.
        The OUTER row (avatar/name/bubble placement) stays flattened as
        ConstraintLayout — that part never had this ambiguity, since
        none of ITS children are MATCH_CONSTRAINT inside a WRAP_CONTENT
        parent.
    -->
    <LinearLayout
        android:id="@+id/ll_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_sent"
        android:minWidth="60dp"
        app:layout_constraintTop_toBottomOf="@id/tv_forwarded"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reply Preview -->
        <LinearLayout
            android:id="@+id/ll_reply_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_reply_preview_sent"
            android:layout_margin="4dp"
            android:minWidth="120dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="#FFD700"
                android:minHeight="36dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tv_reply_sender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFD54F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_reply_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#DDFFFFFF"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_reply_thumb"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:layout_margin="4dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Edited label -->
        <TextView
            android:id="@+id/tv_edited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  edited"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:textStyle="italic"
            android:paddingStart="10dp"
            android:paddingBottom="2dp"
            android:visibility="gone"/>

        <!--
            Overlay group: all message content types + footer.
            Kept as a real FrameLayout (not replaced by a Barrier):
            ViewStub.inflate() swaps stub_* IDs out of the tree for the
            inflated layout's own root ID, so a Barrier referencing
            stub_video/stub_audio/etc. would silently stop tracking the
            correct bottom edge the moment a stub inflates. FrameLayout's
            "tallest visible child" auto-sizing handles that transparently.
        -->
        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <!--
                TEXT MESSAGE
                paddingEnd reserves space for time+tick on last line (WhatsApp style).
                paddingBottom reserves height so footer doesn't cover last line.
            -->
            <TextView
                android:id="@+id/tv_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/msg_bubble_max_width"
                android:paddingStart="8dp"
                android:paddingEnd="6dp"
                android:paddingTop="4dp"
                android:paddingBottom="2dp"
                android:textColor="@color/bubble_sent_text"
                android:textSize="15sp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="0dp"
                android:breakStrategy="simple"
                android:hyphenationFrequency="none"
                android:visibility="gone"/>

            <!--
                IMAGE — Compact 180×180dp card.
            -->
            <ImageView
                android:id="@+id/iv_image"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_media_card"
                android:clipToOutline="true"
                android:visibility="gone"/>

            <!-- Multi Media Group -->
            <LinearLayout
                android:id="@+id/ll_media_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_media_card"
                android:clipToOutline="true"
                android:padding="2dp"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Video player -->
            <ViewStub
                android:id="@+id/stub_video"
                android:layout="@layout/layout_msg_video"
                android:layout_width="180dp"
                android:layout_height="160dp"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Audio player -->
            <ViewStub
                android:id="@+id/stub_audio"
                android:layout="@layout/layout_msg_audio"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- VIEWSTUB: File card -->
            <ViewStub
                android:id="@+id/stub_file"
                android:layout="@layout/layout_msg_file"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Poll card -->
            <ViewStub
                android:id="@+id/stub_poll"
                android:layout="@layout/layout_msg_poll"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- VIEWSTUB: Link preview card -->
            <ViewStub
                android:id="@+id/stub_link_preview"
                android:layout="@layout/layout_msg_link_preview"
                android:layout_width="@dimen/msg_bubble_max_width"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- REEL SHARE -->
            <ViewStub
                android:id="@+id/stub_reel_share"
                android:layout="@layout/layout_msg_reel_share"
                android:layout_width="165dp"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:visibility="gone"/>

            <!-- CONTACT SHARE -->
            <ViewStub
                android:id="@+id/stub_contact"
                android:layout="@layout/item_msg_contact"
                android:layout_width="165dp"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:visibility="gone"/>

            <!-- LOCATION SHARE -->
            <ViewStub
                android:id="@+id/stub_location"
                android:layout="@layout/item_msg_location"
                android:layout_width="165dp"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:visibility="gone"/>

            <!--
                FOOTER: time + tick — inline at bottom-end of bubble (WhatsApp style).
                Sits on same visual row as text end. No separate row.
            -->
            <LinearLayout
                android:id="@+id/ll_msg_footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="5dp"
                android:layout_marginBottom="3dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Sentinel: lets bindTickOnly detect sent bubble -->
                <LinearLayout
                    android:id="@+id/ll_tick_pill"
                    android:layout_width="0dp"
                    android:layout_height="0dp"/>

                <TextView
                    android:id="@+id/tv_expiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFCC00"
                    android:textSize="9sp"
                    android:layout_marginEnd="2dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_starred_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="9sp"
                    android:layout_marginEnd="2dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/bubble_time_sent"
                    android:textSize="9sp"/>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textSize="12sp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Per-message watching dot -->
            <View
                android:id="@+id/view_seen_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-3dp"
                android:layout_marginEnd="-3dp"
                android:background="@drawable/dot_watching_msg"
                android:visibility="gone"/>

            <!-- Live playback badge -->
            <TextView
                android:id="@+id/tv_listening_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginTop="4dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_listening_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="🎧 listening…"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"/>

        </FrameLayout>

    </LinearLayout>

    <!--
        Reaction badge — WhatsApp style: floats OUTSIDE the bubble, hanging
        over its bottom-end corner. Previously this was a child INSIDE
        ll_bubble's vertical stack with a dark pill background — that made
        it render as an extra row taking up bubble space with a visible box,
        instead of a small overlapping emoji badge. Now it's a sibling of
        ll_bubble, constrained to its bottom-end corner and pulled down/out
        with a negative margin so it clearly overlaps without covering the
        message text or footer. No background/padding box — plain emoji
        only, with a soft shadow so it stays legible over any bubble color.
    -->
    <LinearLayout
        android:id="@+id/ll_reactions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:elevation="2dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="-10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/ll_bubble"
        app:layout_constraintBottom_toBottomOf="@id/ll_bubble">

        <TextView
            android:id="@+id/tv_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:shadowColor="#66000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
