<?xml version="1.0" encoding="utf-8"?>
<!--
  Single thumbnail in the media-edit bottom strip.
  Includes video badge, trim indicator badge, and selection highlight.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="58dp"
    android:layout_height="58dp"
    android:layout_marginEnd="6dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp">

    <!-- Thumbnail image -->
    <ImageView
        android:id="@+id/ivThumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_media_edit_thumb_selected"
        android:contentDescription="@null"/>

    <!-- Video play badge (center) -->
    <ImageView
        android:id="@+id/ivVideoBadge"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_media_edit_send"
        android:visibility="gone"
        android:contentDescription="@null"/>

    <!-- Trim done badge (bottom-left green scissors indicator) -->
    <TextView
        android:id="@+id/ivTrimBadge"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="2dp"
        android:text="✂"
        android:textSize="9sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="#CC40C060"
        android:visibility="gone"/>

    <!-- Remove (×) button (top-right) -->
    <ImageButton
        android:id="@+id/btnThumbRemove"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:layout_margin="1dp"
        android:background="@drawable/circle_media_edit_delete"
        android:src="@drawable/ic_media_edit_close"
        android:scaleType="center"
        android:padding="4dp"
        android:contentDescription="Remove"/>

</FrameLayout>
