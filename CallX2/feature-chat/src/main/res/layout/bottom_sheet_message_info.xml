<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_msg_info_sheet"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_sheet_handle"/>

    <!-- Header: title + close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Message Info"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F172A"/>

        <FrameLayout
            android:id="@+id/btn_info_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_close_btn"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_close"
                android:tint="#64748B"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Recipient row (avatar + name) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/iv_info_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/bg_info_icon_sent"
            android:padding="8dp"
            android:tint="#FFFFFF"
            android:scaleType="centerCrop"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_info_recipient"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="—"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Message preview bubble -->
    <LinearLayout
        android:id="@+id/info_msg_preview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@drawable/bg_info_bubble_sent"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tv_info_msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:maxWidth="240dp"
            android:maxLines="4"
            android:ellipsize="end"
            android:text="Message preview"/>

        <TextView
            android:id="@+id/tv_info_msg_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:letterSpacing="0.08"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginHorizontal="16dp" android:background="#F1F5F9"/>

    <!-- ── SENT ROW ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_info_row_ripple"
        android:clickable="false">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_info_icon_sent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_single_tick"
                android:tint="#FFFFFF"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sent"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_sent_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginTop="1dp"
                android:text="—"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_sent_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="11sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginHorizontal="16dp" android:background="#F1F5F9"/>

    <!-- ── DELIVERED ROW ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_info_row_ripple"
        android:clickable="false">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_info_icon_delivered">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_double_tick"
                android:tint="#FFFFFF"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delivered"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_delivered_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginTop="1dp"
                android:text="Waiting..."/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_delivered_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="11sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginHorizontal="16dp" android:background="#F1F5F9"/>

    <!-- ── SEEN ROW ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@drawable/bg_info_row_ripple"
        android:clickable="false">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_info_icon_seen">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_double_tick_blue"
                android:tint="#FFFFFF"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seen"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_seen_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginTop="1dp"
                android:text="Not seen yet"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_seen_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#94A3B8"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- ── EDITED ROW (hidden by default) ────────────────────────────── -->
    <LinearLayout
        android:id="@+id/row_edited"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginHorizontal="16dp" android:background="#F1F5F9"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_info_icon_edited">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_close"
                    android:tint="#FFFFFF"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edited"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_edited_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
