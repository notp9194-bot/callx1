<?xml version="1.0" encoding="utf-8"?>
<!--
    item_group_topic.xml
    Row item for the GroupTopicsActivity RecyclerView.
    Shows: emoji icon | name + lock/pin indicators | last message | time | unread badge
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Emoji Icon Circle -->
        <androidx.cardview.widget.CardView
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/brand_primary">
            <TextView
                android:id="@+id/tv_topic_emoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="💬"
                android:textSize="24sp"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <!-- Content column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp">

            <!-- Name row: topic name + lock/pin icons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_topic_name"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="General"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <ImageView
                    android:id="@+id/iv_topic_pin"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_pin"
                    android:tint="@color/brand_primary"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/iv_topic_lock"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_lock"
                    android:tint="@color/text_muted"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Description (optional) -->
            <TextView
                android:id="@+id/tv_topic_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>

            <!-- Last message preview -->
            <TextView
                android:id="@+id/tv_topic_last_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No messages yet"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Right column: time + unread badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end|center_vertical">

            <TextView
                android:id="@+id/tv_topic_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:layout_marginBottom="4dp"/>

            <!-- Unread badge -->
            <FrameLayout
                android:id="@+id/badge_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tv_topic_unread_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="20dp"
                    android:text="0"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@drawable/badge_bg"/>
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_gravity="bottom"
        android:background="@color/divider"
        android:layout_marginStart="80dp"/>

</FrameLayout>
