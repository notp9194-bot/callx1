<?xml version="1.0" encoding="utf-8"?>
<!--
    item_group.xml — v82 canvas optimisation

    WHAT CHANGED vs v24:
      • CardView root        →  plain FrameLayout with bg_chat_row background
        (cardElevation was already 0dp — no visual change; removes CardView's
        extra measure/layout pass on every RecyclerView bind).
      • tv_group_name (TextView)     →  left side of ChatListNameTimeView (canvas)
      • tv_group_members (TextView)  →  right side of ChatListNameTimeView (canvas)
      • ChatListLastMessageView — UNCHANGED (already canvas since v24).
      • iv_group_avatar (CircleImageView) — UNCHANGED; Glide pipeline kept.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_chat_row">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Group avatar — Glide-loaded, pipeline unchanged -->
        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_group_avatar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_group"
                android:background="@drawable/circle_primary"
                android:padding="12dp"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/brand_primary"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>
        </FrameLayout>

        <!-- Text column -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <!-- v82: group name (left bold) + members count (right muted) — one canvas view -->
            <com.callx.app.chatlist.canvas.ChatListNameTimeView
                android:id="@+id/view_group_name_members"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- v24: last-message + ticks + typing — canvas (unchanged) -->
            <com.callx.app.chatlist.canvas.ChatListLastMessageView
                android:id="@+id/view_group_last_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
