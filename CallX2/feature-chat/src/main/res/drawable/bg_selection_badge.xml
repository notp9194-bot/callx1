<?xml version="1.0" encoding="utf-8"?>
<!-- Filled circle + white ring, used for the numbered multi-select badge
     on selected attach-sheet thumbnails and the send-button count pill. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
    <item android:top="1.5dp" android:bottom="1.5dp" android:left="1.5dp" android:right="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#1FA855"/>
        </shape>
    </item>
</layer-list>
