<?xml version="1.0" encoding="utf-8"?>
<!--
  Circular "+N" overflow badge for the group watching-banner avatar stack
  (3rd+ member currently watching this group chat). Same gradient as
  bg_watching_strip + a green ring matching the watching avatars' border,
  so it reads as part of the same overlapping stack.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#6C2DC7"
                android:centerColor="#A855F7"
                android:endColor="#EC4899"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#22C55E"/>
        </shape>
    </item>
</layer-list>
