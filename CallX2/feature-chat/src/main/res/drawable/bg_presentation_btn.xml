<?xml version="1.0" encoding="utf-8"?>
<!-- v169 — "Slide" button background in the advanced toolbar -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="#1A1976D2"/>
            <stroke android:width="1dp" android:color="#FF1976D2"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp"/>
            <solid android:color="#0D1976D2"/>
            <stroke android:width="1dp" android:color="#661976D2"/>
        </shape>
    </item>
</selector>
