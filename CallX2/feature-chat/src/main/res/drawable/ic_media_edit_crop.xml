<?xml version="1.0" encoding="utf-8"?>
<!--
  Crop icon — two overlapping corner-L shapes forming a crop frame,
  matching the style of the other ic_media_edit_* icons in the toolbar.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top-left corner -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="square"
        android:pathData="M3,8 L3,3 L8,3"/>

    <!-- Top-right corner -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="square"
        android:pathData="M16,3 L21,3 L21,8"/>

    <!-- Bottom-left corner -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="square"
        android:pathData="M3,16 L3,21 L8,21"/>

    <!-- Bottom-right corner -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="square"
        android:pathData="M16,21 L21,21 L21,16"/>

    <!-- Inner cross-hair dots (center guides) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M11.5,11.5 L12.5,11.5 L12.5,12.5 L11.5,12.5 Z"/>
</vector>
