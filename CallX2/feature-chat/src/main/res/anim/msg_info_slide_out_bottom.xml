<?xml version="1.0" encoding="utf-8"?>
<!--
  msg_info_slide_out_bottom.xml
  MessageInfoActivity exit animation: slides back down to the bottom of the screen.
  ChatActivity's enter animation is 0 (no animation), so it snaps back instantly
  and no window-layer conflict occurs.
-->
<translate xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromYDelta="0%p"
    android:toYDelta="100%p"
    android:duration="240"
    android:interpolator="@android:interpolator/accelerate_cubic" />
