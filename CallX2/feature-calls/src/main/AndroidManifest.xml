<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity android:name="com.callx.app.call.CallActivity"
            android:exported="false"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden"
            android:showWhenLocked="true"
            android:turnScreenOn="true"/>
        <activity android:name="com.callx.app.incoming.IncomingCallActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|screenSize"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"/>
        <activity android:name="com.callx.app.group.GroupCallActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden"
            android:showWhenLocked="true"
            android:turnScreenOn="true"/>
        <activity android:name="com.callx.app.incoming.IncomingGroupCallActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:screenOrientation="portrait"
            android:configChanges="keyboardHidden|screenSize"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"/>
        <activity android:name="com.callx.app.notes.AddNoteActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait"/>

        <activity android:name="com.callx.app.group.GroupCallSettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <service android:name="com.callx.app.services.CallForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall"/>
        <service android:name="com.callx.app.services.IncomingRingService"
            android:exported="false"
            android:foregroundServiceType="phoneCall"
            android:stopWithTask="false"/>
        <service android:name="com.callx.app.services.GroupCallRingService"
            android:exported="false"
            android:foregroundServiceType="phoneCall"
            android:stopWithTask="false"/>
        <service android:name="com.callx.app.services.GroupCallForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall"/>

        <receiver android:name="com.callx.app.services.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <!-- Call actions -->
                <action android:name="com.callx.app.ACCEPT_CALL"/>
                <action android:name="com.callx.app.DECLINE_CALL"/>
                <action android:name="com.callx.app.END_CALL"/>
                <action android:name="com.callx.app.ACTION_CALL_BACK"/>
                <action android:name="com.callx.app.ACTION_TOGGLE_MIC"/>
                <action android:name="com.callx.app.ACTION_TOGGLE_CAMERA"/>

                <!-- Missed call actions (Feature 1–6) -->
                <action android:name="com.callx.app.MISSED_CALL_MESSAGE"/>
                <action android:name="com.callx.app.ACTION_VIDEO_CALL_BACK"/>
                <action android:name="com.callx.app.QUICK_REPLY_1"/>
                <action android:name="com.callx.app.QUICK_REPLY_2"/>
                <action android:name="com.callx.app.QUICK_REPLY_3"/>
                <action android:name="com.callx.app.MISSED_CALL_SNOOZE"/>

                <!-- Message notification actions -->
                <action android:name="com.callx.app.ACTION_REPLY"/>
                <action android:name="com.callx.app.ACTION_MARK_READ"/>
                <action android:name="com.callx.app.ACTION_MUTE"/>
                <action android:name="com.callx.app.ACTION_BLOCK"/>
                <action android:name="com.callx.app.ACTION_UNBLOCK"/>
                <action android:name="com.callx.app.ACTION_PERMA_BLOCK"/>
                <action android:name="com.callx.app.ACTION_SPECIAL_UNBLOCK"/>

                <!-- Snooze actions -->
                <action android:name="com.callx.app.SNOOZE_1H"/>
                <action android:name="com.callx.app.SNOOZE_8H"/>
                <action android:name="com.callx.app.SNOOZE_24H"/>

                <!-- Group message actions -->
                <action android:name="com.callx.app.ACTION_GROUP_REPLY"/>
                <action android:name="com.callx.app.ACTION_GROUP_MARK_READ"/>
                <action android:name="com.callx.app.ACTION_GROUP_MUTE"/>
                <action android:name="com.callx.app.ACTION_GROUP_UNMUTE"/>
                <action android:name="com.callx.app.ACTION_GROUP_LEAVE"/>
            </intent-filter>
        </receiver>
        <receiver android:name="com.callx.app.services.MissedCallAvatarReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.callx.app.MISSED_CALL_AVATAR_CLICK"/>
            </intent-filter>
        </receiver>

        <receiver android:name="com.callx.app.services.GroupCallActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.callx.app.ACTION_GROUP_DECLINE_CALL"/>
                <action android:name="com.callx.app.ACTION_GROUP_END_CALL"/>
                <action android:name="com.callx.app.ACTION_GROUP_JOIN_CALL"/>
                <action android:name="com.callx.app.ACTION_GROUP_TOGGLE_MIC"/>
                <action android:name="com.callx.app.ACTION_GROUP_TOGGLE_CAMERA"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>
