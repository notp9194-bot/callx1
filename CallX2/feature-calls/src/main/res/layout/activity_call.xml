<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Full-screen remote video -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- FIX: Remote camera OFF overlay — shown when remote party turns camera off -->
    <LinearLayout
        android:id="@+id/layout_remote_cam_off"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_remote_cam_off_avatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_person"
            android:background="?attr/colorSurface"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera is off"
            android:textColor="#BBFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <!-- Local (PiP) video - top-right corner -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_video"
        android:layout_width="110dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:elevation="8dp"/>

    <!-- FIX: Local camera OFF badge over PiP -->
    <LinearLayout
        android:id="@+id/layout_local_cam_off_badge"
        android:layout_width="110dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:elevation="9dp"
        android:gravity="center"
        android:background="#99000000"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cam off"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Subtle dark scrim for text readability -->
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#44000000"/>

    <!-- FIX: Network quality indicator — top-left -->
    <LinearLayout
        android:id="@+id/layout_quality"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:layout_marginTop="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#55000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/iv_quality_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_signal_good"
            android:layout_marginEnd="4dp"/>
        <TextView
            android:id="@+id/tv_quality_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Caller name + status (top-center) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center"
        android:layout_marginTop="48dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_call_avatar"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_person"
            android:background="@color/surface_input"/>

        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tv_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D0E4FF"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Controls (bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingBottom="36dp"
        android:gravity="center">

        <!-- Row 1: Speaker | Switch Camera -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

              <!-- SWITCH: Audio ↔ Video (like Google Dialer) - shown when call connected -->
              <LinearLayout
                  android:id="@+id/layout_switch_mode"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:gravity="center"
                  android:layout_marginEnd="32dp"
                  android:visibility="gone">
                  <ImageButton
                      android:id="@+id/btn_switch_call_mode"
                      android:layout_width="52dp"
                      android:layout_height="52dp"
                      android:src="@drawable/ic_video"
                      android:background="@drawable/circle_avatar_bg"
                      android:contentDescription="Switch Call Mode"/>
                  <TextView
                      android:id="@+id/tv_switch_mode_label"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Video"
                      android:textColor="#AAFFFFFF"
                      android:textSize="10sp"
                      android:layout_marginTop="4dp"/>
              </LinearLayout>
  

            <!-- FIX: alpha=1.0 (was 0.4) — Java code toggles alpha at runtime correctly -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="32dp">
                <ImageButton
                    android:id="@+id/btn_toggle_speaker"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_audio"
                    android:background="@drawable/circle_avatar_bg"
                    android:alpha="1.0"
                    android:contentDescription="Speaker"/>
                <TextView
                    android:id="@+id/tv_speaker_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speaker"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btn_switch_camera"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_camera"
                    android:background="@drawable/circle_avatar_bg"
                    android:contentDescription="Switch Camera"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flip"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Mic | End Call | Camera -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- FIX: Mic button with label that changes (Muted/Unmuted) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="24dp">
                <ImageButton
                    android:id="@+id/btn_toggle_mic"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_mic"
                    android:background="@drawable/circle_avatar_bg"
                    android:contentDescription="Mute Mic"/>
                <TextView
                    android:id="@+id/tv_mic_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mute"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_end_call"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/circle_reject"
                android:tint="@color/white"
                android:layout_marginEnd="24dp"
                android:contentDescription="End Call"/>

            <!-- FIX: Camera button with label -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <ImageButton
                    android:id="@+id/btn_toggle_camera"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_video"
                    android:background="@drawable/circle_avatar_bg"
                    android:contentDescription="Toggle Camera"/>
                <TextView
                    android:id="@+id/tv_camera_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Camera"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
