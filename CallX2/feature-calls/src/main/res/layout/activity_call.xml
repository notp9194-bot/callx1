<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Full-screen remote video -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remoteVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Local (PiP) video - top-right corner -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/localVideo"
        android:layout_width="110dp"
        android:layout_height="150dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:elevation="8dp"/>

    <!-- Dark scrim for text readability -->
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#44000000"/>

    <!-- Top bar: back + settings + encryption badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <Space android:layout_width="0dp" android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Encryption badge (right side) -->
        <TextView
            android:id="@+id/tvEncryptionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="\uD83D\uDD12"
            android:textColor="#22C55E"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_chip_dark"
            android:visibility="gone"/>

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:layout_marginStart="8dp"
            android:alpha="0.8"
            android:contentDescription="Call Settings"/>
    </LinearLayout>

    <!-- Caller info + status (top-center) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:gravity="center"
        android:layout_marginTop="64dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivCallAvatar"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_person"
            android:background="@color/surface_input"/>

        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#D0E4FF"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>

        <!-- Network quality chip -->
        <TextView
            android:id="@+id/tvNetworkQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good connection"
            android:textColor="#22C55E"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_chip_dark"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Reconnecting overlay (shown on ICE disconnect) -->
    <TextView
        android:id="@+id/tvReconnecting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Reconnecting\u2026"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:background="@drawable/bg_chip_dark"
        android:visibility="gone"
        android:elevation="12dp"/>

    <!-- Controls (bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingBottom="36dp"
        android:gravity="center">

        <!-- Row 1: Speaker | Switch Camera -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnToggleSpeaker"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_audio"
                android:background="@drawable/circle_avatar_bg"
                android:alpha="0.4"
                android:layout_marginEnd="32dp"
                android:contentDescription="Toggle speaker"/>

            <ImageButton
                android:id="@+id/btnSwitchCamera"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/circle_avatar_bg"
                android:contentDescription="Switch camera"/>
        </LinearLayout>

        <!-- Row 2: Mic | End Call | Camera -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnToggleMic"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_mic"
                android:background="@drawable/circle_avatar_bg"
                android:layout_marginEnd="24dp"
                android:contentDescription="Toggle mic"/>

            <ImageButton
                android:id="@+id/btnEndCall"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/circle_reject"
                android:tint="@color/white"
                android:layout_marginEnd="24dp"
                android:contentDescription="End call"/>

            <ImageButton
                android:id="@+id/btnToggleCamera"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_video"
                android:background="@drawable/circle_avatar_bg"
                android:contentDescription="Toggle camera"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
