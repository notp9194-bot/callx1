<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="#1A1A1A"
    android:layout_margin="2dp">

    <!-- Video surface (shown when cam on) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/participantVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Avatar fallback (shown when cam off or audio-only) -->
    <FrameLayout
        android:id="@+id/participantAvatarContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:background="#2A2A2A">

        <TextView
            android:id="@+id/tvParticipantInitials"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_primary"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="?"/>
    </FrameLayout>

    <!-- Bottom bar: name + indicators -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#80000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/tvParticipantName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Member"/>

        <!-- Mic off indicator -->
        <ImageView
            android:id="@+id/ivParticipantMicOff"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_mic"
            android:alpha="0.6"
            android:visibility="gone"/>

        <!-- Hand raised indicator -->
        <ImageView
            android:id="@+id/ivParticipantHandRaised"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_person"
            android:visibility="gone"/>
    </LinearLayout>
</FrameLayout>
