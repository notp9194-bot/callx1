<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Selection bar -->
    <LinearLayout
        android:id="@+id/ll_selection_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/brand_primary"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="0 selected"/>

        <TextView
            android:id="@+id/btn_select_all_calls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_delete_selected_calls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="#FFCDD2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_cancel_selection_calls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:alpha="0.45"
            android:layout_marginEnd="10dp"/>

        <EditText
            android:id="@+id/et_search_calls"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Search contacts"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@null"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"/>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_mic"
            android:alpha="0.5"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Filter chips: All / Missed / Contacts / Non-spam / Spam -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="All"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/chip_selected"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_missed"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Missed"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:background="@drawable/chip_unselected"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_incoming"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Incoming"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:background="@drawable/chip_unselected"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_outgoing"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Outgoing"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:background="@drawable/chip_unselected"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_contacts"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Contacts"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:background="@drawable/chip_unselected"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_nonspam"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Non-spam"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:background="@drawable/chip_unselected"
                android:textColor="@color/text_primary"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_spam"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Spam"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textSize="13sp"
                android:background="@drawable/chip_unselected"
                android:textColor="@color/text_primary"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- View contacts button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Favorites ▾"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tv_view_contacts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View contacts"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:background="@drawable/chip_unselected"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Online users (hidden until someone is online) -->
    <LinearLayout
        android:id="@+id/ll_online_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ONLINE NOW"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingBottom="6dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/ll_online_users"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Hidden compat views (used in Java, must exist) -->
    <TextView
        android:id="@+id/tv_no_online"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <!-- Divider above list -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"/>

    <!-- Calls RecyclerView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_calls"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="12dp"
            android:clipToPadding="false"/>

        <LinearLayout
            android:id="@+id/empty_calls"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_phone"
                android:alpha="0.18"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No call history yet"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your recent calls will appear here"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="5dp"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
