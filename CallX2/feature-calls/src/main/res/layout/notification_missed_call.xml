<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_notif_missed_call"
    android:gravity="center_vertical">

    <!-- Avatar: full height of notification, no padding on left -->
    <ImageView
        android:id="@+id/notif_avatar"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:scaleType="centerCrop"
        android:src="@drawable/circle_avatar_bg"
        android:layout_margin="8dp"/>

    <!-- Vertical divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#33FFFFFF"/>

    <!-- Right side: name + info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/notif_caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caller Name"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/notif_call_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📞 Missed voice call"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="3dp"/>

        <TextView
            android:id="@+id/notif_miss_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 missed calls"
            android:textColor="#FFE57F"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="2dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_notif_rainbow_divider"/>

    </LinearLayout>

    <!-- Time -->
    <TextView
        android:id="@+id/notif_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5:30 PM"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:gravity="top"
        android:layout_gravity="top"/>

</LinearLayout>
