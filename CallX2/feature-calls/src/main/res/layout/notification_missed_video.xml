<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom big content view for MISSED VIDEO CALL notification.
    Used via setCustomBigContentView() — video call variant.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_notif_missed_video"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <!-- Top row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="58dp">
            <ImageView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_notif_avatar_ring"
                android:padding="3dp"/>
            <ImageView
                android:id="@+id/notif_avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_myplaces"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">
            <TextView
                android:id="@+id/notif_caller_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Caller Name"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/notif_call_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📹 Missed video call"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="8dp">
            <TextView
                android:id="@+id/notif_missed_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISSED"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/bg_notif_missed_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>
            <TextView
                android:id="@+id/notif_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5:30 PM"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_notif_rainbow_divider"/>

    <TextView
        android:id="@+id/notif_miss_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 missed calls"
        android:textColor="#FFC107"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginBottom="6dp"/>

    <!-- Video call: Video + Voice + Snooze -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:weightSum="3">

        <!-- Video button: orange -->
        <LinearLayout
            android:id="@+id/notif_btn_video"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_notif_btn_video"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_video_orange"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video"
                android:textColor="#F97316"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Voice button: green -->
        <LinearLayout
            android:id="@+id/notif_btn_voice"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_notif_btn_voice"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_phone_green"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice"
                android:textColor="#22C55E"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Snooze button: yellow -->
        <LinearLayout
            android:id="@+id/notif_btn_snooze"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:background="@drawable/bg_notif_btn_snooze"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_snooze_yellow"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Snooze"
                android:textColor="#EAB308"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
