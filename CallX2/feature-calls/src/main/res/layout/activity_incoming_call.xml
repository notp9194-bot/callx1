<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="@drawable/bg_incoming_call_screen">

    <!-- ── Animated ripple rings behind avatar ── -->
    <View
        android:id="@+id/ripple_ring_3"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_ripple_ring_glow"
        android:alpha="0.12"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.36"/>

    <View
        android:id="@+id/ripple_ring_2"
        android:layout_width="230dp"
        android:layout_height="230dp"
        android:background="@drawable/bg_ripple_ring_glow"
        android:alpha="0.22"
        app:layout_constraintTop_toTopOf="@id/ripple_ring_3"
        app:layout_constraintBottom_toBottomOf="@id/ripple_ring_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/ripple_ring_1"
        android:layout_width="185dp"
        android:layout_height="185dp"
        android:background="@drawable/bg_ripple_ring_glow"
        android:alpha="0.35"
        app:layout_constraintTop_toTopOf="@id/ripple_ring_3"
        app:layout_constraintBottom_toBottomOf="@id/ripple_ring_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Call type badge (top-center pill) ── -->
    <LinearLayout
        android:id="@+id/layout_call_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_call_type_pill"
        android:paddingHorizontal="18dp"
        android:paddingVertical="8dp"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_call_type_icon"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/ic_phone"
            android:tint="#FFFFFF"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/tv_caller_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.04"
            android:text="Incoming voice call"/>
    </LinearLayout>

    <!-- ── Caller avatar with glow ring ── -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_caller_avatar"
        android:layout_width="155dp"
        android:layout_height="155dp"
        android:src="@drawable/ic_person"
        app:civ_border_color="#7B61FF"
        app:civ_border_width="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.36"/>

    <!-- ── Caller name ── -->
    <TextView
        android:id="@+id/tv_caller_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="22dp"
        android:text="Caller"
        app:layout_constraintTop_toBottomOf="@id/iv_caller_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Ringing... animated text ── -->
    <TextView
        android:id="@+id/tv_ringing_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.06"
        android:layout_marginTop="8dp"
        android:text="Ringing..."
        app:layout_constraintTop_toBottomOf="@id/tv_caller_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Quick reply chips row ── -->
    <LinearLayout
        android:id="@+id/layout_quick_replies"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tv_ringing_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btn_quick_reply_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Can't talk"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_quick_reply_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_quick_reply_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call later"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_quick_reply_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btn_quick_reply_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="On my way"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_quick_reply_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ── Swipe hint label (above swipe zone) ── -->
    <TextView
        android:id="@+id/tv_swipe_hint_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↑  Accept"
        android:textColor="#4ADE80"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/swipe_phone_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Central swipe phone button ── -->
    <FrameLayout
        android:id="@+id/swipe_phone_container"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_swipe_phone_btn"
        app:layout_constraintBottom_toTopOf="@id/layout_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/iv_swipe_phone"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_phone"
            android:tint="#FFFFFF"
            android:layout_gravity="center"/>
    </FrameLayout>

    <!-- ── Swipe hint label (below swipe zone) ── -->
    <TextView
        android:id="@+id/tv_swipe_hint_down"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↓  Decline"
        android:textColor="#F87171"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/swipe_phone_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Bottom action row: Reject | Accept ── -->
    <LinearLayout
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reject -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_reject"
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:src="@drawable/ic_phone_off"
                android:background="@drawable/bg_btn_reject_gradient"
                android:tint="@color/white"
                android:elevation="6dp"
                android:contentDescription="Reject call"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Decline"
                android:textColor="#F87171"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- Accept -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_accept"
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/bg_btn_accept_gradient"
                android:tint="@color/white"
                android:elevation="6dp"
                android:contentDescription="Accept call"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accept"
                android:textColor="#4ADE80"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
