<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Partner Avatar — clickable to open chat -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_person"
            android:clickable="true"
            android:focusable="true"
            app:civ_border_width="1.5dp"
            app:civ_border_color="@color/divider"/>

        <!-- Name + Meta — name is clickable to open chat -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="13dp">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <ImageView
                    android:id="@+id/iv_direction"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_phone"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:id="@+id/tv_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Call Back Buttons with gradient -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_video_call"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_video_call"
                android:tint="@color/white"
                android:background="@drawable/gradient_video_btn"
                android:layout_marginEnd="8dp"
                android:padding="8dp"
                android:contentDescription="Video call"/>

            <ImageButton
                android:id="@+id/btn_call_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_phone"
                android:tint="@color/white"
                android:background="@drawable/gradient_call_btn"
                android:padding="9dp"
                android:contentDescription="Voice call"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
