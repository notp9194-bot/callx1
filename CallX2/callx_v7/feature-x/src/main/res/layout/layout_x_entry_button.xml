<?xml version="1.0" encoding="utf-8"?>
  <!--
    X Entry Button — animated strip that slides out from the avatar.
    Embed this in the Toolbar's left side (after the "CallX2" title).
    The strip slides out on first load with a translationX animation.
  -->
  <FrameLayout
      xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:id="@+id/x_entry_root"
      android:layout_width="wrap_content"
      android:layout_height="44dp"
      android:layout_marginStart="8dp">

      <!--
        Avatar — user/content avatar circle.
        Sits on top of the strip (z-order: avatar covers left end of strip).
      -->
      <de.hdodenhof.circleimageview.CircleImageView
          android:id="@+id/iv_x_entry_avatar"
          android:layout_width="36dp"
          android:layout_height="36dp"
          android:layout_gravity="center_vertical|start"
          android:elevation="4dp"
          android:src="@drawable/ic_person"
          app:civ_border_width="2dp"
          app:civ_border_color="@color/brand_primary"/>

      <!--
        Animated strip — slides RIGHT from behind the avatar.
        Initially translationX = -80dp (hidden behind avatar), animates to 0.
      -->
      <LinearLayout
          android:id="@+id/ll_x_entry_strip"
          android:layout_width="wrap_content"
          android:layout_height="28dp"
          android:layout_gravity="center_vertical"
          android:layout_marginStart="18dp"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:background="@color/x_entry_stripe_bg"
          android:paddingStart="20dp"
          android:paddingEnd="8dp"
          android:elevation="2dp"
          android:clipToPadding="false">

          <!-- X logo icon -->
          <ImageView
              android:id="@+id/iv_x_entry_icon"
              android:layout_width="16dp"
              android:layout_height="16dp"
              android:src="@drawable/ic_x_logo"
              android:contentDescription="X"
              android:tint="@android:color/white"/>

      </LinearLayout>

      <!--
        Badge — shows unread X notification count.
        Positioned at top-right of the X icon inside the strip.
      -->
      <TextView
          android:id="@+id/tv_x_entry_badge"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="top|start"
          android:layout_marginStart="34dp"
          android:layout_marginTop="2dp"
          android:minWidth="14dp"
          android:minHeight="14dp"
          android:paddingStart="3dp"
          android:paddingEnd="3dp"
          android:paddingTop="1dp"
          android:paddingBottom="1dp"
          android:textColor="#FFFFFF"
          android:textSize="8sp"
          android:gravity="center"
          android:elevation="6dp"
          android:background="@drawable/bg_x_notif_badge"
          android:visibility="gone"/>

  </FrameLayout>