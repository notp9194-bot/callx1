<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btn_trending_audio_back" android:layout_width="40dp"
            android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Trending Audio" android:textColor="#FFFFFF"
            android:textSize="18sp" android:textStyle="bold" android:paddingStart="12dp"/>
    </LinearLayout>

    <EditText android:id="@+id/et_trending_audio_search" android:layout_width="match_parent"
        android:layout_height="44dp" android:hint="Search audio..."
        android:textColor="#FFFFFF" android:textColorHint="#666666"
        android:background="@drawable/bg_comment_input"
        android:paddingHorizontal="16dp" android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="4dp" android:inputType="text"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:paddingHorizontal="4dp">
        <LinearLayout android:id="@+id/tab_audio_trending" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Trending" android:textColor="#FFFFFF" android:textSize="13sp"/>
            <View android:id="@+id/ind_audio_trending" android:layout_width="24dp"
                android:layout_height="2dp" android:background="#FF3B5C" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab_audio_viral" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Viral" android:textColor="#AAAAAA" android:textSize="13sp"/>
            <View android:id="@+id/ind_audio_viral" android:layout_width="24dp"
                android:layout_height="2dp" android:background="#FF3B5C" android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab_audio_new" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="New" android:textColor="#AAAAAA" android:textSize="13sp"/>
            <View android:id="@+id/ind_audio_new" android:layout_width="24dp"
                android:layout_height="2dp" android:background="#FF3B5C" android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab_audio_saved" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Saved" android:textColor="#AAAAAA" android:textSize="13sp"/>
            <View android:id="@+id/ind_audio_saved" android:layout_width="24dp"
                android:layout_height="2dp" android:background="#FF3B5C" android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tab_audio_sounds" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sounds" android:textColor="#AAAAAA" android:textSize="13sp"/>
            <View android:id="@+id/ind_audio_sounds" android:layout_width="24dp"
                android:layout_height="2dp" android:background="#FF3B5C" android:layout_marginTop="2dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Genre filter chips -->
    <HorizontalScrollView
        android:id="@+id/hsv_genre_chips"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:layout_marginVertical="4dp">
        <LinearLayout
            android:id="@+id/layout_genre_chips"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <ProgressBar android:id="@+id/progress_trending_audio" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center"
        android:visibility="gone" android:layout_marginVertical="16dp"/>

    <TextView android:id="@+id/tv_trending_audio_empty" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="No audio found"
        android:textColor="#555555" android:gravity="center" android:padding="32dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_trending_audio"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
</LinearLayout>
