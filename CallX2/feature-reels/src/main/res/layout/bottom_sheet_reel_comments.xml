<?xml version="1.0" encoding="utf-8"?>
<!-- bottom_sheet_reel_comments.xml — Advanced v2 with sticky add-comment bar -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="Comments"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"/>

    <!-- Comment icon + count row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="14dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_comment_reel"
            android:layout_marginEnd="6dp"
            android:contentDescription="Comments"/>

        <TextView
            android:id="@+id/tv_comments_count_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurface"/>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Section header + search -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"
        android:text="All comments"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/colorOnSurface"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:hint="Search comments"
            android:textSize="14sp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:inputType="text"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/colorOnSurfaceVariant"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- Comments list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="360dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:overScrollMode="never"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/brand_primary"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No comments yet"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Divider above add-comment bar -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── Sticky Add-Comment Bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- My avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_my_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="8dp"/>

        <!-- Comment input -->
        <EditText
            android:id="@+id/et_add_comment"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:hint="Add a comment…"
            android:textSize="14sp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionSend"/>

        <!-- Send button -->
        <ImageButton
            android:id="@+id/btn_send_comment"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_circle_action"
            android:contentDescription="Send comment"
            android:tint="@color/brand_primary"/>

    </LinearLayout>

</LinearLayout>
