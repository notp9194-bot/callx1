<?xml version="1.0" encoding="utf-8"?>
<!-- bottom_sheet_reel_comments.xml — v9: Photo-in-Comment support -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="Comments"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#00C6FF"
        android:gravity="center"/>

    <!-- Comment icon + count row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="14dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_comment_reel"
            android:tint="#00C6FF"
            android:layout_marginEnd="6dp"
            android:contentDescription="Comments"/>

        <TextView
            android:id="@+id/tv_comments_count_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#00C6FF"/>

    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Section header + search -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"
        android:text="All comments"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#00C6FF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:hint="Search comments"
            android:textSize="14sp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:inputType="text"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/colorOnSurfaceVariant"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- Comments list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="360dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_comments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:overScrollMode="never"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/brand_primary"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No comments yet"
            android:textSize="14sp"
            android:textColor="#6BCFEF"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Divider above input -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!--
        ── v9: Photo Preview Strip ──────────────────────────────────────────────
        Visible only after user picks a photo from gallery.
        Shows thumbnail + upload progress bar while uploading.
        Hidden by default (GONE).
    -->
    <LinearLayout
        android:id="@+id/layout_photo_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <!-- Photo thumbnail preview -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/iv_comment_photo_preview"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_comment_photo"
                android:clipToOutline="true"
                android:contentDescription="Selected photo preview"/>

            <!-- Upload spinner — shown while Cloudinary upload is in progress -->
            <ProgressBar
                android:id="@+id/pb_photo_upload"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:indeterminateTint="#FFFFFF"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- Upload status label -->
        <TextView
            android:id="@+id/tv_photo_upload_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Uploading photo…"
            android:textSize="13sp"
            android:textColor="@color/text_muted"/>

        <!-- Remove photo button -->
        <ImageButton
            android:id="@+id/btn_remove_photo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove photo"
            android:padding="6dp"/>

    </LinearLayout>

    <!-- ── Sticky Add-Comment Bar (v9 updated) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- My avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_my_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="6dp"/>

        <!--
            v9: Attach photo button (Instagram-style 📷 icon)
            Opens system image picker.
        -->
        <ImageButton
            android:id="@+id/btn_attach_photo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_image"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Attach photo"
            android:padding="6dp"
            android:layout_marginEnd="4dp"/>

        <!-- Comment input -->
        <EditText
            android:id="@+id/et_add_comment"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:hint="Add a comment…"
            android:textSize="14sp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:singleLine="true"
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionSend"/>

        <!-- Send button -->
        <ImageButton
            android:id="@+id/btn_send_comment"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_circle_action"
            android:contentDescription="Send comment"
            android:tint="#00C6FF"/>

    </LinearLayout>

</LinearLayout>
