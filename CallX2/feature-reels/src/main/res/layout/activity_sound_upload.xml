<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:paddingHorizontal="12dp">
        <ImageButton android:id="@+id/btn_sound_upload_back" android:layout_width="40dp"
            android:layout_height="40dp" android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true" android:text="Upload Sound"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
    </RelativeLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Pick file -->
            <TextView android:id="@+id/btn_pick_audio_file"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="Choose Audio File" android:gravity="center"
                android:textColor="#FF3B5C" android:textSize="15sp" android:textStyle="bold"
                android:background="@drawable/bg_outlined_btn_red"
                android:layout_marginBottom="12dp"/>

            <!-- File info -->
            <LinearLayout android:id="@+id/layout_upload_preview"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="#1E1E1E" android:padding="12dp"
                android:layout_marginBottom="12dp" android:visibility="gone">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tv_upload_filename"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="No file selected" android:textColor="#FFFFFF"
                        android:textSize="14sp" android:maxLines="1"
                        android:ellipsize="end"/>
                    <TextView android:id="@+id/tv_upload_duration"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#888888" android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:id="@+id/btn_upload_preview"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="Preview" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="13sp"
                    android:background="@drawable/bg_speed_chip"
                    android:paddingHorizontal="16dp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Metadata -->
            <LinearLayout android:id="@+id/layout_upload_meta"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SOUND TITLE *" android:textColor="#666666" android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/et_upload_title"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="Enter title…" android:textColor="#FFFFFF"
                    android:textColorHint="#555555" android:background="@drawable/bg_search_field"
                    android:paddingHorizontal="16dp" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ARTIST" android:textColor="#666666" android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/et_upload_artist"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="Artist name…" android:textColor="#FFFFFF"
                    android:textColorHint="#555555" android:background="@drawable/bg_search_field"
                    android:paddingHorizontal="16dp" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GENRE" android:textColor="#666666" android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>
                        <Spinner android:id="@+id/spinner_upload_genre"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/bg_search_field"
                            android:paddingHorizontal="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BPM" android:textColor="#666666" android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/et_upload_bpm"
                            android:layout_width="match_parent" android:layout_height="48dp"
                            android:hint="e.g. 128" android:textColor="#FFFFFF"
                            android:textColorHint="#555555" android:background="@drawable/bg_search_field"
                            android:paddingHorizontal="16dp" android:inputType="number"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VISIBILITY" android:textColor="#666666" android:textSize="11sp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinner_upload_visibility"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/bg_search_field"
                    android:paddingHorizontal="12dp" android:layout_marginBottom="16dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Upload progress -->
    <ProgressBar android:id="@+id/progress_upload_sound"
        android:layout_width="match_parent" android:layout_height="4dp"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:progressTint="#FF3B5C" android:indeterminate="true"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_upload_pct"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:textColor="#AAAAAA"
        android:textSize="13sp" android:padding="4dp" android:visibility="gone"/>

    <!-- Upload button -->
    <TextView android:id="@+id/btn_upload_sound"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Upload Sound" android:gravity="center"
        android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="16dp"/>
</LinearLayout>
