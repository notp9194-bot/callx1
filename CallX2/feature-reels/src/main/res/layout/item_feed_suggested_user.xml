<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_suggested_user.xml
    Individual suggested user card inside the "Suggested for you" horizontal RecyclerView.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="110dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp"
    android:layout_marginEnd="6dp"
    android:background="@drawable/bg_speed_chip"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_suggested_avatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_person"
        app:civ_border_width="1.5dp"
        app:civ_border_color="@color/brand_primary"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Display name -->
    <TextView
        android:id="@+id/tv_suggested_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Name"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"/>

    <!-- Handle -->
    <TextView
        android:id="@+id/tv_suggested_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@handle"
        android:textColor="#888888"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"/>

    <!-- Follower count -->
    <TextView
        android:id="@+id/tv_suggested_followers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="123K followers"
        android:textColor="#666666"
        android:textSize="9sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"/>

    <!-- Follow button -->
    <Button
        android:id="@+id/btn_suggested_follow"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="8dp"
        android:text="Follow"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/brand_primary"
        android:stateListAnimator="@null"
        android:textAllCaps="false"/>

</LinearLayout>
