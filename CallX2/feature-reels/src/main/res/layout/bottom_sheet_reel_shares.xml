<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="Shares and reposts"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#00F260"
        android:gravity="center"/>

    <!-- Shares + Reposts counts row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp">

        <!-- Share icon + shares count -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="24dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_share_reel"
                android:tint="#00F260"
                android:layout_marginEnd="6dp"
                android:contentDescription="Shares"/>

            <TextView
                android:id="@+id/tv_shares_count_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#00F260"/>
        </LinearLayout>

        <!-- Repost icon + reposts count -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_repost"
                android:tint="#A855F7"
                android:layout_marginEnd="6dp"
                android:contentDescription="Reposts"/>

            <TextView
                android:id="@+id/tv_reposts_count_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#A855F7"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- "Shared by" section header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        android:text="Shared by"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#00F260"/>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:hint="Search"
            android:textSize="14sp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:inputType="text"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/colorOnSurfaceVariant"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- Sharers list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="420dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sharers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            android:overScrollMode="never"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/brand_primary"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No reposts yet"
            android:textSize="14sp"
            android:textColor="#6BE8A8"
            android:visibility="gone"/>
    </FrameLayout>

</LinearLayout>
