<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:orientation="vertical" android:background="#0D0D0D">

      <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
          android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="12dp">
          <ImageButton android:id="@+id/btn_multi_duet_back"
              android:layout_width="40dp" android:layout_height="40dp"
              android:src="@drawable/ic_arrow_back" android:background="?attr/selectableItemBackgroundBorderless"
              android:tint="#FFFFFF"/>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
              <TextView android:id="@+id/tv_multi_duet_title"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:text="Multi-Person Duet" android:textColor="#FFFFFF"
                  android:textSize="17sp" android:textStyle="bold"/>
              <TextView android:id="@+id/tv_session_code"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:textColor="#888888" android:textSize="12sp"/>
          </LinearLayout>
      </LinearLayout>

      <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="Participants (max 4)" android:textColor="#AAAAAA"
          android:textSize="13sp" android:paddingHorizontal="16dp" android:paddingBottom="8dp"/>

      <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_multi_duet_slots"
          android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
          android:padding="8dp"/>

      <ProgressBar android:id="@+id/progress_multi_duet"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_gravity="center" android:visibility="gone"/>

      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
          <Button android:id="@+id/btn_add_participant"
              android:layout_width="match_parent" android:layout_height="44dp"
              android:text="+ Add Participant" android:textColor="#FFFFFF"
              android:backgroundTint="#333333"/>
          <Button android:id="@+id/btn_start_multi_duet"
              android:layout_width="match_parent" android:layout_height="48dp"
              android:layout_marginTop="8dp" android:text="Start Multi-Duet (1/4)"
              android:textColor="#000000" android:backgroundTint="#FFD700"
              android:textStyle="bold"/>
      </LinearLayout>
  </LinearLayout>