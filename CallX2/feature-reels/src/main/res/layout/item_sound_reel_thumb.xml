<?xml version="1.0" encoding="utf-8"?>
<!--
    item_sound_reel_thumb — grid cell used only by SoundDetailActivity's
    "Reels with this sound" grid (ReelThumbAdapter).

    Height is set programmatically in ReelThumbAdapter.onCreateViewHolder()
    to keep a 9:16 (vertical) aspect ratio based on the column width, since
    GridLayoutManager slices width by spanCount automatically.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="1dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/iv_media_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_gallery"
        android:background="@color/surface_input"/>

    <!-- Instagram-style "Original" strip — only shown on the original
         creator's reel tile. Hidden by default. -->
    <TextView
        android:id="@+id/tv_original_strip"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_gravity="top"
        android:gravity="center"
        android:text="Original"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-medium"
        android:background="#99000000"
        android:visibility="gone"/>

</FrameLayout>
