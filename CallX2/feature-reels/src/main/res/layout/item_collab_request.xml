<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp"
    android:background="?attr/selectableItemBackground">
    <!-- Added for CollabInboxActivity.InviteAdapter.VH -->
    <ImageView android:id="@+id/iv_collab_req_thumb" android:layout_width="match_parent"
        android:layout_height="60dp" android:scaleType="centerCrop" android:visibility="gone"/>
    <ImageView android:id="@+id/iv_collab_req_avatar" android:layout_width="36dp"
        android:layout_height="36dp" android:visibility="gone"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:id="@+id/tv_collab_req_name" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_collab_req_status" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_collab_req_type" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FF3B5C" android:textSize="13sp" android:paddingTop="2dp"/>
    <TextView android:id="@+id/tv_collab_req_message" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#AAAAAA" android:textSize="13sp" android:paddingTop="2dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingTop="8dp">
        <Button android:id="@+id/btn_collab_accept" android:layout_width="0dp" android:layout_height="36dp"
            android:layout_weight="1" android:text="Accept" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_collab_decline" android:layout_width="0dp" android:layout_height="36dp"
            android:layout_weight="1" android:text="Decline" android:textColor="#FF3B5C"
            android:background="@null"/>
        <Button android:id="@+id/btn_collab_cancel" android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Cancel Request" android:textColor="#FF3B5C" android:background="@null"
            android:visibility="gone"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#333333" android:layout_marginTop="8dp"/>
</LinearLayout>
