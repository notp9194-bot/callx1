<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="16dp"
    android:background="@drawable/bg_card_rounded"
    android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp" android:elevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
        <ImageView android:id="@+id/iv_collab_avatar"
            android:layout_width="48dp" android:layout_height="48dp"
            android:scaleType="centerCrop" android:src="@drawable/ic_default_avatar"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
            <TextView android:id="@+id/tv_collab_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textStyle="bold" android:textSize="15sp" android:textColor="#000"/>
            <TextView android:id="@+id/tv_collab_role"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#555555"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_collab_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888"/>
    </LinearLayout>

    <TextView android:id="@+id/tv_collab_reel_id"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="8dp"/>
    <TextView android:id="@+id/tv_collab_status"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="#7C3AED" android:textStyle="bold"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="12dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept_collab"
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Accept"
            android:layout_marginEnd="6dp" app:cornerRadius="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reject_collab"
            android:layout_width="0dp" android:layout_height="40dp"
            android:layout_weight="1" android:text="Decline"
            android:layout_marginStart="6dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="8dp" xmlns:app="http://schemas.android.com/apk/res-auto"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_collab"
            android:layout_width="match_parent" android:layout_height="40dp"
            android:text="Cancel Invite" android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:cornerRadius="8dp" xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>
</LinearLayout>
