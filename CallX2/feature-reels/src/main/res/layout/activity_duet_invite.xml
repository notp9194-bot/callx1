<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:orientation="vertical" android:background="#0D0D0D">

      <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
          android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="12dp">
          <ImageButton android:id="@+id/btn_invite_back"
              android:layout_width="40dp" android:layout_height="40dp"
              android:src="@drawable/ic_arrow_back" android:background="?attr/selectableItemBackgroundBorderless"
              android:tint="#FFFFFF"/>
          <TextView android:id="@+id/tv_invite_title"
              android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
              android:text="Invite to Duet" android:textColor="#FFFFFF" android:textSize="18sp"
              android:textStyle="bold" android:gravity="center"/>
          <View android:layout_width="40dp" android:layout_height="40dp"/>
      </LinearLayout>

      <EditText android:id="@+id/et_invite_search"
          android:layout_width="match_parent" android:layout_height="44dp"
          android:layout_marginHorizontal="16dp" android:layout_marginBottom="4dp"
          android:background="@drawable/bg_search_bar" android:hint="Search by name or username..."
          android:textColorHint="#888888" android:textColor="#FFFFFF" android:paddingHorizontal="16dp"
          android:inputType="text" android:imeOptions="actionSearch"/>

      <TextView android:id="@+id/tv_search_hint"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:layout_marginHorizontal="16dp" android:layout_marginBottom="8dp"
          android:text="Type a name or username to search"
          android:textColor="#888888" android:textSize="12sp"
          android:visibility="gone"/>

      <ProgressBar android:id="@+id/progress_invite"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_gravity="center" android:visibility="gone"/>

      <TextView android:id="@+id/tv_invite_empty"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="No followers found" android:textColor="#888888"
          android:gravity="center" android:padding="32dp" android:visibility="gone"/>

      <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_invite_users"
          android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
  </LinearLayout>