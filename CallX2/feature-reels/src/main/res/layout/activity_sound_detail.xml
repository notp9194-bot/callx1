<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_sound_detail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_sound_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sound"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"/>

            <ImageButton
                android:id="@+id/btn_sound_share"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_share_reel"
                android:tint="#00F260"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Share sound"/>

            <ImageButton
                android:id="@+id/btn_save_sound"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_bookmark"
                android:tint="#00C6FF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save sound"/>

            <!-- 3-dot overflow menu -->
            <ImageButton
                android:id="@+id/btn_sound_more"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_more_vert"
                android:tint="#AAFFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="More options"/>
        </LinearLayout>

        <!-- ──────────────────── Shimmer skeleton (shown while loading) ──────────────────── -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_sound_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:visibility="visible">

            <!-- Cover + meta skeleton row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Circle placeholder for disc cover -->
                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_skeleton_circle"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <View
                        android:layout_width="140dp"
                        android:layout_height="16dp"
                        android:background="@drawable/bg_skeleton_rect"/>

                    <View
                        android:layout_width="90dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_skeleton_rect"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="110dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_skeleton_rect"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Play button placeholder -->
                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_skeleton_circle"/>
            </LinearLayout>

            <!-- Seekbar skeleton -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_skeleton_rect"
                android:layout_marginTop="24dp"/>

            <!-- Creator row skeleton -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_skeleton_circle"/>

                <View
                    android:layout_width="100dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_skeleton_rect"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Button row skeleton -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skeleton_rect"
                    android:layout_marginEnd="8dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skeleton_rect"/>
            </LinearLayout>

            <!-- Grid skeleton — 3 tiles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skeleton_rect"
                    android:layout_marginEnd="2dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skeleton_rect"
                    android:layout_marginEnd="2dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_skeleton_rect"/>
            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- ──────────────────── Real content (shown after data loads) ──────────────────── -->

        <!-- Sound info card -->
        <LinearLayout
            android:id="@+id/layout_sound_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#111111"
            android:padding="20dp"
            android:visibility="gone">

            <!-- Cover + meta row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Spinning disc cover -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp">

                    <ImageView
                        android:id="@+id/iv_disc_ring"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_music_disc"
                        android:tint="#2A2A2A"
                        android:scaleType="fitXY"/>

                    <ImageView
                        android:id="@+id/iv_sound_cover"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music_note"/>

                    <View
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_circle_white"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tv_sound_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sound Title"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_sound_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Original Audio"
                        android:textColor="#AAFFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="3dp"/>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tv_sound_reel_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Reels"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tv_sound_saves_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  •  0 Saves"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- BPM + Genre + badges -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tv_sound_bpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#77FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_genre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#77FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_original_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Original"
                            android:textColor="#FF3B5C"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_verified_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ Verified"
                            android:textColor="#4FC3F7"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_sound_trending_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#1 Trending"
                        android:textColor="@color/brand_accent"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Play/Pause button -->
                <ImageButton
                    android:id="@+id/btn_sound_play_pause"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_play"
                    android:tint="#A855F7"
                    android:background="@drawable/bg_play_pause_btn"
                    android:padding="14dp"
                    android:contentDescription="Play preview"/>
            </LinearLayout>

            <!-- Seekbar + time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <SeekBar
                    android:id="@+id/seekbar_sound"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:progressTint="#A855F7"
                    android:thumbTint="#A855F7"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:max="100"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tv_sound_current_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textColor="#77FFFFFF"
                        android:textSize="11sp"/>

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tv_sound_total_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textColor="#77FFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Waveform -->
            <LinearLayout
                android:id="@+id/layout_sound_waveform"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"/>

            <!-- Original Creator row -->
            <LinearLayout
                android:id="@+id/layout_sound_creator"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="2dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_creator_avatar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/tv_creator_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Original Creator"
                        android:textColor="#77FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"/>

                    <TextView
                        android:id="@+id/tv_creator_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@username"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="#55FFFFFF"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

            <!-- thin divider after creator row -->
            <View
                android:id="@+id/divider_creator"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <!-- Use sound buttons — both outline style (no fill color on camera btn) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/btn_use_sound_camera"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Use in Camera"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_reel_follow_btn"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btn_use_sound_gallery"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Use with Video"
                    android:gravity="center"
                    android:textColor="@color/brand_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_reel_follow_btn"/>
            </LinearLayout>

            <!-- Trim start chip -->
            <TextView
                android:id="@+id/btn_trim_start"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✂ Set Start Point"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_sort_chip"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Progress bar (buffering indicator) -->
        <ProgressBar
            android:id="@+id/progress_sound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/brand_primary"
            android:layout_marginVertical="8dp"
            android:visibility="gone"/>

        <!-- Reels with this sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone"
            android:id="@+id/layout_reels_header">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reels with this sound"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tv_see_all_reels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all"
                android:textColor="#A855F7"
                android:textSize="13sp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sound_reels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:overScrollMode="never"/>

        <!-- Footer spinner for pagination -->
        <ProgressBar
            android:id="@+id/progress_reels_pagination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/brand_primary"
            android:layout_marginVertical="10dp"
            android:visibility="gone"/>

        <!-- Related sounds section -->
        <LinearLayout
            android:id="@+id/layout_related_sounds_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Similar Sounds"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tv_see_all_related"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#A855F7"
                    android:textSize="13sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_related_sounds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"/>
        </LinearLayout>

        <!-- ──────────────────── Floating mini-player (shown over related sounds on tap) ──────────────────── -->
        <!-- This is a simple bottom-docked bar that stays visible when user navigates
             inside this screen (e.g. taps a related sound which starts a new Activity).
             For true cross-Activity persistence a Service/bound player is needed — that
             wire-up is left as a TODO comment in the Java. -->
        <FrameLayout
            android:id="@+id/layout_mini_player"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#CC1A1A1A"
            android:visibility="gone"
            android:elevation="8dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:id="@+id/iv_mini_cover"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note"/>

                <TextView
                    android:id="@+id/tv_mini_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="10dp"/>

                <ImageButton
                    android:id="@+id/btn_mini_play_pause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_pause"
                    android:tint="#A855F7"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Mini play/pause"/>

                <ImageButton
                    android:id="@+id/btn_mini_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_close"
                    android:tint="#AAFFFFFF"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Close mini player"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Bottom padding for nav bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"/>

    </LinearLayout>
</ScrollView>
