<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Scrollable body ─────────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Top bar ──────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <ImageButton
                    android:id="@+id/btn_sound_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <!-- Trending pill -->
                <TextView
                    android:id="@+id/tv_sound_trending_rank"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="↗ Trending"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:background="@drawable/bg_sort_chip"
                    android:visibility="gone"/>

                <ImageButton
                    android:id="@+id/btn_sound_more"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_more_vert"
                    android:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="More options"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- ── Sound header card ────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layout_sound_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:gravity="top">

                <!-- Square disc cover (spinning in code) -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginTop="2dp">

                    <ImageView
                        android:id="@+id/iv_disc_ring"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_music_disc"
                        android:tint="#1AFFFFFF"
                        android:scaleType="fitXY"/>

                    <ImageView
                        android:id="@+id/iv_sound_cover"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music_note"/>

                    <!-- Pause overlay (shown while playing) -->
                    <FrameLayout
                        android:id="@+id/fl_play_overlay"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:background="#55000000"
                        android:visibility="gone">

                        <ImageButton
                            android:id="@+id/btn_sound_play_pause"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_play"
                            android:tint="@color/white"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Play preview"/>
                    </FrameLayout>

                    <!-- Tap-to-play hint when not playing -->
                    <ImageButton
                        android:id="@+id/btn_sound_play_hint"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play"
                        android:tint="@color/white"
                        android:background="#55000000"
                        android:padding="8dp"
                        android:contentDescription="Play preview"/>
                </FrameLayout>

                <!-- Title + meta -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tv_sound_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Original audio"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_sound_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="username"
                        android:textColor="#AAFFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="3dp"/>

                    <!-- Duration row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tv_sound_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:03"
                            android:textColor="#77FFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- BPM + Genre + badges row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tv_sound_bpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#77FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_genre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#77FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_original_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Original"
                            android:textColor="#FF3B5C"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_verified_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ Verified"
                            android:textColor="#4FC3F7"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Right: Bookmark + Share -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="8dp">

                    <ImageButton
                        android:id="@+id/btn_save_sound"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_bookmark"
                        android:tint="@color/white"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Save sound"/>

                    <ImageButton
                        android:id="@+id/btn_sound_share"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_share_reel"
                        android:tint="@color/white"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Share sound"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── COLORFUL STATS CHIPS ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <!-- Reels count chip — purple/pink gradient -->
                <LinearLayout
                    android:id="@+id/chip_reel_count"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip_reels"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎬 "
                        android:textSize="16sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tv_sound_reel_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reels"
                            android:textColor="#DDFFFFFF"
                            android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Saves count chip — orange/yellow gradient -->
                <LinearLayout
                    android:id="@+id/chip_saves_count"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip_saves"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔖 "
                        android:textSize="16sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tv_sound_saves_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Saves"
                            android:textColor="#DDFFFFFF"
                            android:textSize="10sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Seekbar + time ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <SeekBar
                    android:id="@+id/seekbar_sound"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:progressTint="#FFFFFF"
                    android:thumbTint="#FFFFFF"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:max="100"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tv_sound_current_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textColor="#77FFFFFF"
                        android:textSize="11sp"/>

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tv_sound_total_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textColor="#77FFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Waveform ──────────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layout_sound_waveform"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="2dp"/>

            <!-- ── Use audio button ─────────────────────────────────────────── -->
            <TextView
                android:id="@+id/btn_use_sound_camera"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Use audio"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_reel_upload_btn"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/btn_use_sound_gallery"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Use with Video"
                android:gravity="center"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:background="?attr/selectableItemBackground"
                android:layout_marginHorizontal="16dp"
                android:visibility="gone"/>

            <!-- ── ORIGINAL CREATOR STRIP ────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layout_sound_creator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_creator_strip"
                android:padding="12dp"
                android:visibility="gone">

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎵  ORIGINAL CREATOR"
                    android:textColor="#FFD700"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <!-- Avatar + name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/iv_creator_avatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tv_creator_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@username"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sound creator"
                            android:textColor="#AAFFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="1dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View profile →"
                        android:textColor="#FFD700"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </LinearLayout>

            <!-- hidden divider (kept for backward compat) -->
            <View
                android:id="@+id/divider_creator"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

            <!-- ── Trim chip ─────────────────────────────────────────────────── -->
            <TextView
                android:id="@+id/btn_trim_start"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="✂  Set Start Point"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_sort_chip"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

            <!-- ── Progress bar ──────────────────────────────────────────────── -->
            <ProgressBar
                android:id="@+id/progress_sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:indeterminateTint="@color/brand_primary"
                android:layout_marginVertical="8dp"
                android:visibility="gone"/>

            <!-- ── Reels with this sound header ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reels with this sound"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tv_see_all_reels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- ── Reels grid (2-col, 9:16 vertical) ───────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sound_reels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <!-- ── Related sounds section ────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layout_related_sounds_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Similar Sounds"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tv_see_all_related"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#AAFFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_related_sounds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingBottom="16dp"
                    android:clipToPadding="false"/>
            </LinearLayout>

            <!-- bottom nav padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
