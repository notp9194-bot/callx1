<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/btn_sound_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sound"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"/>

            <ImageButton
                android:id="@+id/btn_sound_share"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_share_reel"
            android:tint="#00F260"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Share sound"/>

            <ImageButton
                android:id="@+id/btn_save_sound"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_bookmark"
            android:tint="#00C6FF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save sound"/>
        </LinearLayout>

        <!-- Sound info card -->
        <LinearLayout
            android:id="@+id/layout_sound_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="20dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Album art -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp">

                    <ImageView
                        android:id="@+id/iv_sound_cover"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_primary"
                        android:src="@drawable/ic_music_note"/>

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_circle_white"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tv_sound_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sound Title"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_sound_artist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Original Audio"
                        android:textColor="#AAFFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tv_sound_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:30"
                            android:textColor="#77FFFFFF"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_sound_reel_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  •  0 Reels"
                            android:textColor="#77FFFFFF"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_sound_saves_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  •  0 Saves"
                            android:textColor="#77FFFFFF"
                            android:textSize="12sp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Metadata badges row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tv_sound_bpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#77FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_genre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#77FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_original_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Original"
                            android:textColor="#FF3B5C"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_sound_verified_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Verified"
                            android:textColor="#4FC3F7"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Trending badge -->
                    <TextView
                        android:id="@+id/tv_sound_trending_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#1 Trending"
                        android:textColor="@color/brand_accent"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- Play/Pause button -->
                <ImageButton
                    android:id="@+id/btn_sound_play_pause"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_play"
            android:tint="#A855F7"
                    android:background="@drawable/circle_primary"
                    android:padding="12dp"
                    android:contentDescription="Play preview"/>
            </LinearLayout>

            <!-- Animated waveform -->
            <LinearLayout
                android:id="@+id/layout_sound_waveform"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="bottom|center_horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"/>

            <!-- Use sound buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/btn_use_sound_camera"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Use in Camera"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_reel_upload_btn"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btn_use_sound_gallery"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Use with Video"
                    android:gravity="center"
                    android:textColor="@color/brand_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_reel_follow_btn"/>
            </LinearLayout>

            <!-- Trim start chip -->
            <TextView
                android:id="@+id/btn_trim_start"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Set Start Point"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_sort_chip"
                android:layout_marginTop="10dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_sound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/brand_primary"
            android:layout_marginVertical="8dp"
            android:visibility="gone"/>

        <!-- Reels using this sound header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reels with this sound"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:padding="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sound_reels"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:clipToPadding="false"/>

        <!-- Related sounds section -->
        <LinearLayout
            android:id="@+id/layout_related_sounds_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Similar Sounds"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_related_sounds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
