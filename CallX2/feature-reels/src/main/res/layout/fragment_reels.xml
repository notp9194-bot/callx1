<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Full-screen reel feed — true edge-to-edge, extends behind status bar + nav bar -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_reels"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"/>

    <!-- ── Top bar ──
         Starts at y=0 — status bar is hidden in full-screen reel mode.
         gradient_reel_top background ensures icons are readable over video.
    -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingTop="0dp"
        android:paddingBottom="8dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_reel_top">

        <ImageButton
            android:id="@+id/btn_reel_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back to app"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <TextView
                android:id="@+id/btn_fyp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="For You"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:alpha="1.0"/>

            <TextView
                android:id="@+id/btn_following"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Following"
                android:textColor="#00C6FF"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:alpha="0.55"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_reel_search"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_search"
            android:tint="#6BCFEF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Search"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/btn_upload_reel"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_add_reels"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Upload Reel"/>
    </LinearLayout>

    <!-- FYP underline indicator -->
    <View
        android:id="@+id/feed_indicator"
        android:layout_width="56dp"
        android:layout_height="2dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="48dp"
        android:layout_marginTop="48dp"
        android:background="?attr/colorSurface"/>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_reels"
            android:tint="#FFFFFF"
            android:alpha="0.5"
            android:contentDescription="No reels"/>

        <TextView
            android:id="@+id/tv_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No Reels Yet"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tv_empty_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Be the first to share a reel!"
            android:textColor="#AAFFFFFF"
            android:textSize="14sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_post_first_reel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Post a Reel"
            android:backgroundTint="@color/brand_primary"/>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_reels"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone"/>

    <!-- Swipe hint -->
    <TextView
        android:id="@+id/tv_swipe_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="72dp"
        android:text="Swipe up for more"
        android:textColor="#88FFFFFF"
        android:textSize="12sp"
        android:visibility="gone"/>

    <!-- Home tab container -->
    <FrameLayout
        android:id="@+id/home_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top"
        android:background="#0D0D0D"
        android:visibility="gone"/>

    <!-- ── Reels Bottom Navigation ──
         android:layout_height="wrap_content" so paddingBottom (= navBarHeight set in Java)
         expands the view naturally without clipping items.
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/reel_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:elevation="8dp"
        app:itemIconTint="@null"
        app:itemTextColor="@color/white"
        app:itemIconSize="22dp"
        app:menu="@menu/reel_bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemRippleColor="@color/brand_primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
