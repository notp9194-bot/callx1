<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_multi_clip_camera.xml  — Multi-Clip Recording screen
    Redesigned with segmented clip bar, countdown overlay, clean bottom panel.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera preview (full screen) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_multi"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter"/>

    <!-- ── Top bar ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingTop="44dp"
        android:background="#55000000">

        <!-- Close / clip count / flash / flip row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_multi_close"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Close"/>

            <TextView
                android:id="@+id/tv_multi_clip_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 clips"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btn_multi_flash"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_volume_on"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#AAFFFFFF"
                android:contentDescription="Flash"/>

            <ImageButton
                android:id="@+id/btn_multi_flip"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_swap"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Flip camera"/>
        </LinearLayout>

        <!-- Duration chips row -->
        <LinearLayout
            android:id="@+id/layout_multi_duration"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView android:id="@+id/chip_multi_15s"
                android:layout_width="56dp"
                android:layout_height="28dp"
                android:text="15s"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_speed_chip"
                android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/chip_multi_30s"
                android:layout_width="56dp"
                android:layout_height="28dp"
                android:text="30s"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_speed_chip_active"
                android:layout_marginEnd="8dp"/>

            <TextView android:id="@+id/chip_multi_60s"
                android:layout_width="56dp"
                android:layout_height="28dp"
                android:text="60s"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_speed_chip"/>
        </LinearLayout>

        <!-- Speed chips row -->
        <LinearLayout
            android:id="@+id/layout_multi_speed"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <TextView android:id="@+id/chip_speed_03"
                android:layout_width="48dp"
                android:layout_height="28dp"
                android:text="0.3x"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/bg_speed_chip"
                android:layout_marginEnd="6dp"/>

            <TextView android:id="@+id/chip_speed_05"
                android:layout_width="48dp"
                android:layout_height="28dp"
                android:text="0.5x"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/bg_speed_chip"
                android:layout_marginEnd="6dp"/>

            <TextView android:id="@+id/chip_speed_1"
                android:layout_width="44dp"
                android:layout_height="28dp"
                android:text="1x"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_speed_chip_active"
                android:layout_marginEnd="6dp"/>

            <TextView android:id="@+id/chip_speed_2"
                android:layout_width="44dp"
                android:layout_height="28dp"
                android:text="2x"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/bg_speed_chip"
                android:layout_marginEnd="6dp"/>

            <TextView android:id="@+id/chip_speed_3"
                android:layout_width="44dp"
                android:layout_height="28dp"
                android:text="3x"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:background="@drawable/bg_speed_chip"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Bottom panel ────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#88000000">

        <!-- Segmented clip bar (built programmatically) -->
        <LinearLayout
            android:id="@+id/layout_segment_bar"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:orientation="horizontal"/>

        <!-- Clip thumbnail strip -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_multi_clips"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"/>

        <!-- Timer + speed label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/tv_multi_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1×"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tv_multi_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_multi_max"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / 0:30"
                android:textColor="#88FFFFFF"
                android:textSize="14sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Delete  •  Record  •  Done row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp"
            android:paddingTop="8dp">

            <!-- Delete last clip -->
            <ImageButton
                android:id="@+id/btn_multi_delete"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/bg_icon_semi"
                android:tint="#FFFFFF"
                android:padding="13dp"
                android:contentDescription="Delete last clip"
                android:visibility="gone"/>

            <!-- Record / Stop button -->
            <ImageButton
                android:id="@+id/btn_multi_record"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/circle_primary"
                android:tint="#FFFFFF"
                android:padding="20dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:contentDescription="Record"/>

            <!-- Done -->
            <TextView
                android:id="@+id/btn_multi_done"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="Done"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_reel_upload_btn"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── 3-2-1 Countdown overlay (shown briefly before recording) ───── -->
    <FrameLayout
        android:id="@+id/layout_countdown"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="3"
            android:textColor="#FFFFFF"
            android:textSize="96sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="16"/>
    </FrameLayout>

</FrameLayout>
