<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="12dp" android:paddingVertical="10dp">

    <!-- Album cover art -->
    <ImageView
        android:id="@+id/iv_audio_cover"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:background="#2A2A2A"
        android:src="@drawable/ic_music_note"
        android:layout_marginEnd="10dp"/>

    <!-- Play/pause preview -->
    <ImageButton android:id="@+id/btn_audio_preview" android:layout_width="40dp"
        android:layout_height="40dp" android:background="@drawable/bg_circle_action"
        android:src="@drawable/ic_play"
            android:tint="#A855F7"
        android:layout_marginEnd="12dp"/>

    <!-- Track info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_audio_title" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"
            android:textSize="14sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end"/>
        <TextView android:id="@+id/tv_audio_artist" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginTop="2dp" android:maxLines="1"
            android:ellipsize="end"/>
        <TextView android:id="@+id/tv_audio_usage" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FF3B5C"
            android:textSize="11sp" android:layout_marginTop="2dp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="2dp">
            <TextView android:id="@+id/tv_audio_bpm"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#777777" android:textSize="10sp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tv_audio_trending_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FF3B5C" android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="6dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <ImageButton android:id="@+id/btn_audio_save" android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_bookmark"
            android:tint="#00C6FF"
        android:layout_marginHorizontal="4dp"/>

    <Button android:id="@+id/btn_audio_use" android:layout_width="52dp"
        android:layout_height="34dp" android:text="Use" android:textColor="#FFFFFF"
        android:backgroundTint="#FF3B5C" android:textSize="12sp"/>
</LinearLayout>
