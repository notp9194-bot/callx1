<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen video surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        app:use_controller="false"
        app:resize_mode="zoom"
        app:surface_type="surface_view"/>

    <!-- ── Photo Slideshow ViewPager2 ───────────────────────────────────────
         Shown instead of PlayerView for photo_slideshow reels.
         Hidden (GONE) by default; shown only when mediaType == "photo_slideshow".
         User can also manually swipe between photos.
    -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vp_photos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Thumbnail placeholder (shown before video loads) -->
    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Reel thumbnail"/>

    <!-- ── Story-style photo progress bar ───────────────────────────────────
         N thin animated segments at the very top, one per photo.
         Each active segment fills left→right over photoDurationMs ms.
         Populated programmatically by ReelPlayerFragment.buildStoryProgress().
         Visible only for photo_slideshow reels.
    -->
    <LinearLayout
        android:id="@+id/ll_story_progress"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"/>

    <!-- Photo counter badge: "2 / 5" — top-right corner -->
    <TextView
        android:id="@+id/tv_photo_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:text="1 / 1"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:background="#66000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone"/>

    <!-- Pause overlay badge: ⏸ shown during long-press hold pause -->
    <TextView
        android:id="@+id/tv_pause_badge"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="center"
        android:text="⏸"
        android:textSize="30sp"
        android:textColor="#EEFFFFFF"
        android:gravity="center"
        android:background="#77000000"
        android:alpha="0"
        android:visibility="gone"/>

    <!-- Per-photo caption overlay: slides up from bottom on photo change -->
    <TextView
        android:id="@+id/tv_caption_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="130dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="60dp"
        android:padding="10dp"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:background="#BB000000"
        android:alpha="0"
        android:visibility="gone"/>

    <!-- Instagram-style dot page indicator -->
    <LinearLayout
        android:id="@+id/ll_dot_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"/>

    <!-- Double tap like animation -->
    <ImageView
        android:id="@+id/iv_like_anim"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_heart_filled"
        android:tint="#FF416C"
        android:visibility="gone"
        android:alpha="0"
        android:contentDescription="Like animation"/>

    <!-- ── Play / Pause center overlay ──
         Shown briefly on tap (animated in/out by ReelPlayerFragment).
         src is updated in Java to ic_play or ic_pause depending on state.
    -->
    <ImageView
        android:id="@+id/iv_play_pause_indicator"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_pause"
        android:tint="#A855F7"
        android:alpha="0"
        android:background="#66000000"
        android:padding="14dp"
        android:contentDescription="Play/Pause indicator"/>

    <!-- Top row: mute button — paddingTop absorbs status-bar height (set in code) -->
    <LinearLayout
        android:id="@+id/top_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="8dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_volume_on"
            android:tint="#FFD700"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mute"/>
    </LinearLayout>

    <!-- Right action bar: Avatar · Like · Comment · Share · More
         paddingBottom is set in code to bottomNavHeight + navBarHeight so actions
         stay above the bottom navigation bar on edge-to-edge screens.
    -->
    <LinearLayout
        android:id="@+id/right_actions"
        android:layout_width="68dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="8dp"
        android:paddingEnd="8dp"
        android:paddingStart="4dp">

        <!-- Like -->
        <ImageButton
            android:id="@+id/btn_like"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_heart"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like"/>
        <TextView
            android:id="@+id/tv_likes_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- Comment -->
        <ImageButton
            android:id="@+id/btn_comment"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_comment_reel"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Comment"/>
        <TextView
            android:id="@+id/tv_comments_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- Share -->
        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_share_reel"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"/>
        <TextView
            android:id="@+id/tv_shares_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- Repost -->
        <ImageButton
            android:id="@+id/btn_repost"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_repost"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Repost"/>
        <TextView
            android:id="@+id/tv_repost_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- 3-dot More -->
        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_more_vert"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"/>
    </LinearLayout>

    <!-- Bottom info strip
         paddingBottom is set in code: navBarHeight only — strip sits at very bottom
    -->
    <LinearLayout
        android:id="@+id/bottom_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="72dp"
        android:paddingBottom="0dp">

        <!-- Owner avatar + name + follow button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <!-- Owner avatar with story ring -->
            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/iv_owner_story_ring"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_status_unseen"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"/>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_owner_avatar"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="#FF6B35"/>

                <TextView
                    android:id="@+id/btn_follow_overlay"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:text="+"
                    android:textColor="#000000"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:background="@color/brand_primary"
                    android:visibility="visible"/>
            
    <!-- ✨ Photo Style picker — visible only for photo_slideshow reels -->
    <TextView
        android:id="@+id/btn_photo_style"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="186dp"
        android:text="✨ Style"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:background="@drawable/bg_reel_follow_btn"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"/>

    <!-- 🎵 Beat-sync BPM indicator — shown when musicBpm > 0 -->
    <TextView
        android:id="@+id/tv_bpm_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="228dp"
        android:text="120 BPM"
        android:textColor="#00E5FF"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:background="#AA000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"/>

</FrameLayout>

            <TextView
                android:id="@+id/tv_owner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@user"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:id="@+id/tv_follow_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Follow"
                android:textColor="#00E5FF"
                android:textSize="13sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/bg_reel_follow_btn"
                android:visibility="visible"/>
        </LinearLayout>

        <!-- Caption -->
        <TextView
            android:id="@+id/tv_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Hashtag chips -->
        <HorizontalScrollView
            android:id="@+id/scroll_hashtags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="4dp"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/container_hashtags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Animated Music Ticker -->
        <LinearLayout
            android:id="@+id/layout_music_ticker"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            
            android:paddingStart="8dp"
            android:paddingEnd="10dp"
            android:layout_marginTop="2dp">

            <ImageView
                android:id="@+id/iv_music_disc"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_music_disc"
                android:tint="#00E5FF"
                android:contentDescription="Music disc"/>

            <TextView
                android:id="@+id/tv_music_name"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Original Audio"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:focusable="true"
                android:focusableInTouchMode="true"/>
        </LinearLayout>

        <!-- Live Reaction Counts -->
        <LinearLayout
            android:id="@+id/layout_live_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

    </LinearLayout>


    <!-- ── Floating Liker Avatars (Instagram explore style) ────────────────
         3 large circular avatars floating above bottom-left info strip.
         Gentle float animation applied in ReelPlayerFragment.
         visibility=gone until at least 1 liker loads.
         Tapping opens ReelLikesBottomSheet.
    -->
    <!-- outer wrapper: extra padding so float animation + hearts never clip -->
    <FrameLayout
        android:id="@+id/ll_likers_avatar_row"
        android:layout_width="140dp"
        android:layout_height="90dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="120dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:visibility="gone">

        <!-- Liker avatar 1 — left, bottom -->
        <FrameLayout
            android:id="@+id/fl_liker_1"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="bottom|start"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_liker_1"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="top|start"
                android:src="@drawable/ic_person"
                app:civ_border_width="1.5dp"
                app:civ_border_color="#FF416C"
                android:elevation="2dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_heart_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:text="&#x2764;&#xFE0F;"
                android:textSize="14sp"
                android:elevation="4dp"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Liker avatar 2 — center, top -->
        <FrameLayout
            android:id="@+id/fl_liker_2"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_liker_2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|start"
                android:src="@drawable/ic_person"
                app:civ_border_width="1.5dp"
                app:civ_border_color="#A855F7"
                android:elevation="3dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_heart_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:text="&#x2764;&#xFE0F;"
                android:textSize="14sp"
                android:elevation="4dp"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Liker avatar 3 — right, bottom -->
        <FrameLayout
            android:id="@+id/fl_liker_3"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="bottom|end"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_liker_3"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="top|start"
                android:src="@drawable/ic_person"
                app:civ_border_width="1.5dp"
                app:civ_border_color="#00E5FF"
                android:elevation="2dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tv_heart_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:text="&#x2764;&#xFE0F;"
                android:textSize="14sp"
                android:elevation="4dp"
                android:visibility="gone"/>
        </FrameLayout>

    </FrameLayout>

    <!-- Video progress bar — pinned to very bottom of video (0dp margin) -->
    <ProgressBar
        android:id="@+id/progress_video"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:max="1000"
        android:progress="0"
        android:progressTint="#FF416C"
        android:progressBackgroundTint="#44FF416C"
        android:layout_marginBottom="0dp"/>

    <!-- Buffering indicator -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="#A855F7"
        android:visibility="gone"/>

    <!-- Emoji reaction panel -->
    <LinearLayout
        android:id="@+id/layout_reactions"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@drawable/bg_reaction_panel"
        android:elevation="10dp"
        android:visibility="gone">

        <TextView android:id="@+id/react_fire"  android:layout_width="40dp" android:layout_height="40dp" android:text="🔥" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_heart" android:layout_width="40dp" android:layout_height="40dp" android:text="❤️" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_wow"   android:layout_width="40dp" android:layout_height="40dp" android:text="😮" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_laugh" android:layout_width="40dp" android:layout_height="40dp" android:text="😂" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_sad"   android:layout_width="40dp" android:layout_height="40dp" android:text="😢" android:textSize="22sp" android:gravity="center"/>
        <TextView android:id="@+id/react_clap"  android:layout_width="40dp" android:layout_height="40dp" android:text="👏" android:textSize="22sp" android:gravity="center"/>
    </LinearLayout>


    <!-- ── REPOST ATTRIBUTION BANNER v4.2.9 ─────────────────────────────────────
         Shown at the top when viewing a reposted reel.
         Java: ReelPlayerFragment binds tv_repost_attribution + ll_repost_attribution
         visibility=gone by default; made VISIBLE only for reposted reels.
    -->
    <LinearLayout
        android:id="@+id/ll_repost_attribution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x1F501;"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_repost_attribution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reposted from @creator"
                android:textColor="#00F260"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_repost_caption_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CE93D8"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_view_original"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View original"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- ── REPOST COUNT CHIP v4.2.9 ──────────────────────────────────────────────
         Shows "🔁 N reposts" bottom-left for the reel owner.
         Tapping opens ReelRepostListActivity to see who reposted.
    -->
    <LinearLayout
        android:id="@+id/ll_repost_count_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="96dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC1A1A1A"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x1F501;"
            android:textSize="13sp"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tv_repost_count_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 reposts"
            android:textColor="#A855F7"
            android:textSize="12sp"/>
    </LinearLayout>

      <!-- ── DUET SERIES CHIP ────────────────────────────────────────────────
           Shown when reel.seriesId != null.
           • Tap  → opens DuetSeriesActivity for this series
           • Long → instant subscribe / unsubscribe toast + Firebase toggle
      -->
      <LinearLayout
          android:id="@+id/ll_series_chip"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom|start"
          android:layout_marginStart="12dp"
          android:layout_marginBottom="138dp"
          android:orientation="horizontal"
          android:gravity="center_vertical"
          android:background="#CC1A1A1A"
          android:paddingStart="10dp"
          android:paddingEnd="10dp"
          android:paddingTop="6dp"
          android:paddingBottom="6dp"
          android:visibility="gone">

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="🎬"
              android:textSize="14sp"
              android:layout_marginEnd="5dp"/>

          <TextView
              android:id="@+id/tv_series_chip_label"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:textColor="#FFFFFF"
              android:textSize="12sp"
              android:fontFamily="sans-serif-medium"
              android:maxLines="1"
              android:ellipsize="end"
              android:maxWidth="200dp"/>

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="  ›"
              android:textColor="#AAFFFFFF"
              android:textSize="12sp"/>
      </LinearLayout>

  
</FrameLayout>
