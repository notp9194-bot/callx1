<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/tv_comment_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Comments"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="2dp"/>

        <!-- Search toggle -->
        <ImageButton
            android:id="@+id/btn_search_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_search"
            android:tint="#6BCFEF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Search comments"
            android:padding="8dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── Search bar (collapsed by default) ── -->
    <LinearLayout
        android:id="@+id/layout_search"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:background="?attr/colorSurface"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_search"
            android:tint="#6BCFEF"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search comments…"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:singleLine="true"
            android:imeOptions="actionSearch"/>

        <ImageButton
            android:id="@+id/btn_close_search"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close search"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- ── Sort chips row ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip_newest"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Newest"
                android:textSize="13sp"
                android:textColor="@color/brand_primary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_sort_chip_selected"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/chip_top"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Top Liked"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_sort_chip"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Comments list ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_comments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <!-- ── Empty state ── -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No comments yet.\nBe the first to comment!"
        android:textColor="@color/text_muted"
        android:textSize="15sp"
        android:visibility="gone"/>

    <!-- ── Replying-to bar ── -->
    <LinearLayout
        android:id="@+id/bar_replying_to"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:background="#F5F5F5"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_replying_to"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Replying to @user"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>

        <ImageButton
            android:id="@+id/btn_cancel_reply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel reply"
            android:padding="6dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── Input row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface">

        <!-- Character counter -->
        <TextView
            android:id="@+id/tv_char_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:paddingEnd="16dp"
            android:paddingTop="2dp"
            android:text="0/300"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <EditText
                android:id="@+id/et_comment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Write a comment…"
                android:textSize="14sp"
                android:maxLines="3"
                android:background="@drawable/bg_comment_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="actionSend"/>

            <ImageButton
                android:id="@+id/btn_send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_send_fill"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Send"
                android:padding="6dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
