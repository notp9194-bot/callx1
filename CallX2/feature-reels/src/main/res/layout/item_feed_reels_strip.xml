<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_reels_strip.xml
    "Reels for you" horizontal mini-reel thumbnails strip injected every ~10 posts.
    Backed by HomeReelsStripAdapter.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:layout_marginBottom="6dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_reels"
            android:tint="@color/brand_primary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Reels for you"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_reels_strip_see_all"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="See all"
            android:textSize="11sp"
            android:textColor="@color/brand_primary"
            android:background="@null"
            android:allCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>

    <!-- Horizontal mini-reel list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_reels_strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:layout_marginTop="8dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:clipToPadding="false"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="14dp"
        android:background="#222222"/>
</LinearLayout>
