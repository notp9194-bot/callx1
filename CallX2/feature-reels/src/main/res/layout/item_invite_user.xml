<?xml version="1.0" encoding="utf-8"?>
<!--
    item_invite_user.xml
    Fix 11 — DuetInviteActivity RecyclerView row
    One follower row with avatar, name, and "Invite" button.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/iv_invite_avatar"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_avatar_bg"
        android:src="@drawable/ic_person"/>

    <!-- Name block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/tv_invite_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@username"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_invite_display_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display Name"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Invite button -->
    <TextView
        android:id="@+id/btn_send_invite"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:text="Invite"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:background="@drawable/bg_btn_primary"/>

</LinearLayout>
