<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Handle bar -->
    <View android:layout_width="48dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginBottom="16dp"
        android:background="#CCCCCC"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Repost" android:textSize="18sp" android:textStyle="bold"
        android:textColor="#000000" android:layout_marginBottom="16dp"/>

    <!-- Caption input -->
    <LinearLayout android:id="@+id/layout_caption" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:hintEnabled="true" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_repost_caption"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Add a caption (optional)" android:maxLength="150"
                android:maxLines="3" android:inputType="textMultiLine"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="4dp">
            <TextView android:id="@+id/tv_ai_hint" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="✨ Generating caption..." android:textColor="#888888"
                android:textSize="12sp" android:visibility="gone"/>
            <TextView android:id="@+id/tv_char_count" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0/150"
                android:textColor="#888888" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- AI Suggest button -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="end" android:layout_marginBottom="16dp">
        <ImageButton android:id="@+id/btn_ai_suggest"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:src="@drawable/ic_sparkle" android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="AI Suggest Caption"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=" AI Caption" android:textColor="#7C3AED" android:textSize="13sp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>

    <!-- Repost type chips -->
    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="20dp" app:singleLine="true">

        <com.google.android.material.chip.Chip android:id="@+id/chip_quote_repost"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💬 Quote Repost" style="@style/Widget.MaterialComponents.Chip.Action"/>

        <com.google.android.material.chip.Chip android:id="@+id/chip_repost_story"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📖 Add to Story" style="@style/Widget.MaterialComponents.Chip.Action"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Progress -->
    <ProgressBar android:id="@+id/progress_repost"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:visibility="gone"
        android:layout_marginBottom="8dp"/>

    <!-- Repost button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_repost"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="🔁 Repost" android:textSize="16sp"
        app:cornerRadius="12dp"/>

    <!-- Undo button (shown when already reposted) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_undo_repost"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Undo Repost" android:textSize="16sp"
        android:layout_marginTop="8dp" android:visibility="gone"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:cornerRadius="12dp"/>
</LinearLayout>
