<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="#1A1A1A">

        <ImageButton
            android:id="@+id/btn_analytics_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/tv_analytics_sound_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sound Analytics"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usage Insights"
                android:textColor="#888888"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_analytics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp"
        android:indeterminateTint="#FF3B5C"/>

    <!-- No data state -->
    <TextView
        android:id="@+id/tv_analytics_no_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No analytics data available for this sound."
        android:textColor="#888888"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone"/>

    <!-- Stats content -->
    <ScrollView
        android:id="@+id/layout_analytics_stats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stat cards row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:marginBottom="12dp">

                <!-- Total Reels -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_analytics_total_reels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Reels"
                        android:textColor="#FF3B5C"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Reels"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Trending Rank -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:marginStart="6dp">

                    <TextView
                        android:id="@+id/tv_analytics_trending_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trending Rank"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Stat cards row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:marginBottom="20dp">

                <!-- Saves -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_analytics_saves"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Saves"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saves"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Avg VTR -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:marginStart="6dp">

                    <TextView
                        android:id="@+id/tv_analytics_vtr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg View-Through"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Top Creator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A1A1A"
                android:padding="16dp"
                android:marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Top Creator Using This Sound"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tv_analytics_top_creator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FF3B5C"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Weekly Usage Chart -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY USAGE (LAST 7 DAYS)"
                android:textColor="#888888"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/layout_weekly_chart"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:background="#1A1A1A"
                android:padding="12dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
