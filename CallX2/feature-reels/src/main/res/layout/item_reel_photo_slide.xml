<?xml version="1.0" encoding="utf-8"?>
<!--
    item_reel_photo_slide.xml  ── Ultra-Advanced Photo Slide v5
    ─────────────────────────────────────────────────────────────
    One page of the photo ViewPager2 in ReelPlayerFragment.

    Layers (bottom → top):
      1. iv_photo_slide          – main photo (centerCrop, Ken Burns target)
      2. v_effect_overlay        – full-bleed shader overlay (vignette / grain / glitch / etc.)
      3. v_color_filter_overlay  – semi-transparent colour tint for live filter preview
      4. ll_sticker_layer        – FrameLayout for programmatically added emoji/text stickers
      5. view_zoom_touch         – transparent hit-target for pinch-zoom & double-tap gestures
      6. tv_photo_caption        – per-photo animated caption bar at the bottom
      7. v_caption_gradient      – gradient scrim behind the caption
      8. ll_spark_row            – subtle sparkle/particle strip above the caption (opt.)
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ── 0a. Blurred letterbox fill (shown behind non-matching aspect photos,
              e.g. landscape photo inside a 9:16 slide, Instagram-style) ────── -->
    <ImageView
        android:id="@+id/iv_photo_blur_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null"/>

    <!-- ── 0b. Low-res blurred placeholder (Instagram-style fade-in while the
              full-resolution photo streams in) ─────────────────────────────── -->
    <ImageView
        android:id="@+id/iv_photo_placeholder_blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null"/>

    <!-- ── 0c. Shimmer skeleton shown until Glide resolves the photo ───────── -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_photo_skeleton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:shimmer_base_alpha="0.15"
        app:shimmer_highlight_alpha="0.35"
        app:shimmer_duration="1100"
        android:visibility="visible">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1AFFFFFF"/>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <!-- ── 1. Main photo ─────────────────────────────────────────────────── -->
    <ImageView
        android:id="@+id/iv_photo_slide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0"
        android:contentDescription="Reel photo"/>

    <!-- ── 1b. Motion photo / Live Photo loop player (muted, hidden until a
              motion clip is attached to this photo) ───────────────────────── -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_motion_photo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="zoom"
        android:visibility="gone"/>

    <!-- ── 1c. "LIVE" badge shown while a motion photo is actively playing ── -->
    <TextView
        android:id="@+id/tv_live_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="14dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:text="LIVE"
        android:textColor="#FFFFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:background="@drawable/bg_search_bar"
        android:visibility="gone"/>

    <!-- ── 2. Effect overlay  (vignette / grain / glitch / neon_glow / etc.) -->
    <!-- DrawingCache is updated by ReelPhotoSlideshowAdapter.applyEffect()   -->
    <View
        android:id="@+id/v_effect_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 3. Colour-filter tint overlay ─────────────────────────────────── -->
    <View
        android:id="@+id/v_color_filter_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 4. Sticker layer (emoji, drawn text, GIF stickers) ────────────── -->
    <FrameLayout
        android:id="@+id/ll_sticker_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"/>

    <!-- ── 5. Zoom gesture hit-target (covers full slide, below caption UI) -->
    <View
        android:id="@+id/view_zoom_touch"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="false"/>

    <!-- ── 5b. Double-tap heart-burst (Instagram-style like animation) ────── -->
    <ImageView
        android:id="@+id/iv_heart_burst"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_heart_filled"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        android:clickable="false"
        android:focusable="false"
        android:contentDescription="@null"/>

    <!-- ── 6. Caption gradient scrim ─────────────────────────────────────── -->
    <View
        android:id="@+id/v_caption_gradient"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_reel_bottom"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 7. Per-photo caption overlay ──────────────────────────────────── -->
    <!--     Animated in from below; alpha = 0 initially. Collapsed to 2 lines
             by default — swipe up or tap to expand the full caption.        -->
    <LinearLayout
        android:id="@+id/ll_caption_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="18dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="52dp"
        android:orientation="vertical"
        android:alpha="0"
        android:translationY="24dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tv_photo_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.35"
            android:background="#BB000000"
            android:maxLines="2"
            android:ellipsize="end"
            android:clickable="false"/>

        <TextView
            android:id="@+id/tv_caption_expand_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:paddingTop="2dp"
            android:text="⌃ swipe up for more"
            android:textColor="#99FFFFFF"
            android:textSize="10sp"
            android:visibility="gone"
            android:clickable="false"/>
    </LinearLayout>

    <!-- ── 8. Sparkle / particle strip above caption ─────────────────────── -->
    <LinearLayout
        android:id="@+id/ll_spark_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="78dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:clickable="false"/>

</FrameLayout>
