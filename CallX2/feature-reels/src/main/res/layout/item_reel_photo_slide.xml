<?xml version="1.0" encoding="utf-8"?>
<!--
    item_reel_photo_slide.xml  ── Instagram-Level Photo Slide v6
    ─────────────────────────────────────────────────────────────
    One page of the photo ViewPager2 in ReelPlayerFragment.

    Layers (bottom → top):
      0. iv_photo_bg_blur        – blurred letterbox fill (Instagram style)
      1. iv_photo_slide          – main photo (fitCenter — never cropped)
      2. v_effect_overlay        – full-bleed shader overlay (vignette / grain / glitch / etc.)
      3. v_color_filter_overlay  – semi-transparent colour tint for live filter preview
      4. ll_sticker_layer        – FrameLayout for programmatically added emoji/text stickers
      5. view_zoom_touch         – transparent hit-target for pinch-zoom & double-tap gestures
      6. v_top_gradient_scrim    – gradient at top for story bar readability
      7. v_bottom_gradient_scrim – deep Instagram-style bottom gradient scrim
      8. tv_photo_caption        – per-photo animated caption card at the bottom
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ── 0. Blurred background (Instagram-style letterbox fill) ─────────
         Same photo blurred + darkened, centerCrop so it fills the full
         9:16 frame. The foreground photo sits on top with fitCenter so it
         is NEVER cropped, regardless of aspect ratio. -->
    <ImageView
        android:id="@+id/iv_photo_bg_blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription=""/>

    <!-- ── 1. Main photo (fitCenter — never cropped) ─────────────────────── -->
    <ImageView
        android:id="@+id/iv_photo_slide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="Reel photo"/>

    <!-- ── 2. Effect overlay  (vignette / grain / glitch / neon_glow / etc.) -->
    <View
        android:id="@+id/v_effect_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 3. Colour-filter tint overlay ─────────────────────────────────── -->
    <View
        android:id="@+id/v_color_filter_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 4. Sticker layer (emoji, drawn text, GIF stickers) ────────────── -->
    <FrameLayout
        android:id="@+id/ll_sticker_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"/>

    <!-- ── 5. Zoom gesture hit-target (covers full slide, below caption UI) -->
    <View
        android:id="@+id/view_zoom_touch"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="false"/>

    <!-- ── 6. Top gradient scrim — keeps story progress readable ──────────
         120dp tall, fades from dark at top to transparent at ~40% height. -->
    <View
        android:id="@+id/v_top_gradient_scrim"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_photo_reel_top"
        android:clickable="false"/>

    <!-- ── 7. Bottom gradient scrim — Instagram-deep fade for action bar ──
         220dp tall deep gradient so caption and action buttons always pop. -->
    <View
        android:id="@+id/v_bottom_gradient_scrim"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_photo_reel_bottom"
        android:clickable="false"/>

    <!-- ── 8. Per-photo caption — animated slide-up frosted card ──────────
         Hidden initially (alpha=0, translateY=+20dp).
         Animated in by adapter when a caption is available.
         Rounded card with semi-transparent backdrop. -->
    <TextView
        android:id="@+id/tv_photo_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="72dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.45"
        android:letterSpacing="0.01"
        android:background="@drawable/bg_photo_caption_card"
        android:alpha="0"
        android:translationY="20dp"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 9. Caption gradient scrim (behind caption text) ─────────────── -->
    <View
        android:id="@+id/v_caption_gradient"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_reel_bottom"
        android:visibility="gone"
        android:clickable="false"/>

    <!-- ── 10. Sparkle / particle strip (opt.) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/ll_spark_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="84dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:clickable="false"/>

</FrameLayout>
