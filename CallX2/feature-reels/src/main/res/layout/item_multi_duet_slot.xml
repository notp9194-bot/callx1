<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="100dp"
      android:orientation="vertical" android:gravity="center"
      android:background="#1A1A1A" android:margin="6dp" android:padding="8dp">

      <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
          <ImageView android:id="@+id/iv_slot_avatar"
              android:layout_width="52dp" android:layout_height="52dp"/>
          <ImageButton android:id="@+id/btn_slot_remove"
              android:layout_width="20dp" android:layout_height="20dp"
              android:layout_gravity="top|end"
              android:src="@android:drawable/ic_menu_close_clear_cancel"
              android:background="#F44336" android:tint="#FFFFFF" android:padding="2dp"/>
      </FrameLayout>

      <TextView android:id="@+id/tv_slot_name"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:textColor="#FFFFFF" android:textSize="12sp" android:gravity="center"
          android:maxLines="1" android:ellipsize="end" android:layout_marginTop="4dp"/>
      <TextView android:id="@+id/tv_slot_status"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:textColor="#4CAF50" android:textSize="11sp"/>
  </LinearLayout>