<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#FFFFFF">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="8dp" android:paddingEnd="16dp"
            android:elevation="4dp" android:background="#FFFFFF">
            <ImageButton android:id="@+id/btn_back" android:layout_width="40dp"
                android:layout_height="40dp" android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Repost Analytics" android:textSize="18sp"
                android:textStyle="bold" android:paddingStart="8dp"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/progress_analytics"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:visibility="gone"
            android:layout_margin="24dp"/>

        <!-- Stats cards row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="16dp"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginEnd="8dp" android:elevation="2dp">
                <TextView android:id="@+id/tv_total_reposts"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="32sp" android:textStyle="bold"
                    android:textColor="#7C3AED"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total Reposts" android:textSize="12sp" android:textColor="#888888"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="16dp"
                android:background="@drawable/bg_card_rounded"
                android:elevation="2dp">
                <TextView android:id="@+id/tv_viral_badge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="16sp" android:textStyle="bold"
                    android:textColor="#F59E0B"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Viral Status" android:textSize="12sp" android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Breakdown -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp"
            android:paddingEnd="16dp" android:paddingBottom="16dp">
            <TextView android:id="@+id/tv_simple_count"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="0 Simple"
                android:gravity="center" android:textSize="14sp"/>
            <TextView android:id="@+id/tv_quote_count"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="0 Quote"
                android:gravity="center" android:textSize="14sp"/>
            <TextView android:id="@+id/tv_story_count"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="0 Story"
                android:gravity="center" android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Top Reposter: " android:textStyle="bold" android:textSize="14sp"/>
            <TextView android:id="@+id/tv_top_reposter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textColor="#7C3AED"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_repost_timeline"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
