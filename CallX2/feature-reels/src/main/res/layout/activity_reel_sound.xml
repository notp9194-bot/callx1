<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- Blurred cover background -->
    <ImageView android:id="@+id/iv_sound_cover"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:scaleType="centerCrop" android:alpha="0.3"/>

    <!-- Gradient overlay -->
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/gradient_reel_bottom"/>

    <!-- Main content -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:paddingHorizontal="12dp">
            <ImageButton android:id="@+id/btn_sound_back"
                android:layout_width="40dp" android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Sound" android:textColor="#FFFFFF"
                android:textSize="17sp" android:textStyle="bold"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                android:orientation="horizontal">
                <ImageButton android:id="@+id/btn_sound_save"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_heart" android:tint="#FFFFFF"/>
                <ImageButton android:id="@+id/btn_sound_share"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_share_reel" android:tint="#FFFFFF"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Spinning disc -->
        <FrameLayout android:layout_width="160dp" android:layout_height="160dp"
            android:layout_gravity="center_horizontal" android:layout_marginTop="16dp">
            <ImageView android:id="@+id/iv_sound_disc"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:scaleType="centerCrop" android:src="@drawable/ic_music_disc"/>
        </FrameLayout>

        <!-- Song info -->
        <TextView android:id="@+id/tv_sound_title"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:textColor="#FFFFFF"
            android:textSize="22sp" android:textStyle="bold"
            android:paddingHorizontal="24dp" android:paddingTop="16dp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_sound_artist"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:textColor="#CCCCCC"
            android:textSize="14sp" android:paddingTop="4dp"/>

        <!-- Stats row -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" android:orientation="horizontal"
            android:paddingTop="8dp">
            <TextView android:id="@+id/tv_sound_usage_count"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 reels" android:textColor="#888888" android:textSize="13sp"/>
            <TextView android:id="@+id/tv_sound_bpm"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FF3B5C" android:textSize="13sp" android:textStyle="bold"
                android:paddingStart="12dp" android:visibility="gone"/>
        </LinearLayout>

        <!-- Waveform -->
        <LinearLayout android:id="@+id/layout_sound_waveform"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal" android:gravity="center"
            android:paddingHorizontal="16dp" android:layout_marginTop="12dp"/>

        <!-- Play/Pause -->
        <TextView android:id="@+id/btn_sound_play_pause"
            android:layout_width="wrap_content" android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:text="▶  Play" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold"
            android:background="@drawable/bg_speed_chip"
            android:paddingHorizontal="32dp" android:gravity="center"
            android:layout_marginTop="12dp"/>

        <ProgressBar android:id="@+id/progress_sound_load"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal" android:visibility="gone"
            android:layout_marginTop="8dp"/>

        <!-- Use this Sound -->
        <TextView android:id="@+id/btn_sound_use"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginHorizontal="24dp" android:layout_marginTop="16dp"
            android:text="Use this Sound" android:gravity="center"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"/>

        <!-- Secondary actions -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginTop="12dp" android:paddingHorizontal="24dp">
            <TextView android:id="@+id/btn_sound_record"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginEnd="8dp"
                android:text="🎙 Record" android:gravity="center"
                android:textColor="#FFFFFF" android:textSize="13sp"
                android:background="@drawable/bg_outlined_btn_red"/>
            <TextView android:id="@+id/btn_sound_browse"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginStart="8dp"
                android:text="🎵 Browse All" android:gravity="center"
                android:textColor="#FFFFFF" android:textSize="13sp"
                android:background="@drawable/bg_outlined_btn_red"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
