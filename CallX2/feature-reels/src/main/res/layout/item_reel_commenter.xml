<?xml version="1.0" encoding="utf-8"?>
<!-- item_reel_commenter.xml — Advanced v2 with in-sheet like, verified badge, long-press -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground"
    android:minHeight="64dp">

    <!-- Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_avatar"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:src="@drawable/ic_person"/>

    <!-- Name + comment text column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <!-- Name row: name + verified + pinned -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"/>

            <ImageView
                android:id="@+id/iv_verified"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_marginStart="3dp"
                android:src="@drawable/ic_verified"
                android:visibility="gone"
                android:contentDescription="Verified"/>

            <TextView
                android:id="@+id/tv_pinned"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="📌"
                android:textSize="11sp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- @username sub-label -->
        <TextView
            android:id="@+id/tv_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>

        <!-- Comment text -->
        <TextView
            android:id="@+id/tv_comment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- Edited label -->
        <TextView
            android:id="@+id/tv_edited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(edited)"
            android:textSize="10sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"/>

        <!--
            v9: Photo thumbnail — shown below comment text when a photo was attached.
            Visibility is toggled at runtime by the adapter (GONE when no photo).
        -->
        <ImageView
            android:id="@+id/iv_comment_photo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="6dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_comment_photo"
            android:clipToOutline="true"
            android:contentDescription="Comment photo"
            android:visibility="gone"/>

        <!-- Comment likes row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <!-- Tappable heart icon for in-sheet like -->
            <ImageButton
                android:id="@+id/btn_like_comment"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:padding="0dp"
                android:src="@drawable/ic_heart"
            android:tint="#FF416C"
                android:background="@null"
                android:contentDescription="Like comment"/>

            <TextView
                android:id="@+id/tv_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Reply button -->
    <Button
        android:id="@+id/btn_reply"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Reply"
        android:textSize="12sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@drawable/bg_btn_secondary"
        android:textColor="?attr/colorOnSurface"/>

</LinearLayout>
