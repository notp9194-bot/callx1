<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="80dp">

                <!-- ── Stories Bar ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <HorizontalScrollView
                        android:id="@+id/scroll_stories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <LinearLayout
                            android:id="@+id/container_stories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Add Story (My story) — always first -->
                            <LinearLayout
                                android:id="@+id/btn_add_story"
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="4dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="60dp"
                                    android:layout_height="60dp">

                                    <de.hdodenhof.circleimageview.CircleImageView
                                        android:id="@+id/iv_my_story_avatar"
                                        android:layout_width="56dp"
                                        android:layout_height="56dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_person"
                                        app:civ_border_width="1dp"
                                        app:civ_border_color="#333333"/>

                                    <!-- "+" overlay -->
                                    <ImageView
                                        android:layout_width="22dp"
                                        android:layout_height="22dp"
                                        android:layout_gravity="bottom|end"
                                        android:src="@drawable/ic_status_add"
                                        android:background="@color/brand_primary"
                                        android:padding="3dp"
                                        android:tint="#FFFFFF"/>
                                </FrameLayout>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Add Story"
                                    android:textColor="#FFFFFF"
                                    android:textSize="10sp"
                                    android:gravity="center"/>
                            </LinearLayout>

                            <!-- Contact story avatars injected here by HomeFragment -->
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A1A1A"/>

                <!-- ── Feed Toggle ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/btn_home_following"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Following"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:paddingEnd="20dp"
                            android:gravity="center_vertical"
                            android:alpha="1.0"/>

                        <TextView
                            android:id="@+id/btn_home_for_you"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="For You"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:paddingEnd="20dp"
                            android:gravity="center_vertical"
                            android:alpha="0.55"/>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"/>

                        <ImageButton
                            android:id="@+id/btn_home_upload"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_add_reels"
                            android:tint="#FFFFFF"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Upload Post"/>
                    </LinearLayout>

                    <!-- Active-tab underline indicator -->
                    <View
                        android:id="@+id/v_feed_indicator"
                        android:layout_width="70dp"
                        android:layout_height="2dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="16dp"
                        android:background="@color/brand_primary"/>
                </FrameLayout>

                <!-- ── Feed Container ── -->
                <LinearLayout
                    android:id="@+id/container_feed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- Feed loading / empty -->
                <ProgressBar
                    android:id="@+id/pb_feed_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/brand_primary"
                    android:visibility="gone"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_feed_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Follow creators to see their posts here.\nSwitch to &quot;For You&quot; to explore all reels."
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <!-- ── Trending Section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔥 Trending Reels"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/btn_see_all_trending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:id="@+id/container_trending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <ProgressBar
                            android:id="@+id/pb_trending"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:indeterminateTint="@color/brand_primary"
                            android:layout_gravity="center"
                            android:visibility="visible"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- ── Suggested Creators Section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✨ Suggested Creators"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/btn_see_all_suggested"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:id="@+id/container_suggested_creators"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <ProgressBar
                            android:id="@+id/pb_suggested"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:indeterminateTint="@color/brand_primary"
                            android:layout_gravity="center"
                            android:visibility="visible"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- ── Friends Activity Section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👥 Friends Activity"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/btn_see_all_activity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_friends_activity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ProgressBar
                        android:id="@+id/pb_activity"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:indeterminateTint="@color/brand_primary"
                        android:layout_gravity="center"
                        android:layout_marginBottom="8dp"/>
                </LinearLayout>

                <!-- ── Continue Watching Section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⏱ Continue Watching"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/btn_clear_history"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:id="@+id/container_continue_watching"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">

                        <ProgressBar
                            android:id="@+id/pb_continue"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:indeterminateTint="@color/brand_primary"
                            android:layout_gravity="center"
                            android:visibility="visible"/>
                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
