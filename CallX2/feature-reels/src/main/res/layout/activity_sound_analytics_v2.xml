<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:background="#111111">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/tv_sound_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sound Analytics"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingStart="4dp"/>

        <TextView
            android:id="@+id/tv_trending_badge"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="🔥 Trending"
            android:textColor="#FF3B5C"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1FFF3B5C"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center"
            android:visibility="gone"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:indeterminateTint="#FF3B5C"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tv_no_data"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No analytics data available yet.\nShare this sound to start tracking."
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone"/>

    <ScrollView
        android:id="@+id/layout_stats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Row 1: Reels + Saves -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:id="@+id/tv_reels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Reels"
                        android:textColor="#FF3B5C"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Reels Made"
                        android:textColor="#666666"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:id="@+id/tv_saves"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Saves"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Saves"
                        android:textColor="#666666"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Trending Rank + Viral Coefficient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:id="@+id/tv_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trending Rank"
                        android:textColor="#666666"
                        android:textSize="11sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:id="@+id/tv_viral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#4FC3F7"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Viral Coefficient"
                        android:textColor="#666666"
                        android:textSize="11sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Share rate row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1A1A1A"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save Rate (saves ÷ reels)"
                    android:textColor="#888888"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tv_share_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- 7-day plays bar chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYS — LAST 7 DAYS"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp"/>

                <com.callx.app.music.SoundAnalyticsActivity.BarChartView
                    android:id="@+id/bar_chart_plays"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"/>
            </LinearLayout>

            <!-- Top creators -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOP CREATORS USING THIS SOUND"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_top_creators"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FF3B5C"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:text="—"/>
            </LinearLayout>

            <!-- Reels using this sound — grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A1A1A"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REELS USING THIS SOUND"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_reels_grid_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No reels yet"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sound_analytics_reels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
