<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_suggested_card.xml
    "Suggested for you" card injected every ~6 feed posts.
    Contains a horizontal RecyclerView of suggested user cards.
    Backed by SuggestedAccountsAdapter.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:layout_marginBottom="6dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Suggested for you"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_suggested_dismiss"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="See all"
            android:textSize="11sp"
            android:textColor="#4CAF50"
            android:background="@null"
            android:allCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>

    <!-- Horizontal list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_suggested_accounts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:layout_marginTop="8dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:clipToPadding="false"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="14dp"
        android:background="#222222"/>
</LinearLayout>
