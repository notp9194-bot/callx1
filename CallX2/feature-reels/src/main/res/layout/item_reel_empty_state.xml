<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingTop="48dp"
    android:paddingBottom="48dp"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <ImageView
        android:id="@+id/iv_empty_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_reels"
        android:alpha="0.6"
        android:tint="#FF416C"
        android:contentDescription="Empty"/>

    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="No Reels Yet"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#FF416C"/>

    <TextView
        android:id="@+id/tv_empty_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="This creator hasn't posted any reels yet."
        android:textSize="14sp"
        android:gravity="center"
        android:textColor="?attr/colorOnSurfaceVariant"/>

</LinearLayout>
