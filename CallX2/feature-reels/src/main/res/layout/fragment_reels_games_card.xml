<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_reels_games_card.xml — Ultra Modern 4-Card Edition
    Full-screen Games card: 2x2 grid, big game image area, neon design.
    Shown ONCE after first 3 reels. Feed continues after.
    Row 1: Bubble Pop + Car Racing (playable)
    Row 2: Game 3 + Game 4 (Coming Soon)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_games_screen_gradient"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- ── HEADER ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="13"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left: title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_games_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● LIVE"
                    android:textColor="#00FFB2"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINI GAMES"
                    android:textColor="#CCCCFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Play Now 🎮"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>
        </LinearLayout>

        <!-- Right: subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instant · No download"
            android:textColor="#55556A"
            android:textSize="11sp"
            android:gravity="end"/>

    </LinearLayout>

    <!-- ── ROW 1: Bubble Pop + Car Racing ──────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="40"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <!-- ── CARD 1: Bubble Pop ────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/card_game_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="7dp"
            android:orientation="vertical"
            android:background="@drawable/bg_reels_game_card_bubble"
            android:clickable="true"
            android:focusable="true"
            android:clipToOutline="true">

            <!-- Big game image area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="58"
                android:background="@drawable/bg_game_img_bubble">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🫧"
                    android:textSize="62sp"/>

                <!-- Live tag -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_game_live_tag"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="FREE"
                    android:textColor="#00FFB2"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
            </FrameLayout>

            <!-- Info area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="42"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_game1_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bubble Pop"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pop &amp; score!"
                    android:textColor="#8888AA"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:id="@+id/btn_game1_play"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/bg_reels_game_play_btn_bubble"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶  PLAY"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── CARD 2: Car Racing ─────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/card_game_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="7dp"
            android:orientation="vertical"
            android:background="@drawable/bg_reels_game_card_racing"
            android:clickable="true"
            android:focusable="true"
            android:clipToOutline="true">

            <!-- Big game image area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="58"
                android:background="@drawable/bg_game_img_racing">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🏎️"
                    android:textSize="62sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_game_live_tag"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="FREE"
                    android:textColor="#00FFB2"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>
            </FrameLayout>

            <!-- Info area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="42"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_game2_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Car Racing"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Race to win!"
                    android:textColor="#8888AA"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:id="@+id/btn_game2_play"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/bg_reels_game_play_btn_racing"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶  PLAY"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- ── ROW 2: Coming Soon × 2 ──────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="40"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <!-- ── CARD 3: Coming Soon ────────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="7dp"
            android:orientation="vertical"
            android:background="@drawable/bg_reels_game_card_cs1"
            android:clipToOutline="true">

            <!-- Big image area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="58"
                android:background="@drawable/bg_game_img_cs1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🧩"
                    android:textSize="62sp"
                    android:alpha="0.4"/>

                <!-- Coming Soon overlay label -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#55000000">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_game_cs_label"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="COMING\nSOON"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.10"/>
                </FrameLayout>
            </FrameLayout>

            <!-- Info area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="42"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Puzzle Mania"
                    android:textColor="#AAAACC"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brain challenge"
                    android:textColor="#55556A"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/bg_game_cs_btn">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔  Notify Me"
                        android:textColor="#8888AA"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── CARD 4: Coming Soon ────────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="7dp"
            android:orientation="vertical"
            android:background="@drawable/bg_reels_game_card_cs2"
            android:clipToOutline="true">

            <!-- Big image area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="58"
                android:background="@drawable/bg_game_img_cs2">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⚔️"
                    android:textSize="62sp"
                    android:alpha="0.4"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#55000000">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_game_cs_label"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:text="COMING\nSOON"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.10"/>
                </FrameLayout>
            </FrameLayout>

            <!-- Info area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="42"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Battle Arena"
                    android:textColor="#AAAACC"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fight &amp; conquer"
                    android:textColor="#55556A"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:background="@drawable/bg_game_cs_btn">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔  Notify Me"
                        android:textColor="#8888AA"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- ── FOOTER ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬆  Swipe for more reels"
            android:textColor="#33334A"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>
