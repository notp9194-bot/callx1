<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:elevation="4dp"
        android:background="@color/surface">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Invite Collaborator"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Reel preview card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/surface"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/iv_collab_invite_thumb"
            android:layout_width="56dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="@color/shimmer_base"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Reel"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_collab_invite_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

    <!-- Selected collaborator chip -->
    <LinearLayout
        android:id="@+id/ll_collab_selected_chip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/surface"
        android:visibility="gone">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_collab_selected_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_person"/>
        <TextView
            android:id="@+id/tv_collab_selected_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="10dp"/>
        <ImageButton
            android:id="@+id/btn_remove_collab"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove"/>
    </LinearLayout>

    <!-- Search field -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/background">
        <EditText
            android:id="@+id/et_collab_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Search by name or @handle"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_rounded_outline"
            android:inputType="text"/>
    </LinearLayout>

    <!-- Search hint -->
    <TextView
        android:id="@+id/tv_collab_search_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search for a user to invite as co-author"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="24dp"/>

    <!-- Search results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_collab_search"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"/>

    <!-- Send invite button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surface">
        <ProgressBar
            android:id="@+id/progress_collab_invite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>
        <Button
            android:id="@+id/btn_send_collab_invite"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Send Collab Invite"
            android:enabled="false"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
