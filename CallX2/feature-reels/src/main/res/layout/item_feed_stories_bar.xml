<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_stories_bar.xml
    The stories bar row at the very top of the home feed (position 0 in RecyclerView).
    Contains a horizontal RecyclerView of story circle thumbnails.
    Backed by StoriesBarAdapter.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_stories_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"/>

    <!-- Thin divider below stories -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="10dp"
        android:background="#222222"/>

</LinearLayout>
