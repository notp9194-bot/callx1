<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground">

    <!-- Thumbnail -->
    <ImageView
        android:id="@+id/iv_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Reel thumbnail"/>

    <!-- Bottom scrim for duration readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_gravity="bottom"
        android:background="#88000000"/>

    <!-- Duration badge (bottom-right) -->
    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:text="0:00"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Feature 15: Views overlay badge (top-left, own profile only) -->
    <TextView
        android:id="@+id/tv_views_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="4dp"
        android:text="👁 0"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:background="#66000000"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"/>

    <!-- Multi-select: dim overlay -->
    <View
        android:id="@+id/view_dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#44000000"
        android:visibility="gone"/>

    <!-- Multi-select: selected highlight overlay -->
    <View
        android:id="@+id/view_select_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#556C5CE7"
        android:visibility="gone"/>

    <!-- Multi-select: checkmark (top-right) -->
    <ImageView
        android:id="@+id/iv_checkmark"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_double_tick_blue"
        android:background="@drawable/circle_primary"
        android:padding="3dp"
        android:contentDescription="Selected"
        android:visibility="gone"/>

</FrameLayout>
