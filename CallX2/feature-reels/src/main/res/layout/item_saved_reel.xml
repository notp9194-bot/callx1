<?xml version="1.0" encoding="utf-8"?>
  <FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="#000000"
      android:foreground="?attr/selectableItemBackground">

      <ImageView
          android:id="@+id/iv_thumb"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:minHeight="160dp"
          android:scaleType="centerCrop"
          android:contentDescription="Reel thumbnail"/>

      <TextView
          android:id="@+id/tv_caption"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_gravity="top"
          android:paddingStart="6dp"
          android:paddingEnd="6dp"
          android:paddingTop="6dp"
          android:textColor="#FFFFFF"
          android:textSize="11sp"
          android:textStyle="bold"
          android:maxLines="3"
          android:ellipsize="end"
          android:shadowColor="#CC000000"
          android:shadowDx="0" android:shadowDy="1" android:shadowRadius="3"
          android:visibility="gone"/>

      <LinearLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="bottom|start"
          android:layout_marginStart="4dp"
          android:layout_marginBottom="4dp"
          android:orientation="horizontal"
          android:gravity="center_vertical">
          <ImageView
              android:layout_width="10dp" android:layout_height="10dp"
              android:src="@drawable/ic_play" android:tint="#FFFFFF"
              android:alpha="0.9" android:contentDescription="Views"/>
          <TextView
              android:id="@+id/tv_views_overlay"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:layout_marginStart="3dp" android:text="0"
              android:textColor="#FFFFFF" android:textSize="10sp"
              android:fontFamily="sans-serif-medium"/>
      </LinearLayout>

      <TextView
          android:id="@+id/tv_duration"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_gravity="bottom|end"
          android:layout_marginEnd="4dp" android:layout_marginBottom="4dp"
          android:text="0:00" android:textColor="#DDDDDD"
          android:textSize="10sp" android:fontFamily="sans-serif-medium"
          android:visibility="gone"/>

      <View android:id="@+id/view_dim_overlay"
          android:layout_width="match_parent" android:layout_height="match_parent"
          android:background="#44000000" android:visibility="gone"/>
      <View android:id="@+id/view_select_overlay"
          android:layout_width="match_parent" android:layout_height="match_parent"
          android:background="#556C5CE7" android:visibility="gone"/>
      <ImageView android:id="@+id/iv_checkmark"
          android:layout_width="24dp" android:layout_height="24dp"
          android:layout_gravity="top|end" android:layout_margin="6dp"
          android:src="@drawable/ic_double_tick_blue"
          android:background="@drawable/circle_primary"
          android:padding="3dp" android:contentDescription="Selected"
          android:visibility="gone"/>
  </FrameLayout>
  