<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_reel_share_sheet.xml
    BottomSheetDialogFragment ka layout — CoordinatorLayout aur backdrop hata diye.
    Material ka BottomSheetDialog apna backdrop/dim/animation khud handle karta hai.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="@color/divider"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share Reel"
            android:textSize="17sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#FFE082"/>

        <ImageButton
            android:id="@+id/btn_share_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:tint="?attr/colorOnSurface"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"/>
    </LinearLayout>

    <!-- Send to contacts label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send to"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:paddingStart="16dp"
        android:layout_marginBottom="8dp"/>

    <ProgressBar
        android:id="@+id/progress_share"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        android:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_share_contacts"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginVertical="4dp"/>

    <!-- Copy Link -->
    <LinearLayout
        android:id="@+id/btn_copy_link"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_share_reel"
            android:tint="#00F260" android:tint="?attr/colorOnSurface"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="16dp" android:text="Copy Link"
            android:textSize="15sp" android:textColor="?attr/colorOnSurface"/>
    </LinearLayout>

    <!-- Share via -->
    <LinearLayout
        android:id="@+id/btn_share_external"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:src="@drawable/ic_send"
            android:tint="#00C6FF" android:tint="?attr/colorOnSurface"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="16dp" android:text="Share via..."
            android:textSize="15sp" android:textColor="?attr/colorOnSurface"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginVertical="4dp"/>

    <!-- ───────────── SYSTEM OPTIONS SECTION ───────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADD TO"
        android:textSize="11sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

    <!-- ★ Add to Story (Instagram-style gradient story in Reels home) -->
    <LinearLayout
        android:id="@+id/btn_add_to_story"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <!-- Gradient ring icon background -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/gradient_story_ring"
                android:layout_gravity="center"/>
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sparkle"
                android:tint="#FFFFFF"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add to Story"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appears with gradient ring in Reels home"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24h"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pin_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>
    </LinearLayout>

    <!-- ★ Add to Status (WhatsApp-style — visible in Status tab) -->
    <LinearLayout
        android:id="@+id/btn_share_to_status"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_status_notification"
                android:tint="?attr/colorOnSurface"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add to Status"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appears in your Status tab for contacts"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24h"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pin_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginVertical="4dp"/>

    <!-- Repost with Caption -->
    <LinearLayout
        android:id="@+id/btn_repost_with_caption"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">
        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="🔁"
            android:textSize="18sp"
            android:gravity="center"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repost with Caption"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add your own words when reposting"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>
    </LinearLayout>

</LinearLayout>
