<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ── Pin badge row (hidden unless isPinned) ── -->
    <LinearLayout
        android:id="@+id/row_pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        android:background="@drawable/bg_pin_badge"
        android:visibility="gone">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_pin"
            android:tint="#00E5FF"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pinned comment"
            android:textSize="11sp"
            android:textColor="#FF9800"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- ── Main comment row ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <!-- Avatar with Story Ring -->
        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="2dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"/>

            <ImageView
                android:id="@+id/iv_story_ring"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="center"
                android:background="@drawable/story_ring_insta_gradient"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>

        </FrameLayout>

        <!-- Comment body -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name + time + edited -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="2h"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"/>

                <TextView
                    android:id="@+id/tv_edited"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="(edited)"
                    android:textSize="10sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Comment text -->
            <TextView
                android:id="@+id/tv_comment_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:maxLines="8"
                android:ellipsize="end"/>

            <!-- Emoji reaction strip (shown when reactions exist) -->
            <LinearLayout
                android:id="@+id/layout_reactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"/>

            <!-- Action bar: Reply + View Replies -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/btn_reply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reply"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif-medium"
                    android:paddingEnd="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_view_replies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View 3 replies"
                    android:textSize="12sp"
                    android:textColor="@color/brand_primary"
                    android:fontFamily="sans-serif-medium"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Replies container (expanded inline) -->
            <LinearLayout
                android:id="@+id/container_replies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Like button + count (right side) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="8dp">

            <ImageButton
                android:id="@+id/btn_like_comment"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_heart"
            android:tint="#FF416C"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Like comment"
                android:padding="6dp"/>

            <TextView
                android:id="@+id/tv_likes_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="58dp"
        android:background="@color/divider"/>

</LinearLayout>
