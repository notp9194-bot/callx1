<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_single_reel_player.xml
    Fix 1 — SingleReelPlayerActivity
    Full-screen single reel player: referenced by DuetsByReelActivity when a duet thumbnail is tapped.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Full-screen video player ───────────────────────────────────────── -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_single_reel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fill"
        app:surface_type="surface_view"/>

    <!-- ── Bottom gradient scrim ─────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_reel_bottom"/>

    <!-- ── Top bar ────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="40dp"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:background="@drawable/gradient_reel_top">

        <ImageButton
            android:id="@+id/btn_single_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/tv_single_owner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- ── Loading spinner ────────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progress_single_reel"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="@color/brand_primary"
        android:visibility="gone"/>

    <!-- ── Bottom info & action row ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="40dp"
        android:paddingTop="12dp">

        <!-- Caption -->
        <TextView
            android:id="@+id/tv_single_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="16dp"/>

        <!-- Duet CTA button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Duet button -->
            <LinearLayout
                android:id="@+id/btn_single_duet"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_btn_primary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_video_call"
                    android:tint="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Duet this"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
