<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- ── Top bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btn_explore_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <EditText
            android:id="@+id/et_explore_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_search_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="Search reels, sounds, creators…"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:focusable="false"
            android:clickable="true"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- ── Category chips ── -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        app:singleSelection="true"/>

    <!-- ── Pull-to-refresh wraps scroll content ── -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_explore"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Trending Hashtags ── -->
                <TextView
                    android:id="@+id/tv_section_hashtags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Trending Hashtags"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp"
                    android:textColor="?attr/colorOnSurface"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_trending_hashtags"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"/>

                <!-- ── Trending Sounds ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎵 Trending Sounds"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_section_sounds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_trending_sounds"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"/>

                <!-- ── Featured Creators ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ Featured Creators"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_section_creators"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_featured_creators"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"/>

                <!-- ── Suggested For You ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✨ Suggested For You"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"/>

                    <TextView
                        android:id="@+id/tv_section_suggested"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See All"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_suggested_creators"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"/>

                <!-- ── Explore Reels Grid ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Explore Reels"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"/>

                    <!-- Result count badge -->
                    <TextView
                        android:id="@+id/tv_result_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:visibility="gone"/>

                    <ProgressBar
                        android:id="@+id/progress_explore"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_explore_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingBottom="24dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
