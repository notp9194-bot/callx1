<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dim backdrop — tap to close -->
    <View
        android:id="@+id/share_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"/>

    <!-- Bottom sheet — rubber jaisi drag hogi upar/neeche -->
    <LinearLayout
        android:id="@+id/share_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_rounded"
        android:paddingBottom="24dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_draggable="true"
        app:behavior_peekHeight="420dp">

        <!-- Drag Handle — rubber feel ke liye -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_skeleton_rect"/>

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Share Reel"
                android:textSize="17sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#FFE082"/>

            <ImageButton
                android:id="@+id/btn_share_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"/>
        </LinearLayout>

        <!-- Send to contacts -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send to"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingStart="16dp"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/progress_share"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:visibility="visible"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_share_contacts"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="4dp"/>

        <!-- Copy Link -->
        <LinearLayout
            android:id="@+id/btn_copy_link"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_share_reel"
            android:tint="#00F260" android:tint="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="16dp" android:text="Copy Link"
                android:textSize="15sp" android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

        <!-- Share via -->
        <LinearLayout
            android:id="@+id/btn_share_external"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_send"
            android:tint="#00C6FF" android:tint="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="16dp" android:text="Share via..."
                android:textSize="15sp" android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

        <!-- Add to Status -->
        <LinearLayout
            android:id="@+id/btn_share_to_status"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_status_notification" android:tint="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="16dp" android:text="Add to Status"
                android:textSize="15sp" android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginVertical="4dp"/>

        <!-- Repost with Caption -->
        <LinearLayout
            android:id="@+id/btn_repost_with_caption"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground">
            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="🔁"
                android:textSize="18sp"
                android:gravity="center"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Repost with Caption"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add your own words when reposting"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="#4CAF50"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
