<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="72dp"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:padding="10dp" android:background="?attr/selectableItemBackground"
      android:layout_marginBottom="1dp">
      <TextView android:id="@+id/tv_lb_rank"
          android:layout_width="36dp" android:layout_height="wrap_content"
          android:textColor="#FFD700" android:textSize="20sp" android:gravity="center"/>
      <ImageView android:id="@+id/iv_lb_avatar"
          android:layout_width="44dp" android:layout_height="44dp" android:layout_marginStart="8dp"/>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
          <TextView android:id="@+id/tv_lb_name"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:orientation="horizontal">
              <TextView android:id="@+id/tv_lb_likes"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:textColor="#888888" android:textSize="12sp" android:layout_marginEnd="12dp"/>
              <TextView android:id="@+id/tv_lb_views"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:textColor="#888888" android:textSize="12sp"/>
          </LinearLayout>
      </LinearLayout>
      <ImageView android:id="@+id/iv_lb_thumb"
          android:layout_width="44dp" android:layout_height="60dp"
          android:scaleType="centerCrop" android:background="#222"/>
  </LinearLayout>