<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="16dp"
    android:gravity="center_vertical">

    <ImageView android:id="@+id/iv_reposter_avatar"
        android:layout_width="44dp" android:layout_height="44dp"
        android:scaleType="centerCrop" android:src="@drawable/ic_default_avatar"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:paddingStart="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_reposter_name"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textStyle="bold"
                android:textSize="15sp" android:textColor="#000000"/>
            <TextView android:id="@+id/tv_repost_type_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#7C3AED"
                android:background="@drawable/bg_chip_purple"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="2dp" android:paddingBottom="2dp"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_repost_caption"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#444444" android:textSize="13sp"
            android:maxLines="2" android:ellipsize="end" android:layout_marginTop="2dp"/>
        <TextView android:id="@+id/tv_repost_time"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp" android:layout_marginTop="4dp"/>
    </LinearLayout>
</LinearLayout>
