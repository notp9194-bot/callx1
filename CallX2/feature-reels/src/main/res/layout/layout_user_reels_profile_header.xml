<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_user_reels_profile_header.xml
    =====================================
    Profile header — inflated as RecyclerView item TYPE_HEADER (position 0) in rvReels and rvSeries.
    Contains: avatar, follower/following/reel stats, mutual followers, bio, social link rows,
              action buttons (message/call/video/X/YouTube) with avatar peek animation overlays.
    The TabLayout is FIXED in activity_user_reels.xml (sticky, always visible).
    Moving header into RecyclerView = profile scrolls naturally with the reel grid.  ← Approach A fix
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Avatar + Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="14dp" android:paddingBottom="10dp">

        <FrameLayout android:layout_width="90dp" android:layout_height="90dp">

            <View android:id="@+id/view_story_ring"
                android:layout_width="90dp" android:layout_height="90dp"
                android:background="@drawable/bg_story_ring"
                android:visibility="gone"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar"
                android:layout_width="80dp" android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/brand_primary"/>

            <View android:layout_width="16dp" android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="2dp" android:layout_marginBottom="2dp"
                android:background="@drawable/bg_story_ring"
                android:backgroundTint="@color/status_online"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="horizontal"
            android:gravity="center" android:layout_marginStart="8dp">

            <LinearLayout android:id="@+id/layout_followers_click"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_followers"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="19sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#00C6FF"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FOLLOWERS" android:textSize="10sp"
                    android:letterSpacing="0.04"
                    android:textColor="#6BCFEF"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/layout_following_click"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground">
                <TextView android:id="@+id/tv_following"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="19sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#00F260"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FOLLOWING" android:textSize="10sp"
                    android:letterSpacing="0.04"
                    android:textColor="#6BE8A8"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tv_reel_count"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="19sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#A855F7"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="REELS" android:textSize="10sp"
                    android:letterSpacing="0.04"
                    android:textColor="#C084FC"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Mutual followers — Instagram style (clickable) -->
    <LinearLayout android:id="@+id/layout_mutual_followers"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="12dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/frame_mutual_avatars"
            android:layout_width="62dp" android:layout_height="30dp"
            android:layout_marginEnd="10dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_mutual_3"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="18dp"
                android:src="@drawable/ic_person"
                android:visibility="gone"
                app:civ_border_width="1.5dp"
                app:civ_border_color="?attr/colorSurface"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_mutual_2"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="9dp"
                android:src="@drawable/ic_person"
                android:visibility="gone"
                app:civ_border_width="1.5dp"
                app:civ_border_color="?attr/colorSurface"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_mutual_1"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_person"
                android:visibility="gone"
                app:civ_border_width="1.5dp"
                app:civ_border_color="?attr/colorSurface"/>
        </FrameLayout>

        <TextView android:id="@+id/tv_mutual_followers"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.2"/>
    </LinearLayout>

    <!-- Bio (max 3 lines, tap to expand) -->
    <TextView android:id="@+id/tv_bio"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="4dp" android:paddingBottom="2dp"
        android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"
        android:maxLines="3" android:ellipsize="end"
        android:clickable="true" android:focusable="true"
        android:visibility="gone"/>

    <!-- Phone number row -->
    <LinearLayout android:id="@+id/layout_phone"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">
        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_phone" android:tint="@color/brand_primary"
            android:contentDescription="Phone"/>
        <TextView android:id="@+id/tv_phone"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:textSize="13sp" android:textColor="?attr/colorOnSurface"
            android:singleLine="true"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- WhatsApp row -->
    <LinearLayout android:id="@+id/layout_whatsapp"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">
        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_whatsapp" android:tint="#25D366"
            android:contentDescription="WhatsApp"/>
        <TextView android:id="@+id/tv_whatsapp"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:textSize="13sp" android:textColor="#25D366"
            android:singleLine="true"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- Instagram row -->
    <LinearLayout android:id="@+id/layout_instagram"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">
        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_instagram" android:tint="#E1306C"
            android:contentDescription="Instagram"/>
        <TextView android:id="@+id/tv_instagram"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:textSize="13sp" android:textColor="#E1306C"
            android:singleLine="true"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- YouTube row -->
    <LinearLayout android:id="@+id/layout_youtube"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">
        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_youtube" android:tint="#FF0000"
            android:contentDescription="YouTube"/>
        <TextView android:id="@+id/tv_youtube"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:textSize="13sp" android:textColor="#FF0000"
            android:singleLine="true"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <!-- Other link row -->
    <LinearLayout android:id="@+id/layout_other_link"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:clickable="true" android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:visibility="gone">
        <ImageView android:layout_width="18dp" android:layout_height="18dp"
            android:src="@drawable/ic_link" android:tint="@color/brand_primary"
            android:contentDescription="Link"/>
        <TextView android:id="@+id/tv_other_link"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="12dp"
            android:textSize="13sp" android:textColor="@color/brand_primary"
            android:singleLine="true" android:ellipsize="end"/>
        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="Open"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Action buttons: Message | Call | Video | X | YouTube -->
    <LinearLayout android:id="@+id/layout_actions"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="12dp" android:paddingBottom="12dp"
        android:visibility="gone">

        <!-- Chat / Message button with avatar peek animation -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                android:clipChildren="false" android:clipToPadding="false">
                <ImageButton android:id="@+id/btn_message"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/bg_circle_action"
                    android:tint="#00C6FF"
                    android:contentDescription="Message" android:padding="13dp"/>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_chat"
                    android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:elevation="4dp"
                    android:visibility="invisible"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="@color/brand_primary"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Message" android:textSize="11sp"
                android:textColor="#00C6FF" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Audio Call button -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageButton android:id="@+id/btn_audio_call"
                android:layout_width="46dp" android:layout_height="46dp"
                android:src="@drawable/ic_phone"
                android:background="@drawable/bg_circle_action"
                android:tint="#00F260"
                android:contentDescription="Audio Call" android:padding="13dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Call" android:textSize="11sp"
                android:textColor="#00F260" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Video Call button -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageButton android:id="@+id/btn_video_call"
                android:layout_width="46dp" android:layout_height="46dp"
                android:src="@drawable/ic_video_call"
                android:background="@drawable/bg_circle_action"
                android:tint="#A855F7"
                android:contentDescription="Video Call" android:padding="13dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Video" android:textSize="11sp"
                android:textColor="#A855F7" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- X button with avatar peek animation -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                android:clipChildren="false" android:clipToPadding="false">
                <ImageButton android:id="@+id/btn_open_x"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:src="@drawable/ic_x_logo"
                    android:background="@drawable/bg_social_x_btn"
                    android:tint="@color/white"
                    android:contentDescription="View X Profile" android:padding="13dp"/>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_x"
                    android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:elevation="4dp"
                    android:visibility="invisible"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="#000000"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="X" android:textSize="11sp"
                android:textColor="#CCCCCC" android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- YouTube button with avatar peek animation -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                android:clipChildren="false" android:clipToPadding="false">
                <ImageButton android:id="@+id/btn_open_youtube"
                    android:layout_width="46dp" android:layout_height="46dp"
                    android:src="@drawable/ic_youtube"
                    android:background="@drawable/bg_social_youtube_btn"
                    android:tint="@color/white"
                    android:contentDescription="View YouTube Channel" android:padding="13dp"/>
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_anim_youtube"
                    android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:elevation="4dp"
                    android:visibility="invisible"
                    app:civ_border_width="1.5dp"
                    app:civ_border_color="#FF0000"/>
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="YouTube" android:textSize="11sp"
                android:textColor="#FF0000" android:layout_marginTop="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

</LinearLayout>
