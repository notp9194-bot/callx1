<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera preview (full screen) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_vr_camera"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top comment card overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="56dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#CC000000"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_vr_commenter_avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:id="@+id/tv_vr_commenter_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Someone"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tv_vr_comment_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"
                        android:maxLines="3"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Replying with video"
            android:textSize="12sp"
            android:textColor="#AAFFFFFF"
            android:paddingTop="6dp"
            android:paddingStart="4dp"/>
    </LinearLayout>

    <!-- Close button top-right -->
    <ImageButton
        android:id="@+id/btn_vr_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/bg_icon_semi"/>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp">

        <ProgressBar
            android:id="@+id/progress_vr"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressTint="#FF3B5BDB"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tv_vr_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="1:00"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Flip -->
            <ImageButton
                android:id="@+id/btn_vr_flip"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_flip"
                android:background="@drawable/bg_icon_semi"
                android:padding="12dp"
                android:layout_marginEnd="32dp"/>

            <!-- Record -->
            <ImageButton
                android:id="@+id/btn_vr_record"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/circle_primary"
                android:padding="18dp"/>

            <Space android:layout_width="52dp" android:layout_height="52dp"
                android:layout_marginStart="32dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
