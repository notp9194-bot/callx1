<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_duet_reel.xml  — v28 (All Fixes Applied)

    NEW views added vs original:
      • view_duet_preview_overlay  (Fix 5)  — DuetPreviewOverlayView live layout indicator
      • tv_chain_duet_banner       (Fix 10) — "Chain Duet (depth N)" banner
      • btn_invite_duet            (Fix 11) — owner-only "Invite to Duet" button
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Split video area (original + camera) ─────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_duet_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Original reel (top half) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.media3.ui.PlayerView
                android:id="@+id/player_view_original"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="zoom"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:text="Original"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="#66000000"/>
        </FrameLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/brand_primary"/>

        <!-- Camera preview (bottom half) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.camera.view.PreviewView
                android:id="@+id/preview_view_camera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:text="You"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="#66000000"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ── Fix 5: Real-time composite preview overlay ─────────────────────
         DuetPreviewOverlayView draws divider lines + labels showing what
         the final composited video will look like in each layout mode.
         Sits on top of the video area but under all controls.             -->
    <com.callx.app.social.DuetPreviewOverlayView
        android:id="@+id/view_duet_preview_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"/>

    <!-- ── Top controls bar ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingTop="36dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_duet_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Close"/>

        <TextView
            android:id="@+id/tv_duet_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Duet"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"/>

        <!-- Fix 11: Invite button — shown only to reel owner (code sets visibility) -->
        <ImageButton
            android:id="@+id/btn_invite_duet"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_group"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#A855F7"
            android:contentDescription="Invite to Duet"
            android:visibility="gone"/>

        <!-- View Duets button -->
        <ImageButton
            android:id="@+id/btn_view_duets"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_reels"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="View Duets"/>

        <ImageButton
            android:id="@+id/btn_duet_flip"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Flip camera"/>
    </LinearLayout>

    <!-- ── Fix 10: Chain Duet banner ──────────────────────────────────────
         Shown below top bar when user is dueting a reel that is itself a duet.
         Code: tvChainDuetBanner.setText("Chain Duet (depth N)").          -->
    <TextView
        android:id="@+id/tv_chain_duet_banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="96dp"
        android:text="Chain Duet"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#BB7C3AED"
        android:visibility="gone"/>

    <!-- ── Layout mode selector (side-by-side / top-bottom / pip / bubble) -->
    <LinearLayout
        android:id="@+id/layout_duet_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="vertical"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="8dp"
        android:background="#55000000"
        android:padding="6dp">

        <ImageButton
            android:id="@+id/btn_layout_side_by_side"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_flip"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Side by Side"
            android:alpha="1.0"/>

        <ImageButton
            android:id="@+id/btn_layout_top_bottom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_flip_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Top Bottom"
            android:alpha="0.4"
            android:layout_marginTop="4dp"/>

        <ImageButton
            android:id="@+id/btn_layout_pip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Picture in Picture"
            android:alpha="0.4"
            android:layout_marginTop="4dp"/>

        <ImageButton
            android:id="@+id/btn_layout_reaction_bubble"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FF4081"
            android:contentDescription="Reaction Bubble"
            android:alpha="0.4"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- ── Fix 2: Reaction Bubble draggable overlay ───────────────────────
         OnTouchListener in DuetReelActivity.setupBubbleDragListener()
         handles ACTION_DOWN + ACTION_MOVE for free drag with clamping.    -->
    <FrameLayout
        android:id="@+id/view_bubble_overlay"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="200dp"
        android:background="@drawable/bg_bubble_circle"
        android:visibility="gone"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:elevation="8dp">

        <androidx.camera.view.PreviewView
            android:id="@+id/preview_view_bubble"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="6dp"
            android:text="drag"
            android:textColor="#CCFFFFFF"
            android:textSize="9sp"/>
    </FrameLayout>

    <!-- ── Bottom controls ───────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp"
        android:paddingTop="12dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="#66000000">

        <!-- Original audio volume row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_volume_off"
                android:tint="#CCFFFFFF"/>

            <SeekBar
                android:id="@+id/seek_original_volume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:progressTint="@color/brand_primary"
                android:thumbTint="@color/brand_primary"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_volume_on"
                android:tint="#CCFFFFFF"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_volume_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Original: 50%"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <!-- Mic gain row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_mic_off"
                android:tint="#CCFFFFFF"/>

            <SeekBar
                android:id="@+id/seek_mic_gain"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="200"
                android:progress="100"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:progressTint="#FF4081"
                android:thumbTint="#FF4081"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_mic"
                android:tint="#CCFFFFFF"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_mic_gain_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic: 100%"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:layout_marginBottom="10dp"/>

        <!-- Timer + progress -->
        <TextView
            android:id="@+id/tv_duet_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/progress_duet"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="60"
            android:progress="0"
            android:progressTint="@color/brand_primary"
            android:progressBackgroundTint="#44FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Record button -->
        <ImageButton
            android:id="@+id/btn_duet_record"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_play"
            android:tint="#A855F7"
            android:background="@drawable/circle_primary"
            android:padding="14dp"
            android:contentDescription="Record duet"/>
    </LinearLayout>

    <!-- ── 3-2-1 Countdown overlay ────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_duet_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="3"
        android:textColor="#FFFFFF"
        android:textSize="96sp"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#AA000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:visibility="gone"/>

</FrameLayout>
