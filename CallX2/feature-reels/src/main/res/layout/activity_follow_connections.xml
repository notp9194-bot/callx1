<?xml version="1.0" encoding="utf-8"?>
<!--
  FollowConnectionsActivity layout — Instagram-style unified followers/following/mutual screen.
  Structure:
    ① Fixed top nav  (back + username)
    ② TabLayout      (Followers count | Following count | Mutual count)
    ③ Search bar     (shared, filters active tab)
    ④ ViewPager2     (3 swipeable pages)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- ① Top nav bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="?attr/colorSurface"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/tv_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="17sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- ② TabLayout — Instagram style: left-aligned, count labels, underline indicator -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="?attr/colorSurface"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabSelectedTextColor="?attr/colorOnSurface"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        app:tabIndicatorColor="?attr/colorOnSurface"
        app:tabIndicatorHeight="2dp"
        app:tabPaddingStart="0dp"
        app:tabPaddingEnd="0dp"/>

    <!-- Divider below tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"/>

    <!-- ③ Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="?attr/colorSurface">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Search"
            android:textSize="14sp"
            android:background="@drawable/bg_comment_input"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:inputType="text"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="?attr/colorOnSurfaceVariant"
            android:imeOptions="actionSearch"/>
    </LinearLayout>

    <!-- ④ ViewPager2 — 3 swipeable pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
