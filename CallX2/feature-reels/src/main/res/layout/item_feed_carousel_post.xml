<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_carousel_post.xml
    Multi-image carousel post — swipeable ViewPager2 with dot indicator.
    Used by HomeFeedAdapter for TYPE_POST_CAROUSEL.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:layout_marginBottom="6dp">

    <!-- ── Post header row ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_post_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_person"
            app:civ_border_width="1.5dp"
            app:civ_border_color="@color/brand_primary"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_post_owner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@username"
                    android:textColor="#FFFFFF"
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:clickable="true"
                    android:focusable="true"/>

                <ImageView
                    android:id="@+id/ic_verified_badge"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    android:visibility="gone"/>

                <!-- Carousel indicator count e.g. "1/5" -->
                <TextView
                    android:id="@+id/tv_carousel_count_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="11sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_post_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2h"
                android:textColor="#888888"
                android:textSize="11sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_post_follow"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Follow"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:backgroundTint="@color/brand_primary"
            android:stateListAnimator="@null"
            android:allCaps="false"/>

        <ImageButton
            android:id="@+id/btn_post_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:tint="#AAAAAA"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"/>
    </LinearLayout>

    <!-- ── Carousel ViewPager2 ──────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_carousel"
            android:layout_width="match_parent"
            android:layout_height="360dp"/>

        <!-- Dot indicator overlay (top-right) -->
        <TextView
            android:id="@+id/tv_carousel_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:text="●○○"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.1"
            android:background="#66000000"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>
    </FrameLayout>

    <!-- ── Action Row ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btn_post_like"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_heart"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like"/>

        <TextView
            android:id="@+id/tv_post_likes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="0"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:minWidth="24dp"/>

        <ImageButton
            android:id="@+id/btn_post_comment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_comment"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Comment"/>

        <TextView
            android:id="@+id/tv_post_comments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="0"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:minWidth="24dp"/>

        <ImageButton
            android:id="@+id/btn_post_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_share"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btn_post_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bookmark_outline"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save"/>
    </LinearLayout>

    <!-- Caption -->
    <TextView
        android:id="@+id/tv_post_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp"
        android:text=""
        android:textColor="#DDDDDD"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#222222"/>
</LinearLayout>
