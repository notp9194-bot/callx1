<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_user_reels.xml — Instagram Profile v4 (Full Rewrite)
    ═══════════════════════════════════════════════════════════════
    Exact Instagram scroll behaviour:
      CHILD 1 — Top nav bar        (noScroll)   → always pinned at top
      CHILD 2 — Full profile header(scroll|exitUntilCollapsed) → collapses fully
      CHILD 3 — Tab bar            (noScroll)   → pins below top nav
      SwipeRefreshLayout           (appbar_scrolling_view_behavior)
                                                → drives AppBar collapse via
                                                   NestedSwipeRefreshLayout
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="false">

    <!-- ══ Multi-select action bar — floating overlay ══════════════════ -->
    <LinearLayout
        android:id="@+id/layout_multi_select_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/brand_primary"
        android:elevation="12dp"
        android:layout_gravity="top"
        android:visibility="gone">

        <ImageButton android:id="@+id/btn_cancel_select"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Cancel"/>

        <TextView android:id="@+id/tv_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:text="0 Selected" android:textColor="#FFFFFF"
            android:textSize="16sp" android:fontFamily="sans-serif-medium"/>

        <ImageButton android:id="@+id/btn_share_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_share_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Share"/>

        <ImageButton android:id="@+id/btn_delete_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Delete"/>

        <ImageButton android:id="@+id/btn_delete_all"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FF4444" android:contentDescription="Delete All"/>
    </LinearLayout>

    <!-- ══ AppBarLayout ════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="0dp"
        app:liftOnScroll="false">

        <!-- ─────────────────────────────────────────────────────────────
             CHILD 1 — Top nav bar (always pinned)
             Instagram layout: ← | username 🔵 | (spacer) | 🔔 | ⋮
             ───────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:background="?attr/colorSurface"
            app:layout_scrollFlags="noScroll">

            <!-- Back -->
            <ImageButton android:id="@+id/btn_back"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorOnSurface"
                android:contentDescription="Back"
                android:padding="10dp"/>

            <!-- Username + verified badge (weight=1, fills remaining space) -->
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="2dp">

                <TextView android:id="@+id/tv_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="username"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <ImageView android:id="@+id/iv_verified"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    android:tint="@color/brand_primary"
                    android:contentDescription="Verified"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Creator Hub (self only, hidden by default) -->
            <ImageButton android:id="@+id/btn_creator_hub"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_reel_creator"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#A855F7"
                android:contentDescription="Creator Hub"
                android:padding="9dp"
                android:visibility="gone"/>

            <!-- Notification bell (Instagram-style) -->
            <ImageButton android:id="@+id/btn_notification"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_notifications"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorOnSurface"
                android:contentDescription="Notifications"
                android:padding="10dp"/>

            <!-- Settings (self only) -->
            <ImageButton android:id="@+id/btn_settings"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorOnSurface"
                android:contentDescription="Settings"
                android:padding="9dp"
                android:visibility="gone"/>

            <!-- 3-dot more menu -->
            <ImageButton android:id="@+id/btn_more"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorOnSurface"
                android:contentDescription="More"
                android:padding="10dp"/>

        </LinearLayout>

        <!-- ─────────────────────────────────────────────────────────────
             CHILD 2 — Full profile header (collapses on scroll)
             Instagram layout:
               • Avatar + Stats row
               • Display name
               • Bio
               • Link chips
               • Mutual followers
               • Action buttons
               • Story Highlights
             ───────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorSurface"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <!-- ── Row 1: Avatar (left) + Stats (right) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp">

                <!-- Avatar with gradient story ring + online dot -->
                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp">

                    <!-- Gradient story ring (shown when user has stories) -->
                    <View android:id="@+id/view_story_ring"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/bg_story_ring"
                        android:visibility="gone"/>

                    <!-- Avatar circle -->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        android:clickable="true"
                        android:focusable="true"
                        app:civ_border_width="2.5dp"
                        app:civ_border_color="?attr/colorSurface"/>

                    <!-- Online dot indicator -->
                    <View android:id="@+id/view_online_dot"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="3dp"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/bg_story_ring"
                        android:backgroundTint="@color/status_online"
                        android:visibility="gone"/>

                </FrameLayout>

                <!-- Stats: Posts | Followers | Following -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginStart="4dp">

                    <!-- Posts/Reels count -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp">

                        <TextView android:id="@+id/tv_reel_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Posts"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>

                    <!-- Followers (clickable) -->
                    <LinearLayout android:id="@+id/layout_followers_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <TextView android:id="@+id/tv_followers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Followers"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>

                    <!-- Following (clickable) -->
                    <LinearLayout android:id="@+id/layout_following_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <TextView android:id="@+id/tv_following"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Following"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurface"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- ── Row 2: Display name (bold) ── -->
            <TextView android:id="@+id/tv_display_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="2dp"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>

            <!-- ── Row 3: Category / Professional tag ── -->
            <TextView android:id="@+id/tv_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="2dp"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="1"
                android:visibility="gone"/>

            <!-- ── Row 4: Bio text ── -->
            <TextView android:id="@+id/tv_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="4dp"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="5"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>

            <!-- ── Row 5: Link chips (Instagram-style horizontal pill chips) ── -->
            <HorizontalScrollView
                android:id="@+id/hsv_link_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ll_link_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <!-- Chips added programmatically -->
                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── Row 6: Mutual followers ("Followed by name and N others") ── -->
            <LinearLayout android:id="@+id/layout_mutual_followers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="2dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">

                <!-- Overlapping small avatars (up to 3) -->
                <FrameLayout
                    android:id="@+id/frame_mutual_avatars"
                    android:layout_width="56dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_mutual_3"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_person"
                        android:visibility="gone"
                        app:civ_border_width="1.5dp"
                        app:civ_border_color="?attr/colorSurface"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_mutual_2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_person"
                        android:visibility="gone"
                        app:civ_border_width="1.5dp"
                        app:civ_border_color="?attr/colorSurface"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_mutual_1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_person"
                        android:visibility="gone"
                        app:civ_border_width="1.5dp"
                        app:civ_border_color="?attr/colorSurface"/>

                </FrameLayout>

                <TextView android:id="@+id/tv_mutual_followers"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="2"
                    android:lineSpacingMultiplier="1.2"/>

            </LinearLayout>

            <!-- ── Row 7: Action buttons ── -->
            <!-- OWN PROFILE: [Edit profile] [Share profile] [▾] -->
            <LinearLayout android:id="@+id/layout_actions_self"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_edit_profile"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Edit profile"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="8dp"
                    app:strokeColor="?attr/colorOutline"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share_profile"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Share profile"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="8dp"
                    app:strokeColor="?attr/colorOutline"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginEnd="6dp"/>

                <!-- Discover people arrow -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_discover_people"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_person_add"
                    app:iconSize="18dp"
                    app:iconTint="?attr/colorOnSurface"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="8dp"
                    app:strokeColor="?attr/colorOutline"
                    android:contentDescription="Discover people"/>

            </LinearLayout>

            <!-- OTHER PROFILE: [Follow/Following ▾] [Message] [Add friend icon] -->
            <LinearLayout android:id="@+id/layout_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <!-- Follow / Following button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_follow"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Follow"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/brand_primary"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="6dp"/>

                <!-- Message button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_message"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:text="Message"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="8dp"
                    app:strokeColor="?attr/colorOutline"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginEnd="6dp"/>

                <!-- Add friend / Subscribe icon button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_friend"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_person_add"
                    app:iconSize="18dp"
                    app:iconTint="?attr/colorOnSurface"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="8dp"
                    app:strokeColor="?attr/colorOutline"
                    android:contentDescription="Add friend"/>

            </LinearLayout>

            <!-- Hidden call/X/YouTube buttons (launched from action sheet or elsewhere) -->
            <ImageButton android:id="@+id/btn_audio_call"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageButton android:id="@+id/btn_video_call"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageButton android:id="@+id/btn_open_x"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <ImageButton android:id="@+id/btn_open_youtube"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>

            <!-- Hidden anim circles (for X/YouTube/Chat peek animation) -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_anim_chat"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="invisible"/>
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_anim_x"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="invisible"/>
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_anim_youtube"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="invisible"/>

            <!-- ── Row 8: Story Highlights (Instagram-style horizontal circles) ── -->
            <HorizontalScrollView
                android:id="@+id/hsv_highlights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ll_highlights"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <!-- Highlight items added programmatically -->
                </LinearLayout>

            </HorizontalScrollView>

            <!-- Hidden legacy social link views — kept for Java compatibility -->
            <LinearLayout android:id="@+id/layout_phone"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_phone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/layout_whatsapp"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_whatsapp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/layout_instagram"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_instagram"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/layout_youtube"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_youtube"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/layout_other_link"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone">
                <TextView android:id="@+id/tv_other_link"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Hidden legacy repost/series row (kept for Java compat) -->
            <LinearLayout android:id="@+id/btn_repost_section"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>
            <LinearLayout android:id="@+id/btn_series_section"
                android:layout_width="0dp" android:layout_height="0dp"
                android:visibility="gone"/>

            <!-- Private account notice -->
            <LinearLayout android:id="@+id/layout_private_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="32dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="56dp" android:layout_height="56dp"
                    android:src="@drawable/ic_lock"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Private"/>

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="This account is private"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Follow to see their reels."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

            </LinearLayout>

            <!-- Divider above tabs -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="?attr/colorOutline"
                android:alpha="0.4"/>

        </LinearLayout>

        <!-- ─────────────────────────────────────────────────────────────
             CHILD 3 — Tab bar (always pinned below top nav)
             Instagram tabs: ⊞ Grid | ▶ Reels | ↻ Collab | 📸 Tagged
             ───────────────────────────────────────────────────────────── -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="?attr/colorSurface"
            app:layout_scrollFlags="noScroll"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabSelectedTextColor="?attr/colorOnSurface"
            app:tabTextColor="?attr/colorOnSurfaceVariant"
            app:tabIndicatorColor="?attr/colorOnSurface"
            app:tabIndicatorHeight="1dp"
            app:tabPaddingStart="0dp"
            app:tabPaddingEnd="0dp">

            <!-- Grid (⊞) -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_grid_view"/>

            <!-- Reels (▶) -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_reels"/>

            <!-- Saved (🔖) -->
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:icon="@drawable/ic_bookmark"/>

        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ Main scroll area ════════════════════════════════════════════
         NestedSwipeRefreshLayout properly forwards NestedScrollingParent3
         events to CoordinatorLayout → AppBarLayout collapses correctly.
         ═════════════════════════════════════════════════════════════════ -->
    <com.callx.app.profile.NestedSwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Filter chips (horizontal scroll) -->
                <HorizontalScrollView
                    android:id="@+id/hsv_filter_chips"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:scrollbars="none"
                    android:background="?attr/colorSurface"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <LinearLayout
                        android:id="@+id/ll_filter_chips"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"/>

                </HorizontalScrollView>

                <!-- Reel grid RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reels"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="?attr/colorSurface"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="true"/>

                <!-- Series RecyclerView (hidden; shown when Series tab selected) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_series"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone"
                    android:overScrollMode="never"/>

            </LinearLayout>

            <!-- Centered progress bar -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/brand_primary"
                android:visibility="gone"/>

            <!-- Empty state -->
            <LinearLayout android:id="@+id/layout_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView android:id="@+id/iv_empty_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_reels"
                    android:alpha="0.5"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Empty"/>

                <TextView android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="No Reels Yet"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"/>

                <TextView android:id="@+id/tv_empty_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="This creator hasn't posted any reels yet."
                    android:textSize="14sp"
                    android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

            </LinearLayout>

        </FrameLayout>

    </com.callx.app.profile.NestedSwipeRefreshLayout>

    <!-- "View All Reels" floating button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_all_reels"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="16dp"
        android:text="View All Reels"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone"
        app:layout_anchor="@id/swipe_refresh"
        app:layout_anchorGravity="bottom"
        app:strokeColor="@color/brand_primary"
        app:rippleColor="@color/brand_primary"
        android:textColor="@color/brand_primary"
        android:elevation="4dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
