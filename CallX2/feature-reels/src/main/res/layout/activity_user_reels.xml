<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="false">

    <!-- ── Multi-select action bar (hidden by default) ── -->
    <LinearLayout
        android:id="@+id/layout_multi_select_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/brand_primary"
        android:elevation="6dp"
        android:visibility="gone">
        <ImageButton android:id="@+id/btn_cancel_select" android:layout_width="44dp"
            android:layout_height="44dp" android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Cancel"/>
        <TextView android:id="@+id/tv_selected_count" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp" android:text="0 Selected"
            android:textColor="#FFFFFF" android:textSize="16sp"
            android:fontFamily="sans-serif-medium"/>
        <ImageButton android:id="@+id/btn_share_selected" android:layout_width="44dp"
            android:layout_height="44dp" android:src="@drawable/ic_share_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Share"/>
        <ImageButton android:id="@+id/btn_delete_selected" android:layout_width="44dp"
            android:layout_height="44dp" android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Delete"/>
    </LinearLayout>

    <!-- ── Top navigation bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="?attr/colorSurface">

        <ImageButton android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="?attr/colorOnSurface"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <ImageView
                    android:id="@+id/iv_verified"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    android:tint="@color/brand_primary"
                    android:contentDescription="Verified"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_reel_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Reel"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Send icon -->
        <ImageButton
            android:id="@+id/btn_share_profile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Send"
            android:padding="10dp"/>

        <!-- Follow button -->
        <Button
            android:id="@+id/btn_follow"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Follow"
            android:textSize="13sp"
            app:textAllCaps="false"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@color/brand_primary"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/btn_creator_hub"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_reel_creator"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Creator Hub"
            android:padding="8dp"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="Settings"
            android:padding="8dp"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurface"
            android:contentDescription="More options"/>
    </LinearLayout>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Profile row: large avatar + stats ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp">

                <!-- Big avatar with story ring + online dot -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <View
                        android:id="@+id/view_story_ring"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/bg_story_ring"
                        android:visibility="gone"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/brand_primary"/>

                    <!-- Online indicator dot -->
                    <View
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_story_ring"
                        android:backgroundTint="@color/status_online"/>
                </FrameLayout>

                <!-- Stats: Followers | Following | Reels -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginStart="8dp">

                    <!-- Followers -->
                    <LinearLayout
                        android:id="@+id/layout_followers_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:id="@+id/tv_followers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="19sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOLLOWERS"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <!-- Following -->
                    <LinearLayout
                        android:id="@+id/layout_following_click"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView
                            android:id="@+id/tv_following"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="19sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOLLOWING"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <!-- Reels count -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="19sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REELS"
                            android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Mutual followers -->
            <TextView
                android:id="@+id/tv_mutual_followers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="4dp"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"/>

            <!-- Bio -->
            <TextView
                android:id="@+id/tv_bio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="2dp"
                android:paddingBottom="6dp"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider"/>

            <!-- ── Action buttons: Message | Call | Video | Status ── -->
            <LinearLayout
                android:id="@+id/layout_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btn_message" android:layout_width="52dp"
                        android:layout_height="52dp" android:src="@drawable/ic_send"
                        android:background="@drawable/bg_circle_action"
                        android:tint="@color/brand_primary"
                        android:contentDescription="Message" android:padding="13dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Message" android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btn_audio_call" android:layout_width="52dp"
                        android:layout_height="52dp" android:src="@drawable/ic_phone"
                        android:background="@drawable/bg_circle_action"
                        android:tint="@color/brand_primary"
                        android:contentDescription="Audio Call" android:padding="13dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Call" android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btn_video_call" android:layout_width="52dp"
                        android:layout_height="52dp" android:src="@drawable/ic_video_call"
                        android:background="@drawable/bg_circle_action"
                        android:tint="@color/brand_primary"
                        android:contentDescription="Video Call" android:padding="13dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Video" android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btn_view_status" android:layout_width="52dp"
                        android:layout_height="52dp" android:src="@drawable/ic_status_add"
                        android:background="@drawable/bg_circle_action"
                        android:tint="@color/brand_primary"
                        android:contentDescription="View Status" android:padding="13dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Status" android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginTop="5dp"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider"/>

            <!-- ── Tabs: Reels | Liked | Saved ── -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:tabMode="fixed"
                app:tabGravity="fill"
                app:tabSelectedTextColor="@color/brand_primary"
                app:tabTextColor="?attr/colorOnSurfaceVariant"
                app:tabIndicatorColor="@color/brand_primary"
                app:tabIndicatorHeight="2dp"
                app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Caption">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reels"
                    android:icon="@drawable/ic_reels"/>

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Liked"
                    android:icon="@drawable/ic_heart"/>

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved"
                    android:icon="@drawable/ic_bookmark"/>
            </com.google.android.material.tabs.TabLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider"/>

            <!-- ── Reel grid ── -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipe_refresh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="400dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="400dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_reels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:padding="1dp"/>

                    <!-- Private account overlay -->
                    <LinearLayout
                        android:id="@+id/layout_private_account"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="40dp"
                        android:background="?attr/colorSurface"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_lock"
                            android:alpha="0.6"
                            android:tint="?attr/colorOnSurface"
                            android:contentDescription="Private account"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="This account is private"
                            android:textSize="17sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Follow this account to see their reels, followers and following."
                            android:textSize="13sp"
                            android:gravity="center"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="48dp"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/layout_empty"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp"
                        android:visibility="gone">

                        <ImageView android:id="@+id/iv_empty_icon"
                            android:layout_width="64dp" android:layout_height="64dp"
                            android:src="@drawable/ic_reels" android:alpha="0.3"
                            android:contentDescription="Empty"/>

                        <TextView android:id="@+id/tv_empty_title"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="16dp" android:text="No Reels Yet"
                            android:textSize="18sp" android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView android:id="@+id/tv_empty_subtitle"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="This creator hasn't posted any reels yet."
                            android:textSize="14sp" android:gravity="center"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
