<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_user_reels.xml — SCROLLING FIX v3  (Approach A: header-in-RecyclerView)
    ==================================================================================
    OLD v2 (PARTIAL FIX): Profile header was FIXED above SwipeRefreshLayout+RecyclerView.
      Problem: SwipeRefreshLayout gesture conflict with the fixed header area;
               grid height limited by fixed header leaving less room to scroll.

    NEW v3 (FULL FIX):  LinearLayout (vertical)
                          ├── MultiSelect bar (fixed top)
                          ├── Top nav bar (fixed top)
                          ├── TabLayout (fixed — sticky below nav bar)
                          ├── Divider
                          └── SwipeRefreshLayout > FrameLayout
                                ├── rvReels  → ConcatAdapter(profileHeaderAdapter, reelGridAdapter)
                                ├── rvSeries → ConcatAdapter(seriesHeaderAdapter, seriesAdapter)
                                ├── layout_private_account (overlay for private accounts)
                                ├── progress_bar
                                └── layout_empty (overlay for series tab empty state)

    Profile header (avatar, stats, bio, links, action buttons) is now RecyclerView item
    position 0 in BOTH rvReels and rvSeries via ProfileHeaderAdapter + ConcatAdapter.

    Benefits:
      ✅ Profile header scrolls naturally with the reel grid
      ✅ SwipeRefreshLayout only sees one RV child — no gesture conflict
      ✅ RecyclerView fills 100 % of remaining height — no height calculation issues
      ✅ Both tabs (reels and series) always show the profile header
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="false">

    <!-- ── Multi-select action bar (hidden by default) ── -->
    <LinearLayout
        android:id="@+id/layout_multi_select_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/brand_primary"
        android:elevation="6dp"
        android:visibility="gone">

        <ImageButton android:id="@+id/btn_cancel_select"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Cancel"/>

        <TextView android:id="@+id/tv_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:text="0 Selected" android:textColor="#FFFFFF"
            android:textSize="16sp" android:fontFamily="sans-serif-medium"/>

        <ImageButton android:id="@+id/btn_share_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_share_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Share"/>

        <ImageButton android:id="@+id/btn_delete_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Delete"/>
    </LinearLayout>

    <!-- ── Top navigation bar ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:background="?attr/colorSurface">

        <ImageButton android:id="@+id/btn_back"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#00C6FF"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="4dp">

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <TextView android:id="@+id/tv_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="User" android:textSize="17sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#FFFFFF"
                    android:maxLines="1" android:ellipsize="end"/>

                <ImageView android:id="@+id/iv_verified"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    android:tint="@color/brand_primary"
                    android:contentDescription="Verified"
                    android:visibility="gone"/>
            </LinearLayout>

        </LinearLayout>

        <ImageButton android:id="@+id/btn_share_profile"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#00F260"
            android:contentDescription="Send" android:padding="10dp"/>

        <Button android:id="@+id/btn_follow"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="Follow" android:textSize="13sp"
            app:textAllCaps="false"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:background="@color/brand_primary"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

        <ImageButton android:id="@+id/btn_creator_hub"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_reel_creator"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#A855F7"
            android:contentDescription="Creator Hub"
            android:padding="8dp" android:visibility="gone"/>

        <ImageButton android:id="@+id/btn_settings"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFA500"
            android:contentDescription="Settings"
            android:padding="8dp" android:visibility="gone"/>

        <ImageButton android:id="@+id/btn_more"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FF416C"
            android:contentDescription="More options"/>
    </LinearLayout>

    <!--
        ── Sticky TabLayout ──
        Stays fixed below the nav bar — always visible even when the profile header
        (inside RecyclerView) scrolls off screen.
    -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabSelectedTextColor="@color/brand_primary"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        app:tabIndicatorColor="@color/brand_primary"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Caption">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Reels" android:icon="@drawable/ic_reels"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Liked" android:icon="@drawable/ic_heart"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Saved" android:icon="@drawable/ic_bookmark"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Reposted" android:icon="@drawable/ic_repost"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Series" android:icon="@drawable/ic_duet_series"/>
    </com.google.android.material.tabs.TabLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!--
        ── SCROLLING FIX v3: SwipeRefreshLayout + RecyclerView fill remaining space ──
        RecyclerView item 0 = profile header (avatar, stats, bio, links, action buttons)
        via ProfileHeaderAdapter + ConcatAdapter. Header scrolls WITH the grid.
        SwipeRefreshLayout has only one direct child → no gesture conflict.
    -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Reel grid — header + reels via ConcatAdapter(profileHeaderAdapter, reelGridAdapter) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reels"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:padding="1dp"/>

            <!-- Series tab — header + series via ConcatAdapter(seriesHeaderAdapter, seriesAdapter) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_series"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="3dp"
                android:visibility="gone"/>

            <!-- Private account overlay (opaque, covers full area — profile info in nav bar still visible) -->
            <LinearLayout android:id="@+id/layout_private_account"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="40dp" android:background="?attr/colorSurface"
                android:visibility="gone">

                <ImageView android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_lock" android:alpha="0.8"
                    android:tint="#A855F7"
                    android:contentDescription="Private account"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="This account is private"
                    android:textSize="17sp" android:fontFamily="sans-serif-medium"
                    android:textColor="#CE93D8"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Follow this account to see their reels, followers and following."
                    android:textSize="13sp" android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:indeterminateTint="#A855F7"
                android:visibility="gone"/>

            <!--
                Empty state overlay — used only for Series tab empty state.
                For Reels/Liked/Saved/Repost tabs, empty state is shown as TYPE_EMPTY
                item inside the RecyclerView (so the profile header remains visible).
            -->
            <LinearLayout android:id="@+id/layout_empty"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="32dp" android:visibility="gone">

                <ImageView android:id="@+id/iv_empty_icon"
                    android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_reels" android:alpha="0.6"
                    android:tint="#FF416C"
                    android:contentDescription="Empty"/>

                <TextView android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" android:text="No Reels Yet"
                    android:textSize="18sp" android:fontFamily="sans-serif-medium"
                    android:textColor="#FF416C"/>

                <TextView android:id="@+id/tv_empty_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="This creator hasn't posted any reels yet."
                    android:textSize="14sp" android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
