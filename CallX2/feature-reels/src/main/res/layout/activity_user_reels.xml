<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_user_reels.xml — SCROLLING FIX v3 (CoordinatorLayout)
    ================================================================
    ROOT CAUSE of v2 failure:
      LinearLayout with layout_weight="1" gives SwipeRefreshLayout ZERO height when
      the profile header sections (bio + phone + whatsapp + instagram + youtube +
      other_link + mutual_followers + action_buttons) together exceed screen height.
      Result: RecyclerView collapses to 0dp → no scroll possible.

    FIX: CoordinatorLayout + AppBarLayout (Instagram/TikTok standard pattern)
      - Profile header (avatar, stats, bio, social links, actions) → AppBarLayout
        with scroll|enterAlways flags → scrolls up when user scrolls the grid.
      - Nav bar (back, name, follow, more) → AppBarLayout but pinEnterAlways → stays visible.
      - TabLayout → pinned at bottom of AppBarLayout (noScroll) → always visible.
      - SwipeRefreshLayout → layout_behavior="appbar_scrolling_view_behavior"
        → ALWAYS gets remaining height regardless of profile content size.
      - MultiSelect bar → CoordinatorLayout overlay at top with high elevation.

    Result: RecyclerView always has proper height. Profile header scrolls up naturally.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="false">

    <!-- ════════════════════════════════════════════════════════════════
         AppBarLayout — holds nav bar + collapsible profile header + tabs
         ════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:fitsSystemWindows="false"
        app:liftOnScroll="true">

        <!-- ── Top navigation bar (always visible, never scrolls) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:background="?attr/colorSurface"
            app:layout_scrollFlags="noScroll">

            <ImageButton android:id="@+id/btn_back"
                android:layout_width="48dp" android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#00C6FF"
                android:contentDescription="Back"/>

            <!--
                Mini avatar — fades IN as profile header scrolls away.
                alpha=0 by default; AppBarLayout.OnOffsetChangedListener drives it.
            -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_avatar_mini"
                android:layout_width="34dp" android:layout_height="34dp"
                android:layout_marginStart="4dp" android:layout_marginEnd="8dp"
                android:src="@drawable/ic_person"
                android:alpha="0"
                app:civ_border_width="1.5dp"
                app:civ_border_color="@color/brand_primary"/>

            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">

                    <TextView android:id="@+id/tv_name"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="User" android:textSize="17sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="#FFFFFF"
                        android:maxLines="1" android:ellipsize="end"/>

                    <ImageView android:id="@+id/iv_verified"
                        android:layout_width="16dp" android:layout_height="16dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_verified"
                        android:tint="@color/brand_primary"
                        android:contentDescription="Verified"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>

            <ImageButton android:id="@+id/btn_share_profile"
                android:layout_width="44dp" android:layout_height="44dp"
                android:src="@drawable/ic_send"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#00F260"
                android:contentDescription="Send" android:padding="10dp"/>

            <Button android:id="@+id/btn_follow"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Follow" android:textSize="13sp"
                app:textAllCaps="false"
                android:paddingStart="20dp" android:paddingEnd="20dp"
                android:background="@color/brand_primary"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

            <ImageButton android:id="@+id/btn_creator_hub"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_reel_creator"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#A855F7"
                android:contentDescription="Creator Hub"
                android:padding="8dp" android:visibility="gone"/>

            <ImageButton android:id="@+id/btn_settings"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFA500"
                android:contentDescription="Settings"
                android:padding="8dp" android:visibility="gone"/>

            <ImageButton android:id="@+id/btn_more"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FF416C"
                android:contentDescription="More options"/>
        </LinearLayout>

        <!-- ── Collapsible profile header (scrolls up when user scrolls grid) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll|enterAlways">

            <!-- Avatar + stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="14dp" android:paddingBottom="10dp">

                <!-- Avatar with story ring -->
                <FrameLayout android:layout_width="90dp" android:layout_height="90dp">

                    <View android:id="@+id/view_story_ring"
                        android:layout_width="90dp" android:layout_height="90dp"
                        android:background="@drawable/bg_story_ring"
                        android:visibility="gone"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="80dp" android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/brand_primary"/>

                    <View android:layout_width="16dp" android:layout_height="16dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp" android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_story_ring"
                        android:backgroundTint="@color/status_online"/>
                </FrameLayout>

                <!-- Stats: Followers | Following | Reels -->
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal"
                    android:gravity="center" android:layout_marginStart="8dp">

                    <LinearLayout android:id="@+id/layout_followers_click"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:clickable="true" android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView android:id="@+id/tv_followers"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="19sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="#00C6FF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="FOLLOWERS" android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textColor="#6BCFEF"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layout_following_click"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center" android:clickable="true" android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <TextView android:id="@+id/tv_following"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="19sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="#00F260"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="FOLLOWING" android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textColor="#6BE8A8"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_reel_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="19sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="#A855F7"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="REELS" android:textSize="10sp"
                            android:letterSpacing="0.04"
                            android:textColor="#C084FC"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Mutual followers — Instagram style (clickable) -->
            <LinearLayout android:id="@+id/layout_mutual_followers"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="12dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/frame_mutual_avatars"
                    android:layout_width="62dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="10dp">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_mutual_3"
                        android:layout_width="28dp" android:layout_height="28dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="18dp"
                        android:src="@drawable/ic_person"
                        android:visibility="gone"
                        app:civ_border_width="1.5dp"
                        app:civ_border_color="?attr/colorSurface"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_mutual_2"
                        android:layout_width="28dp" android:layout_height="28dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="9dp"
                        android:src="@drawable/ic_person"
                        android:visibility="gone"
                        app:civ_border_width="1.5dp"
                        app:civ_border_color="?attr/colorSurface"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_mutual_1"
                        android:layout_width="28dp" android:layout_height="28dp"
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/ic_person"
                        android:visibility="gone"
                        app:civ_border_width="1.5dp"
                        app:civ_border_color="?attr/colorSurface"/>
                </FrameLayout>

                <TextView android:id="@+id/tv_mutual_followers"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="2"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>

            <!-- Bio -->
            <TextView android:id="@+id/tv_bio"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="4dp" android:paddingBottom="2dp"
                android:textSize="13sp" android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="3" android:ellipsize="end"
                android:clickable="true" android:focusable="true"
                android:visibility="gone"/>

            <!-- Phone number row -->
            <LinearLayout android:id="@+id/layout_phone"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_phone"
                    android:tint="@color/brand_primary"
                    android:contentDescription="Phone"/>
                <TextView android:id="@+id/tv_phone"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:textSize="13sp" android:textColor="?attr/colorOnSurface"
                    android:singleLine="true"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open"/>
            </LinearLayout>

            <!-- WhatsApp row -->
            <LinearLayout android:id="@+id/layout_whatsapp"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_whatsapp" android:tint="#25D366"
                    android:contentDescription="WhatsApp"/>
                <TextView android:id="@+id/tv_whatsapp"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:textSize="13sp" android:textColor="#25D366"
                    android:singleLine="true"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open"/>
            </LinearLayout>

            <!-- Instagram row -->
            <LinearLayout android:id="@+id/layout_instagram"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_instagram" android:tint="#E1306C"
                    android:contentDescription="Instagram"/>
                <TextView android:id="@+id/tv_instagram"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:textSize="13sp" android:textColor="#E1306C"
                    android:singleLine="true"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open"/>
            </LinearLayout>

            <!-- YouTube row -->
            <LinearLayout android:id="@+id/layout_youtube"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_youtube" android:tint="#FF0000"
                    android:contentDescription="YouTube"/>
                <TextView android:id="@+id/tv_youtube"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:textSize="13sp" android:textColor="#FF0000"
                    android:singleLine="true"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open"/>
            </LinearLayout>

            <!-- Other link row -->
            <LinearLayout android:id="@+id/layout_other_link"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:clickable="true" android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone">
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_link" android:tint="@color/brand_primary"
                    android:contentDescription="Link"/>
                <TextView android:id="@+id/tv_other_link"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:textSize="13sp" android:textColor="@color/brand_primary"
                    android:singleLine="true" android:ellipsize="end"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Open"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider"/>

            <!-- Action buttons: Message | Call | Video | X | YouTube -->
            <LinearLayout android:id="@+id/layout_actions"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">

                <!-- Chat / Message button with avatar peek animation -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                        android:clipChildren="false" android:clipToPadding="false">
                        <ImageButton android:id="@+id/btn_message"
                            android:layout_width="46dp" android:layout_height="46dp"
                            android:src="@drawable/ic_send"
                            android:background="@drawable/bg_circle_action"
                            android:tint="#00C6FF"
                            android:contentDescription="Message" android:padding="13dp"/>
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_anim_chat"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:elevation="4dp"
                            android:visibility="invisible"
                            app:civ_border_width="1.5dp"
                            app:civ_border_color="@color/brand_primary"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Message" android:textSize="11sp"
                        android:textColor="#00C6FF" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- Audio Call button -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btn_audio_call"
                        android:layout_width="46dp" android:layout_height="46dp"
                        android:src="@drawable/ic_call"
                        android:background="@drawable/bg_circle_action"
                        android:tint="#00F260"
                        android:contentDescription="Audio Call" android:padding="13dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Audio" android:textSize="11sp"
                        android:textColor="#00F260" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- Video Call button -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <ImageButton android:id="@+id/btn_video_call"
                        android:layout_width="46dp" android:layout_height="46dp"
                        android:src="@drawable/ic_video_call"
                        android:background="@drawable/bg_circle_action"
                        android:tint="#A855F7"
                        android:contentDescription="Video Call" android:padding="13dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Video" android:textSize="11sp"
                        android:textColor="#A855F7" android:layout_marginTop="5dp"/>
                </LinearLayout>

                <!-- X / Twitter button -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                        android:clipChildren="false" android:clipToPadding="false">
                        <ImageButton android:id="@+id/btn_open_x"
                            android:layout_width="46dp" android:layout_height="46dp"
                            android:src="@drawable/ic_x_logo"
                            android:background="@drawable/bg_circle_action"
                            android:tint="#FF416C"
                            android:contentDescription="Open X" android:padding="13dp"
                            android:visibility="gone"/>
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_anim_x"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:elevation="4dp"
                            android:visibility="invisible"
                            app:civ_border_width="1.5dp"
                            app:civ_border_color="@color/brand_primary"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="X" android:textSize="11sp"
                        android:textColor="#FF416C" android:layout_marginTop="5dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- YouTube button -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <FrameLayout android:layout_width="46dp" android:layout_height="46dp"
                        android:clipChildren="false" android:clipToPadding="false">
                        <ImageButton android:id="@+id/btn_open_youtube"
                            android:layout_width="46dp" android:layout_height="46dp"
                            android:src="@drawable/ic_youtube"
                            android:background="@drawable/bg_circle_action"
                            android:tint="#FF0000"
                            android:contentDescription="Open YouTube" android:padding="13dp"
                            android:visibility="gone"/>
                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/iv_anim_youtube"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:elevation="4dp"
                            android:visibility="invisible"
                            app:civ_border_width="1.5dp"
                            app:civ_border_color="@color/brand_primary"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="YouTube" android:textSize="11sp"
                        android:textColor="#FF0000" android:layout_marginTop="5dp"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
        <!-- End collapsible profile header -->

        <!-- ── TabLayout — pinned, never scrolls away ── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider"
            app:layout_scrollFlags="noScroll"/>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="?attr/colorSurface"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabIndicatorColor="@color/brand_primary"
            app:tabIndicatorHeight="2dp"
            app:tabTextColor="?attr/colorOnSurfaceVariant"
            app:tabSelectedTextColor="@color/brand_primary"
            app:layout_scrollFlags="noScroll">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:icon="@drawable/ic_reels"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:icon="@drawable/ic_favorite_border"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:icon="@drawable/ic_bookmark_border"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:icon="@drawable/ic_repost"/>

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:icon="@drawable/ic_duet_series"/>
        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ════════════════════════════════════════════════════════════════
         SwipeRefreshLayout + RecyclerView
         app:layout_behavior ensures this ALWAYS gets the remaining
         height below the AppBarLayout — no collapse possible.
         ════════════════════════════════════════════════════════════════ -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Reel grid — RecyclerView owns scrolling -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reels"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:padding="1dp"/>

            <!-- Series tab grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_series"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="3dp"
                android:visibility="gone"/>

            <!-- Private account overlay -->
            <LinearLayout android:id="@+id/layout_private_account"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="40dp" android:background="?attr/colorSurface"
                android:visibility="gone">
                <ImageView android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_lock" android:alpha="0.8"
                    android:tint="#A855F7"
                    android:contentDescription="Private account"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="This account is private"
                    android:textSize="17sp" android:fontFamily="sans-serif-medium"
                    android:textColor="#CE93D8"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Follow this account to see their reels, followers and following."
                    android:textSize="13sp" android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:indeterminateTint="#A855F7"
                android:visibility="gone"/>

            <!-- Empty state -->
            <LinearLayout android:id="@+id/layout_empty"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center"
                android:padding="32dp" android:visibility="gone">
                <ImageView android:id="@+id/iv_empty_icon"
                    android:layout_width="64dp" android:layout_height="64dp"
                    android:src="@drawable/ic_reels" android:alpha="0.6"
                    android:tint="#FF416C"
                    android:contentDescription="Empty"/>
                <TextView android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" android:text="No Reels Yet"
                    android:textSize="18sp" android:fontFamily="sans-serif-medium"
                    android:textColor="#FF416C"/>
                <TextView android:id="@+id/tv_empty_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="This creator hasn't posted any reels yet."
                    android:textSize="14sp" android:gravity="center"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- ════════════════════════════════════════════════════════════════
         Multi-select action bar — floating overlay, always on top.
         Placed LAST in CoordinatorLayout so it draws above everything.
         ════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout_multi_select_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/brand_primary"
        android:elevation="8dp"
        android:visibility="gone">

        <ImageButton android:id="@+id/btn_cancel_select"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Cancel"/>

        <TextView android:id="@+id/tv_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="8dp"
            android:text="0 Selected" android:textColor="#FFFFFF"
            android:textSize="16sp" android:fontFamily="sans-serif-medium"/>

        <ImageButton android:id="@+id/btn_share_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_share_reel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Share"/>

        <ImageButton android:id="@+id/btn_delete_selected"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF" android:contentDescription="Delete"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
