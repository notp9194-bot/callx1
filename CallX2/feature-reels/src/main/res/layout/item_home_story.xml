<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="66dp"
        android:layout_height="66dp">

        <!-- Gradient ring — shown for unseen stories (Instagram-style orange→pink→purple) -->
        <ImageView
            android:id="@+id/iv_reel_story_gradient_ring"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_gravity="center"
            android:src="@drawable/gradient_story_ring"
            android:visibility="gone"
            android:contentDescription="Unseen story gradient ring"/>

        <!-- Gray ring — shown for seen stories -->
        <ImageView
            android:id="@+id/iv_story_seen_ring"
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:contentDescription="Seen story ring"/>

        <!-- Avatar (sits on top of rings, with 3dp gap via padding) -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_story_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            app:civ_border_width="0dp"
            app:civ_border_color="@android:color/transparent"/>

    </FrameLayout>

    <TextView
        android:id="@+id/tv_story_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="User"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"/>
</LinearLayout>
