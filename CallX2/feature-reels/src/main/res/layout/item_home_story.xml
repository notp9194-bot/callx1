<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="82dp"
        android:layout_height="82dp">

        <!-- Instagram-style gradient ring — sweep gradient visible for reel_story type -->
        <ImageView
            android:id="@+id/iv_reel_story_gradient_ring"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_gravity="center"
            android:src="@drawable/story_ring_insta_gradient"
            android:visibility="gone"
            android:contentDescription="Reel story gradient ring"/>

        <!-- Brand-color ring (unseen) / gray ring (seen) — default status -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_story_avatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            app:civ_border_width="3dp"
            app:civ_border_color="@android:color/white"/>

        <ImageView
            android:id="@+id/iv_story_seen_ring"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_gravity="center"
            android:src="@drawable/circle_status_seen"
            android:visibility="gone"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_story_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="User"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"/>
</LinearLayout>
