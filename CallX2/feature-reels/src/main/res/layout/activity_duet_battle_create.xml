<?xml version="1.0" encoding="utf-8"?>
  <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:background="#0D0D0D">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">

          <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
              android:orientation="horizontal" android:gravity="center_vertical">
              <ImageButton android:id="@+id/btn_battle_create_back"
                  android:layout_width="40dp" android:layout_height="40dp"
                  android:src="@drawable/ic_arrow_back" android:background="?attr/selectableItemBackgroundBorderless"
                  android:tint="#FFFFFF"/>
              <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                  android:text="⚔️ Create Duet Battle" android:textColor="#FFFFFF" android:textSize="18sp"
                  android:textStyle="bold" android:layout_marginStart="8dp"/>
          </LinearLayout>

          <LinearLayout android:layout_width="match_parent" android:layout_height="200dp"
              android:orientation="horizontal" android:layout_marginTop="16dp">
              <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                  <ImageView android:id="@+id/iv_battle_my_thumb"
                      android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="#222"/>
                  <TextView android:id="@+id/tv_battle_my_label"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:layout_gravity="bottom" android:padding="8dp" android:text="You"
                      android:textColor="#FFFFFF" android:textSize="12sp" android:background="#88000000"/>
              </FrameLayout>
              <TextView android:layout_width="32dp" android:layout_height="match_parent"
                  android:text="VS" android:textColor="#FFD700" android:textSize="16sp" android:textStyle="bold"
                  android:gravity="center"/>
              <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                  <ImageView android:id="@+id/iv_battle_their_thumb"
                      android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="#222"/>
                  <TextView android:id="@+id/tv_battle_their_label"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:layout_gravity="bottom" android:padding="8dp" android:text="Opponent"
                      android:textColor="#FFFFFF" android:textSize="12sp" android:background="#88000000"/>
              </FrameLayout>
          </LinearLayout>

          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="Battle Duration" android:textColor="#FFFFFF" android:textSize="15sp"
              android:textStyle="bold" android:layout_marginTop="20dp"/>
          <RadioGroup android:id="@+id/rg_battle_duration"
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:orientation="horizontal" android:layout_marginTop="8dp">
              <RadioButton android:id="@+id/rb_battle_24h" android:layout_width="0dp"
                  android:layout_height="wrap_content" android:layout_weight="1"
                  android:text="24h" android:textColor="#CCCCCC"/>
              <RadioButton android:id="@+id/rb_battle_48h" android:layout_width="0dp"
                  android:layout_height="wrap_content" android:layout_weight="1"
                  android:text="48h" android:textColor="#CCCCCC" android:checked="true"/>
              <RadioButton android:id="@+id/rb_battle_72h" android:layout_width="0dp"
                  android:layout_height="wrap_content" android:layout_weight="1"
                  android:text="72h" android:textColor="#CCCCCC"/>
          </RadioGroup>

          <ProgressBar android:id="@+id/progress_battle_create"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:layout_gravity="center" android:visibility="gone"/>

          <Button android:id="@+id/btn_create_battle"
              android:layout_width="match_parent" android:layout_height="52dp"
              android:layout_marginTop="24dp" android:text="⚔️ Start Battle"
              android:textColor="#000000" android:backgroundTint="#FFD700"
              android:textSize="16sp" android:textStyle="bold"/>
      </LinearLayout>
  </ScrollView>