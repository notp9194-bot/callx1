<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Creator Dashboard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="20dp"/>

        <!-- Stats Overview -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="#1AFFFFFF"
                android:padding="12dp"
                android:layout_margin="4dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Views" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:id="@+id/tv_total_views_7d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="#1AFFFFFF"
                android:padding="12dp"
                android:layout_margin="4dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reach" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:id="@+id/tv_total_reach_7d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="#1AFFFFFF"
                android:padding="12dp"
                android:layout_margin="4dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Followers" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:id="@+id/tv_new_followers_7d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+0" android:textSize="20sp" android:textStyle="bold" android:textColor="#4CAF50"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:background="#1AFFFFFF"
                android:padding="12dp"
                android:layout_margin="4dp"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gifts Revenue" android:textSize="12sp" android:textColor="#888888"/>
                <TextView android:id="@+id/tv_total_revenue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/nix/store/smkzrg2vvp3lng3hq7v9svfni5mnqjh2-bash-interactive-5.2p37/bin/bash.00" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFD700"/>
            </LinearLayout>
        </GridLayout>

        <!-- Reach Chart -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reach (Last 7 Days)" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <com.callx.reels.analytics.ReelTimeSeriesChartView
            android:id="@+id/reach_chart"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="24dp"/>

        <!-- Best Time -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Best Time to Post" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <com.callx.reels.analytics.BestTimeToPostView
            android:id="@+id/best_time_grid"
            android:layout_width="match_parent"
            android:layout_height="160dp"/>
        <TextView android:id="@+id/tv_best_time_rec" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="10dp" android:text="Analysis in progress..." android:textColor="#4CAF50" android:gravity="center" android:layout_marginBottom="24dp"/>

        <!-- Top Reels -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top Performing Reels" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top_reels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_marginBottom="24dp"/>

        <!-- Follower Growth -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Follower Growth" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <com.callx.reels.analytics.ReelTimeSeriesChartView
            android:id="@+id/follower_growth_chart"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="24dp"/>

        <!-- Top Gifters -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top Gifters" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <LinearLayout android:id="@+id/layout_top_gifters" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="24dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
