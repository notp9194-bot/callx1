<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btn_mixer_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Audio Mixer"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="8dp"/>

        <ImageButton
            android:id="@+id/btn_mixer_apply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apply"
            android:textSize="15sp"
            android:src="@drawable/ic_double_tick_blue"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>

    <!-- Video Preview -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#000000">

        <androidx.media3.ui.PlayerView
            android:id="@+id/mixer_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ProgressBar
            android:id="@+id/mixer_progress_buf"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Music info bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="?attr/colorSurfaceVariant">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_music_note"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/tv_mixer_music_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No music"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_mixer_music_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Audio Mode Selector -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AUDIO MODE" android:textSize="11sp"
                android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rg_audio_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:background="?attr/colorSurfaceVariant"
                android:padding="4dp">

                <RadioButton
                    android:id="@+id/rb_mic_and_sound"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Mic + Sound"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:button="@null"
                    android:checked="true"
                    android:background="@drawable/bg_audio_mode_tab"/>

                <RadioButton
                    android:id="@+id/rb_sound_only"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Sound Only"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/bg_audio_mode_tab"/>

                <RadioButton
                    android:id="@+id/rb_mic_only"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Mic Only"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/bg_audio_mode_tab"/>
            </RadioGroup>

            <!-- Original Audio -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ORIGINAL AUDIO" android:textSize="11sp"
                android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <ImageButton android:id="@+id/btn_mute_orig" android:layout_width="36dp"
                    android:layout_height="36dp" android:src="@drawable/ic_volume_on"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <SeekBar android:id="@+id/sb_orig_vol" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_orig_vol_pct" android:layout_width="40dp"
                    android:layout_height="wrap_content" android:text="100%"
                    android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Background Music -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BACKGROUND MUSIC" android:textSize="11sp"
                android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <ImageButton android:id="@+id/btn_mute_music" android:layout_width="36dp"
                    android:layout_height="36dp" android:src="@drawable/ic_volume_on"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <SeekBar android:id="@+id/sb_music_vol" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tv_music_vol_pct" android:layout_width="40dp"
                    android:layout_height="wrap_content" android:text="80%"
                    android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>

            <!-- Voiceover -->
            <LinearLayout android:id="@+id/layout_voiceover_row"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VOICEOVER" android:textSize="11sp"
                    android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"
                    android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <ImageButton android:id="@+id/btn_voiceover_record" android:layout_width="44dp"
                        android:layout_height="44dp" android:src="@drawable/ic_mic"
                        android:background="@drawable/circle_primary"
                        android:padding="10dp"/>
                    <TextView android:id="@+id/tv_voiceover_status" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Tap mic to record voiceover"
                        android:textSize="13sp" android:paddingStart="12dp"
                        android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageButton android:id="@+id/btn_mute_voiceover" android:layout_width="36dp"
                        android:layout_height="36dp" android:src="@drawable/ic_volume_on"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                    <SeekBar android:id="@+id/sb_voiceover_vol" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
                    <TextView android:id="@+id/tv_voiceover_vol_pct" android:layout_width="40dp"
                        android:layout_height="wrap_content" android:text="100%"
                        android:textSize="13sp" android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
