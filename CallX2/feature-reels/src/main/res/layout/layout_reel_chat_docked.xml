<?xml version="1.0" encoding="utf-8"?>
<!--
  Mini floating reel player overlay — shown when user switches from Reels → Chat tab.

  v2 advanced features:
    • iv_mini_thumb       — blurred thumbnail fallback (Feature 6: animated out on first frame)
    • iv_swipe_up_hint    — subtle upward arrow (swipe-up = next reel, Feature 4)
    • All existing: mute indicator, close button, thin border
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:elevation="12dp">

    <!-- Feature 6: Blurred thumbnail fallback — visible while video surface loads.
         Loaded at 12×21px via Glide → bilinear upscale creates natural blur.
         Fades out on Player.EVENT_RENDERED_FIRST_FRAME. -->
    <ImageView
        android:id="@+id/iv_mini_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Thumbnail" />

    <!-- Live video surface — receives ExoPlayer via setPlayer() -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/mini_reel_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="zoom"
        app:surface_type="surface_view"
        android:background="#000000" />

    <!-- Feature 4: Swipe-up hint — subtle upward chevron at bottom center.
         Visible only while player is playing. -->
    <LinearLayout
        android:id="@+id/ll_swipe_up_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="6dp"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0.55">

        <View
            android:layout_width="18dp"
            android:layout_height="2dp"
            android:rotation="-45"
            android:layout_marginBottom="-2dp"
            android:layout_marginStart="2dp"
            android:background="#FFFFFFFF" />

        <View
            android:layout_width="18dp"
            android:layout_height="2dp"
            android:rotation="45"
            android:layout_marginStart="-2dp"
            android:background="#FFFFFFFF" />

    </LinearLayout>

    <!-- Mute/unmute feedback icon — shown briefly on single tap -->
    <ImageView
        android:id="@+id/iv_mini_mute_indicator"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_volume_off"
        android:tint="#FFFFFF"
        android:visibility="gone"
        android:contentDescription="Mute indicator" />

    <!-- Close button — top-right corner -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#AA000000"
            android:importantForAccessibility="no" />

        <ImageButton
            android:id="@+id/btn_mini_reel_close"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_close"
            android:tint="#FFFFFF"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:contentDescription="Close mini player" />

    </FrameLayout>

    <!-- Thin border to visually separate from chat background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/mini_player_border"
        android:importantForAccessibility="no" />

</FrameLayout>
