<?xml version="1.0" encoding="utf-8"?>
<!--
    sheet_reel_media_picker.xml
    Bottom-sheet media picker for the Reel camera screen.
    Mimics the chat attach-sheet pattern: drag handle, filter tabs,
    4-column recents grid, floating send/use bar.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_reel_media_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Drag handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_drag_handle"/>

        <!-- Filter tabs: All / Photos / Videos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="All"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_reel_tab_active"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tab_photos"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Photos"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="13sp"
                android:textColor="#99FFFFFF"
                android:background="@drawable/bg_reel_tab_inactive"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tab_videos"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Videos"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="13sp"
                android:textColor="#99FFFFFF"
                android:background="@drawable/bg_reel_tab_inactive"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

        <!-- 4-column media grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_media_grid"
            android:layout_width="match_parent"
            android:layout_height="380dp"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingBottom="72dp"/>

        <!-- Empty state (shown when gallery is empty / no permission) -->
        <LinearLayout
            android:id="@+id/ll_empty_state"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_gallery"
                android:tint="#44FFFFFF"
                android:contentDescription="No media"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No photos or videos found"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Floating send bar — appears when ≥1 item is selected -->
    <LinearLayout
        android:id="@+id/ll_send_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#CC121212"
        android:visibility="gone">

        <!-- Count label -->
        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 item selected"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <!-- Clear selection -->
        <TextView
            android:id="@+id/btn_clear_selection"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- USE button -->
        <TextView
            android:id="@+id/btn_use_media"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Use"
            android:gravity="center"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_reel_use_btn"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</FrameLayout>
