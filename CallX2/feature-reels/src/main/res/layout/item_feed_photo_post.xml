<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_photo_post.xml
    Instagram-like feed post card — used for both photo AND video posts.
    Video posts get the play-icon badge visible; photo posts keep it gone.
    Reused by HomeFeedAdapter for TYPE_POST_PHOTO and TYPE_POST_VIDEO.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:layout_marginBottom="6dp">

    <!-- ── Repost badge (shown if isRepost) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_repost_badge"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_repost"
            android:tint="#AAAAAA"/>

        <TextView
            android:id="@+id/tv_repost_by"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- ── Post header row ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_post_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_person"
            app:civ_border_width="1.5dp"
            app:civ_border_color="@color/brand_primary"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Name + location column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_post_owner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@username"
                    android:textColor="#FFFFFF"
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Verified badge -->
                <ImageView
                    android:id="@+id/ic_verified_badge"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_verified"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_post_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2h"
                    android:textColor="#888888"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tv_post_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text=""
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Follow button -->
        <Button
            android:id="@+id/btn_post_follow"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Follow"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:backgroundTint="@color/brand_primary"
            android:stateListAnimator="@null"
            android:allCaps="false"
            android:visibility="visible"/>

        <!-- More (...) -->
        <ImageButton
            android:id="@+id/btn_post_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_more_vert"
            android:tint="#AAAAAA"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"/>
    </LinearLayout>

    <!-- ── Media area ──────────────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/frame_post_media"
        android:layout_width="match_parent"
        android:layout_height="360dp">

        <!-- Thumbnail image (photo or video thumb) -->
        <ImageView
            android:id="@+id/iv_post_thumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A1A"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Play icon — VISIBLE for video, GONE for photo -->
        <ImageView
            android:id="@+id/iv_video_badge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            android:tint="#CCFFFFFF"
            android:visibility="gone"/>

        <!-- Gradient overlay at bottom of media -->
        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_reel_bottom"/>

        <!-- Music bar overlay -->
        <LinearLayout
            android:id="@+id/layout_music_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_music"
                android:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tv_music_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ── Action Row (Like, Comment, Share, Save) ─────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Heart / Like -->
        <ImageButton
            android:id="@+id/btn_post_like"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_heart"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like"/>

        <TextView
            android:id="@+id/tv_post_likes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="0"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:minWidth="24dp"/>

        <!-- Comment -->
        <ImageButton
            android:id="@+id/btn_post_comment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_comment"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Comment"/>

        <TextView
            android:id="@+id/tv_post_comments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="0"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:minWidth="24dp"/>

        <!-- Share -->
        <ImageButton
            android:id="@+id/btn_post_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_share"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"/>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Save / Bookmark (right-aligned) -->
        <ImageButton
            android:id="@+id/btn_post_save"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bookmark_outline"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Save"/>
    </LinearLayout>

    <!-- ── Caption ─────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_post_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp"
        android:text=""
        android:textColor="#DDDDDD"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#222222"/>

</LinearLayout>
