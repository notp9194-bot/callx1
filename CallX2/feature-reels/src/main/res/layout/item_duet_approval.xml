<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:padding="12dp" android:background="#1A1A1A" android:layout_marginBottom="1dp">

      <ImageView android:id="@+id/iv_approval_avatar"
          android:layout_width="44dp" android:layout_height="44dp"/>

      <ImageView android:id="@+id/iv_approval_thumb"
          android:layout_width="56dp" android:layout_height="80dp"
          android:layout_marginStart="10dp" android:scaleType="centerCrop"/>

      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
          <TextView android:id="@+id/tv_approval_name"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="wants to duet your reel" android:textColor="#888888" android:textSize="12sp"/>
      </LinearLayout>

      <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:orientation="vertical" android:layout_marginStart="8dp">
          <Button android:id="@+id/btn_approval_approve"
              android:layout_width="72dp" android:layout_height="34dp"
              android:text="Approve" android:textSize="12sp" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF"/>
          <Button android:id="@+id/btn_approval_reject"
              android:layout_width="72dp" android:layout_height="34dp" android:layout_marginTop="4dp"
              android:text="Reject" android:textSize="12sp" android:backgroundTint="#F44336" android:textColor="#FFFFFF"/>
      </LinearLayout>
  </LinearLayout>