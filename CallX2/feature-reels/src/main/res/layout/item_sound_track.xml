<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="72dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="12dp" android:paddingVertical="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Cover art -->
    <ImageView android:id="@+id/iv_track_cover"
        android:layout_width="52dp" android:layout_height="52dp"
        android:scaleType="centerCrop" android:src="@drawable/ic_music_disc"
        android:background="#1E1E1E"/>

    <!-- Info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:paddingStart="12dp" android:paddingEnd="8dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tv_track_name"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/badge_track_trending"
                android:layout_width="wrap_content" android:layout_height="22dp"
                android:gravity="center" android:paddingHorizontal="8dp"
                android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"
                android:background="@drawable/bg_reel_chip_selected"
                android:layout_marginStart="4dp" android:visibility="gone"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_track_artist"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#AAAAAA" android:textSize="12sp"
            android:maxLines="1" android:ellipsize="end" android:layout_marginTop="2dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="2dp">
            <TextView android:id="@+id/tv_track_meta"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#666666" android:textSize="11sp"/>
            <TextView android:id="@+id/tv_track_usage"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FF3B5C" android:textSize="11sp"
                android:paddingStart="8dp" android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Actions -->
    <ImageButton android:id="@+id/btn_track_preview"
        android:layout_width="36dp" android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_play" android:tint="#FFFFFF"
        android:layout_marginEnd="4dp"/>

    <TextView android:id="@+id/btn_track_use"
        android:layout_width="52dp" android:layout_height="32dp"
        android:text="Use" android:gravity="center"
        android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"/>
</LinearLayout>
