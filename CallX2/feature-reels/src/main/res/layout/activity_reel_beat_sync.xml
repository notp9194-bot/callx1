<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D0D0D">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:paddingHorizontal="12dp">
        <ImageButton android:id="@+id/btn_beat_back" android:layout_width="40dp"
            android:layout_height="40dp" android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true" android:text="Beat Sync"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
    </RelativeLayout>

    <!-- Status -->
    <TextView android:id="@+id/tv_beat_status" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Analysing beats…"
        android:textColor="#AAAAAA" android:textSize="14sp"
        android:gravity="center" android:padding="12dp"/>

    <ProgressBar android:id="@+id/progress_beat_detect" android:layout_width="match_parent"
        android:layout_height="4dp" style="@android:style/Widget.ProgressBar.Horizontal"
        android:progressTint="#FF3B5C" android:max="100"
        android:layout_marginHorizontal="16dp" android:visibility="gone"/>

    <!-- BPM display + override -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:paddingVertical="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="BPM Override"
            android:textColor="#AAAAAA" android:textSize="13sp"/>
        <SeekBar android:id="@+id/sb_beat_bpm_override" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="2"
            android:max="180" android:progress="0"
            android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
        <TextView android:id="@+id/tv_beat_count" android:layout_width="56dp"
            android:layout_height="wrap_content" android:text="Auto"
            android:textColor="#FFFFFF" android:textSize="14sp"
            android:gravity="end" android:paddingStart="8dp"/>
    </LinearLayout>

    <!-- Beat strip (beat markers drawn here) -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="72dp"
        android:scrollbars="none" android:paddingHorizontal="8dp">
        <LinearLayout android:id="@+id/layout_beat_strip" android:layout_width="wrap_content"
            android:layout_height="match_parent" android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Snap interval -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="SNAP EVERY" android:textColor="#666666" android:textSize="11sp"
        android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"/>

    <RadioGroup android:id="@+id/rg_beat_snap" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:paddingHorizontal="12dp">
        <RadioButton android:id="@+id/rb_snap_1" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Every beat"
            android:textColor="#FFFFFF" android:buttonTint="#FF3B5C"
            android:layout_marginEnd="12dp" android:checked="true"/>
        <RadioButton android:id="@+id/rb_snap_2" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Every 2nd"
            android:textColor="#FFFFFF" android:buttonTint="#FF3B5C"
            android:layout_marginEnd="12dp"/>
        <RadioButton android:id="@+id/rb_snap_4" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Every 4th"
            android:textColor="#FFFFFF" android:buttonTint="#FF3B5C"/>
    </RadioGroup>

    <!-- Apply -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:padding="20dp">
        <TextView android:id="@+id/btn_beat_apply" android:layout_width="wrap_content"
            android:layout_height="48dp" android:text="Apply Beat Sync"
            android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:paddingHorizontal="36dp" android:gravity="center"/>
    </LinearLayout>
</LinearLayout>
