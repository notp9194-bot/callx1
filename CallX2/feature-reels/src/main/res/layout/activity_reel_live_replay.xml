<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212">

    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btn_replay_back" android:layout_width="40dp"
            android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:id="@+id/tv_replay_title" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Live Replay" android:textColor="#FFFFFF" android:textSize="18sp"
            android:textStyle="bold" android:paddingStart="12dp"/>
    </LinearLayout>

    <FrameLayout android:layout_width="match_parent" android:layout_height="220dp"
        android:background="#000000">
        <androidx.media3.ui.PlayerView android:id="@+id/player_replay"
            android:layout_width="match_parent" android:layout_height="match_parent"/>
        <ProgressBar android:id="@+id/progress_replay" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>
    </FrameLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingBottom="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingTop="12dp">
                <TextView android:id="@+id/tv_replay_views" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#AAAAAA" android:textSize="13sp"/>
                <TextView android:id="@+id/tv_replay_peak" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:textColor="#AAAAAA" android:textSize="13sp" android:gravity="end"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_replay_duration" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="#666666" android:textSize="12sp"
                android:paddingTop="2dp" android:paddingBottom="12dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="CLIP SELECTION (post as reel)" android:textColor="#888888"
                android:textSize="11sp" android:paddingBottom="4dp"/>
            <TextView android:id="@+id/tv_clip_start" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Start: 00:00"
                android:textColor="#FFFFFF" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_clip_start" android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tv_clip_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="End: 01:00"
                android:textColor="#FFFFFF" android:textSize="12sp" android:paddingTop="4dp"/>
            <SeekBar android:id="@+id/sb_clip_end" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:paddingBottom="12dp"/>

            <EditText android:id="@+id/et_replay_caption" android:layout_width="match_parent"
                android:layout_height="80dp" android:hint="Add a caption for your reel…"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:background="@drawable/bg_search_field" android:paddingHorizontal="16dp"
                android:paddingTop="12dp" android:gravity="top" android:inputType="textMultiLine"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical" android:paddingTop="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Post as Public" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <Switch android:id="@+id/sw_replay_public" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:checked="true"/>
            </LinearLayout>

            <Button android:id="@+id/btn_replay_post_as_reel" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="🎬 Post Clip as Reel"
                android:backgroundTint="#FF3B5C" android:textColor="#FFFFFF" android:layout_marginTop="12dp"/>
            <Button android:id="@+id/btn_replay_delete" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="Delete Replay"
                android:backgroundTint="#333333" android:textColor="#FF3B5C" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
