<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
    android:paddingTop="8dp">

    <!-- Timeline column -->
    <LinearLayout android:layout_width="36dp" android:layout_height="match_parent"
        android:orientation="vertical" android:gravity="center_horizontal">
        <TextView android:id="@+id/tv_chain_position"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/bg_circle_purple"
            android:gravity="center" android:textColor="#FFFFFF"
            android:textSize="12sp" android:textStyle="bold"/>
        <View android:id="@+id/view_chain_connector"
            android:layout_width="2dp" android:layout_height="40dp"
            android:background="#7C3AED" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Content -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="horizontal"
        android:paddingStart="12dp" android:paddingBottom="12dp"
        android:gravity="center_vertical">
        <ImageView android:id="@+id/iv_chain_avatar"
            android:layout_width="40dp" android:layout_height="40dp"
            android:scaleType="centerCrop" android:src="@drawable/ic_default_avatar"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingStart="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_chain_name"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textStyle="bold"
                    android:textSize="14sp" android:textColor="#000000"/>
                <TextView android:id="@+id/tv_chain_type"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#7C3AED"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_chain_caption"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#555555" android:textSize="13sp"
                android:fontStyle="italic" android:maxLines="2" android:ellipsize="end"/>
            <TextView android:id="@+id/tv_chain_time"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#888888" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
