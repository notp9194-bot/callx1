<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="40dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btn_close_camera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Close"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btn_flash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_volume_on"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Flash"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/btn_flip_camera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:contentDescription="Flip camera"/>
    </LinearLayout>

    <!-- Timer chips -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:orientation="horizontal"
        android:paddingTop="110dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/chip_15s"
            android:layout_width="52dp"
            android:layout_height="32dp"
            android:text="15s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_speed_chip"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/chip_30s"
            android:layout_width="52dp"
            android:layout_height="32dp"
            android:text="30s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_speed_chip"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/chip_60s"
            android:layout_width="52dp"
            android:layout_height="32dp"
            android:text="60s"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_speed_chip"/>
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="36dp"
        android:paddingTop="12dp"
        android:background="#44000000">

        <!-- Timer display -->
        <TextView
            android:id="@+id/tv_record_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <!-- Progress ring -->
        <ProgressBar
            android:id="@+id/progress_record"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:max="30"
            android:progress="0"
            android:progressTint="@color/brand_primary"
            android:progressBackgroundTint="#44FFFFFF"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="20dp"/>

        <!-- Selected duration label -->
        <TextView
            android:id="@+id/tv_selected_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30s"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- Original Audio volume panel (shown only when audio pre-selected via "Use in Camera") -->
        <LinearLayout
            android:id="@+id/ll_audio_volume_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="12dp"
            android:background="#88000000"
            android:visibility="gone">

            <!-- Label -->
            <TextView
                android:id="@+id/tv_audio_panel_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵 Original Audio"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Original audio volume row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_volume_off"
                    android:tint="#CCFFFFFF"/>

                <SeekBar
                    android:id="@+id/seek_camera_orig_vol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="80"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:progressTint="@color/brand_primary"
                    android:thumbTint="@color/brand_primary"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_volume_on"
                    android:tint="#CCFFFFFF"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_camera_orig_vol_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Original audio: 80%"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"
                android:layout_marginBottom="8dp"/>

            <!-- Mic volume row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_mic_off"
                    android:tint="#CCFFFFFF"/>

                <SeekBar
                    android:id="@+id/seek_camera_mic_vol"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="200"
                    android:progress="100"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    android:progressTint="#FF4081"
                    android:thumbTint="#FF4081"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_mic"
                    android:tint="#CCFFFFFF"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_camera_mic_vol_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic: 100%"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp"/>

        </LinearLayout>

        <!-- Record button -->
        <ImageButton
            android:id="@+id/btn_record"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_camera"
            android:background="@drawable/circle_primary"
            android:tint="@color/white"
            android:padding="16dp"
            android:contentDescription="Record"/>
    </LinearLayout>


    <!-- Right-side tool buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingEnd="10dp">

        <ImageButton android:id="@+id/btn_camera_effects"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_sparkle"
            android:tint="#FFD700"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Effects"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Effects" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_filters"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_filter"
            android:tint="#A855F7"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Filters"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Filters" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_text"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_emoji"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Text"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Text" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_stickers"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_emoji"
            android:tint="#FFD60A"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Stickers"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Stickers" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_speed"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_speed"
            android:tint="#FFD700"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Speed"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Speed" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_music"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_music"
            android:tint="#00E5FF"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Music"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Music" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_multiclip"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_gallery"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white" android:contentDescription="Multi Clip"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Multi" android:textColor="#CCFFFFFF" android:textSize="10sp"
            android:layout_marginBottom="10dp"/>

        <ImageButton android:id="@+id/btn_camera_drafts"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_bookmark"
            android:tint="#00C6FF"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="Drafts"
            android:layout_marginBottom="2dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Drafts" android:textColor="#CCFFFFFF" android:textSize="10sp"/>
    </LinearLayout>

</FrameLayout>
