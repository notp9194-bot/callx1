<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="80dp" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="center" android:padding="8dp"
    android:background="?attr/selectableItemBackground">
    <TextView android:id="@+id/tv_gifter_rank" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFD700" android:textSize="12sp" android:textStyle="bold"/>
    <de.hdodenhof.circleimageview.CircleImageView android:id="@+id/iv_gifter_avatar"
        android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_person"/>
    <TextView android:id="@+id/tv_gifter_name" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFFFFF" android:textSize="11sp" android:maxLines="1"
        android:ellipsize="end" android:paddingTop="2dp"/>
    <TextView android:id="@+id/tv_gifter_coins" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFD700" android:textSize="10sp"/>
</LinearLayout>
