<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_story_thumb.xml
    Single story circle used inside the stories bar RecyclerView.

    Ring states:
      v_ring_active   → gradient brand ring (unseen)
      v_ring_seen     → gray ring (fully seen)
      v_ring_my_story → green ring (my own story)
    Only one is visible at a time.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="4dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackgroundBorderless">

    <!-- Avatar + ring stack -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <!-- Active (unseen) gradient ring -->
        <View
            android:id="@+id/v_ring_active"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/gradient_story_ring_active"
            android:visibility="visible"/>

        <!-- Seen (gray) ring -->
        <View
            android:id="@+id/v_ring_seen"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_story_seen_ring"
            android:visibility="gone"/>

        <!-- My story (brand green) ring -->
        <View
            android:id="@+id/v_ring_my_story"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_highlight_ring_active"
            android:visibility="gone"/>

        <!-- Avatar (3dp inset from ring) -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_story_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"/>

        <!-- "+" Add badge (only shown for My Story) -->
        <ImageView
            android:id="@+id/iv_story_add_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_add"
            android:background="@color/brand_primary"
            android:padding="3dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Owner name -->
    <TextView
        android:id="@+id/tv_story_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Username"
        android:textColor="#CCCCCC"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"/>

</LinearLayout>
