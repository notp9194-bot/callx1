<?xml version="1.0" encoding="utf-8"?>
<!--
    item_feed_skeleton.xml
    Loading skeleton shown at the bottom of the feed while fetching the next page.
    Uses simple animated shimmer-like views (pulsing via alpha animation in code, or just static).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111111"
    android:padding="12dp"
    android:layout_marginBottom="6dp">

    <!-- Skeleton post header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Avatar skeleton -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_action"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <View
                android:layout_width="120dp"
                android:layout_height="12dp"
                android:background="#2A2A2A"/>

            <View
                android:layout_width="70dp"
                android:layout_height="10dp"
                android:layout_marginTop="5dp"
                android:background="#222222"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Skeleton media area -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginTop="8dp"
        android:background="#1E1E1E"/>

    <!-- Skeleton action row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <View android:layout_width="36dp" android:layout_height="14dp" android:background="#222222"/>
        <View android:layout_width="36dp" android:layout_height="14dp" android:layout_marginStart="12dp" android:background="#222222"/>
        <View android:layout_width="36dp" android:layout_height="14dp" android:layout_marginStart="12dp" android:background="#222222"/>
    </LinearLayout>

    <!-- Skeleton caption -->
    <View
        android:layout_width="200dp"
        android:layout_height="12dp"
        android:layout_marginTop="8dp"
        android:background="#1E1E1E"/>

    <View
        android:layout_width="140dp"
        android:layout_height="12dp"
        android:layout_marginTop="6dp"
        android:background="#1A1A1A"/>

    <!-- Centered spinner -->
    <ProgressBar
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/brand_primary"/>

</LinearLayout>
