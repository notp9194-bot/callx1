<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_sound_detail.xml — Instagram-style sound detail bottom sheet.
    Screenshot 3 (peek) → Screenshot 4 (expanded, scrolled up to show reels grid).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/sheet_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_sound_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Drag handle ── -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_drag_handle"/>

                <!-- ── Top row: Trending badge + 3-dot menu ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="4dp">

                    <!-- Trending arrow + label -->
                    <TextView
                        android:id="@+id/tv_trending_badge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="↗ Trending"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"/>

                    <ImageButton
                        android:id="@+id/btn_sound_more"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="?attr/colorOnSurface"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="More options"/>
                </LinearLayout>

                <!-- ── Song info row: thumbnail + title/artist + bookmark/share ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="12dp">

                    <!-- Song thumbnail with play/pause overlay -->
                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:id="@+id/iv_sound_cover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@color/surface_input"
                            android:src="@drawable/ic_music_disc"/>

                        <!-- Play/Pause button overlay -->
                        <ImageButton
                            android:id="@+id/btn_play_pause"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_play"
                            android:background="#88000000"
                            android:tint="@color/white"
                            android:padding="6dp"
                            android:contentDescription="Play/Pause"/>
                    </FrameLayout>

                    <!-- Title + Artist (takes remaining space) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_sound_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-bold"
                            android:textColor="?attr/colorOnSurface"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:text="Song title"/>

                        <TextView
                            android:id="@+id/tv_sound_artist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="Artist"/>

                        <!-- Stats row: duration · reel count · Spotify Add -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">

                            <TextView
                                android:id="@+id/tv_sound_duration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:text="0:00"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:text=" · "/>

                            <TextView
                                android:id="@+id/tv_sound_reel_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:text="0 reels"/>

                            <!-- Spotify Add chip -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="24dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_spotify_add_pill"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_music"
                                    android:tint="#1DB954"
                                    android:layout_marginEnd="3dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Add"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurface"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bookmark + Share icons (right side) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginStart="8dp">

                        <ImageButton
                            android:id="@+id/btn_save_sound"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_bookmark"
                            android:tint="?attr/colorOnSurface"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Save sound"/>

                        <ImageButton
                            android:id="@+id/btn_share_sound"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_send"
                            android:tint="?attr/colorOnSurface"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Share sound"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Action buttons: Add to profile | Use audio ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp"
                    android:gravity="center_vertical">

                    <!-- Add to profile (blue filled) -->
                    <Button
                        android:id="@+id/btn_add_to_profile"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Add to profile"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_btn_follow_pill"
                        android:stateListAnimator="@null"/>

                    <!-- Use audio (outlined) -->
                    <Button
                        android:id="@+id/btn_use_audio"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Use audio"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/bg_btn_outline_pill"
                        android:stateListAnimator="@null"/>
                </LinearLayout>

                <!-- ── Divider ── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="?attr/colorOutline"/>

                <!-- ── "Reels with this audio" header ── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="6dp"
                    android:text="Reels with this audio"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <!-- ── 3-column reels grid ── -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sound_reels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

                <!-- Bottom padding for nav bar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
