<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#121212" android:gravity="center_horizontal">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btn_qr_back" android:layout_width="40dp"
            android:layout_height="40dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Share via QR" android:textColor="#FFFFFF"
            android:textSize="18sp" android:textStyle="bold" android:paddingStart="12dp"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progress_qr" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="48dp" android:visibility="gone"/>
    <ImageView android:id="@+id/iv_qr_code" android:layout_width="280dp"
        android:layout_height="280dp" android:layout_marginTop="24dp"
        android:scaleType="centerInside"/>
    <TextView android:id="@+id/tv_qr_caption" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="16sp"
        android:textStyle="bold" android:paddingTop="16dp" android:gravity="center"
        android:paddingHorizontal="24dp" android:maxLines="2" android:ellipsize="end"/>
    <TextView android:id="@+id/tv_qr_link" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="#888888" android:textSize="12sp"
        android:paddingTop="8dp" android:gravity="center" android:paddingHorizontal="24dp"
        android:maxLines="1" android:ellipsize="middle"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:paddingTop="32dp"
        android:paddingHorizontal="24dp">
        <Button android:id="@+id/btn_qr_share" android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="Share" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_qr_save" android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="Save" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_secondary" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_qr_copy" android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:text="Copy Link" android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_secondary"/>
    </LinearLayout>
</LinearLayout>
