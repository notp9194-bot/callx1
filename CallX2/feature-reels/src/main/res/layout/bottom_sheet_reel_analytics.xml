<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded">

    <!-- Drag handle -->
    <View android:layout_width="40dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reel Insights"
            android:textSize="17sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#FFE082"/>

        <ImageButton
            android:id="@+id/btn_close_analytics"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"/>
    </LinearLayout>

    <!-- Thumbnail + caption preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_analytics_thumb"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:background="#11000000"
            android:contentDescription="Reel thumbnail"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_analytics_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:id="@+id/tv_analytics_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 5-stat grid: 2-col on row 1, 3-col on row 2 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:text="OVERVIEW"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:letterSpacing="0.1"/>

    <!-- Row 1: Views + Likes (big numbers) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <!-- Views card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="@drawable/bg_stat_card">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_eye_off"
            android:tint="#FFE082"
                android:contentDescription="Views"/>
            <TextView android:id="@+id/tv_stat_views"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="0"
                android:textSize="24sp" android:fontFamily="sans-serif-bold"
                android:textColor="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Views" android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Likes card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="@drawable/bg_stat_card">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_heart_filled"
            android:tint="#FF416C"
                android:contentDescription="Likes"/>
            <TextView android:id="@+id/tv_stat_likes"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:text="0"
                android:textSize="24sp" android:fontFamily="sans-serif-bold"
                android:textColor="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Likes" android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Comments + Saves + Shares -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <!-- Comments -->
        <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:orientation="vertical" android:gravity="center_vertical"
            android:paddingStart="12dp" android:background="@drawable/bg_stat_card">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_comment_reel"
            android:tint="#00C6FF"
                android:contentDescription="Comments"/>
            <TextView android:id="@+id/tv_stat_comments"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="0"
                android:textSize="20sp" android:fontFamily="sans-serif-bold"
                android:textColor="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Comments" android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Saves -->
        <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
            android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"
            android:orientation="vertical" android:gravity="center_vertical"
            android:paddingStart="12dp" android:background="@drawable/bg_stat_card">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_bookmark_filled"
            android:tint="#00C6FF"
                android:contentDescription="Saves"/>
            <TextView android:id="@+id/tv_stat_saves"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="0"
                android:textSize="20sp" android:fontFamily="sans-serif-bold"
                android:textColor="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Saves" android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- Shares -->
        <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
            android:layout_weight="1" android:layout_marginStart="4dp"
            android:orientation="vertical" android:gravity="center_vertical"
            android:paddingStart="12dp" android:background="@drawable/bg_stat_card">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_share_reel"
            android:tint="#00F260"
                android:contentDescription="Shares"/>
            <TextView android:id="@+id/tv_stat_shares"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="0"
                android:textSize="20sp" android:fontFamily="sans-serif-bold"
                android:textColor="?attr/colorOnSurface"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Shares" android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Engagement rate row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Engagement Rate"
            android:textSize="13sp" android:textColor="?attr/colorOnSurface"/>

        <TextView android:id="@+id/tv_engagement_rate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0.0%" android:textSize="16sp"
            android:fontFamily="sans-serif-bold" android:textColor="@color/brand_primary"/>
    </LinearLayout>

</LinearLayout>
