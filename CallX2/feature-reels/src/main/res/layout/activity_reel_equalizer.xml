<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D0D0D">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:paddingHorizontal="12dp">
        <ImageButton android:id="@+id/btn_eq_back" android:layout_width="40dp"
            android:layout_height="40dp" android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true" android:text="Equalizer"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_eq_reset" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" android:text="Reset"
            android:textColor="#888888" android:textSize="14sp" android:padding="8dp"/>
    </RelativeLayout>

    <ProgressBar android:id="@+id/progress_eq" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>

    <!-- EQ Presets chips -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="PRESETS" android:textColor="#666666" android:textSize="11sp"
        android:paddingHorizontal="16dp" android:paddingTop="8dp" android:paddingBottom="4dp"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_eq_presets"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:paddingHorizontal="10dp" android:clipToPadding="false"/>

    <!-- 5-Band EQ -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="5-BAND EQUALIZER" android:textColor="#666666" android:textSize="11sp"
        android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                android:text="60 Hz" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_band0" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="100" android:progress="50"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_band0_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0 dB"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                android:text="230 Hz" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_band1" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="100" android:progress="50"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_band1_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0 dB"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                android:text="910 Hz" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_band2" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="100" android:progress="50"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_band2_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0 dB"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                android:text="3.6 kHz" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_band3" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="100" android:progress="50"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_band3_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0 dB"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                android:text="14 kHz" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_band4" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="100" android:progress="50"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_band4_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0 dB"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bass Boost / Virtualizer / Loudness -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ENHANCEMENT" android:textColor="#666666" android:textSize="11sp"
        android:paddingHorizontal="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                android:text="Bass Boost" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_bass_boost" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="1000" android:progress="0"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_bass_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
            <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                android:text="Virtualizer" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_virtualizer" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="1000" android:progress="0"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_virtual_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="80dp" android:layout_height="wrap_content"
                android:text="Loudness" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <SeekBar android:id="@+id/sb_eq_loudness" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="1000" android:progress="0"
                android:progressTint="#FF3B5C" android:thumbTint="#FF3B5C"/>
            <TextView android:id="@+id/tv_eq_loudness_val" android:layout_width="44dp"
                android:layout_height="wrap_content" android:text="0"
                android:textColor="#FFFFFF" android:textSize="11sp" android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:padding="16dp" android:layout_marginTop="8dp">

        <TextView android:id="@+id/btn_eq_preview" android:layout_width="wrap_content"
            android:layout_height="44dp" android:text="Preview"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_speed_chip"
            android:paddingHorizontal="24dp" android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <TextView android:id="@+id/btn_eq_apply" android:layout_width="wrap_content"
            android:layout_height="44dp" android:text="Apply"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:paddingHorizontal="32dp" android:gravity="center"/>
    </LinearLayout>
</LinearLayout>
