<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_story_view.xml
    Full-screen story viewer — Instagram-style.
    Used by StoryViewActivity.

    Layout (top → bottom):
      • Segmented progress bar (ProgressBar, single-bar simple version)
      • Owner info overlay (avatar, name, time ago, close, more)
      • Full-screen story media image (fills entire screen)
      • Reply bar at bottom (reply text hint + emoji reactions)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen story media -->
    <ImageView
        android:id="@+id/iv_story_media"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#000000"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Gradient at top for header readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_reel_top"/>

    <!-- Gradient at bottom for reply bar readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_reel_bottom"/>

    <!-- ── Top overlay ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingTop="42dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Progress bar (segments simulated via single ProgressBar) -->
        <ProgressBar
            android:id="@+id/pb_story_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="1"
            android:progress="1"
            android:progressTint="#FFFFFF"
            android:progressBackgroundTint="#66FFFFFF"/>

        <!-- Owner row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_story_owner_avatar"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_person"
                android:app:civ_border_width="1.5dp"
                android:app:civ_border_color="#FFFFFF"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_story_owner_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_story_time_ago"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2m ago"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_story_more"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_more_vert"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="More"/>

            <ImageButton
                android:id="@+id/btn_story_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Bottom reply bar ────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/container_story_reply"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <!-- Reply input (not actually editable — tap opens a sheet) -->
        <TextView
            android:id="@+id/tv_story_reply_hint"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Reply..."
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_comment_input"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Emoji quick reactions -->
        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:text="❤️"
            android:textSize="20sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="😂"
            android:textSize="20sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🔥"
            android:textSize="20sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</FrameLayout>
