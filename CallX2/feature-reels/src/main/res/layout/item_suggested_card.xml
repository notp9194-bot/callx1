<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontal card used in "Suggested for you" inline panel -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:layout_marginEnd="4dp"
    android:background="@drawable/bg_card_rounded"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Dismiss X button (top-right) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton android:id="@+id/btn_dismiss"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="end"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/colorOnSurfaceVariant"
            android:padding="3dp"
            android:contentDescription="Dismiss"/>
    </FrameLayout>

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_avatar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_person"
        android:layout_marginTop="4dp"
        app:civ_border_width="0dp"/>

    <TextView android:id="@+id/tv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Username"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"/>

    <Button android:id="@+id/btn_follow"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="6dp"
        android:text="Follow"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        app:textAllCaps="false"
        android:background="@drawable/bg_btn_follow_pill"
        android:textColor="#FFFFFF"/>

</LinearLayout>
