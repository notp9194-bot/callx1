<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="12dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btn_transitions_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Transitions"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <TextView
            android:id="@+id/btn_transitions_apply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:paddingHorizontal="14dp"
            android:paddingVertical="7dp"
            android:text="Apply"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"/>
    </RelativeLayout>

    <!-- Selected info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?attr/colorSurfaceVariant">

        <TextView
            android:id="@+id/tv_transition_selected_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cut"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <TextView
            android:id="@+id/tv_transition_selected_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Instant hard cut — no transition"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

        <!-- Duration slider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Duration"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/sb_transition_duration"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#FF3B5C"
                android:thumbTint="#FF3B5C"/>

            <TextView
                android:id="@+id/tv_transition_duration_val"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="300 ms"
                android:textSize="13sp"
                android:gravity="end"
                android:textColor="?attr/colorOnSurface"/>
        </LinearLayout>

        <!-- Apply all toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Apply to all clip gaps"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"/>

            <Switch
                android:id="@+id/sw_transition_apply_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Transition list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_transitions_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="8dp"
        android:clipToPadding="false"/>

</LinearLayout>
