<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_reel_action_btn_glow.xml
    Transparent center with a soft blurred ring around the icon.
    The actual tinted glow per-button colour is set via Java (setColorFilter).
    This gives a halo-only effect — no solid background — classic look.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#00000000"/>
            <stroke
                android:width="6dp"
                android:color="#33FFFFFF"/>
        </shape>
    </item>
    <!-- Inner transparent (no fill) -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="#00000000"/>
        </shape>
    </item>
</layer-list>
