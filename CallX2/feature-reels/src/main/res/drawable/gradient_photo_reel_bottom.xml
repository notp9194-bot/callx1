<?xml version="1.0" encoding="utf-8"?>
<!--
    gradient_photo_reel_bottom.xml
    Deep Instagram-style bottom gradient for photo reels.
    Taller and deeper than the standard reel gradient —
    covers 45% of the screen with a strong black fade to transparent.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#EE000000"
        android:centerColor="#88000000"
        android:endColor="#00000000"/>
</shape>
