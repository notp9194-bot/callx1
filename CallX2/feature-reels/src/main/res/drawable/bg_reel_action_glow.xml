<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_reel_action_glow.xml
    Semi-transparent dark gradient that sits behind the right action buttons.
    Fades from solid dark on the right edge to fully transparent on the left,
    ensuring icons (any colour) stay visible on any reel background.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="180"
        android:startColor="#00000000"
        android:centerColor="#55000000"
        android:endColor="#BB000000"/>
</shape>
