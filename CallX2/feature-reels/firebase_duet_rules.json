{
  "_comment": "Firebase Realtime Database security rules — Duet System (merge into your existing rules)",
  "rules": {
    "reels": {
      "reel_duets": {
        "$originalReelId": {
          ".read": "auth != null",
          "$duetReelId": {
            ".write": "auth != null && (
              !data.exists() ||
              data.child('duetUid').val() === auth.uid
            )",
            ".validate": "newData.hasChildren(['duetReelId','duetUid','timestamp'])
              && newData.child('duetUid').val() === auth.uid
              && newData.child('duetReelId').isString()
              && newData.child('timestamp').val() <= now + 5000"
          }
        }
      },
      "user_duets": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$duetReelId": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['originalReelId','timestamp'])"
          }
        }
      },
      "remix_settings": {
        "$reelId": {
          ".read": "auth != null",
          "duet": {
            ".write": "auth != null",
            ".validate": "newData.isString() && (
              newData.val() === 'everyone' ||
              newData.val() === 'followers' ||
              newData.val() === 'off'
            )"
          },
          "stitch": {
            ".write": "auth != null",
            ".validate": "newData.isString() && (
              newData.val() === 'everyone' ||
              newData.val() === 'followers' ||
              newData.val() === 'off'
            )"
          }
        }
      },
      "fcm_queue": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$pushId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['type','fromUid','originalReelId','duetReelId','timestamp'])
              && newData.child('type').val() === 'duet'
              && newData.child('fromUid').val() === auth.uid"
          }
        }
      },
      "notifications": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          "$notifId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['type','timestamp'])"
          }
        }
      }
    }
  }
}
