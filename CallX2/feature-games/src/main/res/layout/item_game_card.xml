<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_game_card"
    android:layout_marginBottom="14dp"
    android:padding="18dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Game icon circle -->
    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_reels_game_icon"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_game_emoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="30sp"
            android:text="🎮"/>
    </FrameLayout>

    <!-- Name + description -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/tv_game_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bubble Pop"
            android:textColor="@color/games_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:id="@+id/tv_game_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bubbles phodo, score badhao!"
            android:textColor="@color/games_text_secondary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- Play button -->
    <LinearLayout
        android:id="@+id/btn_game_play"
        android:layout_width="80dp"
        android:layout_height="38dp"
        android:gravity="center"
        android:background="@drawable/bg_reels_game_play_btn"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶ Play"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>
