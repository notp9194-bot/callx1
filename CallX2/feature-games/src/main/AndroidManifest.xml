<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application>

        <!-- Games Hub — list of all games -->
        <activity
            android:name="com.callx.app.activities.GamesHubActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Games"/>

        <!--
            Single game WebView player.
            android:screenOrientation="unspecified" — orientation is set
            programmatically in GameActivity.onCreate() based on EXTRA_LANDSCAPE.
            Portrait games → portrait, Landscape games (car racing) → sensorLandscape.
        -->
        <activity
            android:name="com.callx.app.activities.GameActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Games.Fullscreen"/>

    </application>

</manifest>
