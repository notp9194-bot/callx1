<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="XActivity.Theme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/x_accent</item>
        <item name="colorPrimaryDark">@color/x_bg</item>
        <item name="colorAccent">@color/x_accent</item>
        <item name="android:windowBackground">@color/x_bg</item>
        <item name="android:statusBarColor">@color/x_bg</item>
        <item name="android:navigationBarColor">@color/x_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- XProfileSheet bottom sheet theme -->
    <style name="XSheet_Theme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/XSheet_Style</item>
        <item name="colorPrimary">@color/x_accent</item>
        <item name="colorAccent">@color/x_accent</item>
    </style>

    <style name="XSheet_Style" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/x_bg</item>
        <item name="android:elevation">8dp</item>
        <item name="shapeAppearanceOverlay">@style/XSheet_Shape</item>
    </style>

    <style name="XSheet_Shape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
