<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/x_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_x_security"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/x_bg"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="24dp">

            <!-- Two-factor authentication -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Two-factor authentication"
                        android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Add an extra layer of security to your account"
                        android:textColor="@color/x_text_secondary" android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_x_2fa"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Password reset protection -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Password reset protection"
                        android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Require additional info to reset your password"
                        android:textColor="@color/x_text_secondary" android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_x_pwd_protection"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Apps and sessions -->
            <LinearLayout android:id="@+id/row_x_apps_sessions"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apps and sessions"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/x_text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Logged-in devices -->
            <LinearLayout android:id="@+id/row_x_devices"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Logged-in devices and apps"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/x_text_secondary"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>