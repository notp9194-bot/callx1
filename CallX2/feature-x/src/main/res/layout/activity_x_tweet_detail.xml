<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/x_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:background="@color/x_bg">

        <ImageButton
            android:id="@+id/btn_x_detail_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/x_text_primary"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Post"
            android:textColor="@color/x_text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btn_x_detail_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_x_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/x_text_primary"
            android:contentDescription="Share"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/x_divider"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Root tweet detail card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_x_detail_avatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_person"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_x_detail_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/x_text_primary"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-bold"/>

                        <TextView
                            android:id="@+id/tv_x_detail_handle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/x_text_secondary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_x_detail_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_primary"
                    android:textSize="20sp"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="3dp"/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tv_x_detail_retweets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/x_text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Reposts  "
                        android:textColor="@color/x_text_secondary"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_x_detail_likes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/x_text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Likes  "
                        android:textColor="@color/x_text_secondary"
                        android:textSize="15sp"/>

                    <TextView
                        android:id="@+id/tv_x_detail_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/x_text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Views"
                        android:textColor="@color/x_text_secondary"
                        android:textSize="15sp"/>
                </LinearLayout>

                <!-- Hidden replies count label (used in code) -->
                <TextView
                    android:id="@+id/tv_x_detail_replies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/x_divider"/>

                <!-- Actions row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout android:id="@+id/btn_x_detail_like"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:gravity="center" android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_x_heart_outline" android:tint="@color/x_icon_default"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp" android:text="Like"
                            android:textColor="@color/x_icon_default" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btn_x_detail_retweet"
                        android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:gravity="center" android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_x_retweet" android:tint="@color/x_icon_default"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp" android:text="Repost"
                            android:textColor="@color/x_icon_default" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                        android:gravity="center" android:orientation="horizontal">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp"
                            android:src="@drawable/ic_x_reply" android:tint="@color/x_icon_default"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp" android:text="Reply"
                            android:textColor="@color/x_icon_default" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp"
                android:background="@color/x_divider"/>

            <!-- Quick reply bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <EditText
                    android:id="@+id/et_x_detail_reply"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Post your reply"
                    android:textColor="@color/x_text_primary"
                    android:textColorHint="@color/x_text_muted"
                    android:textSize="15sp"
                    android:background="@drawable/bg_surface_input"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:maxLines="3"
                    android:inputType="textMultiLine"/>

                <ImageButton
                    android:id="@+id/btn_x_send_reply"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_x_send"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/x_accent"
                    android:contentDescription="Send reply"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Replies list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_x_replies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
