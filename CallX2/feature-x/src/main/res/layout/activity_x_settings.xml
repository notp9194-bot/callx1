<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/x_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_x_settings"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/x_bg"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- YOUR ACCOUNT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your account"
                android:textColor="@color/x_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="6dp"/>

            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_account"/>
            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_security"/>
            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_privacy"/>
            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_notifications"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider" android:layout_marginTop="8dp"/>

            <!-- CONTENT PREFERENCES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Content preferences"
                android:textColor="@color/x_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="6dp"/>

            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_display"/>
            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_accessibility"/>
            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_data_usage"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider" android:layout_marginTop="8dp"/>

            <!-- HELP AND ABOUT -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Help and about"
                android:textColor="@color/x_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="6dp"/>

            <include layout="@layout/item_x_settings_row"
                android:id="@+id/row_x_about"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>