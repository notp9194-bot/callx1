<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent" android:layout_height="match_parent"
      android:orientation="vertical" android:background="@color/x_bg">
      <!-- Header -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:paddingStart="8dp" android:paddingEnd="12dp">
          <ImageButton android:id="@+id/btn_xdm_back"
              android:layout_width="40dp" android:layout_height="40dp"
              android:src="@drawable/ic_arrow_back" android:tint="@color/x_text_primary"
              android:background="?attr/selectableItemBackgroundBorderless"/>
          <de.hdodenhof.circleimageview.CircleImageView
              android:id="@+id/iv_xdm_header_avatar"
              android:layout_width="36dp" android:layout_height="36dp"
              android:layout_marginStart="8dp"/>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:layout_marginStart="8dp"
              android:orientation="vertical">
              <TextView android:id="@+id/tv_xdm_header_name"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:textColor="@color/x_text_primary" android:textStyle="bold"
                  android:textSize="14sp"/>
              <TextView android:id="@+id/tv_xdm_header_handle"
                  android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:textColor="@color/x_text_secondary" android:textSize="12sp"/>
          </LinearLayout>
      </LinearLayout>
      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="@color/x_divider"/>
      <!-- Messages -->
      <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_xdm_messages"
          android:layout_width="match_parent" android:layout_height="0dp"
          android:layout_weight="1" android:padding="8dp"/>
      <!-- Input -->
      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="@color/x_divider"/>
      <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:paddingStart="12dp" android:paddingEnd="8dp">
          <EditText android:id="@+id/et_xdm_message"
              android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
              android:hint="Start a message" android:textColorHint="@color/x_text_muted"
              android:textColor="@color/x_text_primary"
              android:background="@drawable/bg_surface_input"
              android:paddingStart="12dp" android:singleLine="true" android:textSize="15sp"/>
          <ImageButton android:id="@+id/btn_xdm_send"
              android:layout_width="44dp" android:layout_height="44dp"
              android:src="@drawable/ic_send" android:tint="@color/x_accent"
              android:background="?attr/selectableItemBackgroundBorderless"/>
      </LinearLayout>
  </LinearLayout>