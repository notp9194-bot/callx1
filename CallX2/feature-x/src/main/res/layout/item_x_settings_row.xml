<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground"
    android:focusable="true"
    android:clickable="true">

    <ImageView
        android:id="@+id/iv_x_row_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_x_settings"
        android:tint="@color/x_text_secondary"
        android:contentDescription="Setting icon"/>

    <TextView
        android:id="@+id/tv_x_row_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:text="Setting"
        android:textColor="@color/x_text_primary"
        android:textSize="15sp"/>

    <ImageView
        android:id="@+id/iv_x_row_chevron"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        android:tint="@color/x_text_secondary"
        android:contentDescription="Open"/>

</LinearLayout>