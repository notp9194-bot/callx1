<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/x_bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_x_about"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/x_bg"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="24dp">

            <!-- Version info -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="20dp" android:paddingBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Version" android:textColor="@color/x_text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_x_version"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="X for Android" android:textColor="@color/x_text_primary"
                    android:textSize="15sp" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Terms of Service -->
            <LinearLayout android:id="@+id/row_x_tos"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Terms of Service"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/x_text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Privacy Policy -->
            <LinearLayout android:id="@+id/row_x_privacy_policy"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Privacy Policy"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/x_text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Cookie policy -->
            <LinearLayout android:id="@+id/row_x_cookies"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cookie use policy"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/x_text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Help center -->
            <LinearLayout android:id="@+id/row_x_help_center"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Help Center"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/x_text_secondary"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/x_divider"/>

            <!-- Send feedback -->
            <LinearLayout android:id="@+id/row_x_feedback"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Send feedback"
                    android:textColor="@color/x_text_primary" android:textSize="15sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>