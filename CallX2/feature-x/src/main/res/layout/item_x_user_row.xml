<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_x_user_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_person" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tv_x_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/x_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_x_user_handle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/x_text_secondary"
            android:textSize="13sp" />
    
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_x_user_action"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:text="Unblock"
        android:textSize="13sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="@color/x_text_secondary"
        app:cornerRadius="16dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>
</LinearLayout>
