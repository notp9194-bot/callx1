<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_x_suggestion_card"
    android:padding="14dp"
    android:layout_marginEnd="10dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/iv_suggestion_avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_person" />

    <TextView
        android:id="@+id/tv_suggestion_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/x_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_suggestion_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/x_text_secondary"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_suggestion_mutual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/x_text_secondary"
        android:textSize="11sp"
        android:layout_marginTop="4dp"
        android:maxLines="1" />

    <Button
        android:id="@+id/btn_suggestion_follow"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:text="Follow"
        android:textColor="@color/x_bg_primary"
        android:backgroundTint="@color/x_text_primary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="0dp"
        style="@style/Widget.MaterialComponents.Button" />
</LinearLayout>
