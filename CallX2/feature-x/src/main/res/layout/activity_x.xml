<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/x_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/x_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/x_bg"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- Profile avatar (left) — tap opens own profile; live-loaded by XActivity -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_x_header_avatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Unread notification dot — visibility toggled by XActivity -->
                <View
                    android:id="@+id/v_x_notif_dot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="1dp"
                    android:layout_marginEnd="1dp"
                    android:background="@drawable/bg_x_notif_dot"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- X Logo centered -->
            <ImageView
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:src="@drawable/ic_x_logo"
                android:scaleType="center"
                android:contentDescription="X" />

            <!-- Games icon (right, before compose) -->
            <ImageButton
                android:id="@+id/btn_x_header_games"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/x_text_primary"
                android:contentDescription="Games" />

            <!-- Compose icon (right) -->
            <ImageButton
                android:id="@+id/btn_x_header_compose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_x_compose"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/x_text_primary"
                android:contentDescription="Compose" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/x_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="56dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/x_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/x_nav_bg"
        app:itemIconTint="@color/x_nav_icon_default"
        app:itemTextColor="@color/x_nav_icon_default"
        app:itemIconSize="22dp"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/x_bottom_nav"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
