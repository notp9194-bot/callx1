<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Forwarded label -->
    <TextView
        android:id="@+id/tv_dm_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forwarded"
        android:textColor="@color/x_text_secondary"
        android:textSize="11sp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"/>

    <!-- Reply preview bar -->
    <LinearLayout
        android:id="@+id/tv_dm_reply_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/bg_x_quote_card"
        android:padding="8dp"
        android:visibility="gone">

        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@color/x_accent"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/x_text_secondary"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Main bubble -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp">

        <LinearLayout
            android:id="@+id/ll_xdm_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="260dp"
            android:orientation="vertical"
            android:background="@drawable/bg_x_bubble_recv"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_xdm_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/x_text_primary"
                android:textSize="15sp"/>

            <ImageView
                android:id="@+id/iv_xdm_media"
                android:layout_width="200dp"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_x_media_rounded"
                android:clipToOutline="true"
                android:visibility="gone"
                android:contentDescription="DM media"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_xdm_msg_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_muted"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tv_dm_read_receipt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓✓"
                    android:textColor="@color/x_accent"
                    android:textSize="11sp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Emoji reactions row -->
    <LinearLayout
        android:id="@+id/ll_dm_reactions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_x_quote_card"
        android:padding="4dp"
        android:visibility="gone"/>

</LinearLayout>
