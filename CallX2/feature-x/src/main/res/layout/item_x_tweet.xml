<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Thread line (for reply chains) -->
    <View
        android:id="@+id/v_x_thread_line"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:layout_marginStart="34dp"
        android:background="@color/x_divider"
        android:visibility="gone"/>

    <!-- Pinned label -->
    <TextView
        android:id="@+id/tv_x_pinned"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="62dp"
        android:layout_marginTop="4dp"
        android:text="Pinned"
        android:textColor="@color/x_text_secondary"
        android:textSize="12sp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_x_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_person"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <!-- Name row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_x_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <ImageView
                    android:id="@+id/iv_x_verified"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_x_verified"
                    android:visibility="gone"
                    android:contentDescription="Verified"/>

                <TextView
                    android:id="@+id/tv_x_handle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/x_text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_x_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_secondary"
                    android:textSize="13sp"/>

                <ImageButton
                    android:id="@+id/btn_x_more"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_more_vert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/x_text_secondary"
                    android:contentDescription="More"/>
            </LinearLayout>

            <!-- Edited / Audience badges -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_x_edited"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edited"
                    android:textColor="@color/x_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tv_x_audience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_accent"
                    android:textSize="11sp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Tweet text -->
            <TextView
                android:id="@+id/tv_x_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/x_text_primary"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"/>

            <!-- Multi-image grid (up to 4) -->
            <GridLayout
                android:id="@+id/gl_x_multi_media"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:columnCount="2"
                android:rowCount="2"
                android:visibility="gone"/>

            <!-- Single media -->
            <ImageView
                android:id="@+id/iv_x_media"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_x_media_rounded"
                android:clipToOutline="true"
                android:visibility="gone"
                android:contentDescription="Media"/>

            <!-- Sensitive content overlay -->
            <FrameLayout
                android:id="@+id/v_x_sensitive_overlay"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:background="#CC000000"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_sensitive_reveal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Sensitive content\nTap to view"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="#80000000"
                    android:padding="12dp"/>
            </FrameLayout>

            <!-- Link preview card -->
            <LinearLayout
                android:id="@+id/card_x_link_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_x_quote_card"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_x_link_thumb"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Link thumbnail"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/tv_x_link_domain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/x_text_secondary"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_x_link_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/x_text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-bold"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tv_x_link_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/x_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Quote tweet card -->
            <LinearLayout
                android:id="@+id/card_x_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:padding="10dp"
                android:background="@drawable/bg_x_quote_card"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_x_quote_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-bold"/>

                <TextView
                    android:id="@+id/tv_x_quote_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/x_text_primary"
                    android:textSize="14sp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Poll container -->
            <LinearLayout
                android:id="@+id/ll_x_poll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone"/>

            <!-- Action bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout android:id="@+id/btn_x_reply"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:id="@+id/ic_x_reply_icon"
                        android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_x_reply" android:tint="@color/x_icon_default"/>
                    <TextView android:id="@+id/tv_x_replies"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" android:textSize="13sp"
                        android:textColor="@color/x_icon_default"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_x_retweet"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:id="@+id/ic_x_retweet"
                        android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_x_retweet" android:tint="@color/x_icon_default"/>
                    <TextView android:id="@+id/tv_x_retweets"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" android:textSize="13sp"
                        android:textColor="@color/x_icon_default"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_x_like"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:id="@+id/ic_x_like"
                        android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_x_heart_outline"/>
                    <TextView android:id="@+id/tv_x_likes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" android:textSize="13sp"
                        android:textColor="@color/x_icon_default"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_visibility" android:tint="@color/x_icon_default"/>
                    <TextView android:id="@+id/tv_x_views"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp" android:textSize="13sp"
                        android:textColor="@color/x_icon_default"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_x_bookmark"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:id="@+id/ic_x_bookmark"
                        android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_x_bookmark" android:tint="@color/x_icon_default"/>
                    <TextView android:id="@+id/tv_x_bookmarks"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="2dp" android:textSize="12sp"
                        android:textColor="@color/x_icon_default"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_x_share"
                    android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:id="@+id/ic_x_share"
                        android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_x_share" android:tint="@color/x_icon_default"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/x_divider"/>
</LinearLayout>
