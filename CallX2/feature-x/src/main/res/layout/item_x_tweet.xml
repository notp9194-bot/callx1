<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout
      xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:background="?attr/selectableItemBackground">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:padding="12dp">

          <!-- Avatar -->
          <de.hdodenhof.circleimageview.CircleImageView
              android:id="@+id/iv_x_avatar"
              android:layout_width="44dp"
              android:layout_height="44dp"
              android:src="@drawable/ic_person"/>

          <LinearLayout
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_weight="1"
              android:layout_marginStart="10dp"
              android:orientation="vertical">

              <!-- Name row -->
              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  android:gravity="center_vertical">

                  <TextView
                      android:id="@+id/tv_x_name"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textColor="@color/x_text_primary"
                      android:textStyle="bold"
                      android:textSize="14sp"
                      android:maxLines="1"
                      android:ellipsize="end"/>

                  <ImageView
                      android:id="@+id/iv_x_verified"
                      android:layout_width="14dp"
                      android:layout_height="14dp"
                      android:layout_marginStart="4dp"
                      android:src="@drawable/ic_x_verified"
                      android:visibility="gone"
                      android:contentDescription="Verified"/>

                  <TextView
                      android:id="@+id/tv_x_handle"
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:layout_marginStart="4dp"
                      android:textColor="@color/x_text_secondary"
                      android:textSize="13sp"
                      android:maxLines="1"
                      android:ellipsize="end"/>

                  <TextView
                      android:id="@+id/tv_x_time"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textColor="@color/x_text_secondary"
                      android:textSize="13sp"/>

                  <ImageButton
                      android:id="@+id/btn_x_more"
                      android:layout_width="28dp"
                      android:layout_height="28dp"
                      android:src="@drawable/ic_more_vert"
                      android:background="?attr/selectableItemBackgroundBorderless"
                      android:tint="@color/x_text_secondary"
                      android:contentDescription="More"/>
              </LinearLayout>

              <!-- Tweet text -->
              <TextView
                  android:id="@+id/tv_x_text"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="4dp"
                  android:textColor="@color/x_text_primary"
                  android:textSize="15sp"
                  android:lineSpacingExtra="2dp"/>

              <!-- Media -->
              <ImageView
                  android:id="@+id/iv_x_media"
                  android:layout_width="match_parent"
                  android:layout_height="200dp"
                  android:layout_marginTop="8dp"
                  android:scaleType="centerCrop"
                  android:background="@drawable/bg_x_media_rounded"
                  android:clipToOutline="true"
                  android:visibility="gone"
                  android:contentDescription="Media"/>

              <!-- Action bar -->
              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="40dp"
                  android:layout_marginTop="4dp"
                  android:orientation="horizontal"
                  android:gravity="center_vertical">

                  <!-- Reply -->
                  <LinearLayout
                      android:id="@+id/btn_x_reply"
                      android:layout_width="0dp"
                      android:layout_height="match_parent"
                      android:layout_weight="1"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:background="?attr/selectableItemBackground">
                      <ImageView android:id="@+id/ic_x_reply_icon"
                          android:layout_width="18dp" android:layout_height="18dp"
                          android:src="@drawable/ic_x_reply" android:tint="@color/x_icon_default"/>
                      <TextView android:id="@+id/tv_x_replies"
                          android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:layout_marginStart="4dp" android:textSize="13sp"
                          android:textColor="@color/x_icon_default"/>
                  </LinearLayout>

                  <!-- Retweet -->
                  <LinearLayout
                      android:id="@+id/btn_x_retweet"
                      android:layout_width="0dp"
                      android:layout_height="match_parent"
                      android:layout_weight="1"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:background="?attr/selectableItemBackground">
                      <ImageView android:id="@+id/ic_x_retweet"
                          android:layout_width="18dp" android:layout_height="18dp"
                          android:src="@drawable/ic_x_retweet" android:tint="@color/x_icon_default"/>
                      <TextView android:id="@+id/tv_x_retweets"
                          android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:layout_marginStart="4dp" android:textSize="13sp"
                          android:textColor="@color/x_icon_default"/>
                  </LinearLayout>

                  <!-- Like -->
                  <LinearLayout
                      android:id="@+id/btn_x_like"
                      android:layout_width="0dp"
                      android:layout_height="match_parent"
                      android:layout_weight="1"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:background="?attr/selectableItemBackground">
                      <ImageView android:id="@+id/ic_x_like"
                          android:layout_width="18dp" android:layout_height="18dp"
                          android:src="@drawable/ic_x_heart_outline"/>
                      <TextView android:id="@+id/tv_x_likes"
                          android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:layout_marginStart="4dp" android:textSize="13sp"
                          android:textColor="@color/x_icon_default"/>
                  </LinearLayout>

                  <!-- Views -->
                  <LinearLayout
                      android:layout_width="0dp"
                      android:layout_height="match_parent"
                      android:layout_weight="1"
                      android:orientation="horizontal"
                      android:gravity="center_vertical">
                      <ImageView android:layout_width="16dp" android:layout_height="16dp"
                          android:src="@drawable/ic_visibility" android:tint="@color/x_icon_default"/>
                      <TextView android:id="@+id/tv_x_views"
                          android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:layout_marginStart="4dp" android:textSize="13sp"
                          android:textColor="@color/x_icon_default"/>
                  </LinearLayout>

                  <!-- Bookmark -->
                  <LinearLayout
                      android:id="@+id/btn_x_bookmark"
                      android:layout_width="0dp"
                      android:layout_height="match_parent"
                      android:layout_weight="1"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:background="?attr/selectableItemBackground">
                      <ImageView android:id="@+id/ic_x_bookmark"
                          android:layout_width="18dp" android:layout_height="18dp"
                          android:src="@drawable/ic_x_bookmark" android:tint="@color/x_icon_default"/>
                  </LinearLayout>

                  <!-- Share -->
                  <LinearLayout
                      android:id="@+id/btn_x_share"
                      android:layout_width="0dp"
                      android:layout_height="match_parent"
                      android:layout_weight="1"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:background="?attr/selectableItemBackground">
                      <ImageView android:id="@+id/ic_x_share"
                          android:layout_width="18dp" android:layout_height="18dp"
                          android:src="@drawable/ic_x_share" android:tint="@color/x_icon_default"/>
                  </LinearLayout>

              </LinearLayout>
          </LinearLayout>
      </LinearLayout>

      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="@color/x_divider"/>
  </LinearLayout>