<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_x_dm_recv"
        android:padding="10dp"
        android:maxWidth="240dp">

        <ImageView
            android:id="@+id/iv_dm_media"
            android:layout_width="200dp"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Media" />

        <TextView
            android:id="@+id/tv_dm_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/x_text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_dm_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/x_text_secondary"
        android:textSize="11sp"
        android:layout_marginTop="2dp" />

    <View android:id="@+id/tv_dm_seen" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
</LinearLayout>
