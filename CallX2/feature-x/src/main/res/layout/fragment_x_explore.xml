<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout
      xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="@color/x_bg">

      <!-- Search bar -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="48dp"
          android:orientation="horizontal"
          android:paddingStart="16dp"
          android:paddingEnd="16dp"
          android:paddingTop="8dp"
          android:paddingBottom="4dp"
          android:gravity="center_vertical">

          <ImageView
              android:layout_width="20dp"
              android:layout_height="20dp"
              android:src="@drawable/ic_search"
              android:tint="@color/x_text_secondary"/>

          <EditText
              android:id="@+id/et_x_search"
              android:layout_width="0dp"
              android:layout_height="36dp"
              android:layout_weight="1"
              android:layout_marginStart="8dp"
              android:hint="@string/x_search_hint"
              android:background="@drawable/bg_surface_input"
              android:textColor="@color/x_text_primary"
              android:textColorHint="@color/x_text_muted"
              android:textSize="15sp"
              android:paddingStart="12dp"
              android:paddingEnd="12dp"
              android:inputType="text"
              android:imeOptions="actionSearch"
              android:singleLine="true"/>
      </LinearLayout>

      <!-- Hashtag horizontal scroll -->
      <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_x_hashtags"
          android:layout_width="match_parent"
          android:layout_height="44dp"
          android:paddingStart="12dp"
          android:paddingEnd="12dp"
          android:clipToPadding="false"/>

      <View android:layout_width="match_parent" android:layout_height="1dp"
          android:background="@color/x_divider"/>

      <!-- Trending tweets -->
      <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_x_trending"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:visibility="visible"/>

      <!-- Search results -->
      <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_x_search_results"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:visibility="gone"/>

  </LinearLayout>