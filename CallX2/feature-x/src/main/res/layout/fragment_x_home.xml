<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/x_bg">

    <!-- For You / Following tabs -->
    <LinearLayout
        android:id="@+id/ll_x_home_tabs"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/x_bg"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tab_x_for_you"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/x_for_you"
            android:textColor="@color/x_text_primary"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"/>

        <TextView
            android:id="@+id/tab_x_following"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/x_following"
            android:textColor="@color/x_text_secondary"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="48dp"
        android:background="@color/x_divider"/>

    <!-- Main feed with pull-to-refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_x_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="49dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_x_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Empty state (shown when feed loads with 0 posts) -->
    <FrameLayout
        android:id="@+id/layout_x_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="49dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_x_logo"
                android:alpha="0.25"
                android:contentDescription="X logo"/>

            <TextView
                android:id="@+id/tv_x_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Welcome to X"
                android:textColor="@color/x_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_x_empty_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Posts from people you follow will appear here. Follow some accounts to get started."
                android:textColor="@color/x_text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Error state (shown on network/Firebase failure) -->
    <FrameLayout
        android:id="@+id/layout_x_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="49dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="!"
                android:textColor="@color/x_text_secondary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:background="@drawable/bg_x_error_circle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Something went wrong"
                android:textColor="@color/x_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Check your connection and pull down to retry."
                android:textColor="@color/x_text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_x_retry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Try again"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                app:strokeColor="@color/x_accent"
                app:strokeWidth="1dp"
                app:backgroundTint="@android:color/transparent"
                android:textColor="@color/x_accent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Compose FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_x_compose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_x_compose"
        android:contentDescription="Compose"
        app:backgroundTint="@color/x_fab_bg"
        app:tint="@color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
