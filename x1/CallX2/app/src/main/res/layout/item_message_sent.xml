<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end"
    android:padding="4dp">

    <!-- Feature 8: Pinned indicator -->
    <TextView
        android:id="@+id/tv_pinned_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📌 Pinned"
        android:textSize="10sp"
        android:textColor="#FF9800"
        android:layout_marginEnd="6dp"
        android:visibility="gone"/>

    <!-- Feature 6: Forwarded label -->
    <TextView
        android:id="@+id/tv_forwarded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="↪ Forwarded"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginEnd="6dp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_sent"
        android:padding="2dp">

        <!-- Feature 2: Reply preview -->
        <LinearLayout
            android:id="@+id/ll_reply_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33000000"
            android:padding="8dp"
            android:layout_margin="4dp"
            android:minWidth="140dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tv_reply_sender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFD54F"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tv_reply_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="@color/bubble_sent_text"
            android:maxWidth="260dp"
            android:textSize="15sp"/>

        <!-- Feature 4: Edited label -->
        <TextView
            android:id="@+id/tv_edited"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="edited"
            android:textSize="10sp"
            android:textColor="#AAFFFFFF"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/iv_image"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <FrameLayout
            android:id="@+id/fl_video"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/iv_video_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:background="@drawable/circle_primary"
                android:padding="14dp"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/ll_audio"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btn_play_audio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_play"
                android:background="@drawable/circle_avatar_bg"/>
            <SeekBar
                android:id="@+id/seek_audio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"/>
            <TextView
                android:id="@+id/tv_audio_dur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/bubble_sent_text"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_file"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="@drawable/file_card_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/iv_file_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_pdf"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <TextView
                    android:id="@+id/tv_file_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/bubble_sent_text"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:id="@+id/tv_file_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Feature 3: Reactions bar -->
        <TextView
            android:id="@+id/tv_reactions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="4dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Bottom row: time + Feature 1: status ticks + Feature 7: star -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="2dp">
        <TextView
            android:id="@+id/tv_starred_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="10sp"
            android:layout_marginEnd="2dp"
            android:visibility="gone"/>
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="10sp"/>
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:layout_marginStart="3dp"
            android:text="✓"/>
    </LinearLayout>
</LinearLayout>
