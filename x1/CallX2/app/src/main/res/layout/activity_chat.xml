<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_chat_bg"
    android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/gradient_brand"
        app:navigationIcon="@drawable/ic_back"
        app:titleTextColor="@color/white"
        app:subtitleTextColor="#E0E7FF"
        app:menu="@menu/chat_menu"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>
    <ProgressBar
        android:id="@+id/upload_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="gone"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface_card"
        android:gravity="center_vertical">
        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_attach"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Attach"/>
        <ImageButton
            android:id="@+id/btn_camera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Camera"/>
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_input_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">
            <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_message"
                android:textColorHint="@color/text_muted"
                android:textColor="?android:attr/textColorPrimary"
                android:background="@color/transparent"
                android:padding="12dp"
                android:maxLines="4"/>
        </FrameLayout>
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_mic"
            android:background="@drawable/circle_primary"
            android:contentDescription="Voice message"/>
        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/circle_primary"
            android:layout_marginStart="6dp"
            android:visibility="gone"
            android:contentDescription="Send"/>
    </LinearLayout>
</LinearLayout>
